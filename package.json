{
  "name": "tides-of-knowing",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prebuild": "node scripts/generate-article-audio-manifest.mjs",
    "predev": "node scripts/generate-article-audio-manifest.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/fix-cloudflare-routes.mjs",
    "preview": "astro preview",
