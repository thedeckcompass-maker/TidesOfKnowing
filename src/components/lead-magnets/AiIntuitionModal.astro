---
/**
 * Editorial modal for AI + Intuition field guide signup (MailerLite oh85cP).
 * Used only in contextual article placements; not a site-wide pattern.
 */
interface Props {
  /** Must match the open button's aria-controls / data attribute. */
  modalId?: string;
}

const { modalId = "tok-ai-intuition-field-modal" } = Astro.props;
const titleId = `${modalId}-title`;
const descId = `${modalId}-desc`;
---

<dialog
  class="tok-ai-modal"
  id={modalId}
  aria-labelledby={titleId}
  aria-describedby={descId}
  aria-modal="true"
>
  <div class="tok-ai-modal__panel">
    <button
      type="button"
      class="tok-ai-modal__close"
      aria-label="Close this dialog"
      data-ai-intuition-modal-close
    >
      <span class="tok-ai-modal__close-text" aria-hidden="true">Close</span>
    </button>
    <h2 id={titleId} class="tok-ai-modal__title">Field guide and notes</h2>
    <p id={descId} class="tok-ai-modal__lede">
      The same list carries the compiled edition and short weekly field notes. Add your email below when you are
      ready.
    </p>
    <div class="tok-ai-modal__embed-wrap">
      <div class="ml-embedded" data-form="oh85cP"></div>
    </div>
  </div>
</dialog>

<style>
  .tok-ai-modal {
    max-width: min(32rem, calc(100vw - 2rem));
    width: 100%;
    margin: auto;
    padding: 0;
    border: none;
    background: transparent;
    opacity: 0;
    transform: translateY(0.35rem);
    transition:
      opacity var(--dur-base) var(--ease-out),
      transform var(--dur-base) var(--ease-out);
  }

  .tok-ai-modal::backdrop {
    background: color-mix(in srgb, var(--tok-deep-ocean) 28%, transparent);
    backdrop-filter: blur(1px);
    -webkit-backdrop-filter: blur(1px);
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-out) allow-discrete;
  }

  .tok-ai-modal[open] {
    opacity: 1;
    transform: translateY(0);
  }

  .tok-ai-modal[open]::backdrop {
    opacity: 1;
  }

  @starting-style {
    .tok-ai-modal[open] {
      opacity: 0;
      transform: translateY(0.35rem);
    }
    .tok-ai-modal[open]::backdrop {
      opacity: 0;
    }
  }

  .tok-ai-modal__panel {
    position: relative;
    box-sizing: border-box;
    padding: 1.35rem 1.25rem 1.5rem;
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, var(--tok-border-light));
    border-radius: var(--radius-2);
    box-shadow: var(--shadow-md);
  }

  .tok-ai-modal__close {
    position: absolute;
    top: 0.65rem;
    right: 0.65rem;
    margin: 0;
    padding: 0.35rem 0.5rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-meta);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tight);
    text-transform: uppercase;
    color: var(--tok-text-muted);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-2);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  .tok-ai-modal__close:hover {
    color: var(--tok-water);
    border-color: color-mix(in srgb, var(--tok-gold) 35%, transparent);
    background: color-mix(in srgb, var(--tok-gold) 6%, transparent);
  }

  .tok-ai-modal__close:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 2px;
  }

  .tok-ai-modal__title {
    margin: 0 3.25rem 0.65rem 0;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.8vw, 1.45rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--tok-water);
  }

  .tok-ai-modal__lede {
    margin: 0 0 1rem;
    max-width: 38ch;
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: var(--tok-line-body);
    color: color-mix(in srgb, var(--tok-text-dark) 88%, transparent);
  }

  .tok-ai-modal__embed-wrap {
    margin-top: 0.35rem;
    padding: 0.85rem 0.75rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--tok-border-light) 88%, var(--tok-text-dark));
    border-radius: var(--radius-2);
    background: var(--tok-surface-reading-soft);
    min-height: 4rem;
  }

  :global(.tok-ai-modal .ml-embedded) {
    font-family: var(--font-body);
    color: var(--tok-text-dark);
  }

  :global(.tok-ai-modal .ml-embedded input[type="email"]),
  :global(.tok-ai-modal .ml-embedded input[type="text"]) {
    font-family: var(--font-body);
    color: var(--tok-text-dark);
    background-color: var(--tok-surface-reading);
    border: 1px solid color-mix(in srgb, var(--tok-border-light) 88%, var(--tok-text-dark));
    border-radius: var(--radius-2);
    box-shadow: none;
  }

  :global(.tok-ai-modal .ml-embedded button),
  :global(.tok-ai-modal .ml-embedded input[type="submit"]) {
    font-family: var(--font-body);
    font-size: var(--tok-type-meta);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tight);
    text-transform: uppercase;
    color: var(--tok-water);
    background: transparent;
    border: 2px solid var(--tok-gold);
    border-radius: var(--radius-2);
    box-shadow: none;
    cursor: pointer;
  }

  :global(.tok-ai-modal .ml-embedded button:hover),
  :global(.tok-ai-modal .ml-embedded input[type="submit"]:hover) {
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
  }
</style>
