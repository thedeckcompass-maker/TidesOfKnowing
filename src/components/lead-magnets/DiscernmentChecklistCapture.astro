---
/**
 * Shared Discernment Checklist lead capture: LeadMagnetCta + current cover art.
 * Keeps signup/redirect architecture identical across homepage-adjacent placements.
 */
import LeadMagnetCta from "./LeadMagnetCta.astro";

interface Props {
  sourceComponent: string;
  placement?: "top" | "middle" | "bottom" | "resource" | "inline";
  /** Quieter treatment for pages where training/conversion must stay primary. */
  variant?: "default" | "secondary";
  /** When false, form only (e.g. if cover is rendered elsewhere). */
  showCover?: boolean;
  headingId?: string;
}

const {
  sourceComponent,
  placement = "inline",
  variant = "default",
  showCover = true,
  headingId,
} = Astro.props;

const coverSrc = "/images/home/tides-of-knowing-descernement-checklist-cover.png";
const coverAlt =
  "Cover of The Discernment Checklist by Leigh Spencer, featuring 21 questions to ask before pulling another card";

const title = "The Discernment Checklist";
const subtitle = "21 Questions to Ask Before Pulling Another Card";
const description =
  "Use this reader’s checklist to test the question, recognise the cards carrying the answer, decide whether another card is needed, and close the reading cleanly when the answer has landed.";
---

<section
  class:list={[
    "tok-disc-capture",
    variant === "secondary" && "tok-disc-capture--secondary",
  ]}
  aria-labelledby={headingId}
>
  <div class="tok-disc-capture__layout">
    <div class="tok-disc-capture__copy">
      <LeadMagnetCta
        title={title}
        subtitle={subtitle}
        description={description}
        buttonLabel="Get the checklist"
        resourceSlug="discernment-checklist"
        redirectUrl="/resources/discernment-checklist/thank-you/"
        sourceComponent={sourceComponent}
        placement={placement}
      />
    </div>
    {
      showCover ? (
        <figure class="tok-disc-capture__frame">
          <img
            class="tok-disc-capture__img"
            src={coverSrc}
            alt={coverAlt}
            width="633"
            height="819"
            loading="lazy"
            decoding="async"
          />
        </figure>
      ) : null
    }
  </div>
</section>

<style>
  .tok-disc-capture {
    margin: clamp(1.5rem, 4vw, 2.25rem) 0;
    max-width: 100%;
  }

  .tok-disc-capture__layout {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: start;
  }

  @media (min-width: 768px) {
    .tok-disc-capture__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 0.85fr);
      align-items: center;
    }

    .tok-disc-capture--secondary .tok-disc-capture__layout {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.7fr);
    }
  }

  .tok-disc-capture__copy {
    min-width: 0;
  }

  .tok-disc-capture__frame {
    position: relative;
    box-sizing: border-box;
    margin: 0;
    width: 100%;
    max-width: 22rem;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 34%, transparent);
    background: color-mix(in srgb, var(--tok-deep-ocean) 70%, var(--tok-surface-panel));
    justify-self: center;
  }

  .tok-disc-capture--secondary .tok-disc-capture__frame {
    max-width: 16.5rem;
    opacity: 0.96;
  }

  @media (min-width: 768px) {
    .tok-disc-capture__frame {
      justify-self: end;
      max-width: none;
    }

    .tok-disc-capture--secondary .tok-disc-capture__frame {
      max-width: 18rem;
    }
  }

  .tok-disc-capture__img {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center top;
  }

  .tok-disc-capture :global(.tok-lead-magnet-cta) {
    margin: 0;
  }

  .tok-disc-capture--secondary :global(.tok-lead-magnet-cta) {
    border-color: color-mix(in srgb, var(--tok-gold) 28%, transparent);
    background: color-mix(in srgb, var(--tok-surface-panel) 72%, transparent);
  }
</style>
