---
interface Props {
  title: string;
  subtitle?: string;
  description: string;
  buttonLabel: string;
  resourceSlug: string;
  redirectUrl: string;
  /** Human-readable campaign/source identifier stored in MailerLite custom fields. */
  sourceComponent?: string;
  /** Used for analytics/source attribution and middle-slot cloning. */
  placement?: "top" | "middle" | "bottom" | "resource" | "inline";
  /** Tightens vertical spacing when embedded inside an article body. */
  compact?: boolean;
}

const {
  title,
  subtitle,
  description,
  buttonLabel,
  resourceSlug,
  redirectUrl,
  sourceComponent,
  placement = "inline",
  compact = false,
} = Astro.props;

const resolvedSourceComponent =
  sourceComponent ?? `lead-magnet-${resourceSlug}-${placement}`;
---

<section
  class:list={["tok-lead-magnet-cta", compact && "tok-lead-magnet-cta--compact"]}
  data-lead-magnet-cta
  data-resource-slug={resourceSlug}
  data-lead-magnet-placement={placement}
  aria-label={`${title}: ${subtitle ?? buttonLabel}`}
>
  <div class="tok-lead-magnet-cta__content">
    <p class="tok-lead-magnet-cta__eyebrow">Free checklist</p>
    <h2 class="tok-lead-magnet-cta__title">{title}</h2>
    {subtitle ? <p class="tok-lead-magnet-cta__subtitle">{subtitle}</p> : null}
    <p class="tok-lead-magnet-cta__description">{description}</p>
  </div>

  <form
    class="tok-lead-magnet-cta__form"
    data-lead-magnet-form
    data-redirect-url={redirectUrl}
    action="/api/lead-magnet-signup/"
    method="post"
    novalidate
  >
    <input type="hidden" name="resourceSlug" value={resourceSlug} />
    <input type="hidden" name="source_component" value={resolvedSourceComponent} />
    <input
      class="tok-lead-magnet-cta__hp"
      type="text"
      name="website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />
    <label class="tok-lead-magnet-cta__field">
      <span class="tok-lead-magnet-cta__label">First name</span>
      <input
        class="tok-lead-magnet-cta__input"
        type="text"
        name="name"
        autocomplete="given-name"
        placeholder="First name"
        required
      />
    </label>
    <label class="tok-lead-magnet-cta__field">
      <span class="tok-lead-magnet-cta__label">Email</span>
      <input
        class="tok-lead-magnet-cta__input"
        type="email"
        name="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
      />
    </label>
    <button class="tok-lead-magnet-cta__btn" type="submit">{buttonLabel}</button>
    <p class="tok-lead-magnet-cta__status" data-lead-magnet-status hidden></p>
  </form>
</section>

<script>
  import { hydrateLeadMagnetSlots, initLeadMagnetSignup } from "../../scripts/leadMagnetSignup";

  hydrateLeadMagnetSlots(document);
  initLeadMagnetSignup(document);
</script>

<style>
  .tok-lead-magnet-cta {
    margin: clamp(1.5rem, 4vw, 2.1rem) 0;
    padding: clamp(1.1rem, 3vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 38%, var(--tok-border-light));
    border-radius: var(--radius-2);
    background: color-mix(in srgb, var(--tok-gold) 7%, var(--tok-surface-reading-soft));
  }

  .tok-lead-magnet-cta--compact {
    margin-block: 1.35rem;
  }

  .tok-lead-magnet-cta__content {
    max-width: 38rem;
  }

  .tok-lead-magnet-cta__eyebrow {
    margin: 0 0 0.45rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-compact);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .tok-lead-magnet-cta__title {
    margin: 0 0 0.35rem;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.5vw, 1.45rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--tok-water);
  }

  .tok-lead-magnet-cta__subtitle {
    margin: 0 0 0.6rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.3;
    color: var(--tok-text-dark);
  }

  .tok-lead-magnet-cta__description {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: var(--tok-line-body);
    color: color-mix(in srgb, var(--tok-text-dark) 90%, transparent);
  }

  .tok-lead-magnet-cta__form {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.65rem;
    margin-top: 1rem;
    max-width: 36rem;
  }

  @media (min-width: var(--bp-md)) {
    .tok-lead-magnet-cta__form {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr) auto;
      align-items: end;
    }
  }

  .tok-lead-magnet-cta__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .tok-lead-magnet-cta__label {
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-dropdown);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-teal-dim);
  }

  .tok-lead-magnet-cta__input {
    box-sizing: border-box;
    width: 100%;
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.55rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 50%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
    color: var(--tok-text-dark);
  }

  .tok-lead-magnet-cta__input::placeholder {
    color: color-mix(in srgb, var(--tok-text-dark) 45%, transparent);
  }

  .tok-lead-magnet-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.45rem;
    padding: 0.55rem 1rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-meta);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tight);
    text-transform: uppercase;
    color: var(--tok-water);
    background: transparent;
    border: 2px solid var(--tok-gold);
    border-radius: var(--radius-2);
    cursor: pointer;
    transition:
      background var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .tok-lead-magnet-cta__btn:hover:not(:disabled) {
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
  }

  .tok-lead-magnet-cta__btn:disabled {
    opacity: 0.65;
    cursor: wait;
  }

  .tok-lead-magnet-cta__btn:focus-visible,
  .tok-lead-magnet-cta__input:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 2px;
  }

  .tok-lead-magnet-cta__status {
    grid-column: 1 / -1;
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .tok-lead-magnet-cta__status.is-error {
    color: var(--tok-teal-dim);
  }

  .tok-lead-magnet-cta__status.is-success {
    color: var(--tok-teal);
  }

  .tok-lead-magnet-cta__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
</style>
