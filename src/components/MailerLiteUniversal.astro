---
/**
 * MailerLite universal embed loader — include only on pages with `.ml-embedded` forms.
 * Do not load globally: the script initialises reCAPTCHA and scans for embeds site-wide.
 */
const MAILERLITE_ACCOUNT_ID = "2247024";
---

<script is:inline define:vars={{ accountId: MAILERLITE_ACCOUNT_ID }}>
  (function (w, d, e, u, f) {
    w[f] =
      w[f] ||
      function () {
        (w[f].q = w[f].q || []).push(arguments);
      };
    var l = d.createElement(e);
    l.async = 1;
    l.src = u;
    var n = d.getElementsByTagName(e)[0];
    n.parentNode.insertBefore(l, n);
  })(window, document, "script", "https://assets.mailerlite.com/js/universal.js", "ml");
  ml("account", accountId);
</script>
