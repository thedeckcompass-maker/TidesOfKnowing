---
import ShareButtons from "./share/ShareButtons.astro";

interface Props {
  title: string;
  subtitle?: string;
  publishDate: Date;
  readingTime?: number;
  heroImage: string;
  heroImageAlt: string;
  author?: string;
  shareUrl: string;
}

const {
  title,
  subtitle,
  publishDate,
  readingTime,
  heroImage,
  heroImageAlt,
  author = "Leigh Spencer",
  shareUrl,
} = Astro.props;

const displayDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const iso = publishDate.toISOString();
---

<header class="tok-article-header">
  {
    heroImage && (
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="tok-article-header__hero"
        width="1200"
        height="630"
        loading="eager"
        decoding="async"
      />
    )
  }

  <div class="tok-article-header__inner">
    <h1 class="tok-article-header__title">{title}</h1>
    {subtitle && <p class="tok-article-header__subtitle">{subtitle}</p>}

    <div class="tok-article-header__meta">
      <time datetime={iso}>{displayDate}</time>
      {
        readingTime != null && (
          <span class="tok-article-header__read">
            · {readingTime} min read
          </span>
        )
      }
    </div>
    <p class="tok-article-header__byline">
      <a class="tok-article-header__byline-link" href="/about">{author}</a>
    </p>
    <ShareButtons title={title} url={shareUrl} placement="top" />
  </div>
</header>

<style>
  .tok-article-header {
    margin-bottom: 2.5rem;
  }

  .tok-article-header__hero {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    display: block;
    margin-bottom: 1.75rem;
  }

  .tok-article-header__inner {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .tok-article-header__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin: 0 0 0.75rem 0;
    color: var(--ink);
    font-weight: 600;
  }

  .tok-article-header__subtitle {
    font-size: 1.125rem;
    color: var(--mountain-water);
    font-style: italic;
    margin: 0 0 1rem 0;
    line-height: 1.5;
  }

  .tok-article-header__meta {
    color: var(--mountain-water);
    font-size: 0.9375rem;
    font-family: var(--font-nav);
  }

  .tok-article-header__read {
    margin-left: 0.25rem;
  }

  .tok-article-header__byline {
    margin: 0.65rem 0 0;
    font-family: var(--font-nav);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--mountain-water);
    opacity: 0.88;
  }

  .tok-article-header__byline-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(13, 50, 77, 0.22);
    transition: color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .tok-article-header__byline-link:hover {
    color: var(--ink);
    opacity: 1;
    border-bottom-color: var(--gold);
  }
</style>
