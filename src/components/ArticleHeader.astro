---
import ShareButtons from "./share/ShareButtons.astro";

interface Props {
  title: string;
  /** Text used for share buttons; defaults to `title` (frontmatter title when header title is overridden). */
  shareTitle?: string;
  subtitle?: string;
  publishDate: Date;
  readingTime?: number;
  heroImage: string;
  heroImageAlt: string;
  heroImageFit?: "cover" | "contain";
  author?: string;
  shareUrl: string;
  hideTopShare?: boolean;
}

const {
  title,
  shareTitle,
  subtitle,
  publishDate,
  readingTime,
  heroImage,
  heroImageAlt,
  heroImageFit = "cover",
  author = "Leigh Spencer",
  shareUrl,
  hideTopShare = false,
} = Astro.props;

const resolvedShareTitle = shareTitle ?? title;

const displayDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const iso = publishDate.toISOString();
---

<header
  class:list={[
    "tok-article-header",
    { "tok-article-header--fit-contain": heroImageFit === "contain" },
  ]}
>
  {
    heroImage &&
      (heroImageFit === "contain" ? (
        <figure class="tok-article-header__hero-fit">
          <img
            src={heroImage}
            alt={heroImageAlt}
            class="tok-article-header__hero-fit-img"
            loading="eager"
            decoding="async"
          />
        </figure>
      ) : (
        <img
          src={heroImage}
          alt={heroImageAlt}
          class="tok-article-header__hero"
          width="1200"
          height="630"
          loading="eager"
          decoding="async"
        />
      ))
  }

  <div class="tok-article-header__inner">
    <h1 class="tok-article-header__title">{title}</h1>
    {subtitle && <p class="tok-article-header__subtitle">{subtitle}</p>}

    <div class="tok-article-header__meta">
      <time datetime={iso}>{displayDate}</time>
      {
        readingTime != null && (
          <span class="tok-article-header__read">
            · {readingTime} min read
          </span>
        )
      }
    </div>
    <p class="tok-article-header__byline">
      <a class="tok-article-header__byline-link" href="/about">{author}</a>
    </p>
    {!hideTopShare && <ShareButtons title={resolvedShareTitle} url={shareUrl} placement="top" />}
  </div>
</header>

<style>
  .tok-article-header {
    margin-bottom: 2.5rem;
  }

  .tok-article-header__hero {
    width: 100%;
    height: auto;
    max-height: 500px;
    object-fit: cover;
    object-position: center;
    display: block;
    margin-bottom: 1.75rem;
  }

  /**
   * Repeating Card Patterns (and other contain-fit heroes): natural aspect ratio at
   * full width. No max-height, overflow clip, or cover — separate from __hero cover path.
   */
  .tok-article-header--fit-contain {
    margin-bottom: 2.5rem;
  }

  .tok-article-header__hero-fit {
    margin: 0 0 1.75rem;
    padding: clamp(0.5rem, 1.5vw, 0.85rem);
    overflow: visible;
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 65%, var(--tok-surface-reading));
    border: 1px solid color-mix(in srgb, var(--tok-gold) 24%, transparent);
    border-radius: var(--radius-soft);
  }

  .tok-article-header__hero-fit-img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    margin: 0;
    object-fit: unset;
    object-position: center;
  }

  .tok-article-header__inner {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .tok-article-header__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin: 0 0 0.75rem 0;
    color: var(--tok-text-dark);
    font-weight: 600;
  }

  .tok-article-header__subtitle {
    font-size: 1.125rem;
    color: var(--tok-water);
    font-style: italic;
    font-family: var(--font-accent);
    margin: 0 0 1rem 0;
    line-height: 1.5;
  }

  .tok-article-header__meta {
    color: var(--tok-water);
    font-size: 0.9375rem;
    font-family: var(--font-body);
  }

  .tok-article-header__read {
    margin-left: 0.25rem;
  }

  .tok-article-header__byline {
    margin: 0.65rem 0 0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--tok-water);
    opacity: 0.88;
  }

  .tok-article-header__byline-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-water) 22%, transparent);
    transition:
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      opacity var(--dur-base) var(--ease-out);
  }

  .tok-article-header__byline-link:hover {
    color: var(--tok-text-dark);
    opacity: 1;
    border-bottom-color: var(--tok-gold);
  }
</style>
