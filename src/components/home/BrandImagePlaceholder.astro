---
/**
 * Branded development image placeholder for homepage (and similar) layouts.
 * Final WebP assets do not exist yet — these reserve aspect ratio and display
 * production image IDs during development. Replace with a local <img> later.
 */
interface Props {
  /** Production asset reference ID (e.g. TOK-HOME-HERO-01). Not a filename. */
  imageId: string;
  /** Temporary accessible description until the final asset ships. */
  alt: string;
  /** CSS aspect-ratio value, e.g. "4 / 5". */
  aspectRatio?: string;
  /** Intrinsic width hint for layout reservation (CSS pixels). */
  width?: number;
  /** Intrinsic height hint for layout reservation (CSS pixels). */
  height?: number;
  class?: string;
  /** Decorative presentation when the adjacent copy already conveys meaning. */
  decorative?: boolean;
}

const {
  imageId,
  alt,
  aspectRatio = "4 / 5",
  width = 640,
  height = 800,
  class: className = "",
  decorative = false,
} = Astro.props;

const label = decorative ? undefined : alt;
---

<figure
  class:list={["tok-brand-placeholder", className]}
  style={`--tok-ph-ratio: ${aspectRatio}; --tok-ph-w: ${width}; --tok-ph-h: ${height};`}
  data-image-id={imageId}
  aria-label={label}
  role={decorative ? "presentation" : "img"}
>
  <div class="tok-brand-placeholder__canvas" aria-hidden="true">
    <span class="tok-brand-placeholder__mark">Tides of Knowing</span>
    <span class="tok-brand-placeholder__id">{imageId}</span>
    <span class="tok-brand-placeholder__note">Image placeholder · replace with local WebP</span>
  </div>
  {!decorative ? <figcaption class="visually-hidden">{alt}</figcaption> : null}
</figure>

<style>
  .tok-brand-placeholder {
    margin: 0;
    width: 100%;
    max-width: 100%;
    aspect-ratio: var(--tok-ph-ratio);
    min-height: 0;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 34%, transparent);
    background:
      radial-gradient(
        ellipse 80% 70% at 70% 30%,
        color-mix(in srgb, var(--tok-surface-panel) 70%, transparent),
        transparent 68%
      ),
      linear-gradient(
        155deg,
        var(--tok-deep-ocean) 0%,
        #0f2744 48%,
        var(--tok-surface-panel) 100%
      );
    box-sizing: border-box;
  }

  .tok-brand-placeholder__canvas {
    display: grid;
    place-content: center;
    gap: 0.45rem;
    width: 100%;
    height: 100%;
    min-height: inherit;
    padding: 1rem;
    text-align: center;
    box-sizing: border-box;
  }

  .tok-brand-placeholder__mark {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(0.95rem, 2vw, 1.15rem);
    font-weight: 600;
    color: color-mix(in srgb, var(--tok-gold-light) 88%, transparent);
  }

  .tok-brand-placeholder__id {
    font-family: var(--font-body);
    font-size: clamp(0.72rem, 1.6vw, 0.82rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-text-light-strong);
  }

  .tok-brand-placeholder__note {
    max-width: 16rem;
    margin-inline: auto;
    font-family: var(--font-body);
    font-size: 0.68rem;
    line-height: 1.4;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--tok-text-light-soft) 62%, transparent);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
