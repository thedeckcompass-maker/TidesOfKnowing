---
interface Props {
  id?: string;
  name?: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
  label?: string;
}

const {
  id,
  name,
  type = "text",
  placeholder,
  required = false,
  class: className = "",
  label,
} = Astro.props;
const inputId = id ?? name ?? undefined;
---

<div class:list={["tok-ui-field-b", className]}>
  {
    label && inputId && (
      <label class="tok-ui-field-b__label" for={inputId}>
        {label}
      </label>
    )
  }
  <input
    class="tok-ui-field-b__input"
    id={inputId}
    name={name}
    type={type}
    placeholder={placeholder}
    required={required}
  />
</div>

<style>
  .tok-ui-field-b__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--tok-type-label);
    font-weight: 500;
    color: var(--tok-text-light-soft);
    margin-bottom: var(--space-xs);
  }
  .tok-ui-field-b__input {
    width: 100%;
    box-sizing: border-box;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--tok-text-dark);
    background: var(--tok-surface-reading-soft);
    border: 1px solid var(--tok-border-system);
    border-radius: var(--radius-3);
    padding: var(--space-sm) var(--space-md);
    transition: border-color var(--dur-base) var(--ease-out);
  }
  .tok-ui-field-b__input:focus {
    outline: none;
    border-color: var(--tok-teal-light);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--tok-teal-light) 40%, transparent);
  }
  .tok-ui-field-b__input::placeholder {
    color: var(--tok-text-muted);
  }
</style>
