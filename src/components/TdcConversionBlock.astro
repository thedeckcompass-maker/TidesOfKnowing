---
import { isSubscribeHref, withSubscribeSourceAttribution } from "../lib/subscribeAttribution";

interface Props {
  /**
   * default: full navy band (home / footer).
   * subtle: same band, tighter vertical padding.
   * inline: no band; body text + button for long-form pages (e.g. About).
   */
  variant?: "default" | "subtle" | "inline";
  /** Required when multiple blocks exist on one page (unique `aria-labelledby`). */
  headingId?: string;
  kicker?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  /**
   * Query `source_component` / default `utm_content` for /subscribe/ links (placement id).
   * Defaults to `tdc-conversion-block` when omitted.
   */
  subscribePlacement?: string;
}

const {
  variant = "default",
  headingId = "tdc-heading",
  kicker = "Stay close to the work",
  heading = "Get new articles and early access",
  description = "This work develops over time. Join the list to stay close to it.",
  ctaLabel = "Join the list →",
  ctaHref = "/subscribe/",
  subscribePlacement = "tdc-conversion-block",
} = Astro.props;

const resolvedCtaHref = isSubscribeHref(ctaHref)
  ? withSubscribeSourceAttribution(ctaHref, {
      pagePathname: Astro.url.pathname,
      sourceComponent: subscribePlacement,
    })
  : ctaHref;
---

<section
  class:list={[
    "tdc",
    { "tdc--subtle": variant === "subtle" },
    { "tdc--inline": variant === "inline" },
  ]}
  aria-labelledby={headingId}
>
  <div
    class:list={["tdc__inner", { "page-inner": variant !== "inline" }]}
  >
    {kicker && <p class="tdc__kicker">{kicker}</p>}
    {
      variant === "inline" ? (
        <p id={headingId} class="tdc__heading">{heading}</p>
      ) : (
        <h2 id={headingId} class="tdc__heading">{heading}</h2>
      )
    }
    <p class="tdc__sub">{description}</p>
    <a class="tdc__btn" href={resolvedCtaHref}>{ctaLabel}</a>
  </div>
</section>

<style>
  .tdc {
    background: var(--tok-surface-panel);
    color: var(--tok-text-light);
    margin-top: 4rem;
    padding-top: calc(1rem + clamp(2.5rem, 6vw, 3.75rem));
    padding-bottom: clamp(2.5rem, 6vw, 3.75rem);
  }

  .tdc__inner {
    text-align: center;
    max-width: 40rem;
  }

  .tdc__kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tok-text-light-soft) 75%, transparent);
  }

  .tdc__heading {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    line-height: 1.2;
    color: var(--tok-text-light);
  }

  .tdc__sub {
    margin: 0 0 1.75rem;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    opacity: 0.92;
  }

  .tdc__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.75rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-text-light);
    border: 2px solid var(--tok-gold);
    border-radius: 2px;
    transition:
      background var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }

  .tdc__btn:hover {
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
    color: var(--tok-text-light-strong);
    border-color: var(--tok-gold);
  }

  .tdc__btn:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 4px;
  }

  .tdc--subtle {
    margin-top: 2.25rem;
    padding-top: clamp(1.5rem, 4vw, 2.25rem);
    padding-bottom: clamp(1.5rem, 4vw, 2.25rem);
  }

  .tdc--subtle .tdc__heading {
    font-size: clamp(1.45rem, 3.2vw, 1.9rem);
  }

  .tdc--subtle .tdc__sub {
    margin-bottom: 1.35rem;
    font-size: 1rem;
  }

  /* In-flow: no teal box, matches article column */
  .tdc--inline {
    background: transparent;
    color: var(--tok-text-dark);
    margin-top: 0;
    margin-bottom: 0;
    padding: 0;
  }

  .tdc--inline .tdc__inner {
    text-align: left;
    max-width: none;
    margin: 0;
    padding: 1.5rem 0 0.25rem;
    margin-top: 0.35rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
  }

  .tdc--inline .tdc__kicker {
    color: var(--tok-gold);
    margin-bottom: 0.35rem;
  }

  .tdc--inline .tdc__heading {
    margin: 0 0 0.45rem;
    font-size: clamp(1.2rem, 2.5vw, 1.45rem);
    font-weight: 600;
    font-style: italic;
    font-family: var(--font-accent);
    line-height: 1.35;
    color: var(--tok-water);
  }

  .tdc--inline .tdc__sub {
    margin: 0 0 1rem;
    font-size: 1.02rem;
    line-height: 1.65;
    opacity: 0.9;
    color: var(--tok-text-dark);
  }

  .tdc--inline .tdc__btn {
    color: var(--tok-water);
    border-color: var(--tok-gold);
  }

  .tdc--inline .tdc__btn:hover {
    background: color-mix(in srgb, var(--tok-gold) 14%, transparent);
    color: var(--tok-water);
    border-color: var(--tok-gold);
  }

  .tdc--inline .tdc__btn:focus-visible {
    outline-color: var(--tok-water);
  }
</style>
