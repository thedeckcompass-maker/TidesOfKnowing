<section class="tdc" aria-labelledby="tdc-heading">
  <div class="page-inner tdc__inner">
    <h2 id="tdc-heading" class="tdc__title">The Deck Compass launches May 2026</h2>
    <p class="tdc__sub">A subscription platform for intuitive tarot readers. Join the waitlist.</p>
    <a class="tdc__btn" href="https://thedeckcompass.com">Join the Waitlist →</a>
  </div>
</section>

<style>
  .tdc {
    background: var(--mountain-water);
    color: var(--paper);
    padding: clamp(2.5rem, 6vw, 3.75rem) 0;
  }

  .tdc__inner {
    text-align: center;
    max-width: 40rem;
  }

  .tdc__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    line-height: 1.2;
    color: var(--lavender);
  }

  .tdc__sub {
    margin: 0 0 1.75rem;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    opacity: 0.92;
  }

  .tdc__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.75rem;
    font-family: var(--font-nav);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--paper);
    border: 2px solid var(--gold);
    border-radius: 2px;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .tdc__btn:hover {
    background: rgba(198, 161, 74, 0.12);
    color: var(--paper);
    border-color: var(--gold);
  }

  .tdc__btn:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 4px;
  }
</style>
