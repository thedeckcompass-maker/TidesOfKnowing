---
import NewsletterSignupForm from "./NewsletterSignupForm.astro";
import { BLOG_SIDEBAR_SOURCE_COMPONENT } from "../lib/mailerlite";
import type { BlogCategoryRow } from "../lib/blogCategories";

interface Props {
  categories: BlogCategoryRow[];
  /** When set, highlights the active category link in the list. */
  activeCategorySlug?: string | null;
}

const { categories, activeCategorySlug = null } = Astro.props;
---

<aside class="tok-blog-sidebar" aria-label="Field Notes sidebar">
  <section class="tok-blog-sidebar__block" data-reveal>
    <h2 class="tok-blog-sidebar__h">About the author</h2>
    <p class="tok-blog-sidebar__p">
      <strong>Leigh Spencer</strong> writes Tides of Knowing for readers who want stronger symbolic
      perception, deeper readings, and a more grounded relationship with intuitive practice. Articles
      explore the underlying methodology. Field Notes follow the work in real conditions.{" "}
      <a class="tok-blog-sidebar__inline-link" href="/about/">About</a>
    </p>
  </section>

  <section class="tok-blog-sidebar__block" data-reveal>
    <h2 class="tok-blog-sidebar__h">Newsletter</h2>
    <p class="tok-blog-sidebar__p tok-blog-sidebar__p--tight">
      New articles and occasional Field Notes, in your inbox.
    </p>
    <div class="tok-blog-sidebar__form">
      <NewsletterSignupForm
        variant="sidebar"
        sourceComponent={BLOG_SIDEBAR_SOURCE_COMPONENT}
        idPrefix="blog-newsletter"
      />
    </div>
  </section>

  <section class="tok-blog-sidebar__block" data-reveal>
    <h2 class="tok-blog-sidebar__h">Categories</h2>
    {
      categories.length === 0 ? (
        <p class="tok-blog-sidebar__p tok-blog-sidebar__muted">Categories will appear as Field Notes are added.</p>
      ) : (
        <ul class="tok-blog-sidebar__cats">
          {categories.map((c) => (
            <li>
              <a
                class:list={[
                  "tok-blog-sidebar__cat",
                  { "is-active": activeCategorySlug === c.slug },
                ]}
                href={`/blog/category/${c.slug}/`}
              >
                <span>{c.label}</span>
                <span class="tok-blog-sidebar__count">{c.count}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    <p class="tok-blog-sidebar__p tok-blog-sidebar__muted tok-blog-sidebar__tags-note">
      Field Notes focus on the practical reality of reading: pressure, perception, structure, and the
      decisions that shape stronger sessions. Longer-form methodology pieces live in{" "}
      <a href="/articles/">Articles</a>.
    </p>
  </section>
</aside>

<style>
  .tok-blog-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    min-width: 0;
    max-width: 100%;
  }

  @media (min-width: var(--bp-blog-sticky)) {
    .tok-blog-sidebar {
      position: sticky;
      top: var(--tok-sticky-under-header);
      align-self: start;
    }
  }

  .tok-blog-sidebar__block {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
  }

  .tok-blog-sidebar__block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .tok-blog-sidebar__h {
    margin: 0 0 0.65rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-dropdown);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-teal-dim);
  }

  .tok-blog-sidebar__p {
    margin: 0;
    font-size: 0.98rem;
    line-height: var(--tok-line-body);
  }

  .tok-blog-sidebar__p--tight {
    margin-bottom: 0.75rem;
  }

  .tok-blog-sidebar__muted {
    font-size: 0.92rem;
    opacity: 0.88;
  }

  .tok-blog-sidebar__tags-note {
    margin-top: 1rem;
    margin-bottom: 0;
  }

  .tok-blog-sidebar__inline-link {
    font-weight: 600;
    white-space: nowrap;
  }

  .tok-blog-sidebar__form {
    min-width: 0;
    max-width: 100%;
    min-height: 3rem;
  }

  .tok-blog-sidebar__cats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .tok-blog-sidebar__cat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.4rem 0;
    text-decoration: none;
    color: var(--tok-teal-dim);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.08rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 22%, transparent);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .tok-blog-sidebar__cat:hover {
    color: var(--tok-teal);
    border-bottom-color: color-mix(in srgb, var(--tok-teal-light) 45%, transparent);
  }

  .tok-blog-sidebar__cat.is-active {
    color: var(--tok-text-dark);
    border-bottom-color: var(--tok-gold);
  }

  .tok-blog-sidebar__count {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tok-gold);
    font-style: normal;
    flex-shrink: 0;
  }
</style>
