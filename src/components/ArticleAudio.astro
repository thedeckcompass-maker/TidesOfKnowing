---
/**
 * Optional author-read audio for long-form articles.
 *
 * Default: add public/audio/articles/[slug]/article.mp3, then rebuild. The player
 * appears when that slug is listed in src/generated/articleAudioSlugs.ts (prebuild).
 *
 * Override or add duration/transcript via optional frontmatter `audio` (see README
 * in public/audio/articles/).
 */
interface Props {
  /** Article slug (used for stable `aria-labelledby` ids). */
  idPrefix: string;
  src: string;
  duration?: string;
  transcript?: string;
  title?: string;
  byline?: string;
}

const {
  idPrefix,
  src,
  duration,
  transcript,
  title = "Listen to this article.",
  byline = "Read by author.",
} = Astro.props;

const safeId = idPrefix.replace(/[^a-zA-Z0-9_-]/g, "-");
const labelId1 = `article-audio-title-${safeId}`;
const labelId2 = `article-audio-byline-${safeId}`;
---

<section class="article-audio" aria-labelledby={`${labelId1} ${labelId2}`}>
  <div class="article-audio__panel">
    <p id={labelId1} class="article-audio__lead">{title}</p>
    <p id={labelId2} class="article-audio__credit">{byline}</p>
    {
      duration && duration.trim() !== "" && (
        <p class="article-audio__duration">{duration}</p>
      )
    }
    <audio controls preload="metadata" class="article-audio__element">
      <source src={src} type="audio/mpeg" />
      Your browser does not support the audio element.
    </audio>
    {
      transcript && transcript.trim() !== "" && (
        <p class="article-audio__transcript">
          <a href={transcript} class="article-audio__transcript-link">Read transcript</a>
        </p>
      )
    }
  </div>
</section>

<style>
  .article-audio {
    margin: 0 0 2rem;
  }

  .article-audio__panel {
    padding: 1.25rem 1.35rem;
    background: color-mix(in srgb, var(--shore) 65%, var(--paper));
    border: 1px solid rgba(198, 161, 74, 0.28);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .article-audio__lead {
    margin: 0 0 0.35rem;
    font-family: var(--font-display);
    font-size: 1.15em;
    font-weight: 500;
    line-height: 1.35;
    color: var(--mountain-water);
  }

  .article-audio__credit {
    margin: 0 0 0.85rem;
    font-family: var(--font-body);
    font-size: 0.95em;
    line-height: 1.5;
    color: var(--ink);
    opacity: 0.78;
  }

  .article-audio__duration {
    margin: -0.35rem 0 0.85rem;
    font-family: var(--font-body);
    font-size: 0.88em;
    color: var(--ink);
    opacity: 0.62;
  }

  .article-audio__element {
    display: block;
    width: 100%;
    margin: 0;
    min-height: 2.75rem;
  }

  .article-audio__transcript {
    margin: 0.85rem 0 0;
    font-family: var(--font-body);
    font-size: 0.92em;
  }

  .article-audio__transcript-link {
    font-weight: 600;
  }
</style>
