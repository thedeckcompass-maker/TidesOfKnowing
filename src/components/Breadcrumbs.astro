---
import type { BreadcrumbItem } from "../lib/breadcrumbs";

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">
    {
      items.map((item, i) => (
        <li class="breadcrumbs__item">
          {item.url ? (
            <a class="breadcrumbs__link" href={item.url}>
              {item.label}
            </a>
          ) : (
            <span class="breadcrumbs__current" aria-current="page">
              {item.label}
            </span>
          )}
          {i < items.length - 1 && (
            <span class="breadcrumbs__sep" aria-hidden="true">
              /
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .breadcrumbs {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1rem 1rem;
  }

  .breadcrumbs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-teal-dim);
  }

  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumbs__link {
    color: var(--tok-teal);
    text-decoration: none;
  }

  .breadcrumbs__link:hover {
    color: var(--tok-teal-dim);
  }

  .breadcrumbs__current {
    color: var(--tok-text-dark);
    max-width: min(100%, 28rem);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .breadcrumbs__sep {
    color: color-mix(in srgb, var(--tok-teal-dim) 45%, var(--tok-surface-reading));
    user-select: none;
  }
</style>
