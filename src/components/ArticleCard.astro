---
import type { CollectionEntry } from "astro:content";

interface Props {
  article: CollectionEntry<"articles">;
  readingMinutes: number;
}

const { article, readingMinutes } = Astro.props;
const {
  title,
  slug,
  publishDate,
  excerpt,
  heroImage,
  heroImageAlt,
  seriesName,
} = article.data;

const maxExcerpt = 120;
const shortExcerpt =
  excerpt.length > maxExcerpt ? `${excerpt.slice(0, maxExcerpt).trim()}…` : excerpt;

const displayDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="article-card">
  <a class="article-card__link" href={`/articles/${slug}/`}>
    <div class="article-card__media">
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="article-card__img"
        width="640"
        height="360"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="article-card__body">
      {
        seriesName && (
          <span class="article-card__badge">{seriesName}</span>
        )
      }
      <h3 class="article-card__title">{title}</h3>
      <p class="article-card__excerpt">{shortExcerpt}</p>
      <div class="article-card__meta">
        <time datetime={publishDate.toISOString()}>{displayDate}</time>
        <span class="article-card__read">{readingMinutes} min read</span>
      </div>
    </div>
  </a>
</article>

<style>
  .article-card {
    margin: 0;
    height: 100%;
  }

  .article-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, var(--tok-surface-reading) 35%, transparent);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    border-radius: 0.375rem;
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .article-card__link:hover {
    border-color: var(--tok-teal);
    box-shadow: var(--shadow-sm);
  }

  .article-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--tok-surface-reading-soft);
  }

  .article-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-card__body {
    padding: 1rem 1.1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .article-card__badge {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .article-card__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--tok-teal-dim);
  }

  .article-card__link:hover .article-card__title {
    color: var(--tok-teal);
  }

  .article-card__excerpt {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--tok-text-dark);
    opacity: 0.88;
    flex: 1;
  }

  .article-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tok-teal-dim);
    margin-top: 0.25rem;
  }

  .article-card__read {
    color: color-mix(in srgb, var(--tok-teal-dim) 75%, var(--tok-surface-reading));
  }
</style>
