---
import type { CollectionEntry } from "astro:content";
import type { ArticleTopicChip } from "../lib/articleLibraryNav";
import ArticleTopicChips from "./ArticleTopicChips.astro";

type CardVariant = "default" | "method" | "series";

interface Props {
  article: CollectionEntry<"articles">;
  readingMinutes: number;
  topicChips?: ArticleTopicChip[];
  variant?: CardVariant;
  /** Client-side filter haystack for /articles/ search (optional). */
  searchHaystack?: string;
}

const {
  article,
  readingMinutes,
  topicChips = [],
  variant = "default",
  searchHaystack,
} = Astro.props;
const {
  title,
  slug,
  publishDate,
  excerpt,
  heroImage,
  heroImageAlt,
  seriesName,
  listBadge,
} = article.data;

const cardBadge = seriesName?.trim() || listBadge?.trim();
const resolvedVariant: CardVariant = seriesName?.trim()
  ? "series"
  : listBadge?.trim()
    ? "method"
    : variant;

const maxExcerpt = 120;
const shortExcerpt =
  excerpt.length > maxExcerpt ? `${excerpt.slice(0, maxExcerpt).trim()}…` : excerpt;

const displayDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article
  class:list={["article-card", `article-card--${resolvedVariant}`]}
  {...searchHaystack ? { "data-art-search": searchHaystack } : {}}
>
  <a class="article-card__link" href={`/articles/${slug}/`}>
    <div class="article-card__media">
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="article-card__img"
        width="640"
        height="360"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="article-card__body">
      {
        cardBadge && (
          <span
            class:list={[
              "article-card__badge",
              resolvedVariant === "series" && "article-card__badge--series",
              resolvedVariant === "method" && "article-card__badge--method",
            ]}
          >
            {cardBadge}
          </span>
        )
      }
      <h3 class="article-card__title">{title}</h3>
      <p class="article-card__excerpt">{shortExcerpt}</p>
      <div class="article-card__meta">
        <time datetime={publishDate.toISOString()}>{displayDate}</time>
        <span class="article-card__read">{readingMinutes} min read</span>
      </div>
    </div>
  </a>
  <ArticleTopicChips chips={topicChips} class="article-card__topics" />
</article>

<style>
  .article-card {
    margin: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .article-card--method .article-card__link {
    border-left: 3px solid var(--tok-gold);
    background: color-mix(in srgb, var(--tok-gold) 8%, var(--tok-surface-reading));
  }

  .article-card--series .article-card__link {
    border-left: 3px solid var(--tok-water);
    background: color-mix(in srgb, var(--tok-water) 10%, var(--tok-surface-reading-soft));
  }

  .article-card__link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, var(--tok-surface-reading) 35%, transparent);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      border-color var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }

  .article-card__link:hover {
    border-color: var(--tok-teal);
    box-shadow: var(--shadow-sm);
  }

  .article-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--tok-surface-reading-soft);
  }

  .article-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-card__body {
    padding: 1rem 1.1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .article-card__badge {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .article-card__badge--series {
    color: var(--tok-water);
  }

  .article-card__badge--method {
    color: var(--tok-teal-dim);
  }

  .article-card__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--tok-teal-dim);
  }

  .article-card__link:hover .article-card__title {
    color: var(--tok-teal);
  }

  .article-card__excerpt {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--tok-text-dark);
    opacity: 0.88;
    flex: 1;
  }

  .article-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tok-teal-dim);
    margin-top: 0.25rem;
  }

  .article-card__read {
    color: color-mix(in srgb, var(--tok-teal-dim) 75%, var(--tok-surface-reading));
  }

  .article-card__topics {
    margin: 0.45rem 0 0 0.15rem;
  }
</style>
