---
interface SeriesOpt {
  slug: string;
  label: string;
}

interface Props {
  sort: "newest" | "oldest" | "series";
  /** When false, series filter select is hidden (non–newest-first views). */
  showFilter: boolean;
  /** When false, sort select is hidden (e.g. series filter uses reading order). */
  showSort?: boolean;
  /** `all` or series slug. */
  filter: "all" | string;
  seriesOptions: SeriesOpt[];
}

const { sort, showFilter, showSort = true, filter, seriesOptions } = Astro.props;

const sortChoices: { id: "newest" | "oldest" | "series"; label: string; href: string }[] =
  [
    { id: "newest", label: "Newest", href: "/articles/" },
    { id: "oldest", label: "Oldest", href: "/articles/sort/oldest/" },
    { id: "series", label: "By series", href: "/articles/sort/series/" },
  ];
---

<div class="lib-toolbar">
  {
    showSort && (
      <div class="lib-toolbar__field">
        <label class="lib-toolbar__label" for="lib-sort">Sort</label>
        <select id="lib-sort" class="lib-toolbar__select" data-lib-nav="sort">
          {
            sortChoices.map((c) => (
              <option value={c.href} selected={c.id === sort}>
                {c.label}
              </option>
            ))
          }
        </select>
      </div>
    )
  }

  {
    showFilter && (
      <div class="lib-toolbar__field">
        <label class="lib-toolbar__label" for="lib-filter">Series</label>
        <select id="lib-filter" class="lib-toolbar__select" data-lib-nav="filter">
          <option value="/articles/" selected={filter === "all"}>
            All series
          </option>
          {seriesOptions.map((s) => (
            <option
              value={`/articles/filter/${s.slug}/`}
              selected={filter === s.slug}
            >
              {s.label}
            </option>
          ))}
        </select>
      </div>
    )
  }

  {
    !showFilter && (
      <p class="lib-toolbar__hint">
        Series filter applies to the default newest-first library view.
      </p>
    )
  }
</div>

<script is:inline>
  (function () {
    document.querySelectorAll("[data-lib-nav]").forEach(function (el) {
      el.addEventListener("change", function () {
        var v = el.value;
        if (v) window.location.href = v;
      });
    });
  })();
</script>

<style>
  .lib-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem 1.25rem;
    margin-bottom: 1rem;
  }

  .lib-toolbar__field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: min(100%, 11rem);
    flex: 1 1 9rem;
    max-width: 14rem;
  }

  .lib-toolbar__label {
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-dropdown);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-teal-dim);
  }

  .lib-toolbar__select {
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.45rem 0.6rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 50%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--tok-surface-reading) 60%, transparent);
    color: var(--tok-text-dark);
  }

  .lib-toolbar__select:focus-visible {
    outline: 2px solid var(--tok-teal);
    outline-offset: 2px;
  }

  .lib-toolbar__hint {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--tok-teal-dim);
    max-width: 36rem;
    flex: 1 1 100%;
  }
</style>
