---
import { BLOG_SIDEBAR_SOURCE_COMPONENT } from "../lib/mailerlite";
import { withSubscribeSourceAttribution } from "../lib/subscribeAttribution";

const subscribeFallbackHref = withSubscribeSourceAttribution("/subscribe/", {
  pagePathname: Astro.url.pathname,
  sourceComponent: BLOG_SIDEBAR_SOURCE_COMPONENT,
});
---

<form
  class="tok-blog-newsletter"
  data-blog-newsletter-form
  data-source-component={BLOG_SIDEBAR_SOURCE_COMPONENT}
  action="/api/newsletter-subscribe/"
  method="post"
  novalidate
>
  <label class="tok-blog-newsletter__label" for="blog-newsletter-email">Email</label>
  <input
    id="blog-newsletter-email"
    class="tok-blog-newsletter__input"
    type="email"
    name="email"
    autocomplete="email"
    placeholder="your@email.com"
    required
  />
  <input
    class="tok-blog-newsletter__hp"
    type="text"
    name="website"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />
  <button class="tok-blog-newsletter__btn" type="submit">Subscribe</button>
  <p class="tok-blog-newsletter__status" data-newsletter-status hidden></p>
  <p class="tok-blog-newsletter__fallback">
    <a href={subscribeFallbackHref} data-newsletter-fallback>Full signup page</a>
  </p>
</form>

<script>
  import { initBlogNewsletterSignup } from "../scripts/blogNewsletterSignup";

  initBlogNewsletterSignup(document.currentScript?.closest(".tok-blog-sidebar") ?? document);
</script>

<style>
  .tok-blog-newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
    max-width: 100%;
  }

  .tok-blog-newsletter__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .tok-blog-newsletter__input {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.5rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 50%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--tok-surface-reading) 60%, transparent);
    color: var(--tok-text-dark);
  }

  .tok-blog-newsletter__input::placeholder {
    color: color-mix(in srgb, var(--tok-text-dark) 45%, transparent);
  }

  .tok-blog-newsletter__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .tok-blog-newsletter__btn {
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: var(--tok-type-ml-cta);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    border: none;
    border-radius: var(--radius-md);
    background: var(--tok-teal-dim);
    color: var(--tok-text-light);
    cursor: pointer;
    transition: background var(--dur-base) var(--ease-out);
  }

  .tok-blog-newsletter__btn:hover:not(:disabled) {
    background: var(--tok-teal);
  }

  .tok-blog-newsletter__btn:disabled {
    opacity: 0.65;
    cursor: wait;
  }

  .tok-blog-newsletter__btn:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 2px;
  }

  .tok-blog-newsletter__status {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .tok-blog-newsletter__status.is-error {
    color: var(--tok-teal-dim);
  }

  .tok-blog-newsletter__status.is-success {
    color: var(--tok-teal);
  }

  .tok-blog-newsletter__fallback {
    margin: 0.15rem 0 0;
    font-size: 0.82rem;
  }

  .tok-blog-newsletter__fallback a {
    font-weight: 600;
  }
</style>
