---
interface Props {
  title: string;
  intro: string[];
  summaryItems: string[];
  paymentCancelled?: boolean;
  submitted?: boolean;
}

const { title, intro, summaryItems, paymentCancelled = false, submitted = false } = Astro.props;
---

<section class="ask-request__head" aria-labelledby="request-heading">
  <p class="ask-request__kicker">Ask Leilia</p>
  <h1 id="request-heading">{title}</h1>
  {intro.map((paragraph) => <p>{paragraph}</p>)}
  <ul class="ask-request__summary" aria-label="Ask Leilia request summary">
    {summaryItems.map((item) => <li>{item}</li>)}
  </ul>
</section>

{
  paymentCancelled ? (
    <section class="ask-request__confirmation" aria-live="polite">
      <h2>Payment not completed.</h2>
      <p>
        Your payment was not completed. Your reading request has not been booked yet. You can review
        your details and try again when ready.
      </p>
    </section>
  ) : null
}

{
  submitted ? (
    <section class="ask-request__confirmation" aria-live="polite">
      <h2>Thank you.</h2>
      <p>Your request has been received.</p>
      <p>You will receive your written reading within 48 hours.</p>
    </section>
  ) : null
}

{
  !submitted ? (
    <div class="ask-request-form-wrap">
      <slot />
    </div>
  ) : null
}

<style>
  .ask-request__head {
    position: relative;
    max-width: 42rem;
  }

  .ask-request__kicker {
    margin: 0 0 0.25rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .ask-request h1,
  .ask-request__confirmation h2 {
    margin: 0 0 0.35rem;
    font-family: var(--font-accent);
    font-weight: 400;
    color: var(--tok-water);
  }

  .ask-request h1 {
    font-size: clamp(2.4rem, 9vw, 4.8rem);
    line-height: 1.12;
  }

  .ask-request p {
    margin: 0;
    color: var(--tok-text-dark);
    line-height: 1.54;
  }

  .ask-request__head p + p {
    margin-top: 0.16rem;
  }

  .ask-request__summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .ask-request__summary li {
    padding: 0.22rem 0.4rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 46%, transparent);
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
  }

  .ask-request__confirmation,
  .ask-request-form-wrap :global(.ask-request-form) {
    margin-top: clamp(0.6rem, 2vw, 0.9rem);
    padding: clamp(0.65rem, 2.25vw, 0.95rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .ask-request-form-wrap :global(.ask-request-form) {
    display: grid;
    gap: 0.75rem;
  }

  .ask-request-form-wrap :global(.ask-request-form fieldset) {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0 0 0.7rem;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 22%, transparent);
  }

  .ask-request-form-wrap :global(.ask-request-form fieldset:last-of-type) {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .ask-request-form-wrap :global(.ask-request-form .ask-request-form__fieldset--compact) {
    gap: 0.35rem;
    padding-bottom: 0;
  }

  .ask-request-form-wrap :global(.ask-request-form legend) {
    margin-bottom: 0.35rem;
    font-size: var(--tok-type-meta);
    font-weight: 700;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .ask-request-form-wrap :global(.ask-request-form label) {
    display: grid;
    gap: 0.4rem;
    font-size: var(--tok-type-label);
    font-weight: 700;
    color: var(--tok-text-dark);
  }

  .ask-request-form-wrap :global(.ask-request-form .ask-request-form__radio) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    font-weight: 600;
    line-height: 1.35;
  }

  .ask-request-form-wrap :global(.ask-request-form input),
  .ask-request-form-wrap :global(.ask-request-form textarea) {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
    font: inherit;
  }

  .ask-request-form-wrap :global(.ask-request-form .ask-request-form__radio input[type="radio"]) {
    flex: 0 0 auto;
    margin: 0;
    width: auto;
  }

  .ask-request-form-wrap :global(.ask-request-form .ask-request-form__upload) {
    gap: 0.3rem;
    margin-top: 0.2rem;
  }

  .ask-request-form-wrap :global(.ask-request-form input[type="file"]) {
    padding: 0.55rem 0.65rem;
  }

  .ask-request-form-wrap :global(.ask-request-form textarea) {
    line-height: 1.65;
    resize: vertical;
  }

  .ask-request-form-wrap :global(.ask-request-form button) {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .ask-request-form-wrap :global(.ask-request-form__intro) {
    display: grid;
    gap: 0.45rem;
    margin-bottom: 0.15rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 22%, transparent);
  }

  .ask-request-form-wrap :global(.ask-request-form__intro h3) {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.4vw, 1.35rem);
    font-weight: 400;
    line-height: 1.35;
    color: var(--tok-water);
  }

  .ask-request-form-wrap :global(.ask-request-form__intro p) {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.62;
    color: var(--tok-text-dark);
  }

  .ask-request-form-wrap :global(.ask-request-form__helper) {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.55;
    color: var(--tok-text-muted);
  }

  .ask-request-form-wrap :global(.ask-request-form__section-note) {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--tok-text-muted);
  }

  .ask-request-form-wrap :global(.ask-request-form__life-areas) {
    display: grid;
    gap: 0.75rem;
  }

  .ask-request-form-wrap :global(.ask-request-form__checkbox-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem 1rem;
  }

  .ask-request-form-wrap :global(.ask-request-form__checkbox-other) {
    display: grid;
    gap: 0.5rem;
    padding-top: 0.15rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 18%, transparent);
  }

  .ask-request-form-wrap :global(.ask-request-form__checkbox) {
    display: grid;
    grid-template-columns: 1.125rem minmax(0, 1fr);
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    margin: 0;
    font-weight: 600;
    line-height: 1.35;
    cursor: pointer;
  }

  .ask-request-form-wrap :global(.ask-request-form__checkbox-label) {
    min-width: 0;
  }

  .ask-request-form-wrap :global(.ask-request-form__checkbox input[type="checkbox"]) {
    width: 1.125rem;
    height: 1.125rem;
    margin: 0;
    padding: 0;
    accent-color: var(--tok-gold-deep);
  }

  .ask-request-form-wrap :global(.ask-request-form__other-field) {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    padding-left: calc(1.125rem + 0.55rem);
    transition:
      max-height var(--dur-base) var(--ease-out),
      opacity var(--dur-base) var(--ease-out);
  }

  .ask-request-form-wrap :global(.ask-request-form__other-field.is-visible) {
    max-height: 3.5rem;
    opacity: 1;
  }

  .ask-request-form-wrap :global(.ask-request-form__other-field input[type="text"]) {
    width: 100%;
    max-width: 24rem;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
    font: inherit;
  }

  @media (min-width: 640px) {
    .ask-request-form-wrap :global(.ask-request-form__checkbox-grid) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .ask-request-form-wrap :global(.ask-request-form__guidance) {
    margin: 0;
    padding: 0.75rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 24%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 42%, transparent);
  }

  .ask-request-form-wrap :global(.ask-request-form__guidance p) {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.58;
    color: var(--tok-text-muted);
  }
</style>
