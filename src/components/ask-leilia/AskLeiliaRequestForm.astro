---
import type { AskLeiliaReadingType } from "../../lib/ask-leilia/readingTypes";

interface Props {
  readingType: AskLeiliaReadingType;
  action?: string;
  submitLabel?: string;
  questionPlaceholder?: string;
  contextPlaceholder?: string;
  showTierIntro?: boolean;
  showTierGuidance?: boolean;
}

const {
  readingType,
  action = "/api/ask-leilia/checkout",
  submitLabel = "Continue to Payment",
  questionPlaceholder = "Share the single question you would like explored through the cards.",
  contextPlaceholder,
  showTierIntro = true,
  showTierGuidance = true,
} = Astro.props;

const PERSONAL_GUIDANCE_LIFE_AREAS = [
  "Relationships",
  "Family",
  "Career",
  "Business",
  "Finances",
  "Health",
  "Personal Growth",
  "Spiritual Direction",
  "Other",
] as const;

const PERSONAL_GUIDANCE_LIFE_AREAS_STANDARD = PERSONAL_GUIDANCE_LIFE_AREAS.filter(
  (area) => area !== "Other",
);

const tierGuidance: Record<AskLeiliaReadingType, string> = {
  "one-question":
    "If you find yourself trying to ask several questions at once, the In-Depth Reading will usually provide a more satisfying result. This One Question Reading does not include audio or video.",
  "in-depth":
    "If the questions that matter most feel larger than a connected situation — including what you may not yet know to ask — the Personal Guidance Reading may be the better choice. This In-Depth Reading does not include audio or video.",
  "personal-guidance":
    "This Personal Guidance Reading includes Leilia’s signature Waka Spread, a written PDF, spread imagery, and a private recorded interpretation.",
};
---

<form class="ask-request-form" method="post" action={action} enctype="multipart/form-data">
  <input type="hidden" name="readingType" value={readingType} />

  {
    showTierIntro && readingType === "one-question" ? (
      <div class="ask-request-form__intro">
        <h3>One clear question often leads to the clearest answer.</h3>
        <p>
          Bring one clearly defined question and enough context for me to understand what is happening
          and what you most need clarity about. I will choose the spread and draw as many cards as the
          question requires. If you realise you are untangling several connected issues, the In-Depth
          Reading or Personal Guidance Reading will usually serve you better.
        </p>
      </div>
    ) : null
  }

  {
    showTierIntro && readingType === "in-depth" ? (
      <div class="ask-request-form__intro">
        <h3>Some situations need more than one contained answer.</h3>
        <p>
          Use this reading for a complex situation, a major decision, or connected concerns with more
          than one layer. You may follow several related questions, and different areas of life can be
          explored where they belong to the same situation. It is not limited to two areas, and it is
          not an unlimited list of unrelated questions.
        </p>
      </div>
    ) : null
  }

  {
    showTierIntro && readingType === "personal-guidance" ? (
      <div class="ask-request-form__intro">
        <h3>Bring what matters most — and leave room for what you have not yet asked.</h3>
        <p>
          This Personal Guidance Reading includes my signature Waka Spread, structured around the
          metaphor and mechanics of a vessel in motion. Share the questions, concerns, or areas of
          life that matter most; the reading is not confined to them. I also follow the patterns and
          information that emerge through the Waka Spread.
        </p>
      </div>
    ) : null
  }

  <fieldset>
    <legend>Your details</legend>

    <label>
      Name
      <input name="name" type="text" autocomplete="name" required />
    </label>

    <label>
      Email
      <input name="email" type="email" autocomplete="email" required />
    </label>
  </fieldset>

  {
    readingType === "one-question" ? (
      <>
        <fieldset>
          <legend>Your question</legend>

          <label>
            Your Question
            <textarea
              name="question"
              rows="6"
              maxlength="2000"
              required
              placeholder={questionPlaceholder}
            />
          </label>

          <label>
            Background (Optional)
            <textarea name="context" rows="5" maxlength="5000" placeholder={contextPlaceholder} />
            <span class="ask-request-form__helper">
              Include only the background that helps me understand your question. A few sentences are
              usually enough.
            </span>
          </label>
        </fieldset>

        <fieldset class="ask-request-form__fieldset--compact">
          <legend>Card preference</legend>

          <label class="ask-request-form__radio">
            <input type="radio" name="cardPreference" value="pull_for_me" required />
            <span>Please pull the cards for me</span>
          </label>

          <label class="ask-request-form__radio">
            <input type="radio" name="cardPreference" value="own_cards_attached" required />
            <span>I have attached my own cards</span>
          </label>

          <label class="ask-request-form__upload">
            Upload image of cards
            <input name="cardImage" type="file" accept="image/png,image/jpeg,image/webp" />
            <span class="ask-request-form__helper">
              If you're asking me to interpret cards you've already drawn, upload a clear photograph
              here. Otherwise, simply leave this blank and I'll draw the cards for you.
            </span>
          </label>
        </fieldset>
      </>
    ) : null
  }

  {
    readingType === "in-depth" ? (
      <>
        <fieldset>
          <legend>Your reading request</legend>

          <label>
            Primary Question
            <textarea
              name="primaryQuestion"
              rows="6"
              maxlength="2000"
              required
              placeholder="Share the primary question you would like explored through the cards."
            />
          </label>

          <label>
            Tell me what has brought you to this point.
            <textarea
              name="background"
              rows="6"
              maxlength="5000"
              placeholder="Describe the background, history, or circumstances surrounding your question."
            />
          </label>

          <label>
            What outcome or understanding are you hoping this reading will help you reach?
            <textarea
              name="outcome"
              rows="5"
              maxlength="2000"
              required
              placeholder="Describe what you hope this reading will clarify or help you move toward."
            />
          </label>

          <label>
            Is there anything you feel I should know before I begin? (Optional)
            <textarea
              name="beforeBegin"
              rows="4"
              maxlength="5000"
              placeholder="Share anything that would help me prepare before I begin your reading."
            />
          </label>
        </fieldset>
      </>
    ) : null
  }

  {
    readingType === "personal-guidance" ? (
      <>
        <fieldset>
          <legend class="ask-request-form__section-legend">Life areas</legend>

          <p class="ask-request-form__section-note">
            Select the areas of life that matter most for this Personal Guidance Reading. These help
            me understand the ground of your situation; the reading is not limited to the boxes you
            tick.
          </p>

          <div class="ask-request-form__life-areas">
            <div class="ask-request-form__checkbox-grid" role="group" aria-label="Life areas">
              {
                PERSONAL_GUIDANCE_LIFE_AREAS_STANDARD.map((area) => (
                  <label class="ask-request-form__checkbox">
                    <input type="checkbox" name="lifeAreas" value={area} />
                    <span class="ask-request-form__checkbox-label">{area}</span>
                  </label>
                ))
              }
            </div>

            <div class="ask-request-form__checkbox-other">
              <label class="ask-request-form__checkbox">
                <input
                  type="checkbox"
                  name="lifeAreas"
                  value="Other"
                  data-life-area-other-toggle
                />
                <span class="ask-request-form__checkbox-label">Other</span>
              </label>
              <div class="ask-request-form__other-field" data-life-area-other-field hidden>
                <input
                  type="text"
                  name="lifeAreaOther"
                  maxlength="100"
                  placeholder="Please specify..."
                  autocomplete="off"
                  disabled
                  data-life-area-other-input
                />
              </div>
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend class="ask-request-form__section-legend">Questions</legend>

          <label>
            What are the questions or themes you'd like me to explore?
            <textarea
              name="questions"
              rows="6"
              maxlength="2000"
              required
              placeholder="Share the questions, themes, or tensions you would like this reading to address."
            />
          </label>
        </fieldset>

        <fieldset>
          <legend class="ask-request-form__section-legend">Current circumstances</legend>

          <label>
            What is happening in your life at the moment that provides important context for this
            reading?
            <textarea
              name="circumstances"
              rows="6"
              maxlength="5000"
              required
              placeholder="Describe what is unfolding in your life right now and why it matters to this reading."
            />
          </label>
        </fieldset>

        <fieldset>
          <legend class="ask-request-form__section-legend">Looking ahead</legend>

          <label>
            Is there a particular decision, opportunity or change approaching that you'd like this
            reading to help illuminate?
            <textarea
              name="lookingAhead"
              rows="5"
              maxlength="2000"
              required
              placeholder="Describe any decision, transition, or opportunity you would like guidance on."
            />
          </label>
        </fieldset>

        <fieldset>
          <legend class="ask-request-form__section-legend">Anything else</legend>

          <label>
            Is there anything you definitely want me to address, or anything you feel would help me
            prepare before I begin? (Optional)
            <textarea
              name="important"
              rows="4"
              maxlength="5000"
              placeholder="Share anything else that would help me understand your situation before I begin."
            />
          </label>
        </fieldset>
      </>
    ) : null
  }

  {
    showTierGuidance ? (
      <aside class="ask-request-form__guidance" aria-label="Reading tier guidance">
        <p>{tierGuidance[readingType]}</p>
      </aside>
    ) : null
  }

  <button type="submit">{submitLabel}</button>
</form>

<script>
  function initPersonalGuidanceLifeAreas() {
    const toggle = document.querySelector("[data-life-area-other-toggle]");
    const field = document.querySelector("[data-life-area-other-field]");
    const input = document.querySelector("[data-life-area-other-input]");

    if (
      !(toggle instanceof HTMLInputElement) ||
      !(field instanceof HTMLElement) ||
      !(input instanceof HTMLInputElement)
    ) {
      return;
    }

    const syncOtherField = () => {
      const isOtherSelected = toggle.checked;

      if (isOtherSelected) {
        field.hidden = false;
        field.classList.add("is-visible");
        input.disabled = false;
        input.required = true;
      } else {
        field.classList.remove("is-visible");
        input.required = false;
        input.disabled = true;
        input.value = "";
        window.setTimeout(() => {
          if (!toggle.checked) {
            field.hidden = true;
          }
        }, 200);
      }
    };

    if (toggle.dataset.bound !== "true") {
      toggle.dataset.bound = "true";
      toggle.addEventListener("change", syncOtherField);
    }

    syncOtherField();
  }

  initPersonalGuidanceLifeAreas();
  document.addEventListener("astro:page-load", initPersonalGuidanceLifeAreas);
</script>
