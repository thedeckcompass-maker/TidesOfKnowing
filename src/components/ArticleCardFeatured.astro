---
import type { CollectionEntry } from "astro:content";

interface Props {
  article: CollectionEntry<"articles">;
  readingMinutes: number;
}

const { article, readingMinutes } = Astro.props;
const {
  title,
  subtitle,
  slug,
  publishDate,
  excerpt,
  heroImage,
  heroImageAlt,
  seriesName,
} = article.data;

const maxExcerpt = 200;
const longExcerpt =
  excerpt.length > maxExcerpt ? `${excerpt.slice(0, maxExcerpt).trim()}…` : excerpt;

const displayDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="feat-card">
  <a class="feat-card__link" href={`/articles/${slug}/`}>
    <div class="feat-card__media">
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="feat-card__img"
        width="800"
        height="450"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="feat-card__body">
      {
        seriesName && (
          <span class="feat-card__badge">{seriesName}</span>
        )
      }
      <h2 class="feat-card__title">{title}</h2>
      {subtitle && <p class="feat-card__subtitle">{subtitle}</p>}
      <p class="feat-card__excerpt">{longExcerpt}</p>
      <div class="feat-card__meta">
        <time datetime={publishDate.toISOString()}>{displayDate}</time>
        <span>{readingMinutes} min read</span>
      </div>
      <span class="feat-card__cta">Read article</span>
    </div>
  </a>
</article>

<style>
  .feat-card {
    margin: 0;
    height: 100%;
  }

  .feat-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.45);
    border: 1px solid rgba(198, 161, 74, 0.45);
    border-radius: 0.5rem;
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .feat-card__link:hover {
    border-color: var(--gold);
    box-shadow: 0 12px 36px rgba(13, 50, 77, 0.12);
    transform: translateY(-2px);
  }

  .feat-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--shore);
  }

  .feat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feat-card__body {
    padding: 1.25rem 1.35rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .feat-card__badge {
    font-family: var(--font-nav);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .feat-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 600;
    line-height: 1.2;
    color: var(--mountain-water);
  }

  .feat-card__subtitle {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.45;
    color: var(--mountain-water);
    font-style: italic;
    opacity: 0.92;
  }

  .feat-card__excerpt {
    margin: 0;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink);
    opacity: 0.9;
    flex: 1;
  }

  .feat-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    font-family: var(--font-nav);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mountain-water);
  }

  .feat-card__cta {
    margin-top: 0.35rem;
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-nav);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    background: var(--navy);
    color: var(--lavender);
    border-radius: 0.25rem;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .feat-card__link:hover .feat-card__cta {
    background: var(--mountain-water);
    color: #fff;
  }
</style>
