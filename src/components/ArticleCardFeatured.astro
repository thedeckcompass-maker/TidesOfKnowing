---
import type { CollectionEntry } from "astro:content";

interface Props {
  article: CollectionEntry<"articles">;
  readingMinutes: number;
}

const { article, readingMinutes } = Astro.props;
const {
  title,
  subtitle,
  slug,
  publishDate,
  excerpt,
  heroImage,
  heroImageAlt,
  seriesName,
  listBadge,
} = article.data;

const cardBadge = seriesName?.trim() || listBadge?.trim();

const maxExcerpt = 200;
const longExcerpt =
  excerpt.length > maxExcerpt ? `${excerpt.slice(0, maxExcerpt).trim()}…` : excerpt;

const displayDate = publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="feat-card">
  <a class="feat-card__link" href={`/articles/${slug}/`}>
    <div class="feat-card__media">
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="feat-card__img"
        width="800"
        height="450"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="feat-card__body">
      {
        cardBadge && (
          <span class="feat-card__badge">{cardBadge}</span>
        )
      }
      <h2 class="feat-card__title">{title}</h2>
      {subtitle && <p class="feat-card__subtitle">{subtitle}</p>}
      <p class="feat-card__excerpt">{longExcerpt}</p>
      <div class="feat-card__meta">
        <time datetime={publishDate.toISOString()}>{displayDate}</time>
        <span>{readingMinutes} min read</span>
      </div>
      <span class="feat-card__cta">Read article</span>
    </div>
  </a>
</article>

<style>
  .feat-card {
    margin: 0;
    height: 100%;
  }

  .feat-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    background: color-mix(in srgb, var(--tok-surface-reading) 45%, transparent);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 45%, transparent);
    border-radius: var(--radius-promo);
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .feat-card__link:hover {
    border-color: var(--tok-gold);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .feat-card__media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--tok-surface-reading-soft);
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 22%, transparent);
  }

  .feat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feat-card__body {
    padding: clamp(1.4rem, 3.2vw, 1.65rem) clamp(1.35rem, 3vw, 1.5rem)
      clamp(1.55rem, 3.5vw, 1.85rem);
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    flex: 1;
    min-height: 0;
  }

  .feat-card__badge {
    display: block;
    margin: 0 0 0.35rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .feat-card__title {
    margin: 0;
    padding-top: 0.1rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 600;
    line-height: 1.32;
    color: var(--tok-teal-dim);
  }

  .feat-card__subtitle {
    margin: 0.05rem 0 0;
    font-size: 0.98rem;
    line-height: 1.52;
    color: var(--tok-teal-dim);
    font-style: italic;
    opacity: 0.92;
  }

  .feat-card__excerpt {
    margin: 0.1rem 0 0;
    font-size: 1rem;
    line-height: 1.68;
    color: var(--tok-text-dark);
    opacity: 0.9;
    flex: 1;
  }

  .feat-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    margin-top: 0.2rem;
    padding-top: 0.35rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tok-teal-dim);
  }

  .feat-card__cta {
    margin-top: 0.55rem;
    display: inline-flex;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    background: var(--tok-surface-panel);
    color: var(--tok-text-light-soft);
    border-radius: var(--radius-control);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .feat-card__link:hover .feat-card__cta {
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
  }
</style>
