---
interface Props {
  name:
    | "bookmark"
    | "cards"
    | "heart"
    | "journal"
    | "leaf"
    | "magnifier"
    | "pencil"
    | "question"
    | "reply"
    | "user";
  label?: string;
}

const { name, label } = Astro.props;
const ariaHidden = label ? undefined : "true";
---

<svg
  class="community-icon"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={ariaHidden}
>
  {
    name === "bookmark" && (
      <path d="M7 4.75h10v14.5l-5-3-5 3V4.75Z" />
    )
  }
  {
    name === "cards" && (
      <>
        <path d="M7.25 5.5 15 3.75l2.25 10-7.75 1.75-2.25-10Z" />
        <path d="M5.75 8.25h10v12h-10v-12Z" />
        <path d="M8.5 12h5" />
        <path d="M8.5 15h5" />
      </>
    )
  }
  {
    name === "heart" && (
      <path d="M12 20s-7-4.4-7-10.25A3.75 3.75 0 0 1 12 7.8a3.75 3.75 0 0 1 7 1.95C19 15.6 12 20 12 20Z" />
    )
  }
  {
    name === "journal" && (
      <>
        <path d="M6.5 4.5h10.25A1.75 1.75 0 0 1 18.5 6.25v13.25H7.25A1.75 1.75 0 0 1 5.5 17.75V5.5a1 1 0 0 1 1-1Z" />
        <path d="M8.5 4.5v15" />
        <path d="M11 8h4.25" />
        <path d="M11 11h4.25" />
      </>
    )
  }
  {
    name === "leaf" && (
      <>
        <path d="M5 19c8.25-.25 13.25-5.25 14-14-8.75.75-13.75 5.75-14 14Z" />
        <path d="M5 19 15 9" />
      </>
    )
  }
  {
    name === "magnifier" && (
      <>
        <circle cx="10.5" cy="10.5" r="5.75" />
        <path d="m15 15 4.25 4.25" />
      </>
    )
  }
  {
    name === "pencil" && (
      <>
        <path d="M4.75 18.75 6 14l8.75-8.75a2.1 2.1 0 0 1 3 3L9 17l-4.25 1.75Z" />
        <path d="m13.5 6.5 3 3" />
      </>
    )
  }
  {
    name === "question" && (
      <>
        <circle cx="12" cy="12" r="8" />
        <path d="M9.75 9.5a2.35 2.35 0 0 1 4.55.8c0 1.8-2.3 2-2.3 3.7" />
        <path d="M12 17h.01" />
      </>
    )
  }
  {
    name === "reply" && (
      <>
        <path d="M8.5 8.25 4.75 12l3.75 3.75" />
        <path d="M5 12h8.75A5.25 5.25 0 0 1 19 17.25v.5" />
      </>
    )
  }
  {
    name === "user" && (
      <>
        <circle cx="12" cy="8.25" r="3.25" />
        <path d="M5.75 20a6.25 6.25 0 0 1 12.5 0" />
      </>
    )
  }
</svg>

<style>
  .community-icon {
    display: block;
    width: 1.7rem;
    height: 1.7rem;
  }
</style>
