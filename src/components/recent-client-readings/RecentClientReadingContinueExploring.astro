---
import type { ReadingLibraryPublication } from "../../lib/readingLibrary";
import RecentClientReadingCard from "./RecentClientReadingCard.astro";

interface Props {
  publications: ReadingLibraryPublication[];
}

const { publications } = Astro.props;
---

{
  publications.length > 0 ? (
    <section class="rcr-continue" aria-labelledby="continue-exploring-heading">
      <h2 id="continue-exploring-heading" class="rcr-continue__title">
        More readings
      </h2>
      <div class="ask-leilia-portfolio__grid rcr-continue__reading-grid">
        {publications.map((publication) => (
          <RecentClientReadingCard publication={publication} headingLevel="h3" ctaLabel="Read Reading" />
        ))}
      </div>
    </section>
  ) : null
}
