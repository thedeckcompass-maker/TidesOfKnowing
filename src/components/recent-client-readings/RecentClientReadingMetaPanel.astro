---
import type { ReadingLibraryPublication } from "../../lib/readingLibrary";
import { formatLibraryDate, formatLibraryIsoDate } from "../../lib/readingLibrary";

interface Props {
  publication: ReadingLibraryPublication;
}

const { publication } = Astro.props;
const publishedAt = publication.publishedAt;
---

<section class="rcr-meta" aria-label="Reading details">
  <dl class="rcr-meta__grid">
    {
      publication.spreadUsed ? (
        <div>
          <dt>Spread used</dt>
          <dd>{publication.spreadUsed}</dd>
        </div>
      ) : null
    }
    {
      publication.lifeAreas.length > 0 ? (
        <div>
          <dt>Life areas</dt>
          <dd>{publication.lifeAreas.join(", ")}</dd>
        </div>
      ) : null
    }
    {
      publication.primaryCards.length > 0 ? (
        <div>
          <dt>Primary cards</dt>
          <dd>{publication.primaryCards.join(", ")}</dd>
        </div>
      ) : null
    }
    {
      publishedAt ? (
        <div>
          <dt>Published</dt>
          <dd>
            <time datetime={formatLibraryIsoDate(publishedAt)}>{formatLibraryDate(publishedAt)}</time>
          </dd>
        </div>
      ) : null
    }
  </dl>
</section>

<style>
  .rcr-meta {
    margin-top: clamp(1.25rem, 3vw, 2rem);
    padding: clamp(1rem, 3vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 45%, transparent);
  }

  .rcr-meta__grid {
    display: grid;
    gap: 0.85rem;
    margin: 0;
  }

  @media (min-width: 640px) {
    .rcr-meta__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .rcr-meta__grid div {
    margin: 0;
  }

  .rcr-meta__grid dt {
    margin: 0 0 0.2rem;
    font-size: var(--tok-type-meta);
    font-weight: 700;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .rcr-meta__grid dd {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--tok-text-dark);
  }
</style>
