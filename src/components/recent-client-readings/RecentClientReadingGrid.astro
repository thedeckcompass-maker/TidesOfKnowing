---
import type { ReadingLibraryPublication } from "../../lib/readingLibrary";
import RecentClientReadingCard from "./RecentClientReadingCard.astro";

interface Props {
  heading: string;
  headingId: string;
  publications: ReadingLibraryPublication[];
  ctaLabel?: string;
}

const { heading, headingId, publications, ctaLabel } = Astro.props;
---

{
  publications.length > 0 ? (
    <section class="ask-leilia-portfolio" aria-labelledby={headingId}>
      <h2 id={headingId} class="ask-leilia-portfolio__heading">
        {heading}
      </h2>
      <div class="ask-leilia-portfolio__grid">
        {publications.map((publication) => (
          <RecentClientReadingCard publication={publication} ctaLabel={ctaLabel} />
        ))}
      </div>
    </section>
  ) : null
}
