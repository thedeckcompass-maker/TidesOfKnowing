---
import type { ReadingLibraryPublication } from "../../lib/readingLibrary";
import {
  formatLibraryDate,
  formatLibraryIsoDate,
  getFeaturedSpreadImage,
  getReadingLibraryPath,
} from "../../lib/readingLibrary";

interface Props {
  publication: ReadingLibraryPublication;
  headingLevel?: "h2" | "h3" | "h4";
  ctaLabel?: string;
}

const { publication, headingLevel = "h3", ctaLabel = "Read Reading" } = Astro.props;
const TitleTag = headingLevel;
const href = getReadingLibraryPath(publication.slug);
const thumbnail = getFeaturedSpreadImage(publication);
const lifeAreaLabel = publication.lifeAreas.slice(0, 2).join(" · ");
const cardsLabel = publication.primaryCards.slice(0, 4).join(" · ");
const publishedAt = publication.publishedAt;
---

<article class="rcr-card">
  {
    thumbnail ? (
      <a class="rcr-card__media" href={href}>
        <img
          src={thumbnail}
          alt={`Spread photograph for ${publication.title}`}
          class="rcr-card__thumb"
          loading="lazy"
          decoding="async"
        />
      </a>
    ) : null
  }

  <div class="rcr-card__content">
    <p class="rcr-card__type">{publication.readingType}</p>
    <TitleTag class="rcr-card__title">
      <a href={href}>{publication.title}</a>
    </TitleTag>

    {
      publishedAt ? (
        <p class="rcr-card__published">
          <time datetime={formatLibraryIsoDate(publishedAt)}>{formatLibraryDate(publishedAt)}</time>
        </p>
      ) : null
    }

    <p class="rcr-card__excerpt">{publication.summary}</p>

    <dl class="rcr-card__meta">
      <div>
        <dt>Original question</dt>
        <dd>{publication.question}</dd>
      </div>
      {
        lifeAreaLabel ? (
          <div>
            <dt>Primary life area{publication.lifeAreas.length > 1 ? "s" : ""}</dt>
            <dd>{lifeAreaLabel}</dd>
          </div>
        ) : null
      }
      {
        cardsLabel ? (
          <div>
            <dt>Primary cards featured</dt>
            <dd>{cardsLabel}</dd>
          </div>
        ) : null
      }
    </dl>

    <a class="rcr-card__cta" href={href}>
      {ctaLabel}
    </a>
  </div>
</article>
