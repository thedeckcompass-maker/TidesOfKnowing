---
import type { ReadingLibraryPublication } from "../../lib/readingLibrary";
import { getFeaturedSpreadImage } from "../../lib/readingLibrary";

interface Props {
  publication: ReadingLibraryPublication;
  baseUrl: URL;
}

const { publication, baseUrl } = Astro.props;
const src = getFeaturedSpreadImage(publication);
if (!src) return null;
const href = new URL(src, baseUrl).href;
const alt = `Original tarot spread photograph for ${publication.title}`;
---

<figure class="rcr-reading__featured-spread">
  <a href={href} target="_blank" rel="noopener noreferrer">
    <img
      src={src}
      alt={alt}
      width="1200"
      height="800"
      loading="eager"
      decoding="async"
    />
  </a>
  <figcaption>Original spread photograph</figcaption>
</figure>
