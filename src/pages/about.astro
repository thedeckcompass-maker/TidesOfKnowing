---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteBase } from "../lib/site";

const ogUrl = new URL("/about/", siteBase(Astro)).href;
---

<BaseLayout
  title="About — Leigh Spencer & Tides of Knowing"
  description="Leigh Spencer: writer, guide, and founder. Tides of Knowing is the long-form companion to The Deck Compass — essays on tarot, intuition, and fourth-generation Matakite practice."
  ogUrl={ogUrl}
>
  <article class="about page-inner">
    <header class="about__head" data-reveal>
      <h1 class="about__title">About</h1>
    </header>

    <div class="about__body">
      <p class="about__p" data-reveal>
        <strong>Tides of Knowing</strong> is a long-form publication by <strong>Leigh Spencer</strong>,
        created as a companion to <a href="https://thedeckcompass.com">The Deck Compass</a> — a
        subscription platform for intuitive tarot readers. Where The Deck Compass supports practice,
        community, and structured learning, ToK holds the slower work: essays, archetypal
        reflection, and writing meant to surface in search and AI answers for years to come.
      </p>

      <p class="about__p" data-reveal>
        Leigh is a writer, guide, and founder with <strong>49 years of tarot experience</strong> and
        a lineage as a <strong>fourth-generation Matakite</strong> — carrying forward intuitive and
        ancestral ways of seeing. Her work sits at the intersection of reflective practice, pattern
        recognition, and practical navigation for readers who take the cards seriously but leave
        performance at the door.
      </p>

      <blockquote class="about__quote" data-reveal>
        <p>
          This site exists for writing that does not chase trends — only clarity, depth, and a steady
          light for anyone finding their way.
        </p>
      </blockquote>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 40rem;
  }

  .about__head {
    margin-bottom: 2rem;
  }

  .about__title {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 2.85rem);
    color: var(--mountain-water);
  }

  .about__p {
    margin: 0 0 1.35rem;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .about__quote {
    margin: 2rem 0 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    border-left: 3px solid var(--gold);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--ink);
  }

  .about__quote p {
    margin: 0;
  }
</style>
