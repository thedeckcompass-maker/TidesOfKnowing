---
import BaseLayout from "../layouts/BaseLayout.astro";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import { getCollection } from "astro:content";
import { siteBase } from "../lib/site";

const latest = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const homeUrl = new URL("/", siteBase(Astro)).href;

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Tides of Knowing",
  url: homeUrl,
  description:
    "Long-form writing at the intersection of intuition, archetypal wisdom, and personal navigation. Companion publication to The Deck Compass.",
  publisher: {
    "@type": "Organization",
    name: "Tides of Knowing",
    url: homeUrl,
  },
};
---

<BaseLayout
  title="Tides of Knowing — Essays on tarot, intuition & navigation"
  description="Long-form writing by Leigh Spencer: tarot, archetypal insight, and reflective practice. Companion to The Deck Compass — join the waitlist for intuitive readers."
  ogUrl={homeUrl}
  tdcPlacement="none"
  jsonLd={websiteLd}
>
  <section class="hero">
    <div class="page-inner hero__inner">
      <h1 class="hero__title" data-reveal>Tides of Knowing</h1>
      <p class="hero__lead" data-reveal>
        Long-form writing at the intersection of intuition, archetypal wisdom, and personal navigation.
      </p>
    </div>
  </section>

  <section class="intro">
    <div class="page-inner intro__inner">
      <p class="intro__text" data-reveal>
        <em>Tides of Knowing</em> is the companion publication to <strong>The Deck Compass</strong> — a
        quiet home for essays and reflections that stay useful long after the feed moves on. Here,
        depth matters more than velocity.
      </p>
    </div>
  </section>

  <div data-reveal>
    <TdcConversionBlock />
  </div>

  <section class="latest" aria-labelledby="latest-heading">
    <div class="page-inner latest__inner">
      <h2 id="latest-heading" class="latest__title" data-reveal>Latest articles</h2>
      {
        latest.length === 0 ? (
          <p class="latest__empty" data-reveal>
            New pieces will appear here as they are published. Browse the{" "}
            <a href="/library">library</a> for the full archive.
          </p>
        ) : (
          <ul class="latest__list">
            {latest.map((post) => (
              <li class="latest__item" data-reveal>
                <a class="latest__link" href={`/blog/${post.slug ?? post.id}/`}>
                  <span class="latest__post-title">{post.data.title}</span>
                  <span class="latest__post-meta">
                    {post.data.date.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  <span class="latest__post-desc">{post.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: clamp(2.5rem, 8vw, 5rem) 0 clamp(2rem, 5vw, 3rem);
    background: var(--paper);
  }

  .hero__inner {
    max-width: 42rem;
  }

  .hero__title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.75rem, 8vw, 4rem);
    line-height: 1.08;
    color: var(--mountain-water);
  }

  .hero__lead {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    line-height: 1.65;
    color: var(--ink);
    opacity: 0.92;
  }

  .intro {
    padding: 0 0 clamp(2rem, 5vw, 3rem);
    background: linear-gradient(180deg, var(--paper) 0%, var(--pale-horizon) 100%);
  }

  .intro__inner {
    max-width: 40rem;
  }

  .intro__text {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .latest {
    padding: clamp(2.5rem, 7vw, 4.5rem) 0 clamp(3rem, 8vw, 5rem);
    background: var(--lavender);
    background: linear-gradient(
      180deg,
      rgba(216, 219, 241, 0.35) 0%,
      var(--paper) 45%
    );
  }

  .latest__inner {
    max-width: 44rem;
  }

  .latest__title {
    margin: 0 0 1.75rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.85rem, 4vw, 2.35rem);
    color: var(--mountain-water);
  }

  .latest__empty {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 36rem;
  }

  .latest__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .latest__item {
    margin: 0;
  }

  .latest__link {
    display: block;
    padding: 1.25rem 1.35rem;
    text-decoration: none;
    color: inherit;
    background: var(--shore);
    border-left: 3px solid var(--gold);
    border-radius: 0 2px 2px 0;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .latest__link:hover {
    background: var(--paper);
    border-left-color: var(--sky);
  }

  .latest__post-title {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--mountain-water);
    margin-bottom: 0.35rem;
  }

  .latest__post-meta {
    display: block;
    font-family: var(--font-nav);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .latest__post-desc {
    display: block;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--ink);
    opacity: 0.88;
  }
</style>
