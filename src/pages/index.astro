---
import BaseLayout from "../layouts/BaseLayout.astro";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import { getCollection } from "astro:content";
import { siteBase } from "../lib/site";
import { sortArticlesLibraryNewest } from "../lib/articleLibraryOrder";
import { sortBlogPostsForListing } from "../lib/sortBlogPosts";

const latest = sortBlogPostsForListing(
  await getCollection("blog", ({ data }) => !data.draft),
);

const latestMethodology = sortArticlesLibraryNewest(
  await getCollection("articles"),
).slice(0, 5);

const homeUrl = new URL("/", siteBase(Astro)).href;

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Tides of Knowing",
  url: homeUrl,
  description:
    "Long-form writing on intuition, archetype, and usable perception — for readers moving beyond surface meanings toward clearer, grounded readings. Companion to The Deck Compass.",
  publisher: {
    "@type": "Organization",
    name: "Tides of Knowing",
    url: homeUrl,
  },
};
---

<BaseLayout
  title="Tides of Knowing — Intuition, archetype, and grounded reading"
  description="Long-form writing for readers deepening tarot and symbolic practice: perception you can hold and use, not only interpret. Subscribe for new work — companion to The Deck Compass."
  ogUrl={homeUrl}
  tdcPlacement="none"
  jsonLd={websiteLd}
>
  <section class="hero">
    <div class="page-inner hero__inner">
      <h1 class="hero__title" data-reveal>Tides of Knowing</h1>
      <p class="hero__lead" data-reveal>
        Long-form writing for those who read beyond the surface — and want to trust what they're
        seeing.
      </p>
    </div>
  </section>

  <section class="intro">
    <div class="page-inner intro__inner">
      <p class="intro__text" data-reveal>
        Tides of Knowing is where intuitive perception becomes usable.<br />
        It's written for people who already understand the language of tarot, archetype, or symbolism
        — but find that knowing what the cards mean doesn't always translate into clear, grounded
        readings.
      </p>
      <p class="intro__text" data-reveal>
        Here, the focus is not on more meanings, but on how to follow what is already present —<br />
        how to recognise signal, hold it, and move with it in real time.
      </p>
      <p class="intro__text" data-reveal>
        This is the companion publication to The Deck Compass: a body of work designed to deepen
        perception, sharpen discernment, and make intuitive insight
        something you can actually use — for yourself or for others.
      </p>
      <h2 class="latest__title" data-reveal>A quiet invitation</h2>
      <p class="intro__text" data-reveal>
        I've spent more than thirty years working with language, perception, and interpretation — as
        a journalist, a reader, and an educator.
      </p>
      <p class="intro__text" data-reveal>This work comes from that intersection.</p>
      <p class="intro__text" data-reveal>
        If you're looking for a way to move beyond card meanings and into something more precise and
        usable, you're in the right place.
      </p>
      <p class="intro__text" data-reveal>
        You can read more about my background on the{" "}
        <a href="/about/">About page</a>.
      </p>
    </div>
  </section>

  <div data-reveal>
    <TdcConversionBlock />
  </div>

  <section class="latest" aria-labelledby="blog-latest-heading">
    <div class="page-inner latest__inner">
      <h2 id="blog-latest-heading" class="latest__title" data-reveal>
        Latest from the blog
      </h2>
      {
        latest.length === 0 ? (
          <p class="latest__empty" data-reveal>
            New posts will appear here as they are published. Browse the{" "}
            <a href="/library/">blog archive</a>
            {" "}for the full roll. Methodology articles and series live in the{" "}
            <a href="/articles/">article library</a>.
          </p>
        ) : (
          <ul class="latest__list">
            {latest.map((post) => (
              <li class="latest__item" data-reveal>
                <a class="latest__link" href={`/blog/${post.slug ?? post.id}/`}>
                  <span class="latest__post-title">{post.data.title}</span>
                  <span class="latest__post-meta">
                    {post.data.date.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  <span class="latest__post-desc">{post.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  <section class="latest methodology" aria-labelledby="methodology-heading">
    <div class="page-inner latest__inner">
      <h2 id="methodology-heading" class="latest__title" data-reveal>
        Latest in the library
      </h2>
      <p class="methodology__intro" data-reveal>
        Long-form methodology pieces, series, and topics —{" "}
        <a class="methodology__hub-link" href="/articles/">Browse the full article library</a>
      </p>
      {
        latestMethodology.length === 0 ? (
          <p class="latest__empty" data-reveal>
            Articles will appear here as they are published. Open the{" "}
            <a href="/articles/">article library</a> for the full catalog.
          </p>
        ) : (
          <ul class="latest__list">
            {latestMethodology.map((article) => (
              <li class="latest__item" data-reveal>
                <a
                  class="latest__link"
                  href={`/articles/${article.data.slug}/`}
                >
                  <span class="latest__post-title">{article.data.title}</span>
                  <span class="latest__post-meta">
                    {article.data.publishDate.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  <span class="latest__post-desc">{article.data.excerpt}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: clamp(2.5rem, 8vw, 5rem) 0 clamp(2rem, 5vw, 3rem);
    background: var(--paper);
  }

  .hero__inner {
    max-width: 42rem;
  }

  .hero__title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.75rem, 8vw, 4rem);
    line-height: 1.08;
    color: var(--mountain-water);
  }

  .hero__lead {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    line-height: 1.65;
    color: var(--ink);
    opacity: 0.92;
  }

  .intro {
    padding: 0 0 clamp(2rem, 5vw, 3rem);
    background: linear-gradient(180deg, var(--paper) 0%, var(--pale-horizon) 100%);
  }

  .intro__inner {
    max-width: 40rem;
  }

  .intro__text {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .intro__text + .intro__text {
    margin-top: 1.25rem;
  }

  .intro__text br {
    display: block;
    margin-top: 0.35rem;
  }

  .latest {
    padding: clamp(2.5rem, 7vw, 4.5rem) 0 clamp(3rem, 8vw, 5rem);
    background: var(--lavender);
    background: linear-gradient(
      180deg,
      rgba(216, 219, 241, 0.35) 0%,
      var(--paper) 45%
    );
  }

  .latest.methodology {
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
    background: linear-gradient(
      180deg,
      var(--paper) 0%,
      rgba(216, 219, 241, 0.22) 55%,
      var(--paper) 100%
    );
  }

  .methodology__intro {
    margin: 0 0 1.5rem;
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 40rem;
  }

  .methodology__hub-link {
    font-family: var(--font-nav);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mountain-water);
  }

  .methodology__hub-link:hover {
    color: var(--sky);
  }

  .latest__inner {
    max-width: 44rem;
  }

  .latest__title {
    margin: 0 0 1.75rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.85rem, 4vw, 2.35rem);
    color: var(--mountain-water);
  }

  .intro__inner > .latest__title {
    margin-top: 2.2rem;
    margin-bottom: 1.2rem;
  }

  .intro__inner > .latest__title + .intro__text {
    margin-top: 1rem;
  }

  .intro__inner > .latest__title ~ .intro__text + .intro__text {
    margin-top: 1.25rem;
  }

  .latest__empty {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 36rem;
  }

  .latest__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .latest__item {
    margin: 0;
  }

  .latest__link {
    display: block;
    padding: 1.25rem 1.35rem;
    text-decoration: none;
    color: inherit;
    background: var(--shore);
    border-left: 3px solid var(--gold);
    border-radius: 0 2px 2px 0;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .latest__link:hover {
    background: var(--paper);
    border-left-color: var(--sky);
  }

  .latest__post-title {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--mountain-water);
    margin-bottom: 0.35rem;
  }

  .latest__post-meta {
    display: block;
    font-family: var(--font-nav);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .latest__post-desc {
    display: block;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--ink);
    opacity: 0.88;
  }
</style>
