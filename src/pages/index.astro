---
import BaseLayout from "../layouts/BaseLayout.astro";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import { getCollection } from "astro:content";
import { siteBase } from "../lib/site";
import { sortArticlesLibraryNewest } from "../lib/articleLibraryOrder";
import { sortBlogPostsForListing } from "../lib/sortBlogPosts";

const latest = sortBlogPostsForListing(
  await getCollection("blog", ({ data }) => !data.draft),
);

const latestMethodology = sortArticlesLibraryNewest(
  await getCollection("articles"),
).slice(0, 5);

const homeUrl = new URL("/", siteBase(Astro)).href;

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Tides of Knowing",
  url: homeUrl,
  description:
    "Tides of Knowing is a long-form publication about practical intuition, perception and interpretation through tarot and oracle for personal growth and grounded guidance.",
  publisher: {
    "@type": "Organization",
    name: "Tides of Knowing",
    url: homeUrl,
  },
};
---

<BaseLayout
  title="Tides of Knowing | Practical intuition through tarot and oracle"
  description="Long-form writing on practical intuition, perception and interpretation through tarot and oracle for personal growth, clearer boundaries and grounded guidance."
  ogUrl={homeUrl}
  tdcPlacement="none"
  jsonLd={websiteLd}
>
  <section class="home-gate surface-system tok-home-hero" aria-labelledby="home-gate-heading">
    <div class="page-inner home-gate__inner">
      <h1 id="home-gate-heading" class="home-gate__h1" data-reveal>
        For readers who know the meanings but still lose the thread.
      </h1>
      <p class="home-gate__support" data-reveal>
        Tides of Knowing helps tarot and oracle readers move beyond memorised meanings into clearer
        symbolic perception through the COMPASS Method, applied tools, guided practice, and training.
      </p>
      <p class="home-gate__trust" data-reveal>
        40+ years tarot practice · 30 years as a professional journalist · Fourth-generation Matakite
        · Founder of the COMPASS Method
      </p>
    </div>
  </section>

  <section class="home-pathways surface-reading-soft" aria-labelledby="home-pathways-heading">
    <div class="page-inner home-pathways__inner">
      <h2 id="home-pathways-heading" class="home-pathways__vh">Ways into the work</h2>
      <ul class="home-pathways__list">
        <li class="home-pathways__item" data-reveal>
          <a class="home-pathways__card" href="/articles/compass-method/">
            <span class="home-pathways__context">Your readings feel close, but not quite held</span>
            <span class="home-pathways__action">Explore the Method</span>
          </a>
        </li>
        <li class="home-pathways__item" data-reveal>
          <a class="home-pathways__card" href="/tools/">
            <span class="home-pathways__context">You want to experience the framework directly</span>
            <span class="home-pathways__action">Try a Tool</span>
          </a>
        </li>
        <li class="home-pathways__item" data-reveal>
          <a class="home-pathways__card" href="/practice/">
            <span class="home-pathways__context">You want somewhere to practise with others</span>
            <span class="home-pathways__action">Enter the Practice Space</span>
          </a>
        </li>
        <li class="home-pathways__item" data-reveal>
          <a class="home-pathways__card" href="/compass/" data-link="compass">
            <span class="home-pathways__context">You're ready to build this as a real skill</span>
            <span class="home-pathways__action">See the Training</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="intro surface-reading">
    <div class="page-inner intro__inner">
      <p class="intro__text" data-reveal>
        Tides of Knowing is a practical body of work about perception, interpretation, and the
        disciplined use of intuition through the cards.
      </p>
      <p class="intro__text" data-reveal>
        It is written for tarot and oracle readers who want more than card meanings alone. Some read
        for themselves. Some read for others. Many do both. What matters is the desire to work more
        deeply, more accurately, and with greater trust in what is actually being shown.
      </p>
      <p class="intro__text" data-reveal>
        This site is not built around collecting endless interpretations.
      </p>
      <p class="intro__text" data-reveal>
        It is built around learning how to recognise what matters, how to follow what is relevant,
        and how to translate what you perceive into something coherent, grounded, and <a href="/compass/" data-link="compass">usable</a>.
      </p>
      <p class="intro__text" data-reveal>
        Because the deeper value of working with cards is not confined to the reading table.
      </p>
      <p class="intro__text" data-reveal>
        These skills shape how you read people, how you recognise what is and is not yours to carry,
        how you restore boundaries, how you make more meaningful space for yourself, and how you
        navigate life with greater calm, clarity, and self-trust.
      </p>
      <h2 class="latest__title" data-reveal>What you’ll find here</h2>
      <p class="intro__text" data-reveal>
        Tides of Knowing is structured around long-form article series and standalone essays.
      </p>
      <p class="intro__text" data-reveal>
        The series are designed to help readers deepen their relationship with the cards, with
        themselves, and with others. They explore the practical foundations of intuitive work: how
        perception functions, what makes a reading hold together, why meaning alone is often not
        enough, and how intuitive skill can be strengthened through attention, structure, and practice.
      </p>
      <p class="intro__text" data-reveal>
        Alongside these are individual articles written when a particular insight needs to be
        shared. These pieces may respond to something observed in practice, a question that keeps
        arising, or a deeper truth about intuitive work that deserves its own space.
      </p>
      <p class="intro__text" data-reveal>
        Together, the content is intended to support both personal development and better guidance
        for others.
      </p>
      <h2 class="latest__title" data-reveal>What this work is for</h2>
      <p class="intro__text" data-reveal>The purpose of this site is simple:</p>
      <p class="intro__text" data-reveal>
        to help you read, reflect, and deepen your intuition in ways that bring more peace, more
        clarity, and more structure to your life.
      </p>
      <p class="intro__text" data-reveal>
        For some, that will mean becoming a more grounded and trustworthy reader.
      </p>
      <p class="intro__text" data-reveal>
        For others, it will mean using the cards as a tool for personal insight, emotional honesty,
        stronger boundaries, and better decision-making.
      </p>
      <p class="intro__text" data-reveal>
        In both cases, the aim is the same: to make intuitive knowledge more coherent, more
        practical, and more fully lived.
      </p>
      <h2 class="latest__title" data-reveal>About the work</h2>
      <p class="intro__text" data-reveal>
        I have spent more than thirty years working with language, perception, and interpretation
        as a journalist, reader, and educator.
      </p>
      <p class="intro__text" data-reveal>Tides of Knowing grows out of that intersection.</p>
      <p class="intro__text" data-reveal>
        It is the written companion to The Deck Compass and a place for serious, thoughtful
        exploration of what intuition is, how it works, and how it can be developed into a skill that
        serves everyday life.
      </p>
      <p class="intro__text" data-reveal>
        You can read more about my background on the{" "}
        <a href="/about/">About page</a>.
      </p>
    </div>
  </section>

  <section class="home-arch surface-reading-soft" aria-labelledby="home-arch-heading">
    <div class="page-inner home-arch__inner">
      <h2 id="home-arch-heading" class="home-arch__title" data-reveal>How this work is organised</h2>
      <ul class="home-arch__list">
        <li class="home-arch__item" data-reveal>
          <a class="home-arch__card" href="/articles/compass-method/">
            <span class="home-arch__label">Method</span>
            <span class="home-arch__desc">Understand the framework</span>
          </a>
        </li>
        <li class="home-arch__item" data-reveal>
          <a class="home-arch__card" href="/tools/">
            <span class="home-arch__label">Tools</span>
            <span class="home-arch__desc">Experience it directly</span>
          </a>
        </li>
        <li class="home-arch__item" data-reveal>
          <a class="home-arch__card" href="/articles/">
            <span class="home-arch__label">Articles</span>
            <span class="home-arch__desc">Deepen the thinking</span>
          </a>
        </li>
        <li class="home-arch__item" data-reveal>
          <a class="home-arch__card" href="/practice/">
            <span class="home-arch__label">Practice</span>
            <span class="home-arch__desc">Build the habit through The Deck Compass</span>
          </a>
        </li>
        <li class="home-arch__item" data-reveal>
          <a class="home-arch__card" href="/compass/" data-link="compass">
            <span class="home-arch__label">Training</span>
            <span class="home-arch__desc">Learn the system in a guided cohort</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <div class="tok-home-cta-band surface-system" data-reveal>
    <div class="page-inner tok-home-cta-band__inner">
      <TdcConversionBlock />
    </div>
  </div>

  <section class="latest surface-reading-soft" aria-labelledby="field-notes-latest-heading">
    <div class="page-inner latest__inner">
      <h2 id="field-notes-latest-heading" class="latest__title" data-reveal>
        Latest Field Notes
      </h2>
      {
        latest.length === 0 ? (
          <p class="latest__empty" data-reveal>
            New entries will appear here as they are published. Browse the{" "}
            <a href="/blog/">Field Notes archive</a>
            {" "}for shorter pieces. Evergreen methodology and essays live in the{" "}
            <a href="/articles/">article library</a>.
          </p>
        ) : (
          <ul class="latest__list">
            {latest.map((post) => (
              <li class="latest__item" data-reveal>
                <a class="latest__link" href={`/blog/${post.slug ?? post.id}/`}>
                  <span class="latest__post-title">{post.data.title}</span>
                  <span class="latest__post-meta">
                    {post.data.date.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  <span class="latest__post-desc">{post.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  <section class="latest methodology surface-reading" aria-labelledby="methodology-heading">
    <div class="page-inner latest__inner">
      <h2 id="methodology-heading" class="latest__title" data-reveal>
        Articles and methodology
      </h2>
      <p class="methodology__intro" data-reveal>
        Long-form methodology pieces, series, and topics.{" "}
        <a class="methodology__hub-link" href="/articles/">Browse the full article library</a>
      </p>
      {
        latestMethodology.length === 0 ? (
          <p class="latest__empty" data-reveal>
            Articles will appear here as they are published. Open the{" "}
            <a href="/articles/">article library</a> for the full catalog.
          </p>
        ) : (
          <ul class="latest__list">
            {latestMethodology.map((article) => (
              <li class="latest__item" data-reveal>
                <a
                  class="latest__link"
                  href={`/articles/${article.data.slug}/`}
                >
                  <span class="latest__post-title">{article.data.title}</span>
                  <span class="latest__post-meta">
                    {article.data.publishDate.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </span>
                  <span class="latest__post-desc">{article.data.excerpt}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .home-gate {
    padding: clamp(2.5rem, 8vw, 5rem) 0 clamp(2rem, 5vw, 3rem);
  }

  .home-gate__inner {
    max-width: 46rem;
  }

  .home-gate__h1 {
    margin: 0 0 1.15rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 5.5vw, 3rem);
    line-height: 1.12;
    color: var(--tok-text-light);
  }

  .home-gate__support {
    margin: 0 0 1.35rem;
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 2.2vw, 1.22rem);
    line-height: 1.68;
    color: var(--tok-text-light-soft);
    opacity: 0.96;
    max-width: 42rem;
  }

  .home-gate__trust {
    margin: 0;
    max-width: 44rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.65;
    color: color-mix(in srgb, var(--tok-gold) 88%, var(--tok-text-light-soft));
  }

  .home-pathways {
    padding: clamp(1.75rem, 5vw, 2.75rem) 0;
    border-top: 1px solid var(--tok-border-light);
  }

  .home-pathways__inner {
    max-width: 48rem;
  }

  .home-pathways__vh {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .home-pathways__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .home-pathways__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  .home-pathways__item {
    margin: 0;
  }

  .home-pathways__card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    height: 100%;
    padding: 1.1rem 1.2rem 1.15rem;
    text-decoration: none;
    color: inherit;
    background: var(--tok-surface-reading);
    border: 1px solid var(--tok-border-light);
    border-left: 3px solid var(--tok-gold);
    border-radius: 0 0.2rem 0.2rem 0;
    transition:
      background var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }

  .home-pathways__card:hover {
    background: color-mix(in srgb, var(--tok-surface-reading) 88%, var(--tok-surface-reading-soft));
    border-left-color: var(--tok-teal);
  }

  .home-pathways__context {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--tok-text-dark);
    opacity: 0.92;
  }

  .home-pathways__action {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tok-water);
  }

  .home-pathways__card:hover .home-pathways__action {
    color: var(--tok-teal);
  }

  .home-arch {
    padding: clamp(2.25rem, 6vw, 3.5rem) 0;
    border-top: 1px solid var(--tok-border-light);
  }

  .home-arch__inner {
    max-width: 52rem;
  }

  .home-arch__title {
    margin: 0 0 1.35rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.65rem, 3.5vw, 2.1rem);
    line-height: 1.2;
    color: var(--tok-water);
    max-width: 40rem;
  }

  .home-arch__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 560px) {
    .home-arch__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 900px) {
    .home-arch__list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .home-arch__item {
    margin: 0;
  }

  .home-arch__card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    height: 100%;
    min-height: 5.5rem;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: inherit;
    background: var(--tok-surface-reading);
    border: 1px solid var(--tok-border-light);
    border-radius: 0.2rem;
    box-shadow: var(--shadow-sm);
    transition:
      background var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }

  .home-arch__card:hover {
    border-color: color-mix(in srgb, var(--tok-teal) 35%, var(--tok-border-light));
    background: color-mix(in srgb, var(--tok-surface-reading) 92%, var(--tok-surface-reading-soft));
  }

  .home-arch__label {
    font-family: var(--font-heading);
    font-size: 1.12rem;
    font-weight: 600;
    font-style: normal;
    color: var(--tok-teal-dim);
  }

  .home-arch__desc {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--tok-text-dark);
    opacity: 0.9;
  }

  .tok-home-cta-band {
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--tok-border-system);
    border-bottom: 1px solid var(--tok-border-system);
  }

  .tok-home-cta-band__inner {
    max-width: var(--reading-width);
  }

  .tok-home-hero a {
    color: var(--tok-teal-light);
  }

  .tok-home-hero a:hover {
    color: var(--tok-text-light-strong);
  }

  .intro {
    padding: clamp(2rem, 5vw, 3rem) 0;
    border-top: 1px solid var(--tok-border-light);
  }

  .intro__inner {
    max-width: 40rem;
  }

  .intro__text {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .intro__text + .intro__text {
    margin-top: 1.25rem;
  }

  .intro__text br {
    display: block;
    margin-top: 0.35rem;
  }

  .latest {
    padding: clamp(2.5rem, 7vw, 4.5rem) 0 clamp(3rem, 8vw, 5rem);
    border-top: 1px solid var(--tok-border-light);
  }

  .latest.methodology {
    padding-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .methodology__intro {
    margin: 0 0 1.5rem;
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 40rem;
  }

  .methodology__hub-link {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-water);
  }

  .methodology__hub-link:hover {
    color: var(--tok-teal);
  }

  .tok-home-cta-band .tdc {
    background: transparent;
    margin-top: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  .latest__inner {
    max-width: 44rem;
  }

  .latest__title {
    margin: 0 0 1.75rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.85rem, 4vw, 2.35rem);
    color: var(--tok-water);
  }

  .intro__inner > .latest__title {
    margin-top: 2.2rem;
    margin-bottom: 1.2rem;
  }

  .intro__inner > .latest__title + .intro__text {
    margin-top: 1rem;
  }

  .intro__inner > .latest__title ~ .intro__text + .intro__text {
    margin-top: 1.25rem;
  }

  .latest__empty {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 36rem;
  }

  .latest__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .latest__item {
    margin: 0;
  }

  .latest__link {
    display: block;
    padding: 1.25rem 1.35rem;
    text-decoration: none;
    color: inherit;
    background: var(--tok-surface-reading-soft);
    border-left: 3px solid var(--tok-gold);
    border-radius: 0 2px 2px 0;
    transition:
      background var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }

  .latest__link:hover {
    background: var(--tok-surface-reading);
    border-left-color: var(--tok-teal);
  }

  .latest__post-title {
    display: block;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--tok-water);
    margin-bottom: 0.35rem;
  }

  .latest__post-meta {
    display: block;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
    margin-bottom: 0.5rem;
  }

  .latest__post-desc {
    display: block;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--tok-text-dark);
    opacity: 0.88;
  }
</style>
