---
import { getCollection } from "astro:content";
import ArticlesLayout from "../../layouts/ArticlesLayout.astro";

const articles = await getCollection("articles");
const article = articles.find((entry) => entry.data.slug === "compass-method");

if (!article) {
  return Astro.redirect("/articles/");
}

const readingMinutes = article.data.readingTime;

const pillars = [
  {
    key: "center",
    letter: "C",
    name: "Center",
    text: "Presence before perception",
    icon: "/images/compass/icons/center/center-transparent.svg",
    featured: true,
  },
  {
    key: "open",
    letter: "O",
    name: "Open",
    text: "Receptivity without agenda",
    icon: "/images/compass/icons/open/open-transparent.svg",
  },
  {
    key: "map",
    letter: "M",
    name: "Map",
    text: "Observation before interpretation",
    icon: "/images/compass/icons/map/map-transparent.svg",
  },
  {
    key: "perceive",
    letter: "P",
    name: "Perceive",
    text: "Signal clarity",
    icon: "/images/compass/icons/perceive/perceive-transparent.svg",
  },
  {
    key: "align",
    letter: "A",
    name: "Align",
    text: "Checking for distortion",
    icon: "/images/compass/icons/align/align-transparent.svg",
  },
  {
    key: "sense",
    letter: "S",
    name: "Sense",
    text: "Integrating the whole",
    icon: "/images/compass/icons/sense/sense-transparent.svg",
  },
  {
    key: "seal",
    letter: "S",
    name: "Seal",
    text: "Final condition",
    icon: "/images/compass/icons/seal/seal-transparent.svg",
  },
];

const pathways = [
  {
    href: "/articles/",
    label: "Read the applied essays",
    support: "Editorial and research environment",
    step: "01",
  },
  {
    href: "/tools/",
    label: "Enter controlled practice",
    support: "Use tools to train signal tracking",
    step: "02",
  },
  {
    href: "/practice/",
    label: "Stabilise in live conditions",
    support: "Move from insight to repeatable habit",
    step: "03",
  },
  {
    href: "/compass/",
    label: "Train with the method directly",
    support: "Live methodology teaching environment",
    step: "04",
    dataCompass: true,
  },
] as const;
---

<ArticlesLayout
  article={article}
  readingMinutes={readingMinutes}
  headerTitle="The COMPASS Method"
  headerSubtitle="A seven-pillar framework for moving from memorised meanings into reliable symbolic perception."
  hideSystemPathway={true}
>
  <div class="method-hub" slot="prepend">
    <section class="method-hub__manifesto" aria-labelledby="method-manifesto-heading">
      <h2 id="method-manifesto-heading" class="method-hub__manifesto-title">
        A framework for perception under pressure
      </h2>
      <p class="method-hub__manifesto-lede">
        The COMPASS Method treats reading as a perceptual discipline. It is not a memorisation
        system, not a dictionary, and not a rigid procedural script. It is a way of organising
        attention so meaning can form clearly, stay coherent, and be spoken without distortion.
      </p>
      <p class="method-hub__manifesto-note">
        The COMPASS Method™ is an original interpretive framework created by Tides of Knowing.
      </p>
    </section>

    <section class="method-hub__pillars" aria-labelledby="method-pillars-heading">
      <h2 id="method-pillars-heading" class="method-hub__pillars-title">The seven pillars</h2>
      <div class="method-pillars">
        {
          pillars
            .filter((p) => p.featured)
            .map((p) => (
              <article class="method-pillar-card method-pillar-card--featured">
                <img
                  class="method-pillar-card__icon"
                  src={p.icon}
                  alt=""
                  aria-hidden="true"
                  loading="lazy"
                  decoding="async"
                />
                <h3 class="method-pillar-card__title">
                  {p.letter} · {p.name}
                </h3>
                <p class="method-pillar-card__text">{p.text}</p>
              </article>
            ))
        }
        <ul class="method-pillars__grid">
          {
            pillars
              .filter((p) => !p.featured)
              .map((p) => (
                <li class="method-pillars__item">
                  <article class="method-pillar-card">
                    <img
                      class="method-pillar-card__icon"
                      src={p.icon}
                      alt=""
                      aria-hidden="true"
                      loading="lazy"
                      decoding="async"
                    />
                    <h3 class="method-pillar-card__title">
                      {p.letter} · {p.name}
                    </h3>
                    <p class="method-pillar-card__text">{p.text}</p>
                  </article>
                </li>
              ))
          }
        </ul>
      </div>
    </section>

    <section class="method-hub__solve" aria-labelledby="method-solve-heading">
      <h2 id="method-solve-heading" class="method-hub__section-title">
        What the method is actually solving
      </h2>
      <p class="method-hub__section-lede">
        Most experienced readers do not fail from lack of vocabulary. They destabilise when pressure
        rises, when stakes sharpen, or when a reading demands precision faster than attention can
        organise itself.
      </p>
      <ul class="method-hub__solve-list">
        <li>Knowing many meanings does not prevent interpretive drift.</li>
        <li>Signal collapses when attention outruns what is actually present.</li>
        <li>Clarity fails when pace replaces structure.</li>
        <li>Confidence breaks when perception is not held long enough to settle.</li>
      </ul>
      <p class="method-hub__section-lede">
        COMPASS addresses that exact threshold: the point where information is abundant, but
        perceptual discipline is not yet stable.
      </p>
    </section>

    <section class="method-hub__origin" aria-labelledby="method-origin-heading">
      <h2 id="method-origin-heading" class="method-hub__section-title">Origin and method</h2>
      <p class="method-hub__section-lede">
        The framework emerged from two long practices held together: 40+ years of tarot work and 30
        years of professional journalism. One trains symbolic perception. The other trains disciplined
        observation and language under pressure.
      </p>
      <blockquote class="method-hub__pull">
        If it can be seen clearly, it can be said clearly.
      </blockquote>
      <p class="method-hub__section-lede">
        COMPASS is where those disciplines converge into a teachable architecture for reading.
      </p>
    </section>

    <section class="method-hub__ecosystem" aria-labelledby="method-ecosystem-heading">
      <h2 id="method-ecosystem-heading" class="method-hub__section-title">The working ecosystem</h2>
      <div class="method-hub__ecosystem-grid">
        <article class="method-hub__ecosystem-card">
          <h3 class="method-hub__ecosystem-title">The COMPASS Method</h3>
          <p class="method-hub__ecosystem-text">
            The framework itself: seven perceptual conditions that organise interpretation.
          </p>
        </article>
        <article class="method-hub__ecosystem-card">
          <h3 class="method-hub__ecosystem-title">Tides of Knowing</h3>
          <p class="method-hub__ecosystem-text">
            The editorial and research environment where the method is developed in public.
          </p>
        </article>
        <article class="method-hub__ecosystem-card">
          <h3 class="method-hub__ecosystem-title">The Deck Compass</h3>
          <p class="method-hub__ecosystem-text">
            The teaching and training environment where the method is applied in live practice.
          </p>
        </article>
      </div>
    </section>
  </div>

  <div class="method-hub-next" slot="append">
    <section class="method-hub-next__inner" aria-labelledby="method-next-heading">
      <h2 id="method-next-heading" class="method-hub-next__title">Enter the system</h2>
      <ul class="method-hub-next__list">
        {
          pathways.map((p) => (
            <li class="method-hub-next__item">
              <a
                class="method-hub-next__card"
                href={p.href}
                {...("dataCompass" in p && p.dataCompass ? { "data-link": "compass" } : {})}
              >
                <span class="method-hub-next__step">{p.step}</span>
                <span class="method-hub-next__label">{p.label}</span>
                <span class="method-hub-next__support">{p.support}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</ArticlesLayout>

<style>
  .method-hub {
    margin-bottom: 2rem;
  }

  .method-hub__manifesto {
    margin: 0 0 2rem;
    padding: 0 0 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 34%, transparent);
  }

  .method-hub__manifesto-title {
    margin: 0 0 0.7rem;
    font-family: var(--font-heading);
    font-size: clamp(1.55rem, 3.2vw, 1.95rem);
    font-weight: 600;
    line-height: 1.18;
    color: var(--tok-water);
  }

  .method-hub__manifesto-lede {
    margin: 0;
    max-width: 66ch;
    font-size: 1.06rem;
    line-height: 1.74;
    color: var(--tok-text-dark);
  }

  .method-hub__manifesto-note {
    margin: 1rem 0 0;
    font-family: var(--font-body);
    font-size: 0.86rem;
    line-height: 1.6;
    color: var(--tok-text-muted);
    letter-spacing: 0.01em;
  }

  .method-hub__pillars {
    margin: 0 0 2rem;
  }

  .method-hub__pillars-title {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.5vw, 1.45rem);
    font-weight: 600;
    font-style: normal;
    line-height: 1.25;
    color: var(--tok-water);
  }

  .method-pillars {
    display: grid;
    gap: 0.95rem;
  }

  .method-pillars__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.95rem;
    grid-template-columns: 1fr;
  }

  .method-pillars__item {
    margin: 0;
  }

  @media (min-width: 640px) {
    .method-pillars__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .method-pillar-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
    padding: clamp(1.1rem, 2.8vw, 1.45rem) clamp(1rem, 2.5vw, 1.25rem);
    background: color-mix(in srgb, var(--tok-surface-reading) 94%, var(--tok-surface-reading-soft));
    border: 1px solid color-mix(in srgb, var(--tok-gold) 24%, var(--tok-border-light));
    border-radius: 0.35rem;
    box-shadow: var(--shadow-sm);
  }

  .method-pillar-card--featured {
    max-width: min(100%, 44rem);
    margin-inline: auto;
    width: 100%;
  }

  .method-pillar-card__icon {
    width: clamp(4.3rem, 9vw, 5.3rem);
    height: auto;
    margin: 0 0 0.65rem;
  }

  .method-pillar-card__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.8vw, 1.55rem);
    line-height: 1.22;
    font-weight: 600;
    color: var(--tok-water);
  }

  .method-pillar-card__text {
    margin: 0.45rem 0 0;
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--tok-text-dark);
  }

  .method-hub__solve,
  .method-hub__origin,
  .method-hub__ecosystem {
    margin: 0 0 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--tok-border-light);
  }

  .method-hub__section-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.8vw, 1.65rem);
    font-weight: 600;
    line-height: 1.24;
    color: var(--tok-water);
  }

  .method-hub__section-lede {
    margin: 0 0 0.95rem;
    max-width: 66ch;
    font-size: 1.04rem;
    line-height: 1.72;
    color: var(--tok-text-dark);
  }

  .method-hub__solve-list {
    margin: 0 0 1rem;
    padding-left: 1.2rem;
    max-width: 66ch;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--tok-text-dark);
  }

  .method-hub__solve-list li {
    margin-bottom: 0.35rem;
  }

  .method-hub__pull {
    margin: 0.9rem 0 1rem;
    padding: 0.35rem 0 0.35rem 1rem;
    border-left: 3px solid var(--tok-gold);
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(1.2rem, 2.4vw, 1.38rem);
    line-height: 1.55;
    color: var(--tok-water);
  }

  .method-hub__ecosystem-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .method-hub__ecosystem-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .method-hub__ecosystem-card {
    padding: 0.95rem 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, var(--tok-border-light));
    border-radius: 0.28rem;
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 86%, var(--tok-surface-reading));
  }

  .method-hub__ecosystem-title {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    line-height: 1.28;
    color: var(--tok-water);
  }

  .method-hub__ecosystem-text {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.58;
    color: var(--tok-text-dark);
  }

  .method-hub-next {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem 2.5rem;
  }

  .method-hub-next__inner {
    margin: 0;
    padding: clamp(1.75rem, 4vw, 2.25rem) 0 0;
    border-top: 1px solid var(--tok-border-light);
  }

  .method-hub-next__title {
    margin: 0 0 1.15rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.8vw, 1.6rem);
    font-weight: 600;
    font-style: italic;
    line-height: 1.2;
    color: var(--tok-water);
  }

  .method-hub-next__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .method-hub-next__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .method-hub-next__item {
    margin: 0;
  }

  .method-hub-next__card {
    display: grid;
    gap: 0.35rem;
    height: 100%;
    padding: 1rem 1.1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.55;
    font-weight: 500;
    text-decoration: none;
    color: var(--tok-water);
    background: var(--tok-surface-reading-soft);
    border: 1px solid var(--tok-border-light);
    border-left: 3px solid var(--tok-gold);
    border-radius: 0 0.2rem 0.2rem 0;
    transition:
      background var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .method-hub-next__card:hover {
    background: var(--tok-surface-reading);
    border-left-color: var(--tok-teal);
    color: var(--tok-teal-dim);
  }

  .method-hub-next__step {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .method-hub-next__label {
    font-family: var(--font-heading);
    font-size: 1.12rem;
    line-height: 1.24;
    color: var(--tok-water);
  }

  .method-hub-next__support {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--tok-text-dark);
    opacity: 0.9;
  }
</style>
