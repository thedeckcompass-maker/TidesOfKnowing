---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  getLibraryFeaturedArticles,
  sortArticlesLibraryNewest,
} from "../../lib/articleLibraryOrder";
import {
  articleSearchHaystack,
  topicChipsFromArticleTags,
} from "../../lib/articleLibraryNav";
import {
  LIBRARY_FEATURED_COUNT,
  LIBRARY_PER_PAGE,
  slicePage,
  totalPages,
} from "../../lib/libraryPagination";
import { readingMinutesForArticle } from "../../lib/articleReadingMinutes";
import { seriesOptionsFromArticles } from "../../lib/librarySeries";
import { libraryPaginationState } from "../../lib/libraryPageUrls";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import ArticleCardFeatured from "../../components/ArticleCardFeatured.astro";
import ArticlesFindPanel from "../../components/ArticlesFindPanel.astro";
import LibraryToolbar from "../../components/LibraryToolbar.astro";
import LibraryPagination from "../../components/LibraryPagination.astro";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { siteBase } from "../../lib/site";
import { ENTITY_IDS } from "../../lib/ecosystem-structured-data";

const PAGE_TITLE =
  "Articles | Tides of Knowing | Tarot Methodology & Intuition Development";
const PAGE_DESCRIPTION =
  "Evergreen essays on symbolic interpretation, tarot methodology, AI and intuition, and reflective practice from Tides of Knowing.";
const AUTHORITY_LINE =
  "Articles by Leigh Spencer, founder of The COMPASS Method™, drawing on 40+ years of tarot practice and 30 years of professional journalism.";

const articles = await getCollection("articles");
const sortedNewest = sortArticlesLibraryNewest(articles);
const {
  featured,
  heading: featuredHeading,
  featuredHeadingId,
  ogArticle,
} = getLibraryFeaturedArticles(articles, sortedNewest, LIBRARY_FEATURED_COUNT);
const listPage = slicePage(sortedNewest, 1, LIBRARY_PER_PAGE);
const tp = totalPages(sortedNewest.length, LIBRARY_PER_PAGE);

const seriesOpts = seriesOptionsFromArticles(articles);

const base = siteBase(Astro);
const siteHref = base.href;
const canonical = new URL("/articles/", base).href;

const minutesById = new Map(
  articles.map((a) => [a.id, readingMinutesForArticle(a)]),
);

const articlesItemListLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: PAGE_TITLE,
  description: PAGE_DESCRIPTION,
  url: canonical,
  author: { "@type": "Person", name: "Leigh Spencer", "@id": ENTITY_IDS.person },
  publisher: { "@id": ENTITY_IDS.tidesOrg },
  about: [
    { "@type": "Thing", name: "Symbolic interpretation" },
    { "@type": "Thing", name: "Tarot methodology" },
    { "@id": ENTITY_IDS.compassMethod },
  ],
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: sortedNewest.length,
    itemListElement: sortedNewest.map((a, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: a.data.title,
      url: new URL(`/articles/${a.data.slug}/`, siteHref).href,
    })),
  },
};

const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Articles", url: null },
];

const jsonLd = [articlesItemListLd, breadcrumbJsonLd(crumbs, siteHref)];

const ogImage = ogArticle
  ? new URL(ogArticle.data.heroImage, base).href
  : new URL("/favicon.svg", base).href;

const pager = libraryPaginationState({ kind: "newest" }, 1, tp, base);
---

<BaseLayout
  title={PAGE_TITLE}
  description={PAGE_DESCRIPTION}
  ogUrl={canonical}
  ogImage={ogImage}
  metaAuthor="Leigh Spencer"
  sequentialLinks={{
    prev: pager.relPrevAbsolute ?? undefined,
    next: pager.relNextAbsolute ?? undefined,
  }}
  jsonLd={jsonLd}
>
  <div class="tok-library tok-library--articles page-inner">
    <div class="tok-library__crumbs">
      <Breadcrumbs items={crumbs} />
    </div>

    <header class="tok-library__hero tok-library__hero--brand surface-system">
      <h1 class="tok-library__title">Articles</h1>
      <p class="tok-library__lede">{PAGE_DESCRIPTION}</p>
      <p class="tok-library__authority">{AUTHORITY_LINE}</p>
    </header>

    <ArticlesFindPanel />

    <p class="tok-library__notes-aside">
      For shorter observational practice notes, <a href="/blog/">browse Field Notes</a>.
    </p>

    {
      featured.length > 0 ? (
        <section
          class="tok-library__section tok-library__section--featured"
          aria-labelledby={featuredHeadingId}
        >
          <h2 id={featuredHeadingId} class="tok-library__h2">
            {featuredHeading}
          </h2>
          <div class="tok-library__feat-grid">
            {featured.map((a) => (
              <ArticleCardFeatured
                article={a}
                readingMinutes={minutesById.get(a.id) ?? 1}
                archiveFeatured
              />
            ))}
          </div>
        </section>
      ) : null
    }

    <section
      class="tok-library__section"
      id="all-articles"
      aria-labelledby="all-heading"
    >
      <h2 id="all-heading" class="tok-library__h2">All articles</h2>

      <LibraryToolbar
        sort="newest"
        showFilter={true}
        filter="all"
        seriesOptions={seriesOpts}
      />

      <p class="tok-art-find-count" data-art-find-count hidden></p>

      {
        listPage.length === 0 ? (
          <p class="tok-library__empty">
            No articles are currently published in this library.
          </p>
        ) : (
          <>
            <p class="tok-library__empty tok-library__empty--search" data-art-find-empty hidden>
              No articles match your search on this page. Try{" "}
              <a href="/articles/topics/">browse topics</a> or{" "}
              <a href="/articles/">clear the search</a>.
            </p>
            <div class="tok-library__grid" data-art-find-grid>
              {listPage.map((a) => (
                <ArticleCard
                  article={a}
                  readingMinutes={minutesById.get(a.id) ?? 1}
                  topicChips={topicChipsFromArticleTags(a.data.tags)}
                  searchHaystack={articleSearchHaystack(a)}
                />
              ))}
            </div>
            <LibraryPagination
              prevHref={pager.prevHref}
              nextHref={pager.nextHref}
              pages={pager.pages}
            />
          </>
        )
      }
    </section>
  </div>

  <script>
    function normalizeQuery(s: string): string {
      return s.toLowerCase().trim();
    }

    function initArticleFind() {
      const input = document.querySelector<HTMLInputElement>("[data-art-find-input]");
      const grid = document.querySelector("[data-art-find-grid]");
      if (!input || !grid) return;

      const cards = grid.querySelectorAll<HTMLElement>("[data-art-search]");
      const empty = document.querySelector<HTMLElement>("[data-art-find-empty]");
      const countEl = document.querySelector<HTMLElement>("[data-art-find-count]");

      function applyFilter() {
        const raw = input!.value.trim();
        const q = raw ? normalizeQuery(raw) : "";
        let visible = 0;

        cards.forEach((card) => {
          if (!q) {
            card.hidden = false;
            visible += 1;
            return;
          }
          const haystack = card.getAttribute("data-art-search") ?? "";
          const match = haystack.includes(q);
          card.hidden = !match;
          if (match) visible += 1;
        });

        if (empty) {
          empty.hidden = !q || visible > 0;
        }
        if (countEl) {
          countEl.hidden = !q;
          countEl.textContent =
            visible === 1
              ? "1 article matches your search."
              : `${visible} articles match your search.`;
        }

        const url = new URL(window.location.href);
        if (q) url.searchParams.set("q", raw);
        else url.searchParams.delete("q");
        window.history.replaceState({}, "", url);
      }

      input.addEventListener("input", applyFilter);

      const initial = input.value.trim();
      if (initial) applyFilter();
      else {
        cards.forEach((card) => {
          card.hidden = false;
        });
      }
    }

    initArticleFind();
    document.addEventListener("astro:page-load", initArticleFind);
  </script>
</BaseLayout>

