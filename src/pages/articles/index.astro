---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  sortArticlesLibraryNewest,
} from "../../lib/articleLibraryOrder";
import {
  LIBRARY_FEATURED_COUNT,
  LIBRARY_PER_PAGE,
  slicePage,
  totalPages,
} from "../../lib/libraryPagination";
import { readingMinutesForArticle } from "../../lib/articleReadingMinutes";
import { groupArticlesBySeries, seriesOptionsFromArticles } from "../../lib/librarySeries";
import { libraryPaginationState } from "../../lib/libraryPageUrls";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import ArticleCardFeatured from "../../components/ArticleCardFeatured.astro";
import LibraryToolbar from "../../components/LibraryToolbar.astro";
import LibraryPagination from "../../components/LibraryPagination.astro";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { siteBase } from "../../lib/site";

const PAGE_TITLE =
  "Articles — Tides of Knowing | Tarot Methodology & Intuition Development";
const PAGE_DESCRIPTION =
  "Browse methodology articles on tarot, precision reading, and intuition development — with series, topics, and pagination. Insights from 40+ years of professional practice.";

const articles = await getCollection("articles");
const sortedNewest = sortArticlesLibraryNewest(articles);
const featured = sortedNewest.slice(0, LIBRARY_FEATURED_COUNT);
const listPage = slicePage(sortedNewest, 1, LIBRARY_PER_PAGE);
const tp = totalPages(sortedNewest.length, LIBRARY_PER_PAGE);

const seriesOpts = seriesOptionsFromArticles(articles);
const seriesGroups = groupArticlesBySeries(articles);

const base = siteBase(Astro);
const siteHref = base.href;
const canonical = new URL("/articles/", base).href;

const minutesById = new Map(
  articles.map((a) => [a.id, readingMinutesForArticle(a)]),
);

const blogPostLd = sortedNewest.map((a) => ({
  "@type": "BlogPosting",
  headline: a.data.title,
  url: new URL(`/articles/${a.data.slug}/`, siteHref).href,
  datePublished: a.data.publishDate.toISOString().slice(0, 10),
}));

const blogLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Tides of Knowing — Articles",
  description: PAGE_DESCRIPTION,
  url: canonical,
  blogPost: blogPostLd,
};

const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Articles", url: null },
];

const jsonLd = [blogLd, breadcrumbJsonLd(crumbs, siteHref)];

const ogImage = featured[0]
  ? new URL(featured[0].data.heroImage, base).href
  : new URL("/favicon.svg", base).href;

const pager = libraryPaginationState({ kind: "newest" }, 1, tp, base);
---

<BaseLayout
  title={PAGE_TITLE}
  description={PAGE_DESCRIPTION}
  ogUrl={canonical}
  ogImage={ogImage}
  metaAuthor="Leigh Spencer"
  sequentialLinks={{
    prev: pager.relPrevAbsolute ?? undefined,
    next: pager.relNextAbsolute ?? undefined,
  }}
  jsonLd={jsonLd}
>
  <div class="tok-library page-inner">
    <Breadcrumbs items={crumbs} />

    <header class="tok-library__hero" data-reveal>
      <h1 class="tok-library__title">Articles</h1>
      <p class="tok-library__lede">{PAGE_DESCRIPTION}</p>
    </header>

    {
      featured.length > 0 && (
        <section class="tok-library__section" aria-labelledby="latest-heading" data-reveal>
          <h2 id="latest-heading" class="tok-library__h2">
            Latest articles
          </h2>
          <div class="tok-library__feat-grid">
            {featured.map((a) => (
              <ArticleCardFeatured
                article={a}
                readingMinutes={minutesById.get(a.id) ?? 1}
              />
            ))}
          </div>
        </section>
      )
    }

    {
      seriesGroups.length > 0 && (
        <section class="tok-library__section" aria-labelledby="series-heading" data-reveal>
          <h2 id="series-heading" class="tok-library__h2">
            Series collections
          </h2>
          <div class="tok-library__series">
            {seriesGroups.map((g, i) => (
              <details class="tok-series-acc" open={i === 0}>
                <summary class="tok-series-acc__summary">
                  <span class="tok-series-acc__name">{g.seriesName}</span>
                  <span class="tok-series-acc__count">({g.items.length})</span>
                </summary>
                <ol class="tok-series-acc__parts">
                  {g.items.map((a) => (
                    <li>
                      <a href={`/articles/${a.data.slug}/`}>{a.data.title}</a>
                      {a.data.seriesOrder != null && (
                        <span class="tok-series-acc__part">
                          {" "}
                          · Part {a.data.seriesOrder}
                        </span>
                      )}
                    </li>
                  ))}
                </ol>
                <p class="tok-series-acc__more">
                  <a href={`/articles/${g.items[0].data.slug}/`}>Start reading →</a>
                  {" · "}
                  <a href={`/series/${g.seriesSlug}/`}>Series overview</a>
                </p>
              </details>
            ))}
          </div>
        </section>
      )
    }

    <section
      class="tok-library__section"
      id="all-articles"
      aria-labelledby="all-heading"
      data-reveal
    >
      <h2 id="all-heading" class="tok-library__h2">All articles</h2>

      <LibraryToolbar
        sort="newest"
        showFilter={true}
        filter="all"
        seriesOptions={seriesOpts}
      />

      {
        listPage.length === 0 ? (
          <p class="tok-library__empty">
            Articles will appear here as they are published.
          </p>
        ) : (
          <>
            <div class="tok-library__grid">
              {listPage.map((a) => (
                <ArticleCard
                  article={a}
                  readingMinutes={minutesById.get(a.id) ?? 1}
                />
              ))}
            </div>
            <LibraryPagination
              prevHref={pager.prevHref}
              nextHref={pager.nextHref}
              pages={pager.pages}
            />
          </>
        )
      }
    </section>
  </div>
</BaseLayout>

<style>
  .tok-library {
    padding: clamp(1.5rem, 4vw, 2.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 72rem;
  }

  .tok-library__hero {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--gold);
  }

  .tok-library__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 2.85rem);
    color: var(--mountain-water);
  }

  .tok-library__lede {
    margin: 0;
    max-width: 42rem;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .tok-library__section {
    margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
  }

  .tok-library__h2 {
    margin: 0 0 1.25rem;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 600;
    color: var(--mountain-water);
  }

  .tok-library__feat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 18rem), 1fr));
    gap: 1.25rem;
  }

  .tok-library__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: 1.15rem;
  }

  .tok-library__empty {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--mountain-water);
  }

  .tok-library__series {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tok-series-acc {
    border: 1px solid rgba(198, 161, 74, 0.4);
    border-radius: 0.35rem;
    background: rgba(255, 255, 255, 0.25);
    padding: 0 1rem 0.75rem;
  }

  .tok-series-acc__summary {
    cursor: pointer;
    font-family: var(--font-nav);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.85rem 0;
    list-style: none;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--ink);
  }

  .tok-series-acc__summary::-webkit-details-marker {
    display: none;
  }

  .tok-series-acc__name {
    flex: 1;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--mountain-water);
  }

  .tok-series-acc__count {
    color: var(--gold);
    font-size: 0.65rem;
  }

  .tok-series-acc__parts {
    margin: 0 0 0.75rem;
    padding-left: 1.25rem;
    line-height: 1.65;
  }

  .tok-series-acc__part {
    font-size: 0.88rem;
    color: var(--mountain-water);
  }

  .tok-series-acc__more {
    margin: 0;
    font-size: 0.9rem;
  }
</style>
