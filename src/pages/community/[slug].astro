---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CommunityAdminControls from "../../components/community/CommunityAdminControls.astro";
import CommunityAuthPrompt from "../../components/community/CommunityAuthPrompt.astro";
import CommunityReplyForm from "../../components/community/CommunityReplyForm.astro";
import CommunityReplyList from "../../components/community/CommunityReplyList.astro";
import CommunityReportForm from "../../components/community/CommunityReportForm.astro";
import { canContribute, isAdminProfile } from "../../lib/community/auth";
import { getCommunityPostBySlug, getCommunityReplies } from "../../lib/community/queries";
import { communityPostPath, communitySectionPath } from "../../lib/community/slugs";
import { getSpreadImagePublicUrl } from "../../lib/community/spreadImages";
import { readingPracticePostTypeLabel } from "../../lib/community/types";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { siteBase } from "../../lib/site";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const post = Astro.locals.supabase ? await getCommunityPostBySlug(Astro.locals.supabase, slug) : null;
if (!post) return Astro.redirect("/community/", 302);

const isAdmin = isAdminProfile(Astro.locals.profile);
const replies = Astro.locals.supabase
  ? await getCommunityReplies(Astro.locals.supabase, post.id, { includeModerated: isAdmin })
  : [];
const base = siteBase(Astro);
const canonical = new URL(communityPostPath(post.slug), base).href;
const returnTo = `${communityPostPath(post.slug)}?moderation=updated#replies`;
const reportRedirectTo = `${communityPostPath(post.slug)}?report=sent#replies`;
const sectionHref = post.section ? communitySectionPath(post.section.key) : "/community/";
const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Practice Commons", url: "/community/" },
  { label: post.section?.name ?? "Post", url: sectionHref },
  { label: post.title, url: null },
];
const canEdit = Boolean(
  Astro.locals.user &&
    (Astro.locals.user.id === post.author_id || isAdmin),
);
const canReport = canContribute(Astro.locals.profile);
const postTypeLabel = readingPracticePostTypeLabel(post.post_type);
const reportSent = Astro.url.searchParams.get("report") === "sent";
const isLocked = post.status === "locked";
const spreadImageUrl = Astro.locals.supabase
  ? getSpreadImagePublicUrl(Astro.locals.supabase, post.image_url)
  : null;
const jsonLd = [
  breadcrumbJsonLd(crumbs, base.href),
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: post.title,
    url: canonical,
    datePublished: post.created_at,
    dateModified: post.updated_at,
    author: {
      "@type": "Person",
      name: post.author?.display_name ?? "Reader",
    },
  },
];

function formatDate(value: string): string {
  return new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(new Date(value));
}
---

<BaseLayout
  title={`${post.title} | Practice Commons | Tides of Knowing`}
  description={post.body.replace(/\s+/g, " ").slice(0, 155)}
  ogUrl={canonical}
  jsonLd={jsonLd}
>
  <main class="community-post page-inner">
    <Breadcrumbs items={crumbs} />

    <article class="community-post__article">
      {
        reportSent ? (
          <p class="community-post__notice" role="status">Thank you. This has been sent to Leilia for review.</p>
        ) : null
      }
      {
        isLocked ? (
          <p class="community-post__notice">
            This discussion has been closed to new replies, but remains available for reading.
          </p>
        ) : null
      }
      <p class="community-post__meta">
        <a href={sectionHref}>{post.section?.name ?? "Practice Commons"}</a>
        <span aria-hidden="true"> · </span>
        <time datetime={post.created_at}>{formatDate(post.created_at)}</time>
        {postTypeLabel ? <span class="community-post__type">{postTypeLabel}</span> : null}
      </p>
      <h1>{post.title}</h1>
      <p class="community-post__byline">By {post.author?.display_name ?? "Reader"}</p>
      {
        spreadImageUrl ? (
          <figure class="community-post__spread">
            <figcaption>Spread image</figcaption>
            <a href={spreadImageUrl} target="_blank" rel="noopener">
              <img
                src={spreadImageUrl}
                alt={`Spread image for ${post.title}`}
                loading="lazy"
                decoding="async"
              />
            </a>
            <p>Click image to enlarge.</p>
          </figure>
        ) : null
      }
      <div class="community-post__body">
        {post.body.split("\n\n").map((paragraph) => <p>{paragraph}</p>)}
      </div>
      {
        canEdit ? (
          <p class="community-post__edit">
            <a href={`${communityPostPath(post.slug)}edit/`}>Edit post</a>
          </p>
        ) : null
      }
      {
        canReport ? (
          <CommunityReportForm
            contentType="post"
            contentId={post.id}
            label="Report this discussion"
            redirectTo={reportRedirectTo}
          />
        ) : null
      }
    </article>

    {isAdmin ? <CommunityAdminControls postId={post.id} isPinned={post.is_pinned} status={post.status} returnTo={communityPostPath(post.slug)} /> : null}

    <section id="replies" class="community-post__replies" aria-labelledby="replies-heading">
      <h2 id="replies-heading">Replies</h2>
      <CommunityReplyList
        replies={replies}
        canReport={canReport}
        isAdmin={isAdmin}
        returnTo={returnTo}
        reportRedirectTo={reportRedirectTo}
      />
    </section>

    <section class="community-post__reply-form" aria-labelledby="reply-heading">
      <h2 id="reply-heading">Add a thoughtful reply</h2>
      {
        isLocked ? (
          <p class="community-post__locked">
            This discussion has been closed to new replies, but remains available for reading.
          </p>
        ) : canContribute(Astro.locals.profile) ? (
          <CommunityReplyForm postId={post.id} />
        ) : (
          <CommunityAuthPrompt message="Join the Practice Commons to reply to this practice note." redirectTo={communityPostPath(post.slug)} />
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .community-post {
    position: relative;
    isolation: isolate;
    max-width: 48rem;
    padding: clamp(1.25rem, 4vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .community-post::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    z-index: -2;
    width: 100vw;
    content: "";
    background:
      linear-gradient(
        120deg,
        color-mix(in srgb, var(--tok-deep-ocean) 10%, transparent),
        transparent 56%
      ),
      url("/images/community/compass-feather-hourglass.png") right top / min(50vw, 40rem) auto no-repeat;
    opacity: 0.18;
    pointer-events: none;
    transform: translateX(-50%);
  }

  .community-post::after {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    z-index: -1;
    width: 100vw;
    content: "";
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--tok-surface-reading) 82%, transparent),
      color-mix(in srgb, var(--tok-surface-reading) 62%, transparent)
    );
    pointer-events: none;
    transform: translateX(-50%);
  }

  .community-post__article {
    margin-top: 1rem;
  }

  .community-post__notice,
  .community-post__locked {
    padding: 0.85rem 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-border-light) 82%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-gold-100) 38%, transparent);
    color: var(--tok-text-dark);
    line-height: 1.6;
  }

  .community-post__meta,
  .community-post__byline,
  .community-post__edit {
    color: var(--tok-text-muted);
    line-height: 1.7;
  }

  .community-post__meta {
    font-size: var(--tok-type-meta);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .community-post__type {
    color: var(--tok-gold-deep);
    font-weight: 700;
  }

  .community-post h1 {
    margin: 0 0 0.75rem;
    font-family: var(--font-accent);
    font-size: clamp(2.2rem, 8vw, 4rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--tok-water);
  }

  .community-post__body {
    margin-top: 1.5rem;
    color: var(--tok-text-dark);
    font-size: 1.03rem;
    line-height: 1.85;
  }

  .community-post__body p {
    margin: 0 0 1rem;
  }

  .community-post__spread {
    margin: 1.5rem 0 0;
  }

  .community-post__spread figcaption {
    margin: 0 0 0.5rem;
    color: var(--tok-text-dark);
    font-size: var(--tok-type-label);
    font-weight: 700;
  }

  .community-post__spread a {
    display: block;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 34%, transparent);
    border-radius: var(--radius-lg);
    background: var(--tok-surface-reading-soft);
  }

  .community-post__spread img {
    display: block;
    width: 100%;
    height: auto;
  }

  .community-post__spread p {
    margin-top: 0.5rem;
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
  }

  .community-post__replies,
  .community-post__reply-form {
    margin-top: clamp(2rem, 6vw, 3rem);
  }

  .community-post h2 {
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }
</style>
