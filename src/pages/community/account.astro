---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommunityNotificationSettings from "../../components/community/CommunityNotificationSettings.astro";
import { isAdminProfile } from "../../lib/community/auth";
import { getNotificationPreferences, getOpenCommunityReports } from "../../lib/community/queries";
import { createCommunityServiceClient } from "../../lib/community/supabaseServer";
import { communityReportReasonLabel, type CommunityReportQueueItem } from "../../lib/community/types";

export const prerender = false;

if (!Astro.locals.user) {
  return Astro.redirect("/auth/register/", 303);
}

const profile = Astro.locals.profile;
const preferences =
  Astro.locals.supabase && Astro.locals.user
    ? await getNotificationPreferences(Astro.locals.supabase, Astro.locals.user.id)
    : null;
const isAdmin = isAdminProfile(profile);

let moderationPosts: {
  id: string;
  title: string;
  slug: string;
  status: string;
  created_at: string;
}[] = [];
let moderatedProfiles: {
  id: string;
  display_name: string;
  status: string;
  role: string;
}[] = [];
let openReports: CommunityReportQueueItem[] = [];

if (isAdmin) {
  const service = createCommunityServiceClient(Astro.locals);
  openReports = await getOpenCommunityReports(service);
  const { data: posts } = await service
    .from("community_posts")
    .select("id, title, slug, status, created_at")
    .in("status", ["hidden", "locked"])
    .order("created_at", { ascending: false })
    .limit(20);
  moderationPosts = (posts ?? []) as typeof moderationPosts;

  const { data: profiles } = await service
    .from("profiles")
    .select("id, display_name, status, role")
    .neq("status", "active")
    .order("updated_at", { ascending: false })
    .limit(20);
  moderatedProfiles = (profiles ?? []) as typeof moderatedProfiles;
}

function formatDateTime(value: string): string {
  return new Intl.DateTimeFormat("en", {
    dateStyle: "medium",
    timeStyle: "short",
  }).format(new Date(value));
}

function reportTitle(report: CommunityReportQueueItem): string {
  return report.post?.title ?? report.reply?.post?.title ?? "Reported content";
}

function reportHref(report: CommunityReportQueueItem): string {
  const slug = report.post?.slug ?? report.reply?.post?.slug;
  if (!slug) return "/community/account/";
  return report.reply_id ? `/community/${slug}/#reply-${report.reply_id}` : `/community/${slug}/`;
}

function reportTargetMemberId(report: CommunityReportQueueItem): string | null {
  return report.post?.author_id ?? report.reply?.author_id ?? null;
}
---

<BaseLayout
  title="Practice Commons Account | Tides of Knowing"
  description="Manage your Practice Commons account and email preferences."
  metaRobots="noindex, nofollow"
>
  <main class="community-account page-inner">
    <p class="community-account__kicker">Practice Commons</p>
    <h1>Your account</h1>

    <section class="community-account__panel" aria-labelledby="profile-heading">
      <h2 id="profile-heading">Profile</h2>
      <p><strong>Display name:</strong> {profile?.display_name ?? "Reader"}</p>
      <p><strong>Status:</strong> {profile?.status ?? "active"}</p>
      <form class="community-account__logout" method="post" action="/auth/logout/">
        <button class="community-account__logout-button" type="submit">Log out</button>
      </form>
    </section>

    <section class="community-account__panel" aria-labelledby="email-heading">
      <h2 id="email-heading">Email preferences</h2>
      <p>Keep notifications minimal and useful. You can return to the Commons when you have time.</p>
      <CommunityNotificationSettings preferences={preferences} />
    </section>

    {
      isAdmin ? (
        <section class="community-account__panel" aria-labelledby="admin-heading">
          <h2 id="admin-heading">Admin moderation</h2>
          <p>Open reports, recent hidden or locked posts, and restricted members.</p>

          <h3>Open reports</h3>
          {openReports.length > 0 ? (
            <ol class="community-account__reports" role="list">
              {openReports.map((report) => {
                const targetMemberId = reportTargetMemberId(report);
                return (
                  <li>
                    <article class="community-account__report">
                      <p class="community-account__report-meta">
                        <span>{report.post_id ? "Discussion" : "Reply"}</span>
                        <span>{communityReportReasonLabel(report.reason)}</span>
                        <time datetime={report.created_at}>{formatDateTime(report.created_at)}</time>
                      </p>
                      <h4>
                        <a href={reportHref(report)}>{reportTitle(report)}</a>
                      </h4>
                      <p>
                        <strong>Reporter:</strong> {report.reporter?.display_name ?? "Member"}
                      </p>
                      {report.reply ? (
                        <blockquote>{report.reply.body.replace(/\s+/g, " ").slice(0, 220)}</blockquote>
                      ) : null}
                      {report.notes ? (
                        <p>
                          <strong>Notes:</strong> {report.notes}
                        </p>
                      ) : null}
                      <div class="community-account__report-actions">
                        <form method="post" action={`/api/community/reports/${report.id}`}>
                          <input type="hidden" name="intent" value="dismiss" />
                          <input type="hidden" name="redirectTo" value="/community/account/" />
                          <button type="submit">Dismiss report</button>
                        </form>
                        {report.post_id ? (
                          <>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="hide_post" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Hide discussion</button>
                            </form>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="delete_post" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Delete discussion</button>
                            </form>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="lock_post" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Lock discussion</button>
                            </form>
                          </>
                        ) : null}
                        {report.reply_id ? (
                          <>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="hide_reply" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Hide reply</button>
                            </form>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="delete_reply" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Delete reply</button>
                            </form>
                          </>
                        ) : null}
                        {targetMemberId ? (
                          <>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="restrict_member" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Restrict member</button>
                            </form>
                            <form method="post" action={`/api/community/reports/${report.id}`}>
                              <input type="hidden" name="intent" value="block_member" />
                              <input type="hidden" name="redirectTo" value="/community/account/" />
                              <button type="submit">Block member</button>
                            </form>
                          </>
                        ) : null}
                      </div>
                    </article>
                  </li>
                );
              })}
            </ol>
          ) : (
            <p>No open reports.</p>
          )}

          <h3>Posts</h3>
          {moderationPosts.length > 0 ? (
            <ul>
              {moderationPosts.map((post) => (
                <li>
                  <a href={`/community/${post.slug}/`}>{post.title}</a> <span>{post.status}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p>No posts currently need review.</p>
          )}

          <h3>Members</h3>
          {moderatedProfiles.length > 0 ? (
            <ul>
              {moderatedProfiles.map((member) => (
                <li>
                  {member.display_name} <span>{member.status}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p>No restricted or blocked members.</p>
          )}
        </section>
      ) : null
    }
  </main>
</BaseLayout>

<style>
  .community-account {
    max-width: 48rem;
    padding: clamp(1.25rem, 4vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .community-account__kicker,
  .community-account h2 {
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-account h1 {
    margin: 0 0 1.5rem;
    font-family: var(--font-accent);
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 400;
    color: var(--tok-water);
  }

  .community-account__panel {
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
    border-radius: var(--radius-lg);
  }

  .community-account p,
  .community-account li {
    color: var(--tok-text-dark);
    line-height: 1.7;
  }

  .community-account__logout {
    margin: 1rem 0 0;
  }

  .community-account__logout-button {
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, transparent);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--tok-water);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .community-account__logout-button:hover {
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
  }

  .community-account__reports {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .community-account__report {
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-border-light) 82%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 78%, transparent);
  }

  .community-account__report h4 {
    margin: 0.35rem 0 0.65rem;
    font-size: 1.05rem;
  }

  .community-account__report-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.55rem;
    margin: 0;
    font-size: var(--tok-type-meta);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-account__report blockquote {
    margin: 0.75rem 0;
    padding-left: 0.85rem;
    border-left: 3px solid color-mix(in srgb, var(--tok-gold) 45%, transparent);
    color: var(--tok-text-dark);
  }

  .community-account__report-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .community-account__report-actions button {
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--tok-text-dark);
    cursor: pointer;
  }

  @media (max-width: 640px) {
    .community-account__report-actions {
      display: grid;
    }

    .community-account__report-actions button {
      width: 100%;
      text-align: left;
    }
  }
</style>
