---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommunityAccountDisplayName from "../../components/community/CommunityAccountDisplayName.astro";
import CommunityNotificationSettings from "../../components/community/CommunityNotificationSettings.astro";
import { isAdminProfile } from "../../lib/community/auth";
import { getNotificationPreferences } from "../../lib/community/queries";

export const prerender = false;

if (!Astro.locals.user) {
  return Astro.redirect("/auth/register/", 303);
}

const profile = Astro.locals.profile;
const email = Astro.locals.user.email ?? "";
const preferences =
  Astro.locals.supabase && Astro.locals.user
    ? await getNotificationPreferences(Astro.locals.supabase, Astro.locals.user.id)
    : null;
const isAdmin = isAdminProfile(profile);
const displayName = profile?.display_name ?? "Reader";
const roleLabel = isAdmin ? "Administrator" : "Member";
const statusLabel =
  profile?.status === "active"
    ? "Active"
    : profile?.status
      ? profile.status.charAt(0).toUpperCase() + profile.status.slice(1)
      : "Active";

function formatMemberSince(value: string | undefined): string {
  if (!value) return "—";
  return new Intl.DateTimeFormat("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(new Date(value));
}

const memberSince = formatMemberSince(profile?.created_at);
---

<BaseLayout
  title="Practice Commons Account | Tides of Knowing"
  description="Manage your Practice Commons account and email preferences."
  metaRobots="noindex, nofollow"
>
  <main class="community-account page-inner">
    <p class="community-account__kicker">Practice Commons</p>

    <nav class="community-account__nav" aria-label="Account navigation">
      <a class="community-account__nav-link" href="/community/">← Back to Practice Commons</a>
      {isAdmin ? (
        <a class="community-account__nav-link" href="/ask-leilia/admin/">Administration</a>
      ) : null}
    </nav>

    <h1>Your account</h1>

    <section class="community-account__panel" aria-labelledby="account-summary-heading">
      <h2 id="account-summary-heading">Account summary</h2>
      <dl class="community-account__summary">
        <div class="community-account__summary-row">
          <dt>Display name</dt>
          <dd>
            <CommunityAccountDisplayName displayName={displayName} />
          </dd>
        </div>
        <div class="community-account__summary-row">
          <dt>Email</dt>
          <dd>{email || "—"}</dd>
        </div>
        <div class="community-account__summary-row">
          <dt>Role</dt>
          <dd>{roleLabel}</dd>
        </div>
        <div class="community-account__summary-row">
          <dt>Member since</dt>
          <dd>
            <time datetime={profile?.created_at}>{memberSince}</time>
          </dd>
        </div>
        <div class="community-account__summary-row">
          <dt>Status</dt>
          <dd>{statusLabel}</dd>
        </div>
      </dl>
    </section>

    <section class="community-account__panel" aria-labelledby="email-heading">
      <h2 id="email-heading">Email preferences</h2>
      <p>Keep notifications minimal and useful. You can return to the Commons when you have time.</p>
      <CommunityNotificationSettings preferences={preferences} />
    </section>

    <section class="community-account__panel community-account__placeholder" aria-labelledby="community-heading">
      <h2 id="community-heading">Community</h2>
      <p class="community-account__placeholder-text">
        Your discussions, replies and community activity will appear here.
      </p>
    </section>

    <section class="community-account__panel community-account__placeholder" aria-labelledby="ask-leilia-heading">
      <h2 id="ask-leilia-heading">Ask Leilia</h2>
      <p class="community-account__placeholder-text">
        Your reading requests and completed readings will appear here.
      </p>
    </section>

    <section class="community-account__panel" aria-labelledby="security-heading">
      <h2 id="security-heading">Security</h2>
      <form class="community-account__logout" method="post" action="/auth/logout/">
        <button class="community-account__logout-button" type="submit">Log out</button>
      </form>
      <p class="community-account__placeholder-text">
        Additional account security options will be added here.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .community-account {
    max-width: 48rem;
    padding: clamp(1.25rem, 4vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .community-account__kicker,
  .community-account h2 {
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-account h1 {
    margin: 0 0 1.5rem;
    font-family: var(--font-accent);
    font-size: clamp(2rem, 7vw, 3.5rem);
    font-weight: 400;
    color: var(--tok-water);
  }

  .community-account__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem 1rem;
    margin: 0 0 1rem;
    font-size: var(--tok-type-meta);
  }

  .community-account__nav-link {
    color: var(--tok-gold-deep);
    font-weight: 700;
    text-decoration: none;
  }

  .community-account__nav-link:hover,
  .community-account__nav-link:focus-visible {
    color: var(--tok-water);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .community-account__panel {
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
    border-radius: var(--radius-lg);
  }

  .community-account p,
  .community-account li,
  .community-account dd {
    color: var(--tok-text-dark);
    line-height: 1.7;
  }

  .community-account__summary {
    display: grid;
    gap: 0.85rem;
    margin: 0.75rem 0 0;
  }

  .community-account__summary-row {
    display: grid;
    gap: 0.2rem;
  }

  .community-account__summary dt {
    margin: 0;
    font-size: var(--tok-type-meta);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-account__summary dd {
    margin: 0;
  }

  .community-account__placeholder-text {
    margin: 0.75rem 0 0;
    color: var(--tok-text-muted);
    font-style: italic;
  }

  .community-account__logout {
    margin: 0.75rem 0 0;
  }

  .community-account__logout-button {
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, transparent);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--tok-water);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .community-account__logout-button:hover {
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
  }

  @media (max-width: 640px) {
    .community-account__nav {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
