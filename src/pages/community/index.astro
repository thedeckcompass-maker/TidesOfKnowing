---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import LibraryPagination from "../../components/LibraryPagination.astro";
import CommunityAuthPrompt from "../../components/community/CommunityAuthPrompt.astro";
import CommunityPostList from "../../components/community/CommunityPostList.astro";
import CommunitySectionCard from "../../components/community/CommunitySectionCard.astro";
import { canContribute } from "../../lib/community/auth";
import { communityPaginationState } from "../../lib/community/pagination";
import { getCommunityPosts, getCommunitySections } from "../../lib/community/queries";
import { communitySectionPath } from "../../lib/community/slugs";
import { COMMUNITY_SECTION_FALLBACKS } from "../../lib/community/types";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { siteBase } from "../../lib/site";

export const prerender = false;

const base = siteBase(Astro);
const canonical = new URL("/community/", base).href;
const title = "Practice Commons | Tides of Knowing";
const description =
  "A quiet Practice Commons for tarot readers developing interpretation, intuition, confidence, and symbolic literacy.";
const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Practice Commons", url: null },
];

const loadedSections = Astro.locals.supabase ? await getCommunitySections(Astro.locals.supabase) : [];
const sections = loadedSections.length > 0 ? loadedSections : COMMUNITY_SECTION_FALLBACKS;
const { posts, totalPages } = Astro.locals.supabase
  ? await getCommunityPosts(Astro.locals.supabase, { mode: { kind: "all" }, page: 1 })
  : { posts: [], totalPages: 1 };
const pager = communityPaginationState({ kind: "all" }, 1, totalPages, base);
const canPost = canContribute(Astro.locals.profile);
const isAuthenticated = Boolean(Astro.locals.user);
const displayName = Astro.locals.profile?.display_name ?? "Reader";
const signedOut = Astro.url.searchParams.get("signed_out") === "true";
const joinSubmissionId = crypto.randomUUID();
const signInSubmissionId = crypto.randomUUID();
const jsonLd = [
  breadcrumbJsonLd(crumbs, base.href),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Practice Commons",
    description,
    url: canonical,
  },
];
---

<BaseLayout title={title} description={description} ogUrl={canonical} jsonLd={jsonLd}>
  <main class={`community page-inner${isAuthenticated ? " community--dashboard" : ""}`}>
    <Breadcrumbs items={crumbs} />

    <header class="community-hero">
      <p class="community-kicker">Practice Commons</p>
      <h1>{isAuthenticated ? `Welcome back, ${displayName}.` : "A quiet place for readers to become better readers."}</h1>
      {
        isAuthenticated ? (
          <p class="community-hero__summary">
            Continue your practice, join a discussion, or explore another room.
          </p>
        ) : null
      }
    </header>

    {
      signedOut ? (
        <p class="community-status-message" role="status">
          You've been signed out successfully.
        </p>
      ) : null
    }

    {
      isAuthenticated ? (
        <>
          <section class="community-dashboard-rooms" aria-labelledby="sections-heading">
            <div class="community-dashboard-rooms__heading">
              <h2 id="sections-heading">Choose a room</h2>
            </div>
            <div class="community-section-grid community-section-grid--dashboard">
              {sections.map((section) => <CommunitySectionCard section={section} compact />)}
            </div>
          </section>

          <section class="community-posts community-posts--dashboard" aria-labelledby="recent-heading">
            <div class="community-section-heading">
              <h2 id="recent-heading">Latest activity</h2>
              {totalPages > 1 ? <a href="/community/page/2/">More discussions</a> : null}
            </div>
            <CommunityPostList posts={posts} compact />
            <LibraryPagination prevHref={pager.prevHref} nextHref={pager.nextHref} pages={pager.pages} />
          </section>

          <section class="community-actions" aria-labelledby="actions-heading">
            <h2 id="actions-heading">Actions</h2>
            {
              canPost ? (
                <div class="community-actions__row">
                  {sections.map((section) => (
                    <a class="community-actions__button" href={communitySectionPath(section.key)}>
                      Start in {section.name}
                    </a>
                  ))}
                  <a class="community-actions__button community-actions__button--secondary" href="/community/search/">
                    Search discussions
                  </a>
                </div>
              ) : (
                <CommunityAuthPrompt message="Your account is signed in, but posting is not available for this profile right now." />
              )
            }
          </section>

          <section class="community-philosophy community-philosophy--dashboard" aria-labelledby="philosophy-heading">
            <h2 id="philosophy-heading">How this space works</h2>
            <p>
              The Practice Commons is a space for thoughtful practice, careful observation,
              and learning together.
            </p>
            <p>
              Bring real questions from your reading life, respond generously to other
              readers, and let the room stay focused on practice rather than performance.
            </p>
          </section>
        </>
      ) : (
        <>
          <section class="community-auth-card community-auth-card--join" aria-labelledby="community-auth-heading">
            <div data-auth-entry>
              <div>
                <p class="community-auth-card__kicker">Join the Practice Commons</p>
                <h2 id="community-auth-heading">Join the Practice Commons</h2>
                <p>Enter your name and email address and we'll email you a secure sign-in link.</p>
              </div>
              <form class="community-join-form" method="post" action="/auth/register/" data-auth-register-form>
                <input type="hidden" name="authMode" value="join" />
                <input type="hidden" name="submissionId" value={joinSubmissionId} />
                <label for="community-display-name">Your name</label>
                <input
                  id="community-display-name"
                  name="displayName"
                  type="text"
                  autocomplete="nickname"
                  minlength="2"
                  maxlength="60"
                  required
                />
                <label for="community-email">Email address</label>
                <input id="community-email" name="email" type="email" autocomplete="email" required />
                <button
                  type="submit"
                  data-auth-register-submit
                  data-default-text="Continue"
                  data-sending-text="Sending sign-in link..."
                >
                  Continue
                </button>
                <p class="community-join-form__help" data-auth-register-status hidden>
                  Please wait... we're sending your secure sign-in link.
                </p>
              </form>
              <section class="community-returning-member" aria-labelledby="community-returning-heading">
                <div>
                  <p class="community-returning-member__kicker">Already a member?</p>
                  <h3 id="community-returning-heading">Send yourself a sign-in link</h3>
                  <p>Enter the email address you used to join. We'll send a secure link if the account is active.</p>
                </div>
                <form class="community-join-form" method="post" action="/auth/register/" data-auth-register-form>
                  <input type="hidden" name="authMode" value="sign-in" />
                  <input type="hidden" name="submissionId" value={signInSubmissionId} />
                  <label for="community-returning-email">Email address</label>
                  <input id="community-returning-email" name="email" type="email" autocomplete="email" required />
                  <button
                    type="submit"
                    data-auth-register-submit
                    data-default-text="Send Sign-in Link"
                    data-sending-text="Sending sign-in link..."
                  >
                    Send Sign-in Link
                  </button>
                  <p class="community-join-form__help" data-auth-register-status hidden>
                    Please wait... we're sending your secure sign-in link.
                  </p>
                </form>
              </section>
            </div>
            <div class="community-auth-confirmation" data-auth-confirmation hidden>
              <h3>✓ Check your email</h3>
              <p>
                Check your email for your secure sign-in link:
                <strong data-auth-confirmation-email></strong>
              </p>
              <p>Click the link in that email to enter the Practice Commons.</p>
              <p>If it doesn't arrive within a minute or two, check your Spam or Promotions folder.</p>
              <button type="button" data-auth-reset>Send another link</button>
            </div>
          </section>

          <section class="community-intro" aria-label="About the Practice Commons" data-auth-secondary>
            <p>
              Every tarot reader reaches a point where knowing what the cards mean is no
              longer enough. Practice Commons is a reflective learning community for tarot
              readers and intuitive practitioners who want to develop deeper discernment
              through thoughtful discussion, shared interpretation and practical experience.
            </p>
            <p>
              Members bring real readings, symbols, questions and uncertainties into
              conversation. Leilia participates throughout the Community, sharing the
              practical wisdom and pattern recognition developed over more than 40 years
              of reading tarot and oracle cards. Her role is not to provide definitive
              answers, but to help members become more confident, more discerning and
              ultimately more capable readers in their own right.
            </p>
          </section>
        </>
      )
    }
  </main>
</BaseLayout>

<script>
  import { bindAuthRegisterForms } from "../../lib/community/authRegisterForm";

  bindAuthRegisterForms({
    cardSelector: ".community-auth-card",
    confirmedClass: "community-auth-card--confirmed",
  });
</script>

<style>
  .community {
    position: relative;
    isolation: isolate;
    min-height: calc(100dvh - var(--tok-header-height));
    padding: clamp(1.25rem, 4vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .community::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    z-index: -2;
    width: 100vw;
    content: "";
    background:
      linear-gradient(
        120deg,
        color-mix(in srgb, var(--tok-deep-ocean) 10%, transparent),
        transparent 55%
      ),
      url("/images/community/compass-feather-hourglass.png") right top / min(50vw, 40rem) auto no-repeat;
    opacity: 0.18;
    pointer-events: none;
    transform: translateX(-50%);
  }

  .community::after {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    z-index: -1;
    width: 100vw;
    content: "";
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--tok-surface-reading) 82%, transparent),
      color-mix(in srgb, var(--tok-surface-reading) 58%, transparent)
    );
    pointer-events: none;
    transform: translateX(-50%);
  }

  .community:not(.community--dashboard) {
    display: grid;
    gap: clamp(1rem, 3vw, 1.6rem);
    padding-top: clamp(0.9rem, 3vw, 2rem);
  }

  .community--dashboard {
    padding-top: clamp(0.75rem, 2.5vw, 1.75rem);
  }

  .community-hero {
    max-width: 48rem;
    margin-top: 1rem;
  }

  .community:not(.community--dashboard) .community-hero {
    max-width: 44rem;
    margin-top: 0.25rem;
  }

  .community--dashboard .community-hero {
    max-width: 62rem;
    margin-top: 0.35rem;
  }

  .community-hero__topline,
  .community-member-actions {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }

  .community-hero__topline {
    justify-content: space-between;
    margin-bottom: 0.45rem;
  }

  .community-kicker {
    margin: 0 0 0.55rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .community-hero__topline .community-kicker {
    margin-bottom: 0;
  }

  .community-member-actions {
    flex-wrap: wrap;
    justify-content: flex-end;
    font-size: var(--tok-type-meta);
  }

  .community-member-actions a,
  .community-member-actions button {
    color: var(--tok-gold-deep);
    font: inherit;
    font-weight: 700;
    text-decoration: none;
  }

  .community-member-actions form {
    margin: 0;
  }

  .community-member-actions button {
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .community-member-actions a:hover,
  .community-member-actions button:hover,
  .community-member-actions a:focus-visible,
  .community-member-actions button:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .community-member-actions form::before {
    color: var(--tok-text-muted);
    content: "·";
    margin-right: 0.55rem;
  }

  .community-hero h1 {
    margin: 0 0 0.85rem;
    font-family: var(--font-accent);
    font-size: clamp(2.15rem, 8vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--tok-water);
  }

  .community:not(.community--dashboard) .community-hero h1 {
    margin-bottom: 0;
    font-size: clamp(2.4rem, 8vw, 4rem);
    line-height: 1.02;
  }

  .community--dashboard .community-hero h1 {
    margin-bottom: 0.35rem;
    font-size: clamp(2rem, 6vw, 3.2rem);
    line-height: 1.05;
  }

  .community-hero__summary {
    max-width: 42rem;
    margin: 0;
    color: var(--tok-text-muted);
    font-size: clamp(1rem, 2.2vw, 1.1rem);
    line-height: 1.55;
  }

  .community-status-message {
    max-width: 48rem;
    margin: 1rem 0 0;
    padding: 0.75rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--tok-teal) 34%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-teal) 8%, var(--tok-surface-reading) 92%);
    color: var(--tok-text-dark);
    line-height: 1.6;
  }

  .community-intro p,
  .community-create p,
  .community-philosophy p {
    color: var(--tok-text-muted);
    line-height: 1.8;
  }

  .community-intro {
    max-width: 54rem;
    margin-top: 0;
  }

  .community-intro p {
    max-width: 50rem;
    margin: 0;
  }

  .community-intro p + p {
    margin-top: 0.75rem;
  }

  .community-auth-card {
    display: grid;
    gap: 1rem;
    align-items: center;
    max-width: 48rem;
    margin-top: clamp(1.25rem, 4vw, 2rem);
    padding: clamp(1rem, 4vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 38%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 78%, transparent);
    box-shadow: var(--shadow-sm);
  }

  .community-auth-card--join {
    grid-row: 2;
    grid-template-columns: minmax(0, 1fr);
    max-width: 38rem;
    margin-top: 0;
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .community-auth-card__kicker {
    margin: 0 0 0.35rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .community-auth-card h2 {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 5vw, 1.8rem);
    color: var(--tok-water);
  }

  .community-auth-card p {
    margin: 0;
    color: var(--tok-text-muted);
    line-height: 1.55;
  }

  [data-auth-entry][hidden] {
    display: none;
  }

  .community-auth-card--confirmed [data-auth-entry] {
    display: none !important;
  }

  .community-auth-card__button {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    text-decoration: none;
  }

  .community-join-form {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .community-join-form[hidden] {
    display: none;
  }

  .community-join-form label {
    font-size: var(--tok-type-label);
    font-weight: 700;
    color: var(--tok-text-dark);
  }

  .community-join-form__help {
    margin: -0.35rem 0 0.15rem;
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
    line-height: 1.45;
  }

  .community-auth-confirmation {
    display: grid;
    gap: 0.55rem;
    margin-top: 1rem;
    padding: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--tok-teal) 34%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-teal) 7%, var(--tok-surface-reading) 93%);
  }

  .community-auth-confirmation[hidden] {
    display: none;
  }

  .community-auth-confirmation h3 {
    margin: 0;
    font-family: var(--font-heading);
    color: var(--tok-water);
  }

  .community-auth-confirmation p {
    margin: 0;
    color: var(--tok-text-muted);
    line-height: 1.5;
  }

  .community-auth-confirmation strong {
    display: block;
    margin-top: 0.2rem;
    color: var(--tok-text-dark);
    font-weight: 800;
  }

  .community-auth-confirmation button {
    justify-self: start;
    padding: 0.55rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, transparent);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--tok-water);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .community-returning-member {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.1rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
  }

  .community-returning-member__kicker {
    margin: 0 0 0.25rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-returning-member h3 {
    margin: 0 0 0.35rem;
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 4vw, 1.25rem);
    color: var(--tok-water);
  }

  .community-join-form input {
    width: 100%;
    padding: 0.72rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
  }

  .community-join-form button {
    justify-self: start;
    margin-top: 0.2rem;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .community-search {
    display: grid;
    gap: 0.45rem;
    max-width: 42rem;
    margin: 2rem 0;
  }

  .community-search label,
  .community h2 {
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-auth-card h2 {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 5vw, 1.8rem);
    letter-spacing: normal;
    text-transform: none;
    color: var(--tok-water);
  }

  .community-search div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .community-search input {
    flex: 1 1 16rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
  }

  .community-search button {
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    cursor: pointer;
  }

  .community-sections,
  .community-philosophy,
  .community-create,
  .community-posts,
  .community-actions {
    margin-top: clamp(2rem, 6vw, 3.5rem);
  }

  .community-dashboard-rooms,
  .community-posts--dashboard,
  .community-actions,
  .community-philosophy--dashboard {
    margin-top: clamp(0.95rem, 2.4vw, 1.55rem);
  }

  .community-dashboard-rooms__heading,
  .community-section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.65rem;
  }

  .community-dashboard-rooms__heading h2,
  .community-section-heading h2 {
    margin: 0;
  }

  .community-dashboard-rooms__heading a,
  .community-section-heading a {
    color: var(--tok-gold-deep);
    font-size: var(--tok-type-meta);
    font-weight: 700;
    text-decoration: none;
  }

  .community-dashboard-rooms__heading a:hover,
  .community-section-heading a:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .community-section-grid--dashboard {
    gap: 0.85rem;
  }

  .community-actions {
    max-width: 62rem;
  }

  .community-actions h2 {
    margin: 0 0 0.55rem;
  }

  .community-actions__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .community-actions__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.62rem 0.85rem;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-size: var(--tok-type-meta);
    font-weight: var(--tok-ui-btn-font-weight);
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .community-actions__button--secondary {
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, transparent);
    background: transparent;
    color: var(--tok-water);
  }

  .community-philosophy {
    max-width: 48rem;
    padding: clamp(1rem, 4vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 62%, transparent);
  }

  .community-philosophy--dashboard {
    max-width: 62rem;
    padding: clamp(0.9rem, 3vw, 1.2rem);
  }

  .community-philosophy h2 {
    margin-top: 0;
  }

  .community-philosophy p:last-child {
    margin-bottom: 0;
  }

  .community-section-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 760px) {
    .community-auth-card {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .community-section-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .community-hero__topline {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.45rem;
    }

    .community-member-actions {
      justify-content: flex-start;
    }

    .community-dashboard-rooms__heading,
    .community-section-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
