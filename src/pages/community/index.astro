---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import LibraryPagination from "../../components/LibraryPagination.astro";
import CommunityAuthPrompt from "../../components/community/CommunityAuthPrompt.astro";
import CommunityPostForm from "../../components/community/CommunityPostForm.astro";
import CommunityPostList from "../../components/community/CommunityPostList.astro";
import CommunitySectionCard from "../../components/community/CommunitySectionCard.astro";
import { canContribute } from "../../lib/community/auth";
import { communityPaginationState } from "../../lib/community/pagination";
import { getCommunityPosts, getCommunitySections } from "../../lib/community/queries";
import { COMMUNITY_SECTION_FALLBACKS } from "../../lib/community/types";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { siteBase } from "../../lib/site";

export const prerender = false;

const base = siteBase(Astro);
const canonical = new URL("/community/", base).href;
const title = "Practice Commons | Tides of Knowing";
const description =
  "A quiet Practice Commons for tarot readers developing interpretation, intuition, confidence, and symbolic literacy.";
const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Practice Commons", url: null },
];

const loadedSections = Astro.locals.supabase ? await getCommunitySections(Astro.locals.supabase) : [];
const sections = loadedSections.length > 0 ? loadedSections : COMMUNITY_SECTION_FALLBACKS;
const { posts, totalPages } = Astro.locals.supabase
  ? await getCommunityPosts(Astro.locals.supabase, { mode: { kind: "all" }, page: 1 })
  : { posts: [], totalPages: 1 };
const pager = communityPaginationState({ kind: "all" }, 1, totalPages, base);
const canPost = canContribute(Astro.locals.profile);
const displayName = Astro.locals.profile?.display_name ?? "Reader";
const signedOut = Astro.url.searchParams.get("signed_out") === "true";
const roomCreationCopy = {
  "reading-practice": {
    short: "Bring cards and readings.",
    examples: [
      "What else do you see in this spread?",
      "This card combination puzzles me.",
    ],
  },
  "reader-development": {
    short: "Bring experiences and growth.",
    examples: [
      "How do you know when you're forcing an interpretation?",
      "What helped you trust your intuition?",
    ],
  },
} as const;
const jsonLd = [
  breadcrumbJsonLd(crumbs, base.href),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Practice Commons",
    description,
    url: canonical,
  },
];
---

<BaseLayout title={title} description={description} ogUrl={canonical} jsonLd={jsonLd}>
  <main class="community page-inner">
    <Breadcrumbs items={crumbs} />

    <header class="community-hero">
      <p class="community-kicker">Practice Commons</p>
      <h1>A quiet place for readers to become better readers.</h1>
    </header>

    {
      signedOut ? (
        <p class="community-status-message" role="status">
          You've been signed out successfully.
        </p>
      ) : null
    }

    <section class="community-auth-card" aria-labelledby="community-auth-heading">
      {
        canPost ? (
          <>
            <div>
              <p class="community-auth-card__kicker">Welcome back</p>
              <h2 id="community-auth-heading">Welcome back, {displayName}</h2>
              <p>Share a question, reading dilemma, or practice note when you are ready.</p>
            </div>
            <a class="community-auth-card__button" href="#create-heading">Start a conversation</a>
          </>
        ) : (
          <>
            <div>
              <p class="community-auth-card__kicker">Join the Practice Commons</p>
              <h2 id="community-auth-heading">Continue to the Practice Commons</h2>
              <p>Enter your name and email and we'll send you a sign-in link.</p>
            </div>
            <a class="community-auth-card__button" href="/auth/register/">Continue</a>
          </>
        )
      }
    </section>

    <section class="community-intro" aria-label="About the Practice Commons">
      <p>
        The Practice Commons is a quieter space for readers who want to deepen their
        craft away from the noise of social platforms.
      </p>
      <p class="community-intro__plain">
        No competition.<br />
        No posturing.<br />
        No algorithmic pressure.
      </p>
      <p>
        Just thoughtful practice, reflection, and reader development.
      </p>
    </section>

    <form class="community-search" method="get" action="/community/search/">
      <label for="community-search">Search the Practice Commons</label>
      <div>
        <input id="community-search" name="q" type="search" placeholder="clarifiers, confidence, ethics..." />
        <button type="submit">Search</button>
      </div>
    </form>

    <section class="community-sections" aria-labelledby="sections-heading">
      <h2 id="sections-heading">Two rooms</h2>
      <div class="community-section-grid">
        {sections.map((section) => <CommunitySectionCard section={section} />)}
      </div>
    </section>

    <section class="community-philosophy" aria-labelledby="philosophy-heading">
      <h2 id="philosophy-heading">Why this space exists</h2>
      <p>
        The wider social platforms can be noisy, harsh, competitive, and performative.
        They often reward certainty, speed, drama, and visibility.
      </p>
      <p>
        That is not the atmosphere many readers need when they are trying to grow.
      </p>
      <p>
        The Practice Commons is intentionally different. It is small by design,
        personalised where possible, and focused on thoughtful development rather than
        public performance.
      </p>
      <p>
        Readers and seekers are welcome here when they are genuinely interested in
        strengthening practice, asking better questions, and learning to work with
        symbolism more carefully.
      </p>
    </section>

    <section class="community-create" aria-labelledby="create-heading">
      <h2 id="create-heading">Share a practice note</h2>
      <p>
        Start with one clear question, observation, or reading dilemma. There is no need to rush.
      </p>
      {
        canPost ? (
          <>
            <aside class="community-room-guide" aria-labelledby="room-guide-heading">
              <h3 id="room-guide-heading">Which room fits best?</h3>
              <div class="community-room-guide__grid">
                <article>
                  <h4>Reading Practice</h4>
                  <p>Bring cards and readings.</p>
                  <ul>
                    <li>What else do you see in this spread?</li>
                    <li>This card combination puzzles me.</li>
                  </ul>
                </article>
                <article>
                  <h4>Reader Development</h4>
                  <p>Bring experiences and growth.</p>
                  <ul>
                    <li>How do you know when you're forcing an interpretation?</li>
                    <li>What helped you trust your intuition?</li>
                  </ul>
                </article>
              </div>
            </aside>

            <div class="community-create-grid">
              {sections.map((section) => {
                const roomCopy = roomCreationCopy[section.key];
                return (
                  <article class={`community-create-card community-create-card--${section.key}`}>
                    <h3>{section.name}</h3>
                    <p>{roomCopy.short}</p>
                    <CommunityPostForm sections={sections} selectedSectionKey={section.key} />
                  </article>
                );
              })}
            </div>
          </>
        ) : (
          <CommunityAuthPrompt message="Join the Practice Commons to share a practice note or reply to another reader." />
        )
      }
    </section>

    <section class="community-posts" aria-labelledby="recent-heading">
      <h2 id="recent-heading">Recent practice notes</h2>
      <CommunityPostList posts={posts} />
      <LibraryPagination prevHref={pager.prevHref} nextHref={pager.nextHref} pages={pager.pages} />
    </section>
  </main>
</BaseLayout>

<style>
  .community {
    padding: clamp(1.25rem, 4vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .community-hero {
    max-width: 48rem;
    margin-top: 1rem;
  }

  .community-kicker {
    margin: 0 0 0.55rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .community-hero h1 {
    margin: 0 0 0.85rem;
    font-family: var(--font-accent);
    font-size: clamp(2.15rem, 8vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    color: var(--tok-water);
  }

  .community-status-message {
    max-width: 48rem;
    margin: 1rem 0 0;
    padding: 0.75rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--tok-teal) 34%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-teal) 8%, var(--tok-surface-reading) 92%);
    color: var(--tok-text-dark);
    line-height: 1.6;
  }

  .community-intro p,
  .community-create p,
  .community-philosophy p {
    color: var(--tok-text-muted);
    line-height: 1.8;
  }

  .community-intro {
    max-width: 48rem;
    margin-top: clamp(1.25rem, 4vw, 2rem);
  }

  .community-intro__plain {
    color: var(--tok-text-dark);
  }

  .community-auth-card {
    display: grid;
    gap: 1rem;
    align-items: center;
    max-width: 48rem;
    margin-top: clamp(1.25rem, 4vw, 2rem);
    padding: clamp(1rem, 4vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 38%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 78%, transparent);
    box-shadow: var(--shadow-sm);
  }

  .community-auth-card__kicker {
    margin: 0 0 0.35rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .community-auth-card h2 {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 5vw, 1.8rem);
    color: var(--tok-water);
  }

  .community-auth-card p {
    margin: 0;
    color: var(--tok-text-muted);
    line-height: 1.7;
  }

  .community-auth-card__button {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    text-decoration: none;
  }

  .community-search {
    display: grid;
    gap: 0.45rem;
    max-width: 42rem;
    margin: 2rem 0;
  }

  .community-search label,
  .community h2 {
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .community-auth-card h2 {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 5vw, 1.8rem);
    letter-spacing: normal;
    text-transform: none;
    color: var(--tok-water);
  }

  .community-search div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .community-search input {
    flex: 1 1 16rem;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
  }

  .community-search button {
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    cursor: pointer;
  }

  .community-sections,
  .community-philosophy,
  .community-create,
  .community-posts {
    margin-top: clamp(2rem, 6vw, 3.5rem);
  }

  .community-philosophy {
    max-width: 48rem;
    padding: clamp(1rem, 4vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 62%, transparent);
  }

  .community-philosophy h2 {
    margin-top: 0;
  }

  .community-philosophy p:last-child {
    margin-bottom: 0;
  }

  .community-section-grid,
  .community-create-grid {
    display: grid;
    gap: 1rem;
  }

  .community-room-guide {
    margin-bottom: 1rem;
    padding: clamp(1rem, 4vw, 1.4rem);
    border: 1px solid color-mix(in srgb, var(--tok-border-light) 80%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 50%, transparent);
  }

  .community-room-guide h3,
  .community-room-guide h4 {
    margin: 0;
    font-family: var(--font-heading);
    color: var(--tok-water);
  }

  .community-room-guide h3 {
    margin-bottom: 0.85rem;
    font-size: clamp(1.2rem, 4vw, 1.55rem);
  }

  .community-room-guide__grid {
    display: grid;
    gap: 0.85rem;
  }

  .community-room-guide article {
    padding: 0.85rem;
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .community-room-guide p,
  .community-room-guide ul {
    color: var(--tok-text-muted);
    line-height: 1.65;
  }

  .community-room-guide ul {
    margin: 0.55rem 0 0;
    padding-left: 1.15rem;
  }

  .community-create-card {
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, transparent);
    border-radius: var(--radius-lg);
  }

  .community-create-card--reading-practice {
    background: color-mix(in srgb, var(--tok-water) 8%, var(--tok-surface-reading) 92%);
    border-color: color-mix(in srgb, var(--tok-gold) 38%, transparent);
  }

  .community-create-card--reader-development {
    background: color-mix(in srgb, var(--tok-teal) 8%, var(--tok-surface-reading) 92%);
    border-color: color-mix(in srgb, var(--tok-teal) 34%, transparent);
  }

  .community-create-grid h3 {
    margin: 0 0 0.8rem;
    font-family: var(--font-heading);
    color: var(--tok-water);
  }

  @media (min-width: 760px) {
    .community-auth-card {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .community-room-guide__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .community-section-grid,
    .community-create-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
