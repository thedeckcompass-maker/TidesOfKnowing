---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteBase } from "../lib/site";

const title = "Terms of Use | Tides of Knowing";
const description = "Terms of Use for Tides of Knowing and the COMPASS programme.";
const ogUrl = new URL("/terms/", siteBase(Astro)).href;
---

<BaseLayout title={title} description={description} ogUrl={ogUrl}>
  <article class="legal page-inner">
    <h1 class="legal__title">Terms of Use</h1>
    <p class="legal__updated">Last updated: 30 April 2026</p>

    <p>
      By accessing this website and applying to the COMPASS programme, you agree to the following terms.
    </p>

    <h2>Programme Nature</h2>
    <p>
      COMPASS is a live training programme designed to develop intuitive reading skills. It is not a certification, guarantee of results, or professional accreditation.
    </p>

    <h2>Participation</h2>
    <p>Participation requires:</p>
    <ul>
      <li>Engagement in live sessions</li>
      <li>Willingness to receive feedback</li>
      <li>Responsibility for your own learning and application</li>
    </ul>

    <h2>Payments</h2>
    <p>Programme participation is confirmed upon payment.</p>
    <p>All payments are processed via Stripe.</p>

    <h2>Refunds</h2>
    <p>Refunds are available up to 48 hours before the programme begins.</p>
    <p>No refunds are issued after the programme has started.</p>

    <h2>Intellectual Property</h2>
    <p>
      All materials, methods, and content provided within COMPASS remain the intellectual property of Tides of Knowing.
    </p>
    <p>They may not be copied, distributed, or reproduced without permission.</p>

    <h2>Disclaimer</h2>
    <p>
      The programme is for personal development and learning purposes only. It does not provide legal, financial, or medical advice.
    </p>

    <h2>Changes</h2>
    <p>
      We reserve the right to update these terms at any time. Continued use of the website constitutes acceptance of any changes.
    </p>

    <h2>Contact</h2>
    <p>For any questions, contact:</p>
    <p><a href="mailto:hello@tidesofknowing.com">hello@tidesofknowing.com</a></p>
  </article>
</BaseLayout>

<style>
  .legal {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 42rem;
  }

  .legal__title {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.65rem);
    line-height: 1.15;
    color: var(--mountain-water);
  }

  .legal__updated {
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
    opacity: 0.8;
  }

  .legal h2 {
    margin: 2rem 0 0.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.8vw, 1.65rem);
    font-weight: 600;
    line-height: 1.25;
    color: var(--mountain-water);
  }

  .legal p,
  .legal ul {
    margin: 0 0 1rem;
    font-size: 1.06rem;
    line-height: 1.75;
  }

  .legal ul {
    padding-left: 1.35rem;
  }

  .legal li {
    margin-bottom: 0.4rem;
  }

  .legal a {
    color: var(--sky);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .legal a:hover {
    color: var(--mountain-water);
  }
</style>
