---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getRelatedForSlug } from "../../data/relatedPosts";
import { estimateReadingMinutes } from "../../lib/readingTime";
import { countWords } from "../../lib/wordCount";
import { siteBase } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => {
    const slug = post.slug ?? post.id;
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const slug = post.slug ?? post.id;
const rendered = await render(post);
const { Content, headings } = rendered;

const body = post.body ?? "";
const wordCount = countWords(body);
const tocHeadings = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, text: h.text }));

const readingMinutes =
  post.data.readingTime ?? estimateReadingMinutes(body);

const defaultHero = "/images/blog/placeholders/hero.svg";
const heroImage = post.data.heroImage ?? defaultHero;
const base = siteBase(Astro);
const heroImageAbsolute = new URL(heroImage, base).href;

const ogUrl = new URL(`/blog/${slug}/`, base).href;
const related = getRelatedForSlug(slug);
const showToc = wordCount >= 1500 && tocHeadings.length >= 4;
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  readingMinutes={readingMinutes}
  ogUrl={ogUrl}
  related={related}
  heroImage={heroImage}
  heroImageAlt={post.data.heroImageAlt}
  heroCaption={post.data.heroCaption}
  heroImageAbsolute={heroImageAbsolute}
  articleTags={post.data.tags}
  tocHeadings={tocHeadings}
  showToc={showToc}
>
  <Content />
</ArticleLayout>
