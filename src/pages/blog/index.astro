---
/**
 * Field Notes index — public section label: "Field Notes".
 * URLs stay under `/blog/` for compatibility (collection id `blog`, files in `src/content/blog/`).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogSidebar from "../../components/BlogSidebar.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { siteBase } from "../../lib/site";
import {
  blogCategoryIndex,
  blogCategoryLabel,
  blogCategorySlugFromLabel,
} from "../../lib/blogCategories";
import {
  buildBlogIndexItems,
  fieldNoteSeriesStripeCount,
  getStandaloneFieldNotes,
  type BlogIndexItem,
} from "../../lib/blogFieldNotes";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { ENTITY_IDS } from "../../lib/ecosystem-structured-data";

const allEntries = await getCollection("blog", ({ data }) => !data.draft);
const items = buildBlogIndexItems(allEntries, blogCategoryLabel);

const standaloneForSidebar = getStandaloneFieldNotes(allEntries);
const categoryRows = blogCategoryIndex(standaloneForSidebar);

const PAGE_TITLE = "Field Notes | Tides of Knowing | Observations & shorter writing";
const PAGE_DESCRIPTION =
  "Field Notes: practitioner notes, reflective fragments, and shorter pieces drawn from real interpretive work. Methodology and framework writing lives elsewhere on the site.";

const base = siteBase(Astro);
const siteHref = base.href;
const canonical = new URL("/blog/", base).href;

const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Field Notes", url: null },
];

const blogPostSummaries = items.flatMap((item: BlogIndexItem) => {
  if (item.kind === "standalone") {
    return [
      {
        "@type": "BlogPosting",
        headline: item.title,
        url: new URL(item.href, siteHref).href,
        datePublished: item.date.toISOString(),
      },
    ];
  }
  return [];
});

const blogLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Tides of Knowing | Field Notes",
  description: PAGE_DESCRIPTION,
  url: canonical,
  publisher: { "@id": ENTITY_IDS.tidesOrg },
  blogPost: blogPostSummaries,
};

const jsonLd = [blogLd, breadcrumbJsonLd(crumbs, siteHref)];
---

<BaseLayout
  title={PAGE_TITLE}
  description={PAGE_DESCRIPTION}
  ogUrl={canonical}
  ogImage={new URL("/favicon.svg", base).href}
  metaAuthor="Leigh Spencer"
  jsonLd={jsonLd}
>
  <div class="tok-blog-index page-inner">
    <div class="tok-blog-index-breadcrumbs">
      <Breadcrumbs items={crumbs} />
    </div>

    <div class="tok-blog-index-grid">
      <div class="tok-blog-index-main">
        <header class="tok-blog-index-head" data-reveal>
          <h1 class="tok-blog-index-title">Field Notes</h1>
          <p class="tok-blog-index-lede">
            The living observational layer of Tides of Knowing: practitioner notes, reflections,
            and shorter pieces drawn from real interpretive work.
          </p>
          <p class="tok-blog-index-lede tok-blog-index-lede--follow">
            Longer-form methodology and framework writing lives in Articles. Field Notes focus on
            the practical application of symbolic perception, helping readers create deeper
            readings and stronger resonance with clients.
          </p>
        </header>

        {
          items.length === 0 ? (
            <p class="tok-blog-index-empty" data-reveal>
              The first Field Notes are on their way. Browse the{" "}
              <a href="/articles/">articles</a> or learn more{" "}
              <a href="/about/">about this publication</a>.
            </p>
          ) : (
            <ul class="tok-blog-feed">
              {items.map((item) =>
                item.kind === "series" ? (
                  <li class="tok-blog-feed__item tok-blog-feed__item--series" data-reveal>
                    <article class="tok-blog-feed__article tok-blog-feed__article--series">
                      <div
                        class="tok-blog-feed__series-stripes"
                        aria-hidden="true"
                      >
                        {
                          Array.from({
                            length: fieldNoteSeriesStripeCount(item.noteCount),
                          }).map(() => <span class="tok-blog-feed__series-stripe" />)
                        }
                      </div>
                      <div class="tok-blog-feed__series-body">
                      <p class="tok-blog-feed__meta">
                        <span class="tok-blog-feed__badge tok-blog-feed__badge--series">
                          Field Note Series
                        </span>
                        <span class="tok-blog-feed__sep" aria-hidden="true">
                          ·
                        </span>
                        <span>
                          {item.noteCount === 1
                            ? "1 part"
                            : `${item.noteCount}-part series`}
                        </span>
                        {item.cheatSheetAvailable ? (
                          <>
                            <span class="tok-blog-feed__sep" aria-hidden="true">
                              ·
                            </span>
                            <span class="tok-blog-feed__cheat-flag">Cheat sheet</span>
                          </>
                        ) : null}
                      </p>
                      <h2 class="tok-blog-feed__title">
                        <a href={item.href}>{item.title}</a>
                      </h2>
                      {item.subtitle ? (
                        <p class="tok-blog-feed__subtitle">{item.subtitle}</p>
                      ) : null}
                      <p class="tok-blog-feed__excerpt">{item.description}</p>
                      <p class="tok-blog-feed__more-wrap">
                        <a class="tok-blog-feed__more" href={item.href}>
                          View series
                        </a>
                      </p>
                      </div>
                    </article>
                  </li>
                ) : (
                  <li
                    class:list={[
                      "tok-blog-feed__item tok-blog-feed__item--standalone",
                      item.foundational
                        ? "tok-blog-feed__item--foundational"
                        : "tok-blog-feed__item--note",
                    ]}
                    data-reveal
                  >
                    <article
                      class:list={[
                        "tok-blog-feed__article",
                        item.foundational
                          ? "tok-blog-feed__article--foundational"
                          : "tok-blog-feed__article--note",
                      ]}
                    >
                      <p class="tok-blog-feed__meta">
                        <span
                          class:list={[
                            "tok-blog-feed__badge",
                            item.foundational
                              ? "tok-blog-feed__badge--foundational"
                              : "tok-blog-feed__badge--note",
                          ]}
                        >
                          {item.foundational ? "Foundational Field Note" : "Field Note"}
                        </span>
                        <span class="tok-blog-feed__sep" aria-hidden="true">
                          ·
                        </span>
                        <time datetime={item.date.toISOString()}>
                          {item.date.toLocaleDateString("en-AU", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                          })}
                        </time>
                        {
                          !item.foundational ? (
                            <>
                              <span class="tok-blog-feed__sep" aria-hidden="true">
                                ·
                              </span>
                              <a
                                class="tok-blog-feed__cat"
                                href={`/blog/category/${blogCategorySlugFromLabel(item.categoryLabel)}/`}
                              >
                                {item.categoryLabel}
                              </a>
                            </>
                          ) : null
                        }
                        {item.cheatSheetAvailable ? (
                          <>
                            <span class="tok-blog-feed__sep" aria-hidden="true">
                              ·
                            </span>
                            <span class="tok-blog-feed__cheat-flag">Cheat sheet</span>
                          </>
                        ) : null}
                      </p>
                      <h2 class="tok-blog-feed__title">
                        <a href={item.href}>{item.title}</a>
                      </h2>
                      <p class="tok-blog-feed__excerpt">{item.description}</p>
                      <p class="tok-blog-feed__more-wrap">
                        <a class="tok-blog-feed__more" href={item.href}>
                          Read more
                        </a>
                      </p>
                    </article>
                  </li>
                ),
              )}
            </ul>
          )
        }
      </div>

      <BlogSidebar categories={categoryRows} />
    </div>
  </div>
</BaseLayout>

<style>
  .tok-blog-index-breadcrumbs {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .tok-blog-index-grid {
    display: grid;
    gap: 2.5rem;
    padding: 0 0 clamp(3rem, 8vw, 5rem);
    align-items: start;
  }

  @media (min-width: 960px) {
    .tok-blog-index-grid {
      grid-template-columns: minmax(0, 1fr) minmax(14rem, var(--tok-blog-sidebar-max));
      gap: 2.75rem;
    }
  }

  .tok-blog-index-head {
    margin-bottom: 2.25rem;
    padding-bottom: 1.35rem;
    border-bottom: 1px solid var(--tok-gold);
  }

  .tok-blog-index-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 2.85rem);
    color: var(--tok-teal-dim);
  }

  .tok-blog-index-lede {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.75;
    max-width: 40rem;
  }

  .tok-blog-index-lede--follow {
    margin-top: 0.85rem;
  }

  .tok-blog-index-empty {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 36rem;
  }

  .tok-blog-feed {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .tok-blog-feed__article {
    padding-bottom: 2rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
  }

  .tok-blog-feed__article--foundational,
  .tok-blog-feed__article--note,
  .tok-blog-feed__article--series {
    border-bottom: none;
    border-radius: var(--radius-soft);
  }

  .tok-blog-feed__article--foundational {
    padding: 1.1rem 1.05rem 1.35rem;
    border-left: 3px solid var(--tok-earth);
    background: color-mix(in srgb, var(--tok-earth) 11%, var(--tok-surface-reading-soft));
  }

  .tok-blog-feed__article--note {
    padding: 1.05rem 1rem 1.3rem;
    border-left: 2px solid color-mix(in srgb, var(--tok-air) 50%, var(--tok-water));
    background: color-mix(in srgb, var(--tok-air) 16%, var(--tok-surface-reading));
  }

  .tok-blog-feed__article--series {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: 0.85rem;
    align-items: start;
    padding: 1.15rem 1.1rem 1.35rem;
    background: color-mix(in srgb, var(--tok-water) 12%, var(--tok-surface-reading-soft));
  }

  .tok-blog-feed__series-stripes {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 4px;
    min-height: 3.25rem;
    padding-top: 0.15rem;
  }

  .tok-blog-feed__series-stripe {
    display: block;
    width: 3px;
    border-radius: 1px;
    background: color-mix(in srgb, var(--tok-air) 45%, var(--tok-water));
  }

  .tok-blog-feed__series-body {
    min-width: 0;
  }

  .tok-blog-feed__item:last-child .tok-blog-feed__article {
    border-bottom: none;
    padding-bottom: 0;
  }

  .tok-blog-feed__item:last-child .tok-blog-feed__article--foundational,
  .tok-blog-feed__item:last-child .tok-blog-feed__article--note,
  .tok-blog-feed__item:last-child .tok-blog-feed__article--series {
    padding-bottom: 1.35rem;
  }

  .tok-blog-feed__meta {
    margin: 0 0 0.45rem;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .tok-blog-feed__badge--series {
    color: var(--tok-water);
  }

  .tok-blog-feed__badge--note {
    color: color-mix(in srgb, var(--tok-water) 88%, var(--tok-teal-dim));
  }

  .tok-blog-feed__badge--foundational {
    color: var(--tok-earth);
  }

  .tok-blog-feed__item--foundational .tok-blog-feed__excerpt {
    line-height: 1.72;
  }

  .tok-blog-feed__cheat-flag {
    color: var(--tok-teal-dim);
  }

  .tok-blog-feed__sep {
    margin: 0 0.4rem;
    opacity: 0.85;
  }

  .tok-blog-feed__cat {
    color: inherit;
    text-decoration: none;
  }

  .tok-blog-feed__cat:hover {
    color: var(--tok-teal);
  }

  .tok-blog-feed__title {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.45rem, 3.5vw, 1.85rem);
    line-height: 1.2;
  }

  .tok-blog-feed__subtitle {
    margin: -0.35rem 0 0.55rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.4;
    opacity: 0.9;
  }

  .tok-blog-feed__title a {
    color: var(--tok-teal-dim);
    text-decoration: none;
  }

  .tok-blog-feed__title a:hover {
    color: var(--tok-teal);
  }

  .tok-blog-feed__excerpt {
    margin: 0 0 0.85rem;
    font-size: 1.02rem;
    line-height: 1.7;
    opacity: 0.92;
  }

  .tok-blog-feed__more-wrap {
    margin: 0;
  }

  .tok-blog-feed__more {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-teal);
  }

  .tok-blog-feed__more:hover {
    color: var(--tok-teal-dim);
  }
</style>
