---
/**
 * Field Notes index — public section label: "Field Notes".
 * URLs stay under `/blog/` for compatibility (collection id `blog`, files in `src/content/blog/`).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogSidebar from "../../components/BlogSidebar.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FieldNotesFeed from "../../components/FieldNotesFeed.astro";
import FieldNotesFindPanel from "../../components/FieldNotesFindPanel.astro";
import FieldNoteSeriesMarker from "../../components/FieldNoteSeriesMarker.astro";
import FieldNoteTopicChips from "../../components/FieldNoteTopicChips.astro";
import { getCollection } from "astro:content";
import { siteBase } from "../../lib/site";
import {
  blogCategoryIndex,
  blogCategoryLabel,
} from "../../lib/blogCategories";
import {
  buildBlogFeedItems,
  getStandaloneFieldNotes,
} from "../../lib/blogFieldNotes";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../../lib/breadcrumbs";
import { ENTITY_IDS } from "../../lib/ecosystem-structured-data";

const AUTHORITY_LINE =
  "Field Notes by Leigh Spencer, fourth-generation Matakite (seer), trace the practical reality of symbolic reading, drawing on 40+ years of tarot practice, professional journalism, and The COMPASS Method™.";

const allEntries = await getCollection("blog", ({ data }) => !data.draft);
const feedItems = buildBlogFeedItems(allEntries, blogCategoryLabel);
const seriesHighlight = feedItems.filter((item) => item.kind === "series").slice(0, 3);

const standaloneForSidebar = getStandaloneFieldNotes(allEntries);
const categoryRows = blogCategoryIndex(standaloneForSidebar);

const PAGE_TITLE = "Field Notes | Tides of Knowing | Observations & shorter writing";
const PAGE_DESCRIPTION =
  "Field Notes: practitioner observations, reflective fragments, and shorter writing drawn from real interpretive work at Tides of Knowing.";

const base = siteBase(Astro);
const siteHref = base.href;
const canonical = new URL("/blog/", base).href;

const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Field Notes", url: null },
];

const blogPostSummaries = feedItems.flatMap((item) => {
  if (item.kind === "standalone") {
    return [
      {
        "@type": "BlogPosting",
        headline: item.title,
        url: new URL(item.href, siteHref).href,
        datePublished: item.date.toISOString(),
      },
    ];
  }
  return [];
});

const blogLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Tides of Knowing | Field Notes",
  description: PAGE_DESCRIPTION,
  url: canonical,
  author: { "@type": "Person", name: "Leigh Spencer", "@id": ENTITY_IDS.person },
  publisher: { "@id": ENTITY_IDS.tidesOrg },
  about: { "@id": ENTITY_IDS.compassMethod },
  blogPost: blogPostSummaries,
};

const jsonLd = [blogLd, breadcrumbJsonLd(crumbs, siteHref)];
---

<BaseLayout
  title={PAGE_TITLE}
  description={PAGE_DESCRIPTION}
  ogUrl={canonical}
  ogImage={new URL("/favicon.svg", base).href}
  metaAuthor="Leigh Spencer"
  jsonLd={jsonLd}
>
  <div class="tok-blog-index page-inner">
    <div class="tok-blog-index-breadcrumbs">
      <Breadcrumbs items={crumbs} />
    </div>

    <div class="tok-blog-index-grid">
      <div class="tok-blog-index-main">
        <header class="tok-blog-index-head" data-reveal>
          <h1 class="tok-blog-index-title">Field Notes</h1>
          <p class="tok-blog-index-lede">
            The living observational layer of Tides of Knowing: practitioner notes,
            reflections, and shorter pieces drawn from real interpretive work.
          </p>
          <p class="tok-blog-index-lede tok-blog-index-lede--follow">
            Longer-form methodology and framework writing lives in{" "}
            <a href="/articles/">Articles</a>. Field Notes focus on symbolic reading in
            practice: what showed up in the reading field and how attention moved.
          </p>
          <p class="tok-blog-index-authority">{AUTHORITY_LINE}</p>
        </header>

        <FieldNotesFindPanel />

        {
          seriesHighlight.length > 0 ? (
            <section
              class="tok-blog-index-series-highlight"
              aria-labelledby="fn-series-highlight-heading"
              data-reveal
            >
              <h2 id="fn-series-highlight-heading" class="tok-blog-feed-section-title">
                Field Note series
              </h2>
              <ul class="tok-blog-index-series-highlight__list">
                {seriesHighlight.map((item) => (
                  <li class="tok-blog-index-series-highlight__item">
                    <article class="tok-blog-feed__article tok-blog-feed__article--series">
                      <FieldNoteSeriesMarker class="tok-blog-feed__series-marker" />
                      <div class="tok-blog-feed__series-body">
                        <p class="tok-blog-feed__meta">
                          <span class="tok-blog-feed__badge tok-blog-feed__badge--series">
                            Field Note Series
                          </span>
                          <span class="tok-blog-feed__sep" aria-hidden="true">·</span>
                          <span>
                            {item.noteCount === 1
                              ? "1 part"
                              : `${item.noteCount}-part series`}
                          </span>
                        </p>
                        <h3 class="tok-blog-feed__title">
                          <a href={item.href}>{item.title}</a>
                        </h3>
                        {item.subtitle ? (
                          <p class="tok-blog-feed__subtitle">{item.subtitle}</p>
                        ) : null}
                        <p class="tok-blog-feed__excerpt">{item.description}</p>
                        <FieldNoteTopicChips chips={item.topicChips} />
                        <p class="tok-blog-feed__more-wrap">
                          <a class="tok-blog-feed__more" href={item.href}>
                            View series
                          </a>
                        </p>
                      </div>
                    </article>
                  </li>
                ))}
              </ul>
            </section>
          ) : null
        }

        <section
          id="all-field-notes"
          class="tok-blog-index-all"
          aria-labelledby="fn-all-heading"
        >
          <h2 id="fn-all-heading" class="tok-blog-feed-section-title" data-reveal>
            All Field Notes
          </h2>

          <p class="tok-fn-find-count" data-fn-find-count hidden></p>

          <p
            class="tok-blog-index-empty tok-blog-index-empty--search"
            data-fn-find-empty
            hidden
          >
            No Field Notes match your search on this page. Try{" "}
            <a href="/blog/topics/">browse topics</a> or{" "}
            <a href="/blog/">clear the search</a>.
          </p>

          <FieldNotesFeed
            items={feedItems}
            emptyMessage="No Field Notes are currently published in this section."
          />
        </section>
      </div>

      <BlogSidebar categories={categoryRows} />
    </div>
  </div>

  <script>
    function normalizeQuery(s: string): string {
      return s.toLowerCase().trim();
    }

    function initFieldNoteFind() {
      const input = document.querySelector<HTMLInputElement>("[data-fn-find-input]");
      const grid = document.querySelector("[data-fn-find-grid]");
      if (!input || !grid) return;

      const cards = grid.querySelectorAll<HTMLElement>("[data-fn-search]");
      const empty = document.querySelector<HTMLElement>("[data-fn-find-empty]");
      const countEl = document.querySelector<HTMLElement>("[data-fn-find-count]");

      function applyFilter() {
        const raw = input!.value.trim();
        const q = raw ? normalizeQuery(raw) : "";
        let visible = 0;

        cards.forEach((card) => {
          if (!q) {
            card.hidden = false;
            visible += 1;
            return;
          }
          const haystack = card.getAttribute("data-fn-search") ?? "";
          const match = haystack.includes(q);
          card.hidden = !match;
          if (match) visible += 1;
        });

        if (empty) {
          empty.hidden = !q || visible > 0;
        }
        if (countEl) {
          countEl.hidden = !q;
          countEl.textContent =
            visible === 1
              ? "1 Field Note matches your search."
              : `${visible} Field Notes match your search.`;
        }

        const url = new URL(window.location.href);
        if (q) url.searchParams.set("q", raw);
        else url.searchParams.delete("q");
        window.history.replaceState({}, "", url);
      }

      input.addEventListener("input", applyFilter);

      const initial = input.value.trim();
      if (initial) applyFilter();
      else {
        cards.forEach((card) => {
          card.hidden = false;
        });
      }
    }

    initFieldNoteFind();
    document.addEventListener("astro:page-load", initFieldNoteFind);
  </script>
</BaseLayout>
