---
import { ASK_LEILIA_PUBLIC_BRAND } from "../../data/askLeilia";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RecentClientReadingGrid from "../../components/recent-client-readings/RecentClientReadingGrid.astro";
import { createCommunityServiceClient } from "../../lib/community/supabaseServer";
import {
  getLibraryJsonLd,
  getLibraryBreadcrumbs,
  getPublishedLibraryPublications,
  READING_LIBRARY_HUB_PATH,
} from "../../lib/readingLibrary";
import { siteBase } from "../../lib/site";
import "../../styles/ask-leilia.css";
import "../../styles/recent-client-readings.css";

export const prerender = false;

const title = "Reading Library | Ask Leilia | Tides of Knowing";
const description =
  "Explore genuine client tarot readings shared with permission and carefully anonymised — professionally written and personally interpreted by Leilia.";

const service = createCommunityServiceClient(Astro.locals);
const publications = await getPublishedLibraryPublications(service);

const base = siteBase(Astro);
const canonical = new URL(READING_LIBRARY_HUB_PATH, base).href;
const crumbs = getLibraryBreadcrumbs();
const jsonLd = getLibraryJsonLd(publications, base.href);
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={canonical}
  ogTitle={title}
  ogDescription={description}
  metaAuthor={ASK_LEILIA_PUBLIC_BRAND}
  jsonLd={jsonLd}
>
  <main class="ask-leilia page-inner rcr-library">
    <Breadcrumbs items={crumbs} />

    <section class="ask-leilia-hero" aria-labelledby="reading-library-heading">
      <div class="ask-leilia-hero__copy">
        <p class="ask-leilia__kicker">Ask Leilia</p>
        <h1 id="reading-library-heading">Reading Library</h1>
        <p class="ask-leilia-hero__subheading">
          Explore a growing collection of genuine client readings, shared with permission and
          carefully anonymised to protect privacy.
        </p>
        <p class="ask-leilia-hero__lede">
          Each reading demonstrates a different question, spread and interpretive approach while
          preserving the integrity of the original consultation.
        </p>
        <p class="ask-leilia-hero__lede rcr-library__human-led">
          These are real readings, professionally written and personally interpreted by Leilia. No AI
          is used in either the reading or the writing.
        </p>
      </div>
    </section>

    {
      publications.length > 0 ? (
        <RecentClientReadingGrid
          heading="Published readings"
          headingId="published-readings-heading"
          publications={publications}
        />
      ) : (
        <section class="rcr-library__empty" aria-labelledby="library-empty-heading">
          <h2 id="library-empty-heading" class="visually-hidden">No published readings yet</h2>
          <p>
            Published client readings will begin appearing here as they are completed and released with
            permission.
          </p>
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
