---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import AskLeiliaPricingGrid from "../../components/ask-leilia/AskLeiliaPricingGrid.astro";
import RecentClientReadingMetaPanel from "../../components/recent-client-readings/RecentClientReadingMetaPanel.astro";
import RecentClientReadingContinueExploring from "../../components/recent-client-readings/RecentClientReadingContinueExploring.astro";
import RecentClientReadingFeaturedSpread from "../../components/recent-client-readings/RecentClientReadingFeaturedSpread.astro";
import RecentClientReadingSpreadGallery from "../../components/recent-client-readings/RecentClientReadingSpreadGallery.astro";
import { ASK_LEILIA_READINGS, ASK_LEILIA_PUBLIC_BRAND } from "../../data/askLeilia";
import { createCommunityServiceClient } from "../../lib/community/supabaseServer";
import {
  formatLibraryDate,
  formatLibraryIsoDate,
  getFeaturedSpreadImage,
  getPublishedLibraryPublicationBySlug,
  getPublishedLibraryPublications,
  resolveLibraryPdfSource,
  getReadingBreadcrumbs,
  getReadingCanonicalUrl,
  getReadingJsonLd,
  getReadingMetaTitle,
  READING_LIBRARY_HUB_PATH,
} from "../../lib/readingLibrary";
import MarkdownIt from "markdown-it";
import { siteBase } from "../../lib/site";
import "../../styles/ask-leilia.css";
import "../../styles/recent-client-readings.css";

export const prerender = false;

const slug = Astro.params.slug?.trim();
if (!slug) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const service = createCommunityServiceClient(Astro.locals);
const publication = await getPublishedLibraryPublicationBySlug(service, slug);

if (!publication) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const allPublished = await getPublishedLibraryPublications(service);
const relatedPublications = allPublished
  .filter((item) => item.slug !== publication.slug)
  .slice(0, 4);

const base = siteBase(Astro);
const canonical = getReadingCanonicalUrl(publication, base.href);
const title = getReadingMetaTitle(publication);
const crumbs = getReadingBreadcrumbs(publication);
const jsonLd = getReadingJsonLd(publication, base.href);
// Presence-only check; the resolved storage path stays server-side and is never
// rendered. The link points at the signed-URL route, not the storage path.
const pdfSource = await resolveLibraryPdfSource(service, publication.slug);
const pdfHref = pdfSource
  ? new URL(`/api/reading-library/${publication.slug}/pdf`, base).href
  : null;
const featuredSpreadSrc = getFeaturedSpreadImage(publication);
const ogImage = featuredSpreadSrc ? new URL(featuredSpreadSrc, base).href : undefined;
const md = new MarkdownIt({ html: false, linkify: true });
const readingHtml = md.render(publication.body);
const publishedAt = publication.publishedAt;
---

<BaseLayout
  title={title}
  description={publication.seoDescription}
  ogUrl={canonical}
  ogTitle={title}
  ogDescription={publication.seoDescription}
  ogType="article"
  ogImage={ogImage}
  metaAuthor={ASK_LEILIA_PUBLIC_BRAND}
  jsonLd={jsonLd}
>
  <main class="ask-leilia page-inner rcr-reading">
    <Breadcrumbs items={crumbs} />

    <header class="rcr-reading__hero">
      <p class="ask-leilia__kicker">{publication.readingType}</p>
      <h1>{publication.title}</h1>
      <p class="rcr-reading__question">
        <span class="rcr-reading__question-label">Original question</span>
        {publication.question}
      </p>
      <p class="rcr-reading__privacy">
        Identifying details have been removed or anonymised where necessary to protect client
        privacy.
      </p>
      {
        publishedAt ? (
          <p class="rcr-reading__published">
            Published{" "}
            <time datetime={formatLibraryIsoDate(publishedAt)}>{formatLibraryDate(publishedAt)}</time>
          </p>
        ) : null
      }
    </header>

    <RecentClientReadingFeaturedSpread publication={publication} baseUrl={base} />

    <section class="rcr-reading__summary" aria-labelledby="reading-summary-heading">
      <h2 id="reading-summary-heading">Summary</h2>
      <p>{publication.summary}</p>
    </section>

    <article class="rcr-reading__body article-prose">
      <div class="rcr-reading__section rcr-reading__section--reading">
        <Fragment set:html={readingHtml} />
      </div>
      <RecentClientReadingSpreadGallery publication={publication} baseUrl={base} />
    </article>

    <RecentClientReadingMetaPanel publication={publication} />

    {
      pdfHref ? (
        <section class="rcr-reading__download" aria-labelledby="download-heading">
          <h2 id="download-heading" class="visually-hidden">Download</h2>
          <a class="ask-leilia-portfolio__cta" href={pdfHref}>
            Download Complete PDF
          </a>
        </section>
      ) : null
    }

    <RecentClientReadingContinueExploring publications={relatedPublications} />

    <section class="rcr-reading__cta-copy" aria-labelledby="reading-cta-heading">
      <h2 id="reading-cta-heading">Ready to explore your own question?</h2>
      <p>
        Whether you're seeking clarity on a single decision or guidance through a more complex
        situation, I'd be honoured to prepare a written reading for you.
      </p>
    </section>

    <AskLeiliaPricingGrid readings={ASK_LEILIA_READINGS} buttonLabel="Request Reading" />

    <p class="rcr-reading__back">
      <a href={READING_LIBRARY_HUB_PATH}>Back to Reading Library</a>
    </p>
  </main>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
