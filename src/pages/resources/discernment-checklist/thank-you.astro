---
/**
 * Temporary delivery page. Replace the public resource-page direct download with
 * an email delivery path when Discernment lead-magnet automation exists.
 * PDF: public/downloads/discernment-checklist.pdf
 */
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { siteBase } from "../../../lib/site";

const title = "Your Discernment Checklist | Tides of Knowing";
const description =
  "Download The Discernment Checklist, a practical tarot reader's guide for cleaner questions, clearer card weight, and stronger reading closure.";
const ogUrl = new URL("/resources/discernment-checklist/thank-you/", siteBase(Astro)).href;
const pdfHref = "/downloads/discernment-checklist.pdf";
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={ogUrl}
  tdcPlacement="none"
  metaRobots="noindex, nofollow"
>
  <article class="tok-resource-thanks page-inner">
    <header class="tok-resource-thanks__hero">
      <p class="tok-resource-thanks__eyebrow">Discernment resource</p>
      <h1 class="tok-resource-thanks__title">Your Discernment Checklist</h1>
    </header>

    <div class="tok-resource-thanks__body">
      <p class="tok-resource-thanks__p">
        The Discernment Checklist is available below. It includes 21 questions for clarifying the
        right question, recognising which cards are carrying the answer, and knowing when a tarot
        reading is complete.
      </p>
      <p class="tok-resource-thanks__actions">
        <a
          class="tok-resource-thanks__dl"
          href={pdfHref}
          download="discernment-checklist.pdf"
        >
          Download the checklist
        </a>
      </p>
      <p class="tok-resource-thanks__p tok-resource-thanks__p--muted">
        For the full context behind the checklist, read{" "}
        <a href="/series/the-discernment-series/">The Discernment Series</a>.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .tok-resource-thanks {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 40rem;
  }

  .tok-resource-thanks__hero {
    margin-bottom: 1.35rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
  }

  .tok-resource-thanks__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-compact);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .tok-resource-thanks__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.65rem, 3.5vw, 2rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--tok-water);
  }

  .tok-resource-thanks__p {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-dark);
  }

  .tok-resource-thanks__p--muted {
    margin-bottom: 0;
    color: color-mix(in srgb, var(--tok-text-dark) 82%, transparent);
    font-size: 0.98rem;
  }

  .tok-resource-thanks__actions {
    margin: 0 0 1.15rem;
  }

  .tok-resource-thanks__dl {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.35rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-meta);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-water);
    border: 2px solid var(--tok-gold);
    border-radius: var(--radius-2);
    transition:
      background var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }

  .tok-resource-thanks__dl:hover {
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
  }

  .tok-resource-thanks__dl:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 3px;
  }
</style>
