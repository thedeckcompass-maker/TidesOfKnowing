---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteBase } from "../lib/site";

const tdcUrl = "https://www.thedeckcompass.com/";
const title = "Practice with The Deck Compass | Tides of Knowing";
const description =
  "The Deck Compass is a live practice environment where readers and seekers meet, practise readings, and use guided journaling to reinforce the COMPASS Method.";
const ogUrl = new URL("/practice/", siteBase(Astro)).href;
---

<BaseLayout title={title} description={description} ogUrl={ogUrl}>
  <article class="practice page-inner">
    <header class="practice__hero">
      <h1 class="practice__h1">Where symbolic perception becomes practice.</h1>
      <p class="practice__lede">
        The Deck Compass is a live practice environment for readers and seekers who want to move beyond memorised meanings and strengthen the habits that make readings hold together.
      </p>
      <p class="practice__cta-row">
        <a class="practice__cta" href={tdcUrl}>Continue to The Deck Compass</a>
      </p>
      <p class="practice__support">
        A companion practice platform to Tides of Knowing and the COMPASS Method.
      </p>
    </header>

    <section class="practice__section" aria-labelledby="practice-why-heading">
      <h2 id="practice-why-heading" class="practice__h2">Why Practice Matters</h2>
      <p class="practice__p">
        Reading changes when it happens under live conditions. It is one thing to understand a method in theory. It is another to notice what appears, stay with it, and reflect on what happened afterwards.
      </p>
      <p class="practice__pull">
        Most readers accumulate meanings. Very few develop perception under live conditions.
      </p>
    </section>

    <section class="practice__section" aria-labelledby="practice-inside-heading">
      <h2 id="practice-inside-heading" class="practice__h2">What Happens Inside</h2>
      <div class="practice__cards">
        <div class="practice__card">
          <h3 class="practice__card-label">Meet</h3>
          <p class="practice__card-text">
            Readers and seekers connect for practice readings.
          </p>
        </div>
        <div class="practice__card">
          <h3 class="practice__card-label">Read</h3>
          <p class="practice__card-text">
            Sessions give the method a live symbolic field.
          </p>
        </div>
        <div class="practice__card">
          <h3 class="practice__card-label">Reflect</h3>
          <p class="practice__card-text">
            Guided journaling helps you notice what occurred.
          </p>
        </div>
        <div class="practice__card">
          <h3 class="practice__card-label">Reinforce</h3>
          <p class="practice__card-text">
            Repeated practice strengthens the habits behind clearer interpretation.
          </p>
        </div>
      </div>
    </section>

    <section class="practice__section" aria-labelledby="practice-compass-heading">
      <h2 id="practice-compass-heading" class="practice__h2">How It Connects to COMPASS</h2>
      <ul class="practice__method-lines">
        <li class="practice__method-line">COMPASS gives the method.</li>
        <li class="practice__method-line">The tools give controlled practice.</li>
        <li class="practice__method-line">
          The Deck Compass gives repetition, reflection, and live conditions.
        </li>
      </ul>
    </section>

    <section class="practice__section" aria-labelledby="practice-for-heading">
      <h2 id="practice-for-heading" class="practice__h2">Who It Is For</h2>
      <div class="practice__audience">
        <div class="practice__audience-col">
          <h3 class="practice__audience-title">For readers who:</h3>
          <ul class="practice__list">
            <li>know meanings but lose the thread</li>
            <li>want to practise without performance pressure</li>
            <li>need repetition to develop confidence</li>
            <li>want to strengthen perception before explanation</li>
            <li>are ready to move from insight into habit</li>
          </ul>
        </div>
        <div class="practice__audience-col">
          <h3 class="practice__audience-title">For seekers who:</h3>
          <ul class="practice__list">
            <li>want thoughtful readings</li>
            <li>are open to reflective dialogue</li>
            <li>want to participate in a more conscious reading environment</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="practice__section practice__section--final" aria-labelledby="practice-final-heading">
      <h2 id="practice-final-heading" class="practice__visually-hidden">Continue to The Deck Compass</h2>
      <p class="practice__cta-row practice__cta-row--final">
        <a class="practice__cta" href={tdcUrl}>Continue to The Deck Compass</a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .practice {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 48rem;
    margin-inline: auto;
  }

  .practice__hero {
    padding-bottom: clamp(2rem, 5vw, 2.75rem);
    margin-bottom: clamp(2rem, 5vw, 2.75rem);
    border-bottom: 1px solid var(--tok-border-light);
  }

  .practice__h1 {
    margin: 0 0 1rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.8vw, 2.75rem);
    line-height: 1.12;
    color: var(--tok-teal-dim);
  }

  .practice__lede {
    margin: 0 0 1.35rem;
    max-width: 40rem;
    font-size: 1.06rem;
    line-height: 1.75;
    color: var(--tok-text-dark);
  }

  .practice__cta-row {
    margin: 0 0 1rem;
  }

  .practice__cta-row--final {
    margin-bottom: 0;
  }

  .practice__cta {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--tok-teal);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  .practice__cta:hover {
    color: var(--tok-teal-dim);
  }

  .practice__support {
    margin: 0;
    max-width: 36rem;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--tok-text-muted);
  }

  .practice__section {
    margin-top: clamp(2.25rem, 5vw, 3rem);
  }

  .practice__section:first-of-type {
    margin-top: 0;
  }

  .practice__section--final {
    margin-top: clamp(2.75rem, 6vw, 3.5rem);
    padding-top: clamp(1.75rem, 4vw, 2.25rem);
    border-top: 1px solid var(--tok-border-light);
  }

  .practice__h2 {
    margin: 0 0 1rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.8vw, 1.65rem);
    font-weight: 600;
    font-style: normal;
    line-height: 1.25;
    color: var(--tok-water);
  }

  .practice__p {
    margin: 0 0 1.1rem;
    font-size: 1.06rem;
    line-height: 1.75;
    color: var(--tok-text-dark);
  }

  .practice__pull {
    margin: 0;
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(1.15rem, 2.4vw, 1.35rem);
    line-height: 1.55;
    color: var(--tok-water);
    padding-left: 1rem;
    border-left: 3px solid var(--tok-gold);
  }

  .practice__cards {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .practice__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.1rem;
    }
  }

  .practice__card {
    padding: 1.1rem 1.15rem 1.05rem;
    background: var(--tok-surface-reading-soft);
    border: 1px solid var(--tok-border-light);
    border-radius: 0.2rem;
    box-shadow: var(--shadow-sm);
  }

  .practice__card-label {
    margin: 0 0 0.45rem;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--tok-teal-dim);
  }

  .practice__card-text {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--tok-text-dark);
  }

  .practice__method-lines {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .practice__method-line {
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.65;
    color: var(--tok-text-dark);
    padding: 0.65rem 0.85rem 0.65rem 1rem;
    border-left: 3px solid color-mix(in srgb, var(--tok-teal) 55%, transparent);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 65%, transparent);
  }

  .practice__audience {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2rem);
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .practice__audience {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }
  }

  .practice__audience-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .practice__list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 1.02rem;
    line-height: 1.68;
    color: var(--tok-text-dark);
  }

  .practice__list li {
    margin-bottom: 0.35rem;
  }

  .practice__list li:last-child {
    margin-bottom: 0;
  }

  .practice__visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
