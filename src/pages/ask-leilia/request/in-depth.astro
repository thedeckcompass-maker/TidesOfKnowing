---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AskLeiliaRequestForm from "../../../components/ask-leilia/AskLeiliaRequestForm.astro";
import AskLeiliaRequestShell from "../../../components/ask-leilia/AskLeiliaRequestShell.astro";
import { ASK_LEILIA_DELIVERABLES, ASK_LEILIA_PUBLIC_BRAND } from "../../../data/askLeilia";

export const prerender = false;

const submitted = Astro.url.searchParams.get("submitted") === "true";
const paymentCancelled = Astro.url.searchParams.get("payment") === "cancelled";
---

<BaseLayout
  title="Request In-Depth Reading | Ask Leilia"
  description="Request an In-Depth Reading from Ask Leilia for a complex situation, connected concerns, or a decision with more than one layer. Written PDF with spread photographs — no audio or video."
  metaAuthor={ASK_LEILIA_PUBLIC_BRAND}
  metaRobots="noindex, nofollow"
>
  <main class="ask-request page-inner">
    <AskLeiliaRequestShell
      title="In-Depth Reading"
      intro={[
        "Tell me about the complex situation, decision, or connected concerns you want explored. You do not need to reduce everything to one perfectly phrased question. Include the context, the people or choices involved, and what feels most important or uncertain.",
        "This reading can follow several connected questions and explore different areas of life where they form part of the same situation. It is not limited to two areas, and it is not an unlimited bundle of unrelated questions.",
        "After you submit, you will be taken to secure payment to complete your booking.",
      ]}
      summaryItems={[
        "In-Depth Reading",
        ...ASK_LEILIA_DELIVERABLES["in-depth"],
        "Payment follows",
      ]}
      paymentCancelled={paymentCancelled}
      submitted={submitted}
    >
      <AskLeiliaRequestForm readingType="in-depth" />
    </AskLeiliaRequestShell>
  </main>
</BaseLayout>

<style>
  .ask-request {
    position: relative;
    isolation: isolate;
    max-width: 52rem;
    padding: clamp(0.5rem, 2.5vw, 1.25rem) 0 clamp(2.25rem, 6vw, 3.75rem);
  }

  .ask-request::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 50%;
    z-index: -1;
    width: min(68rem, 100vw);
    height: min(22rem, 48vw);
    border-radius: var(--radius-promo);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--tok-surface-reading) 92%, transparent),
        color-mix(in srgb, var(--tok-surface-reading) 62%, transparent)
      ),
      url("/images/articles/discernment-series/too-many-tarot-cards-hero-v2.png") center right / cover
        no-repeat;
    opacity: 0.12;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .ask-request__confirmation,
  .ask-request-form-wrap :global(.ask-request-form) {
    margin-top: clamp(0.6rem, 2vw, 0.9rem);
    padding: clamp(0.65rem, 2.25vw, 0.95rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }
</style>
