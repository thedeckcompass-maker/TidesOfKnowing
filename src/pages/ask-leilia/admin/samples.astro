---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AuthorisedSampleForm from "../../../components/ask-leilia/AuthorisedSampleForm.astro";
import { isAdminProfile } from "../../../lib/community/auth";
import { createCommunityServiceClient } from "../../../lib/community/supabaseServer";
import { ASK_LEILIA_PUBLIC_BRAND } from "../../../data/askLeilia";
import {
  formatLibraryDate,
  getReadingLibraryPath,
  getAuthorisedSamplePublications,
} from "../../../lib/readingLibrary";

export const prerender = false;

if (!Astro.locals.user) {
  return Astro.redirect("/auth/register/", 303);
}

if (!isAdminProfile(Astro.locals.profile)) {
  return Astro.redirect("/ask-leilia/", 302);
}

const service = createCommunityServiceClient(Astro.locals);
const samples = await getAuthorisedSamplePublications(service);

// No-JS fallback flags (the primary flow uses fetch and never reloads).
const saved = Astro.url.searchParams.get("sample_saved") === "1";
const errorMessage = Astro.url.searchParams.get("sample_error")?.trim() ?? "";
---

<BaseLayout
  title="Authorised Sample Readings | Administration"
  description="Create and edit authorised historical sample readings for the Reading Library."
  metaAuthor={ASK_LEILIA_PUBLIC_BRAND}
  metaRobots="noindex, nofollow"
>
  <main class="rls-admin page-inner">
    <header class="rls-admin__head">
      <p class="rls-admin__kicker">Ask Leilia · Reading Library</p>
      <h1>Authorised sample readings</h1>
      <p class="rls-admin__lede">
        Publish historical readings that were completed outside the current Ask Leilia order
        system. These are separate from request-linked readings and are never attached to a fake
        order. A reading can be saved as a draft or published directly once its private PDF is
        uploaded and consent has been confirmed.
      </p>
      <p class="rls-admin__nav">
        <a href="/ask-leilia/admin/">Reading requests</a>
        <span aria-hidden="true">·</span>
        <a href="/recent-client-readings/">Public Reading Library</a>
      </p>
      {saved ? <p class="rls-admin__notice" role="status">Authorised sample saved.</p> : null}
      {
        errorMessage ? (
          <p class="rls-admin__notice rls-admin__notice--error" role="alert">{errorMessage}</p>
        ) : null
      }
    </header>

    <section class="rls-admin__create" aria-label="Add a new authorised sample">
      <h2>Add a new authorised sample</h2>
      <AuthorisedSampleForm
        mode="create"
        action="/api/ask-leilia/reading-library/samples/new/"
        sample={null}
      />
    </section>

    <section class="rls-admin__list" aria-label="Saved authorised samples">
      <h2>Saved readings ({samples.length})</h2>
      {samples.length === 0 ? <p class="rls-admin__empty">No authorised samples yet.</p> : null}

      {
        samples.map((sample) => (
          <article class="rls-card" data-sample-id={sample.id}>
            <div class="rls-card__row">
              <div class="rls-card__meta">
                <h3 class="rls-card__title">{sample.title}</h3>
                <p class="rls-card__facts">
                  <span>{sample.sampleClientDisplayName || "No name"}</span>
                  <span aria-hidden="true">·</span>
                  <span>{sample.readingType}</span>
                  <span aria-hidden="true">·</span>
                  <span>Updated {formatLibraryDate(sample.updatedAt)}</span>
                </p>
                <p class="rls-card__badges">
                  <span class={`rls-badge ${sample.isPublished ? "rls-badge--published" : "rls-badge--draft"}`}>
                    {sample.isPublished ? "Published" : "Draft"}
                  </span>
                  <span class={`rls-badge ${sample.samplePdfStoragePath ? "rls-badge--ok" : "rls-badge--warn"}`}>
                    {sample.samplePdfStoragePath ? "Private PDF uploaded" : "No PDF"}
                  </span>
                  <span class={`rls-badge ${sample.sampleConsentConfirmedAt ? "rls-badge--ok" : "rls-badge--warn"}`}>
                    {sample.sampleConsentConfirmedAt ? "Consent confirmed" : "Consent not confirmed"}
                  </span>
                </p>
              </div>
              <div class="rls-card__actions">
                <button
                  type="button"
                  class="rls-btn rls-btn--edit"
                  data-edit-toggle={sample.id}
                  aria-expanded="false"
                  aria-controls={`edit-${sample.id}`}
                >
                  Edit
                </button>
                {
                  sample.isPublished ? (
                    <a class="rls-btn rls-btn--view" href={getReadingLibraryPath(sample.slug)}>
                      View published reading
                    </a>
                  ) : null
                }
              </div>
            </div>

            <div class="rls-card__edit" id={`edit-${sample.id}`} hidden>
              <AuthorisedSampleForm
                mode="edit"
                action={`/api/ask-leilia/reading-library/samples/${sample.id}/`}
                sample={sample}
              />
            </div>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

<script>
  function setLoading(form: HTMLFormElement, loading: boolean, submitter?: HTMLButtonElement) {
    const buttons = form.querySelectorAll<HTMLButtonElement>("button[type=submit]");
    buttons.forEach((btn) => {
      btn.disabled = loading;
      const def = btn.getAttribute("data-label-default");
      const load = btn.getAttribute("data-label-loading");
      if (!def || !load) return;
      if (loading && btn === submitter) {
        btn.textContent = load;
      } else if (!loading) {
        btn.textContent = def;
      }
    });
  }

  function showBanner(
    form: HTMLFormElement,
    kind: "success" | "error",
    message: string,
    links: { label: string; href: string }[] = [],
  ) {
    const banner = form.querySelector<HTMLElement>("[data-banner]");
    if (!banner) return;
    banner.hidden = false;
    banner.className = `rls-banner rls-banner--${kind}`;
    banner.textContent = message;
    for (const link of links) {
      const a = document.createElement("a");
      a.href = link.href;
      a.textContent = link.label;
      a.className = "rls-banner__link";
      banner.appendChild(a);
    }
    banner.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  async function submitForm(form: HTMLFormElement, submitter: HTMLButtonElement) {
    const intent = submitter.value === "publish" ? "publish" : "draft";
    const formData = new FormData(form);
    formData.set("intent", intent);

    setLoading(form, true, submitter);
    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      const data = await res.json().catch(() => ({ ok: false, error: "Unexpected server response." }));

      if (res.ok && data.ok) {
        const links: { label: string; href: string }[] = [];
        if (data.viewUrl) links.push({ label: "View published reading", href: data.viewUrl });
        // Once created, the form must edit the saved record (no duplicate on re-save).
        if (form.dataset.mode === "create" && data.editAction) {
          form.setAttribute("action", data.editAction);
          form.dataset.mode = "edit";
          form.dataset.id = data.id;
          links.push({ label: "Edit saved draft", href: "#" });
        }
        showBanner(
          form,
          "success",
          data.published ? "Reading published successfully. " : "Draft saved successfully. ",
          links,
        );
      } else {
        showBanner(form, "error", data.error || "Something went wrong. Your entries have been kept.");
      }
    } catch {
      showBanner(form, "error", "Network error. Your entries have been kept, please try again.");
    } finally {
      setLoading(form, false);
    }
  }

  document.querySelectorAll<HTMLFormElement>(".rls-sample-form").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const submitter = (event as SubmitEvent).submitter as HTMLButtonElement | null;
      if (!submitter || submitter.type !== "submit") return;
      void submitForm(form, submitter);
    });
  });

  // Expand exactly one saved reading for editing at a time.
  document.querySelectorAll<HTMLButtonElement>("[data-edit-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-edit-toggle");
      const panel = document.getElementById(`edit-${id}`);
      if (!panel) return;
      const willOpen = panel.hidden;
      document.querySelectorAll<HTMLElement>(".rls-card__edit").forEach((p) => (p.hidden = true));
      document
        .querySelectorAll<HTMLButtonElement>("[data-edit-toggle]")
        .forEach((b) => b.setAttribute("aria-expanded", "false"));
      panel.hidden = !willOpen;
      btn.setAttribute("aria-expanded", String(willOpen));
      if (willOpen) panel.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>

<style is:global>
  /* ── Authorised sample admin (scoped by rls- prefix) ───────────────────── */
  .rls-admin {
    max-width: 1180px;
    margin-inline: auto;
    padding: clamp(1.5rem, 5vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    color: var(--tok-text-dark);
  }
  .rls-admin__head {
    margin-bottom: 1.75rem;
  }
  .rls-admin__kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--tok-type-meta);
    font-weight: 700;
    color: var(--tok-gold-deep);
    margin: 0 0 0.35rem;
  }
  .rls-admin h1 {
    font-family: var(--font-heading);
    color: var(--tok-text-dark);
    margin: 0 0 0.75rem;
  }
  .rls-admin__lede {
    max-width: 62ch;
    color: var(--tok-text-muted);
    line-height: 1.6;
    margin: 0 0 0.85rem;
  }
  .rls-admin__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0;
    font-size: 0.9rem;
  }
  .rls-admin__nav a {
    color: var(--tok-water);
    font-weight: 600;
  }
  .rls-admin__notice {
    margin: 1rem 0 0;
    padding: 0.85rem 1.1rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 40%, transparent);
    background: color-mix(in srgb, var(--tok-gold) 14%, transparent);
    color: var(--tok-text-dark);
  }
  .rls-admin__notice--error {
    border-color: color-mix(in srgb, #b42318 45%, transparent);
    background: color-mix(in srgb, #b42318 12%, transparent);
    color: #7a271a;
  }

  /* ── Section panels ────────────────────────────────────────────────────── */
  .rls-admin__create {
    margin-top: 1.5rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-lg);
    background: var(--tok-surface-reading-soft);
    box-shadow: var(--shadow-sm);
  }
  .rls-admin__create > h2,
  .rls-admin__list > h2 {
    font-family: var(--font-heading);
    color: var(--tok-text-dark);
    font-size: 1.4rem;
    margin: 0 0 1.1rem;
  }
  .rls-admin__list {
    margin-top: 2.5rem;
  }
  .rls-admin__empty {
    color: var(--tok-text-muted);
    padding: 1.25rem 0;
  }

  /* ── Form layout ───────────────────────────────────────────────────────── */
  .rls-sample-form {
    display: grid;
    gap: 1.5rem;
  }
  .rls-section {
    margin: 0;
    min-width: 0;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-md);
    padding: clamp(1rem, 2.5vw, 1.5rem);
    background: color-mix(in srgb, var(--tok-surface-reading) 55%, transparent);
  }
  .rls-section--publish {
    border-color: color-mix(in srgb, var(--tok-teal) 45%, transparent);
    background: color-mix(in srgb, var(--tok-teal) 8%, transparent);
  }
  .rls-section__title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--tok-text-dark);
    padding: 0 0.4rem;
    margin-bottom: 0.75rem;
  }

  .rls-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.15rem 1.35rem;
  }
  .rls-col-6 { grid-column: span 6; }
  .rls-col-4 { grid-column: span 4; }
  .rls-col-3 { grid-column: span 3; }
  .rls-col-2 { grid-column: span 2; }

  .rls-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }
  .rls-field > label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--tok-text-dark);
    line-height: 1.3;
  }

  .rls-sample-form input:not([type="checkbox"]):not([type="file"]),
  .rls-sample-form select,
  .rls-sample-form textarea {
    width: 100%;
    box-sizing: border-box;
    min-height: 44px;
    padding: 0.65rem 0.75rem;
    font: inherit;
    font-size: 0.95rem;
    color: var(--tok-text-dark);
    background: var(--tok-surface-reading);
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    transition:
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
  }
  .rls-sample-form input:not([type="checkbox"]):not([type="file"]):focus-visible,
  .rls-sample-form select:focus-visible,
  .rls-sample-form textarea:focus-visible {
    outline: none;
    border-color: var(--tok-teal);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--tok-teal) 32%, transparent);
  }
  .rls-sample-form textarea {
    resize: vertical;
    line-height: 1.55;
  }
  .rls-ta--q { min-height: 100px; }
  .rls-ta--scope { min-height: 100px; }
  .rls-ta--note { min-height: 120px; }
  .rls-ta--excerpt { min-height: 110px; }
  .rls-ta--seo { min-height: 100px; }
  .rls-ta--body { min-height: 500px; }
  .rls-ta--images { min-height: 100px; }

  .rls-sample-form input[type="file"] {
    width: 100%;
    box-sizing: border-box;
    padding: 0.6rem 0.75rem;
    font: inherit;
    font-size: 0.85rem;
    color: var(--tok-text-muted);
    background: var(--tok-surface-reading);
    border: 1px dashed color-mix(in srgb, var(--tok-border-light) 100%, transparent);
    border-radius: var(--radius-control);
  }
  .rls-sample-form input[type="file"]:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--tok-teal) 55%, transparent);
    outline-offset: 2px;
  }

  /* ── Checkboxes ────────────────────────────────────────────────────────── */
  .rls-checks {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 0.25rem 0;
  }
  .rls-check {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .rls-check input[type="checkbox"] {
    width: 1.35rem;
    height: 1.35rem;
    flex: none;
    margin: 0;
    accent-color: var(--tok-teal);
    cursor: pointer;
  }
  .rls-check label {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--tok-text-dark);
    cursor: pointer;
    line-height: 1.35;
  }

  /* ── Private PDF status ────────────────────────────────────────────────── */
  .rls-pdf-status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-control);
    border: 1px solid transparent;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .rls-pdf-status__dot {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    flex: none;
  }
  .rls-pdf-status.is-attached {
    background: color-mix(in srgb, #067647 14%, transparent);
    border-color: color-mix(in srgb, #067647 40%, transparent);
    color: #05603a;
  }
  .rls-pdf-status.is-attached .rls-pdf-status__dot { background: #067647; }
  .rls-pdf-status.is-missing {
    background: color-mix(in srgb, #b42318 12%, transparent);
    border-color: color-mix(in srgb, #b42318 40%, transparent);
    color: #7a271a;
  }
  .rls-pdf-status.is-missing .rls-pdf-status__dot { background: #b42318; }

  .rls-hint {
    margin: 0.6rem 0 0;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--tok-text-muted);
  }
  .rls-section--publish .rls-hint {
    margin: 0 0 1rem;
  }

  /* ── Buttons ───────────────────────────────────────────────────────────── */
  .rls-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }
  .rls-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.7rem 1.5rem;
    border: 1px solid transparent;
    border-radius: var(--radius-control);
    font: inherit;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.1;
    cursor: pointer;
    text-decoration: none;
    transition:
      background var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }
  .rls-btn:hover {
    transform: translateY(-1px);
  }
  .rls-btn:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--tok-teal) 55%, transparent);
    outline-offset: 2px;
  }
  .rls-btn:disabled {
    opacity: 0.6;
    cursor: progress;
    transform: none;
  }
  .rls-btn--publish {
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-size: 1rem;
    padding-inline: 1.85rem;
    box-shadow: var(--shadow-sm);
  }
  .rls-btn--publish:hover {
    background: color-mix(in srgb, var(--tok-btn-filled-bg) 86%, #000);
  }
  .rls-btn--draft,
  .rls-btn--view {
    background: transparent;
    color: var(--tok-text-dark);
    border-color: var(--tok-border-light);
  }
  .rls-btn--draft:hover,
  .rls-btn--view:hover {
    background: color-mix(in srgb, var(--tok-text-dark) 8%, transparent);
  }
  .rls-btn--edit {
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
  }
  .rls-btn--edit:hover {
    background: color-mix(in srgb, var(--tok-btn-filled-bg) 86%, #000);
  }

  /* ── Saved reading cards ───────────────────────────────────────────────── */
  .rls-card {
    margin-top: 1rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-md);
    background: var(--tok-surface-reading-soft);
    box-shadow: var(--shadow-sm);
  }
  .rls-card__row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
  }
  .rls-card__meta {
    min-width: 0;
    flex: 1 1 20rem;
  }
  .rls-card__title {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--tok-text-dark);
  }
  .rls-card__facts {
    margin: 0 0 0.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--tok-text-muted);
  }
  .rls-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
  }
  .rls-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }
  .rls-badge--published,
  .rls-badge--ok {
    background: color-mix(in srgb, #067647 16%, transparent);
    color: #05603a;
    border-color: color-mix(in srgb, #067647 35%, transparent);
  }
  .rls-badge--draft {
    background: color-mix(in srgb, var(--tok-gold) 20%, transparent);
    color: var(--tok-gold-deep);
    border-color: color-mix(in srgb, var(--tok-gold) 45%, transparent);
  }
  .rls-badge--warn {
    background: color-mix(in srgb, #b42318 14%, transparent);
    color: #7a271a;
    border-color: color-mix(in srgb, #b42318 35%, transparent);
  }
  .rls-card__actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .rls-card__edit {
    padding: 0 1.25rem 1.5rem;
    border-top: 1px solid var(--tok-border-light);
  }
  .rls-card__edit .rls-sample-form {
    margin-top: 1.25rem;
  }

  /* ── Result banner ─────────────────────────────────────────────────────── */
  .rls-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    border: 1px solid transparent;
  }
  .rls-banner::before {
    font-weight: 900;
    font-size: 1.15rem;
    line-height: 1;
  }
  .rls-banner--success {
    background: color-mix(in srgb, #067647 14%, transparent);
    border-color: color-mix(in srgb, #067647 45%, transparent);
    color: #05603a;
  }
  .rls-banner--success::before {
    content: "\2713";
  }
  .rls-banner--error {
    background: color-mix(in srgb, #b42318 12%, transparent);
    border-color: color-mix(in srgb, #b42318 45%, transparent);
    color: #7a271a;
  }
  .rls-banner--error::before {
    content: "\26A0";
  }
  .rls-banner__link {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    margin-left: 0.25rem;
    padding: 0.4rem 1rem;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid currentColor;
    border-radius: var(--radius-control);
    background: rgba(255, 255, 255, 0.35);
    color: inherit;
  }
  .rls-banner__link:hover {
    background: rgba(255, 255, 255, 0.55);
  }
  .rls-banner__link:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--tok-teal) 55%, transparent);
    outline-offset: 2px;
  }

  /* ── Responsive: stack to one column on tablet/mobile ──────────────────── */
  @media (max-width: 768px) {
    .rls-grid {
      grid-template-columns: 1fr;
    }
    .rls-col-6,
    .rls-col-4,
    .rls-col-3,
    .rls-col-2 {
      grid-column: span 1;
    }
    .rls-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .rls-actions .rls-btn {
      width: 100%;
    }
