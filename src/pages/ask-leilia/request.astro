---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ASK_LEILIA_STATUSES } from "../../lib/ask-leilia/types";

export const prerender = false;

const submitted = Astro.url.searchParams.get("submitted") === "true";
const paymentCancelled = Astro.url.searchParams.get("payment") === "cancelled";
---

<BaseLayout
  title="Request Your Reflection"
  description="Share your Ask Leilia question before completing your booking."
  metaRobots="noindex, nofollow"
>
  <main class="ask-request page-inner">
    <section class="ask-request__head" aria-labelledby="request-heading">
      <p class="ask-request__kicker">Ask Leilia</p>
      <h1 id="request-heading">Request Your Reflection</h1>
      <p>Begin by sharing the question you would like reflected through the cards.</p>
      <p>After you submit this form, you will be taken to secure payment to complete your booking.</p>
      <ul class="ask-request__summary" aria-label="Ask Leilia request summary">
        <li>One question</li>
        <li>Payment follows</li>
        <li>Delivered within 48 hours</li>
        <li>Optional card photo upload</li>
      </ul>
    </section>

    {
      paymentCancelled ? (
        <section class="ask-request__confirmation" aria-live="polite">
          <h2>Payment not completed.</h2>
          <p>
            Your payment was not completed. Your question has not been booked yet. You can
            review your details and try again when ready.
          </p>
        </section>
      ) : null
    }

    {
      submitted ? (
        <section class="ask-request__confirmation" aria-live="polite">
          <h2>Thank you.</h2>
          <p>Your request has been received.</p>
          <p>You will receive your written reflection within 48 hours.</p>
        </section>
      ) : null
    }

    <form class="ask-request-form" method="post" action="/api/ask-leilia/checkout" enctype="multipart/form-data">
      <fieldset>
        <legend>Your details</legend>

        <label>
          Name
          <input name="name" type="text" autocomplete="name" required />
        </label>

        <label>
          Email
          <input name="email" type="email" autocomplete="email" required />
        </label>
      </fieldset>

      <fieldset>
        <legend>Your question</legend>

        <label>
          One Question
          <textarea
            name="question"
            rows="6"
            maxlength="2000"
            required
            placeholder="Share the question you would like reflected through the cards."
          ></textarea>
        </label>

        <label>
          Additional context
          <textarea
            name="context"
            rows="6"
            maxlength="5000"
            placeholder="Optional: add any context that would help the reflection stay grounded."
          ></textarea>
        </label>
      </fieldset>

      <fieldset class="ask-request-form__fieldset--compact">
        <legend>Card Preference</legend>

        <label class="ask-request-form__radio">
          <input type="radio" name="cardPreference" value="pull_for_me" required />
          <span>Please pull the cards for me</span>
        </label>

        <label class="ask-request-form__radio">
          <input type="radio" name="cardPreference" value="own_cards_attached" required />
          <span>I have attached my own cards</span>
        </label>

        <label class="ask-request-form__upload">
          Upload image of cards
          <input name="cardImage" type="file" accept="image/png,image/jpeg,image/webp" />
        </label>
      </fieldset>

      <div class="ask-request-statuses" aria-label="Future status workflow">
        {ASK_LEILIA_STATUSES.map((status) => <span>{status}</span>)}
      </div>

      <button type="submit">Continue to Payment</button>
    </form>
  </main>
</BaseLayout>

<style>
  .ask-request {
    position: relative;
    isolation: isolate;
    max-width: 52rem;
    padding: clamp(0.5rem, 2.5vw, 1.25rem) 0 clamp(2.25rem, 6vw, 3.75rem);
  }

  .ask-request::before {
    content: "";
    position: absolute;
    inset: 0 auto auto 50%;
    z-index: -1;
    width: min(68rem, 100vw);
    height: min(22rem, 48vw);
    border-radius: var(--radius-promo);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--tok-surface-reading) 92%, transparent),
        color-mix(in srgb, var(--tok-surface-reading) 62%, transparent)
      ),
      url("/images/articles/discernment-series/too-many-tarot-cards-hero-v2.png") center right / cover
        no-repeat;
    opacity: 0.12;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .ask-request__head {
    position: relative;
    max-width: 42rem;
  }

  .ask-request__kicker {
    margin: 0 0 0.25rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .ask-request h1,
  .ask-request__confirmation h2 {
    margin: 0 0 0.35rem;
    font-family: var(--font-accent);
    font-weight: 400;
    color: var(--tok-water);
  }

  .ask-request h1 {
    font-size: clamp(2.4rem, 9vw, 4.8rem);
    line-height: 1.12;
  }

  .ask-request p {
    margin: 0;
    color: var(--tok-text-dark);
    line-height: 1.54;
  }

  .ask-request__head p + p {
    margin-top: 0.16rem;
  }

  .ask-request__summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .ask-request__summary li {
    padding: 0.22rem 0.4rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 28%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 46%, transparent);
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
  }

  .ask-request__confirmation,
  .ask-request-form {
    margin-top: clamp(0.6rem, 2vw, 0.9rem);
    padding: clamp(0.65rem, 2.25vw, 0.95rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .ask-request-form {
    display: grid;
    gap: 0.75rem;
  }

  .ask-request-form fieldset {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0 0 0.7rem;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 22%, transparent);
  }

  .ask-request-form fieldset:last-of-type {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .ask-request-form .ask-request-form__fieldset--compact {
    gap: 0.35rem;
    padding-bottom: 0;
  }

  .ask-request-form legend {
    margin-bottom: 0.35rem;
    font-size: var(--tok-type-meta);
    font-weight: 700;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .ask-request-form label {
    display: grid;
    gap: 0.4rem;
    font-size: var(--tok-type-label);
    font-weight: 700;
    color: var(--tok-text-dark);
  }

  .ask-request-form .ask-request-form__radio {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    font-weight: 600;
    line-height: 1.35;
  }

  .ask-request-form input,
  .ask-request-form textarea {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
    font: inherit;
  }

  .ask-request-form .ask-request-form__radio input[type="radio"] {
    flex: 0 0 auto;
    margin: 0;
    width: auto;
  }

  .ask-request-form .ask-request-form__upload {
    gap: 0.3rem;
    margin-top: 0.2rem;
  }

  .ask-request-form input[type="file"] {
    padding: 0.55rem 0.65rem;
  }

  .ask-request-form textarea {
    line-height: 1.65;
    resize: vertical;
  }

  .ask-request-statuses {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ask-request-statuses span {
    padding: 0.35rem 0.55rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    border-radius: var(--radius-pill);
    font-size: var(--tok-type-meta);
    color: var(--tok-text-muted);
  }

  .ask-request-form button {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }
</style>
