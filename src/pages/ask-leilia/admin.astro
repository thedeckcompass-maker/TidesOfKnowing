---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isAdminProfile } from "../../lib/community/auth";
import { createCommunityServiceClient } from "../../lib/community/supabaseServer";
import {
  ASK_LEILIA_DB_READING_TYPES,
  readingTypeLabel,
} from "../../lib/ask-leilia/readingTypes";
import { cardPreferenceLabel } from "../../lib/ask-leilia/types";
import { ASK_LEILIA_PUBLIC_BRAND } from "../../data/askLeilia";
import {
  adminQueueReturnPath,
  formatCompactDateTimeUtc,
  formatFileSize,
  formatSubmissionDisplayUtc,
  isAskLeiliaRequestArchived,
  parseAskLeiliaAdminSort,
  parseAskLeiliaAdminView,
} from "../../lib/ask-leilia/adminQueue";
import {
  ASK_LEILIA_DELIVERY_METHOD_LABELS,
  ASK_LEILIA_MANUAL_DELIVERY_METHODS,
  ASK_LEILIA_MANUAL_PAYMENT_METHOD_LABELS,
  ASK_LEILIA_MANUAL_PAYMENT_METHODS,
  PRIMARY_ACTION_LABELS,
  deriveAskLeiliaEffectivePaymentState,
  deriveAskLeiliaFulfilmentStatus,
  derivePdfDeliverySummary,
  describeAskLeiliaPaymentSource,
  effectivePaymentLabel,
  fulfilmentStatusLabel,
  isAskLeiliaEffectivelyPaid,
  isAskLeiliaManualPaymentActive,
  primaryActionForRequest,
  rawStripeStatusLabel,
  resolveReviewWorkflowStatus,
  reviewWorkflowStatusLabel,
} from "../../lib/ask-leilia/fulfilment";
import {
  getAskLeiliaDeliveryPdfUrl,
  getAskLeiliaQueueCounts,
  getAskLeiliaRequests,
  getAskLeiliaUploadUrl,
} from "../../lib/ask-leilia/queries";
import type { AskLeiliaDbReadingType } from "../../lib/ask-leilia/readingTypes";
import {
  getLibraryPublicationsByRequestIds,
  normalizeLibrarySlug,
} from "../../lib/readingLibrary";

export const prerender = false;

if (!Astro.locals.user) {
  return Astro.redirect("/auth/register/", 303);
}

if (!isAdminProfile(Astro.locals.profile)) {
  return Astro.redirect("/ask-leilia/", 302);
}

const readingTypeFilterRaw = Astro.url.searchParams.get("reading_type") ?? "all";
const readingTypeFilter =
  readingTypeFilterRaw === "all" ||
  ASK_LEILIA_DB_READING_TYPES.includes(readingTypeFilterRaw as AskLeiliaDbReadingType)
    ? readingTypeFilterRaw
    : "all";
const sortFilter = parseAskLeiliaAdminSort(Astro.url.searchParams.get("sort"));
const viewFilter = parseAskLeiliaAdminView(Astro.url.searchParams.get("view"));
const searchFilter = (Astro.url.searchParams.get("q") ?? "").trim();
const returnTo = adminQueueReturnPath({
  readingType: readingTypeFilter,
  sort: sortFilter,
  view: viewFilter,
  search: searchFilter,
});
const librarySaved = Astro.url.searchParams.get("library_saved") === "1";
const libraryError = Astro.url.searchParams.get("library_error")?.trim() ?? "";
const notice = Astro.url.searchParams.get("notice")?.trim() ?? "";
const errorNotice = Astro.url.searchParams.get("error")?.trim() ?? "";

const service = createCommunityServiceClient(Astro.locals);
const [requests, counts] = await Promise.all([
  getAskLeiliaRequests(service, {
    readingType: readingTypeFilter === "all" ? "all" : (readingTypeFilter as AskLeiliaDbReadingType),
    sort: sortFilter,
    view: viewFilter,
    search: searchFilter,
  }),
  getAskLeiliaQueueCounts(service),
]);
const libraryByRequestId = await getLibraryPublicationsByRequestIds(
  service,
  requests.map((request) => request.id),
);
const rows = await Promise.all(
  requests.map(async (request) => {
    const fulfilment = deriveAskLeiliaFulfilmentStatus(request);
    const review = resolveReviewWorkflowStatus(request);
    const pdfDelivery = derivePdfDeliverySummary(request);
    const paymentState = deriveAskLeiliaEffectivePaymentState(request);
    const effectivelyPaid = isAskLeiliaEffectivelyPaid(request);
    const primaryAction = primaryActionForRequest(request);
    return {
      request,
      fulfilment,
      review,
      pdfDelivery,
      paymentState,
      effectivelyPaid,
      paymentSource: describeAskLeiliaPaymentSource(request),
      rawStripeLabel: rawStripeStatusLabel(request),
      manualPaymentActive: isAskLeiliaManualPaymentActive(request),
      primaryAction,
      imageUrl: await getAskLeiliaUploadUrl(service, request.image_url),
      deliveryPdfUrl: await getAskLeiliaDeliveryPdfUrl(service, request.delivery_pdf_path),
      submission: formatSubmissionDisplayUtc(request.created_at),
      isArchived: isAskLeiliaRequestArchived(request),
    };
  }),
);

const matchLabel =
  rows.length === 1 ? "1 matching reading" : `${rows.length} matching readings`;

const viewTabs: { id: typeof viewFilter; label: string }[] = [
  { id: "active", label: "Active" },
  { id: "unpaid", label: "Unpaid" },
  { id: "paid", label: "Paid" },
  { id: "new", label: "New" },
  { id: "in_progress", label: "In progress" },
  { id: "ready_to_send", label: "Ready to send" },
  { id: "delivered", label: "Delivered" },
  { id: "review_outstanding", label: "Review outstanding" },
  { id: "review_provided", label: "Review provided" },
  { id: "archived", label: "Archived" },
];

const nowLocalValue = new Date().toISOString().slice(0, 16);

function compactPdfLabel(
  pdfDelivery: (typeof rows)[number]["pdfDelivery"],
): string {
  if (pdfDelivery.label === "Sent" || pdfDelivery.label === "Resent" || pdfDelivery.label === "Manually delivered") {
    if (pdfDelivery.at) {
      return `${pdfDelivery.label} · ${formatCompactDateTimeUtc(pdfDelivery.at)}`;
    }
  }
  return pdfDelivery.label;
}
---

<BaseLayout
  title="Ask Leilia Admin | Tides of Knowing"
  description="Ask Leilia reading fulfilment dashboard."
  metaAuthor={ASK_LEILIA_PUBLIC_BRAND}
  metaRobots="noindex, nofollow"
>
  <main class="ask-admin page-inner">
    <header class="ask-admin__head">
      <p class="ask-admin__kicker">Ask Leilia</p>
      <h1>Reading Requests</h1>
      <p class="ask-admin__lede">
        Compact fulfilment queue for every submitted Ask Leilia questionnaire, including unpaid
        Stripe attempts.
      </p>
      <p class="ask-admin__summary" aria-live="polite">
        <span>{counts.unpaid} unpaid</span>
        <span aria-hidden="true"> · </span>
        <span>{counts.new} new</span>
        <span aria-hidden="true"> · </span>
        <span>{counts.in_progress} in progress</span>
        <span aria-hidden="true"> · </span>
        <span>{counts.ready_to_send} ready to send</span>
        <span aria-hidden="true"> · </span>
        <span>{counts.reviews_outstanding} reviews outstanding</span>
      </p>
      <p>
        <a href="/ask-leilia/admin/reviews/">Moderate Ask Leilia reviews</a>
        <span aria-hidden="true"> · </span>
        <a href="/ask-leilia/admin/samples/">Authorised sample readings</a>
      </p>
      {
        notice ? (
          <p class="ask-admin__notice" role="status">{notice}</p>
        ) : null
      }
      {
        errorNotice ? (
          <p class="ask-admin__notice ask-admin__notice--error" role="alert">{errorNotice}</p>
        ) : null
      }
      {
        librarySaved ? (
          <p class="ask-admin__notice" role="status">Reading Library entry saved.</p>
        ) : null
      }
      {
        libraryError ? (
          <p class="ask-admin__notice ask-admin__notice--error" role="alert">{libraryError}</p>
        ) : null
      }
    </header>

    <nav class="ask-admin__views" aria-label="Fulfilment views">
      {
        viewTabs.map((tab) => {
          const href = adminQueueReturnPath({
            readingType: readingTypeFilter,
            sort: sortFilter,
            view: tab.id,
            search: searchFilter,
          });
          return (
            <a
              href={href}
              class:list={["ask-admin__view", viewFilter === tab.id && "ask-admin__view--active"]}
              aria-current={viewFilter === tab.id ? "page" : undefined}
            >
              {tab.label}
            </a>
          );
        })
      }
    </nav>

    <form class="ask-admin__filters" method="get" action="/ask-leilia/admin/">
      <input type="hidden" name="view" value={viewFilter} />
      <label>
        Search client
        <input
          type="search"
          name="q"
          value={searchFilter}
          placeholder="Name or email"
          autocomplete="off"
        />
      </label>
      <label>
        Reading type
        <select name="reading_type">
          <option value="all" selected={readingTypeFilter === "all"}>All reading types</option>
          {
            ASK_LEILIA_DB_READING_TYPES.map((readingType) => (
              <option value={readingType} selected={readingTypeFilter === readingType}>
                {readingTypeLabel(readingType)}
              </option>
            ))
          }
        </select>
      </label>
      <label>
        Sort by submission
        <select name="sort">
          <option value="newest" selected={sortFilter === "newest"}>Newest first</option>
          <option value="oldest" selected={sortFilter === "oldest"}>Oldest first</option>
        </select>
      </label>
      <button type="submit">Apply</button>
    </form>

    <p class="ask-admin__count" aria-live="polite">{matchLabel}</p>

    {
      rows.length > 0 ? (
        <div class="ask-admin__table-wrap">
          <table class="ask-admin-table">
            <thead>
              <tr>
                <th scope="col">Received</th>
                <th scope="col">Client</th>
                <th scope="col">Reading type</th>
                <th scope="col">Payment</th>
                <th scope="col">Fulfilment</th>
                <th scope="col">PDF / delivery</th>
                <th scope="col">Review</th>
                <th scope="col">Action</th>
                <th scope="col"><span class="visually-hidden">Expand</span></th>
              </tr>
            </thead>
            <tbody>
              {rows.map(({
                request,
                fulfilment,
                review,
                pdfDelivery,
                paymentState,
                effectivelyPaid,
                paymentSource,
                rawStripeLabel,
                manualPaymentActive,
                primaryAction,
                imageUrl,
                deliveryPdfUrl,
                submission,
                isArchived,
              }) => {
                const panelId = `ask-admin-panel-${request.id}`;
                const libraryPublication = libraryByRequestId.get(request.id);
                const suggestedSlug = normalizeLibrarySlug(
                  libraryPublication?.slug ??
                    `${readingTypeLabel(request.reading_type)}-${request.id.slice(0, 8)}`,
                );
                const actionHref = `#${panelId}`;

                return (
                  <Fragment>
                    <tr
                      class:list={[
                        "ask-admin-table__row",
                        isArchived && "ask-admin-table__row--archived",
                      ]}
                      data-ask-admin-row={request.id}
                    >
                      <td>
                        <span
                          class="ask-admin-table__when"
                          data-ask-admin-local-time={submission.unavailable ? "" : request.created_at}
                          title={submission.title}
                        >
                          <span data-ask-admin-date>{submission.dateText}</span>
                          {submission.timeText ? (
                            <>
                              <br />
                              <span data-ask-admin-time class="ask-admin-table__muted">
                                {submission.timeText}
                              </span>
                            </>
                          ) : null}
                        </span>
                      </td>
                      <td>
                        <span class="ask-admin-table__name">{request.name}</span>
                        <span class="ask-admin-table__email">{request.email}</span>
                      </td>
                      <td>{readingTypeLabel(request.reading_type)}</td>
                      <td>
                        <span
                          class:list={[
                            "ask-admin-payment",
                            paymentState === "paid"
                              ? "ask-admin-payment--paid"
                              : "ask-admin-payment--unpaid",
                          ]}
                        >
                          <span class="ask-admin-payment__mark" aria-hidden="true">
                            {paymentState === "paid" ? "✓" : "✗"}
                          </span>
                          <span>{effectivePaymentLabel(paymentState)}</span>
                        </span>
                      </td>
                      <td>
                        <span class={`ask-admin-status ask-admin-status--${fulfilment}`}>
                          {fulfilmentStatusLabel(fulfilment)}
                        </span>
                      </td>
                      <td>
                        <span class="ask-admin-table__pdf">{compactPdfLabel(pdfDelivery)}</span>
                      </td>
                      <td>
                        <span class={`ask-admin-review ask-admin-review--${review}`}>
                          {reviewWorkflowStatusLabel(review)}
                        </span>
                      </td>
                      <td>
                        {primaryAction === "mark_paid" ? (
                          <a class="ask-admin-btn ask-admin-btn--primary" href={actionHref} data-ask-admin-expand={request.id}>
                            {PRIMARY_ACTION_LABELS.mark_paid}
                          </a>
                        ) : primaryAction === "start" ? (
                          <form
                            method="post"
                            action={`/api/ask-leilia/requests/${request.id}`}
                            class="ask-admin-inline-form"
                          >
                            <input type="hidden" name="return_to" value={returnTo} />
                            <input type="hidden" name="action" value="start_reading" />
                            <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                              {PRIMARY_ACTION_LABELS.start}
                            </button>
                          </form>
                        ) : primaryAction === "send" ? (
                          <form
                            method="post"
                            action={`/api/ask-leilia/requests/${request.id}`}
                            class="ask-admin-inline-form"
                            onsubmit="return confirm('Email the completed PDF and mark this reading delivered?');"
                          >
                            <input type="hidden" name="return_to" value={returnTo} />
                            <input type="hidden" name="action" value="send_delivery" />
                            <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                              {PRIMARY_ACTION_LABELS.send}
                            </button>
                          </form>
                        ) : primaryAction === "restore" ? (
                          <form
                            method="post"
                            action={`/api/ask-leilia/requests/${request.id}`}
                            class="ask-admin-inline-form"
                          >
                            <input type="hidden" name="return_to" value={returnTo} />
                            <input type="hidden" name="action" value="restore" />
                            <button type="submit" class="ask-admin-btn">
                              {PRIMARY_ACTION_LABELS.restore}
                            </button>
                          </form>
                        ) : primaryAction === "view_review" && request.linked_review_id ? (
                          <a
                            class="ask-admin-btn"
                            href={`/ask-leilia/admin/reviews/?focus=${encodeURIComponent(request.linked_review_id)}`}
                          >
                            {PRIMARY_ACTION_LABELS.view_review}
                          </a>
                        ) : (
                          <a class="ask-admin-btn" href={actionHref} data-ask-admin-expand={request.id}>
                            {PRIMARY_ACTION_LABELS[primaryAction]}
                          </a>
                        )}
                      </td>
                      <td>
                        <button
                          type="button"
                          class="ask-admin-expand"
                          aria-expanded="false"
                          aria-controls={panelId}
                          data-ask-admin-toggle={request.id}
                        >
                          <span class="visually-hidden">Expand reading details</span>
                          <span class="ask-admin-expand__chevron" aria-hidden="true"></span>
                        </button>
                      </td>
                    </tr>
                    <tr class="ask-admin-table__detail" hidden data-ask-admin-detail={request.id}>
                      <td colspan="9">
                        <div id={panelId} class="ask-admin-panel">
                          <div class="ask-admin-panel__grid">
                            <section class="ask-admin-panel__section" aria-labelledby={`brief-${request.id}`}>
                              <h2 id={`brief-${request.id}`}>Reading brief</h2>
                              <dl class="ask-admin-dl">
                                <div>
                                  <dt>Client</dt>
                                  <dd>
                                    {request.name}
                                    <br />
                                    <a href={`mailto:${request.email}`}>{request.email}</a>
                                  </dd>
                                </div>
                                <div>
                                  <dt>Reading type</dt>
                                  <dd>{readingTypeLabel(request.reading_type)}</dd>
                                </div>
                                <div>
                                  <dt>Submitted</dt>
                                  <dd>
                                    <span
                                      data-ask-admin-local-time={
                                        submission.unavailable ? "" : request.created_at
                                      }
                                      title={submission.title}
                                    >
                                      <span data-ask-admin-date>{submission.dateText}</span>
                                      {submission.timeText ? (
                                        <>
                                          <span aria-hidden="true"> · </span>
                                          <span data-ask-admin-time>{submission.timeText}</span>
                                        </>
                                      ) : null}
                                    </span>
                                  </dd>
                                </div>
                                <div class="ask-admin-dl__question">
                                  <dt>Question</dt>
                                  <dd>{request.question}</dd>
                                </div>
                                <div>
                                  <dt>Context</dt>
                                  <dd>{request.context || "No additional context."}</dd>
                                </div>
                                <div>
                                  <dt>Card preference</dt>
                                  <dd>{cardPreferenceLabel(request.card_preference)}</dd>
                                </div>
                                <div>
                                  <dt>Client image</dt>
                                  <dd>
                                    {imageUrl ? (
                                      <a href={imageUrl} target="_blank" rel="noopener noreferrer">
                                        View uploaded image
                                      </a>
                                    ) : (
                                      "No image uploaded."
                                    )}
                                  </dd>
                                </div>
                              </dl>
                            </section>

                            <section class="ask-admin-panel__section" aria-labelledby={`pay-${request.id}`}>
                              <h2 id={`pay-${request.id}`}>Payment</h2>
                              <p>
                                <span
                                  class:list={[
                                    "ask-admin-payment",
                                    paymentState === "paid"
                                      ? "ask-admin-payment--paid"
                                      : "ask-admin-payment--unpaid",
                                  ]}
                                >
                                  <span class="ask-admin-payment__mark" aria-hidden="true">
                                    {paymentState === "paid" ? "✓" : "✗"}
                                  </span>
                                  <span>{effectivePaymentLabel(paymentState)}</span>
                                </span>
                              </p>
                              <p class="ask-admin-meta">{paymentSource}</p>
                              <dl class="ask-admin-dl ask-admin-dl--compact">
                                <div>
                                  <dt>Raw Stripe status</dt>
                                  <dd>{rawStripeLabel}</dd>
                                </div>
                                {request.payment?.stripe_payment_intent ? (
                                  <div>
                                    <dt>Stripe payment intent</dt>
                                    <dd>
                                      <code>{request.payment.stripe_payment_intent}</code>
                                    </dd>
                                  </div>
                                ) : null}
                                {request.payment_exception_reference ? (
                                  <div>
                                    <dt>Exception reference</dt>
                                    <dd>{request.payment_exception_reference}</dd>
                                  </div>
                                ) : null}
                                {manualPaymentActive ? (
                                  <>
                                    <div>
                                      <dt>Manual payment method</dt>
                                      <dd>
                                        {request.manual_payment_method
                                          ? ASK_LEILIA_MANUAL_PAYMENT_METHOD_LABELS[
                                              request.manual_payment_method
                                            ]
                                          : "Recorded"}
                                      </dd>
                                    </div>
                                    {request.manual_payment_recorded_at ? (
                                      <div>
                                        <dt>Manual payment recorded</dt>
                                        <dd>{formatCompactDateTimeUtc(request.manual_payment_recorded_at)}</dd>
                                      </div>
                                    ) : null}
                                    {request.manual_payment_reference ? (
                                      <div>
                                        <dt>Payment reference</dt>
                                        <dd>{request.manual_payment_reference}</dd>
                                      </div>
                                    ) : null}
                                    {request.manual_payment_note ? (
                                      <div>
                                        <dt>Internal note</dt>
                                        <dd>{request.manual_payment_note}</dd>
                                      </div>
                                    ) : null}
                                  </>
                                ) : null}
                                {request.manual_payment_reversed_at ? (
                                  <div>
                                    <dt>Manual payment reversed</dt>
                                    <dd>{formatCompactDateTimeUtc(request.manual_payment_reversed_at)}</dd>
                                  </div>
                                ) : null}
                              </dl>

                              {!effectivelyPaid ? (
                                <form
                                  method="post"
                                  action={`/api/ask-leilia/requests/${request.id}`}
                                  class="ask-admin-form"
                                >
                                  <input type="hidden" name="return_to" value={returnTo} />
                                  <input type="hidden" name="action" value="mark_as_paid" />
                                  <h3>Mark as paid</h3>
                                  <p class="ask-admin-meta">
                                    Record a manual payment without changing the raw Stripe result.
                                  </p>
                                  <label>
                                    Payment method
                                    <select name="manual_payment_method" required>
                                      {ASK_LEILIA_MANUAL_PAYMENT_METHODS.map((method) => (
                                        <option value={method}>
                                          {ASK_LEILIA_MANUAL_PAYMENT_METHOD_LABELS[method]}
                                        </option>
                                      ))}
                                    </select>
                                  </label>
                                  <label>
                                    Payment date and time
                                    <input
                                      type="datetime-local"
                                      name="manual_payment_recorded_at"
                                      value={nowLocalValue}
                                      required
                                    />
                                  </label>
                                  <label>
                                    Optional payment reference
                                    <input type="text" name="manual_payment_reference" maxlength="200" />
                                  </label>
                                  <label>
                                    Optional internal note
                                    <textarea name="manual_payment_note" rows="2" maxlength="2000"></textarea>
                                  </label>
                                  <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                                    Confirm mark as paid
                                  </button>
                                </form>
                              ) : null}

                              {manualPaymentActive ? (
                                <details class="ask-admin-secondary">
                                  <summary>Reverse manual payment</summary>
                                  <form
                                    method="post"
                                    action={`/api/ask-leilia/requests/${request.id}`}
                                    class="ask-admin-form"
                                    onsubmit="return confirm('Reverse the manual payment confirmation? Stripe data will not change.');"
                                  >
                                    <input type="hidden" name="return_to" value={returnTo} />
                                    <input type="hidden" name="action" value="reverse_manual_payment" />
                                    <p class="ask-admin-meta">
                                      Deactivates only the administrative override. A verified Stripe
                                      payment remains Paid.
                                    </p>
                                    <button type="submit" class="ask-admin-btn ask-admin-btn--ghost">
                                      Reverse manual payment
                                    </button>
                                  </form>
                                </details>
                              ) : null}
                            </section>

                            <section class="ask-admin-panel__section" aria-labelledby={`fulfil-${request.id}`}>
                              <h2 id={`fulfil-${request.id}`}>Fulfilment</h2>
                              <p>
                                <span class={`ask-admin-status ask-admin-status--${fulfilment}`}>
                                  {fulfilmentStatusLabel(fulfilment)}
                                </span>
                              </p>
                              {!effectivelyPaid ? (
                                <p class="ask-admin-meta" role="status">
                                  Fulfilment actions unlock after effective payment (Stripe success or Mark as
                                  paid).
                                </p>
                              ) : null}
                              {request.started_at ? (
                                <p class="ask-admin-meta">
                                  Started:{" "}
                                  <span data-ask-admin-local-time={request.started_at}>
                                    <span data-ask-admin-date>
                                      {formatCompactDateTimeUtc(request.started_at)}
                                    </span>
                                  </span>
                                </p>
                              ) : null}

                              {effectivelyPaid && fulfilment === "new" ? (
                                <form
                                  method="post"
                                  action={`/api/ask-leilia/requests/${request.id}`}
                                  class="ask-admin-form"
                                >
                                  <input type="hidden" name="return_to" value={returnTo} />
                                  <input type="hidden" name="action" value="start_reading" />
                                  <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                                    Start reading
                                  </button>
                                </form>
                              ) : null}

                              {effectivelyPaid ? (
                              <>
                              <div class="ask-admin-pdf">
                                <h3>Completed reading PDF</h3>
                                {request.delivery_pdf_path ? (
                                  <div class="ask-admin-pdf__row">
                                    <div>
                                      <p class="ask-admin-pdf__name">
                                        {request.delivery_pdf_filename || "Ask-Leilia-Reading.pdf"}
                                      </p>
                                      <p class="ask-admin-meta">
                                        {request.delivery_pdf_uploaded_at
                                          ? `Uploaded ${formatCompactDateTimeUtc(request.delivery_pdf_uploaded_at)}`
                                          : "Uploaded"}
                                        {request.delivery_pdf_size_bytes
                                          ? ` · ${formatFileSize(request.delivery_pdf_size_bytes)}`
                                          : ""}
                                      </p>
                                    </div>
                                    <div class="ask-admin-pdf__actions">
                                      {deliveryPdfUrl ? (
                                        <>
                                          <a
                                            class="ask-admin-btn ask-admin-btn--ghost"
                                            href={deliveryPdfUrl}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                          >
                                            View
                                          </a>
                                          <a
                                            class="ask-admin-btn ask-admin-btn--ghost"
                                            href={deliveryPdfUrl}
                                            download={request.delivery_pdf_filename || "Ask-Leilia-Reading.pdf"}
                                          >
                                            Download
                                          </a>
                                        </>
                                      ) : null}
                                    </div>
                                    {fulfilment !== "delivered" && fulfilment !== "archived" ? (
                                      <>
                                        <form
                                          method="post"
                                          action={`/api/ask-leilia/requests/${request.id}`}
                                          enctype="multipart/form-data"
                                          class="ask-admin-form ask-admin-form--inline"
                                        >
                                          <input type="hidden" name="return_to" value={returnTo} />
                                          <input type="hidden" name="action" value="replace_pdf" />
                                          <label>
                                            Replace PDF
                                            <input type="file" name="deliveryPdf" accept="application/pdf,.pdf" required />
                                          </label>
                                          <button type="submit" class="ask-admin-btn ask-admin-btn--ghost">
                                            Replace
                                          </button>
                                        </form>
                                        <form
                                          method="post"
                                          action={`/api/ask-leilia/requests/${request.id}`}
                                          class="ask-admin-form ask-admin-form--inline"
                                          onsubmit="return confirm('Remove the completed PDF? This returns the reading to In progress.');"
                                        >
                                          <input type="hidden" name="return_to" value={returnTo} />
                                          <input type="hidden" name="action" value="remove_pdf" />
                                          <button type="submit" class="ask-admin-btn ask-admin-btn--ghost">
                                            Remove
                                          </button>
                                        </form>
                                      </>
                                    ) : fulfilment === "delivered" ? (
                                      <form
                                        method="post"
                                        action={`/api/ask-leilia/requests/${request.id}`}
                                        enctype="multipart/form-data"
                                        class="ask-admin-form ask-admin-form--inline"
                                      >
                                        <input type="hidden" name="return_to" value={returnTo} />
                                        <input type="hidden" name="action" value="replace_pdf" />
                                        <label>
                                          Replace PDF (keeps delivery record)
                                          <input type="file" name="deliveryPdf" accept="application/pdf,.pdf" required />
                                        </label>
                                        <button type="submit" class="ask-admin-btn ask-admin-btn--ghost">
                                          Replace
                                        </button>
                                      </form>
                                    ) : null}
                                  </div>
                                ) : (
                                  <div class="ask-admin-pdf__empty">
                                    <p>No completed reading uploaded.</p>
                                    {fulfilment !== "archived" ? (
                                      <form
                                        method="post"
                                        action={`/api/ask-leilia/requests/${request.id}`}
                                        enctype="multipart/form-data"
                                        class="ask-admin-form"
                                      >
                                        <input type="hidden" name="return_to" value={returnTo} />
                                        <input type="hidden" name="action" value="upload_pdf" />
                                        <label>
                                          Upload completed reading PDF
                                          <input type="file" name="deliveryPdf" accept="application/pdf,.pdf" required />
                                        </label>
                                        <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                                          Upload completed reading PDF
                                        </button>
                                      </form>
                                    ) : null}
                                  </div>
                                )}
                              </div>

                              {fulfilment === "ready_to_send" ? (
                                <form
                                  method="post"
                                  action={`/api/ask-leilia/requests/${request.id}`}
                                  class="ask-admin-form"
                                  onsubmit="return confirm('Email the completed PDF and mark this reading delivered?');"
                                >
                                  <input type="hidden" name="return_to" value={returnTo} />
                                  <input type="hidden" name="action" value="send_delivery" />
                                  <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                                    Send PDF and mark delivered
                                  </button>
                                </form>
                              ) : null}

                              {fulfilment === "delivered" || fulfilment === "archived" ? (
                                <div class="ask-admin-delivery">
                                  <h3>Delivery</h3>
                                  {request.manually_delivered ? (
                                    <p role="status">Manually marked as delivered</p>
                                  ) : request.delivery_method === "system_email" ? (
                                    <p>Sent by system email</p>
                                  ) : null}
                                  {request.delivered_at ? (
                                    <p class="ask-admin-meta">
                                      Delivered: {formatCompactDateTimeUtc(request.delivered_at)}
                                    </p>
                                  ) : null}
                                  {request.delivered_to ? (
                                    <p class="ask-admin-meta">Delivered to: {request.delivered_to}</p>
                                  ) : null}
                                  {request.delivery_method ? (
                                    <p class="ask-admin-meta">
                                      Method: {ASK_LEILIA_DELIVERY_METHOD_LABELS[request.delivery_method]}
                                    </p>
                                  ) : null}
                                  {request.delivery_note ? (
                                    <p class="ask-admin-meta">Note: {request.delivery_note}</p>
                                  ) : null}
                                  {request.last_resent_at ? (
                                    <p class="ask-admin-meta">
                                      Last resent: {formatCompactDateTimeUtc(request.last_resent_at)}
                                    </p>
                                  ) : null}
                                  {request.delivery_attempt_count > 0 ? (
                                    <p class="ask-admin-meta">
                                      Send attempts: {request.delivery_attempt_count}
                                    </p>
                                  ) : null}
                                  {fulfilment === "delivered" && request.delivery_pdf_path ? (
                                    <form
                                      method="post"
                                      action={`/api/ask-leilia/requests/${request.id}`}
                                      class="ask-admin-form"
                                      onsubmit="return confirm('Resend the completed reading PDF to the client?');"
                                    >
                                      <input type="hidden" name="return_to" value={returnTo} />
                                      <input type="hidden" name="action" value="resend_delivery" />
                                      <button type="submit" class="ask-admin-btn">
                                        Resend reading
                                      </button>
                                    </form>
                                  ) : null}
                                </div>
                              ) : null}

                              {fulfilment !== "delivered" && fulfilment !== "archived" ? (
                                <details class="ask-admin-secondary">
                                  <summary>Secondary actions</summary>
                                  <form
                                    method="post"
                                    action={`/api/ask-leilia/requests/${request.id}`}
                                    class="ask-admin-form"
                                  >
                                    <input type="hidden" name="return_to" value={returnTo} />
                                    <input type="hidden" name="action" value="mark_delivered_manual" />
                                    <p class="ask-admin-meta">
                                      Mark as delivered manually when the reading was sent outside the system.
                                    </p>
                                    <label>
                                      Delivery date and time
                                      <input type="datetime-local" name="delivered_at" value={nowLocalValue} required />
                                    </label>
                                    <label>
                                      Delivery method
                                      <select name="delivery_method" required>
                                        {ASK_LEILIA_MANUAL_DELIVERY_METHODS.map((method) => (
                                          <option value={method}>
                                            {ASK_LEILIA_DELIVERY_METHOD_LABELS[method]}
                                          </option>
                                        ))}
                                      </select>
                                    </label>
                                    <label>
                                      Optional internal note
                                      <textarea name="delivery_note" rows="2" maxlength="2000"></textarea>
                                    </label>
                                    <button type="submit" class="ask-admin-btn ask-admin-btn--ghost">
                                      Mark as delivered manually
                                    </button>
                                  </form>
                                </details>
                              ) : null}
                              </>
                              ) : null}
                            </section>

                            <section class="ask-admin-panel__section" aria-labelledby={`review-${request.id}`}>
                              <h2 id={`review-${request.id}`}>Review</h2>
                              {fulfilment === "delivered" || fulfilment === "archived" ? (
                                <>
                                  <p>
                                    <span class={`ask-admin-review ask-admin-review--${review}`}>
                                      {reviewWorkflowStatusLabel(review)}
                                    </span>
                                  </p>
                                  {request.review_requested_at ? (
                                    <p class="ask-admin-meta">
                                      Requested: {formatCompactDateTimeUtc(request.review_requested_at)}
                                      {request.review_request_recipient
                                        ? ` · ${request.review_request_recipient}`
                                        : ""}
                                    </p>
                                  ) : null}
                                  {review === "not_requested" ? (
                                    <form
                                      method="post"
                                      action={`/api/ask-leilia/requests/${request.id}`}
                                      class="ask-admin-form"
                                    >
                                      <input type="hidden" name="return_to" value={returnTo} />
                                      <input type="hidden" name="action" value="request_review" />
                                      <button type="submit" class="ask-admin-btn ask-admin-btn--primary">
                                        Request review
                                      </button>
                                    </form>
                                  ) : null}
                                  {review === "requested" ? (
                                    <form
                                      method="post"
                                      action={`/api/ask-leilia/requests/${request.id}`}
                                      class="ask-admin-form"
                                      onsubmit="return confirm('Resend the review request email?');"
                                    >
                                      <input type="hidden" name="return_to" value={returnTo} />
                                      <input type="hidden" name="action" value="resend_review_request" />
                                      <button type="submit" class="ask-admin-btn">
                                        Resend review request
                                      </button>
                                    </form>
                                  ) : null}
                                  {review === "provided" && request.linked_review_id ? (
                                    <p>
                                      <a
                                        class="ask-admin-btn"
                                        href={`/ask-leilia/admin/reviews/?focus=${encodeURIComponent(request.linked_review_id)}`}
                                      >
                                        View review
                                      </a>
                                    </p>
                                  ) : null}
                                  <p>
                                    <a href="/ask-leilia/admin/reviews/">Open review moderation</a>
                                  </p>
                                </>
                              ) : (
                                <p class="ask-admin-meta">Review actions unlock after delivery.</p>
                              )}
                            </section>

                            <section class="ask-admin-panel__section" aria-labelledby={`admin-${request.id}`}>
                              <h2 id={`admin-${request.id}`}>Internal administration</h2>
                              <form
                                method="post"
                                action={`/api/ask-leilia/requests/${request.id}`}
                                class="ask-admin-form"
                              >
                                <input type="hidden" name="return_to" value={returnTo} />
                                <input type="hidden" name="action" value="save_notes" />
                                <label>
                                  Internal notes
                                  <textarea name="notes" rows="4">{request.admin_notes ?? ""}</textarea>
                                </label>
                                <button type="submit" class="ask-admin-btn">Save notes</button>
                              </form>
                              <form
                                method="post"
                                action={`/api/ask-leilia/requests/${request.id}`}
                                class="ask-admin-form"
                                onsubmit={
                                  isArchived
                                    ? "return confirm('Restore this reading to the active queue?');"
                                    : "return confirm('Archive this reading? It will leave the active queue but will not be deleted.');"
                                }
                              >
                                <input type="hidden" name="return_to" value={returnTo} />
                                <input type="hidden" name="action" value={isArchived ? "restore" : "archive"} />
                                <button type="submit" class="ask-admin-btn ask-admin-btn--ghost">
                                  {isArchived ? "Restore from archive" : "Archive"}
                                </button>
                              </form>

                              {fulfilment === "delivered" ? (
                                <details class="ask-admin-secondary">
                                  <summary>Reading Library publication</summary>
                                  {libraryPublication?.isPublished ? (
                                    <p class="ask-admin-meta">
                                      Published:{" "}
                                      <a href={`/recent-client-readings/${libraryPublication.slug}/`}>
                                        View in library
                                      </a>
                                    </p>
                                  ) : libraryPublication ? (
                                    <p class="ask-admin-meta">Saved as draft (not published).</p>
                                  ) : (
                                    <p class="ask-admin-meta">Not yet added to the Reading Library.</p>
                                  )}
                                  <form
                                    class="ask-admin-form"
                                    method="post"
                                    action={`/api/ask-leilia/reading-library/${request.id}`}
                                  >
                                    <label>
                                      Library title
                                      <input
                                        type="text"
                                        name="libraryTitle"
                                        required
                                        minlength="4"
                                        maxlength="200"
                                        value={libraryPublication?.title ?? ""}
                                      />
                                    </label>
                                    <label>
                                      URL slug
                                      <input
                                        type="text"
                                        name="librarySlug"
                                        required
                                        pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
                                        value={libraryPublication?.slug ?? suggestedSlug}
                                      />
                                    </label>
                                    <label>
                                      Short excerpt (card summary)
                                      <textarea name="librarySummary" rows="3" required minlength="20" maxlength="500">
                                        {libraryPublication?.summary ?? ""}
                                      </textarea>
                                    </label>
                                    <label>
                                      SEO description
                                      <textarea
                                        name="librarySeoDescription"
                                        rows="2"
                                        required
                                        minlength="40"
                                        maxlength="320"
                                      >
                                        {libraryPublication?.seoDescription ?? ""}
                                      </textarea>
                                    </label>
                                    <label>
                                      Reading body (Markdown)
                                      <textarea name="libraryBody" rows="8" required minlength="100">
                                        {libraryPublication?.body ?? ""}
                                      </textarea>
                                    </label>
                                    <label>
                                      Primary life areas (comma-separated)
                                      <input
                                        type="text"
                                        name="libraryLifeAreas"
                                        value={libraryPublication?.lifeAreas.join(", ") ?? ""}
                                      />
                                    </label>
                                    <label>
                                      Primary cards featured (comma-separated)
                                      <input
                                        type="text"
                                        name="libraryPrimaryCards"
                                        value={libraryPublication?.primaryCards.join(", ") ?? ""}
                                      />
                                    </label>
                                    <label>
                                      Spread used
                                      <input
                                        type="text"
                                        name="librarySpreadUsed"
                                        value={libraryPublication?.spreadUsed ?? readingTypeLabel(request.reading_type)}
                                      />
                                    </label>
                                    <label>
                                      Spread image paths (one per line, under public/)
                                      <textarea name="librarySpreadImages" rows="3">
                                        {libraryPublication?.spreadImagePaths.join("\n") ?? ""}
                                      </textarea>
                                    </label>
                                    <label class="ask-admin-publish">
                                      <input
                                        type="checkbox"
                                        name="libraryPublish"
                                        checked={libraryPublication?.isPublished ?? false}
                                      />
                                      Publish to Reading Library
                                    </label>
                                    <button type="submit" class="ask-admin-btn">Save library entry</button>
                                  </form>
                                </details>
                              ) : null}
                            </section>
                          </div>
                        </div>
                      </td>
                    </tr>
                  </Fragment>
                );
              })}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="ask-admin__empty">No Ask Leilia readings match this filter.</p>
      )
    }
  </main>

  <script>
    function formatLocalSubmission(iso) {
      const date = new Date(iso);
      if (Number.isNaN(date.getTime())) return null;
      const dateText = new Intl.DateTimeFormat(undefined, {
        day: "numeric",
        month: "short",
        year: "numeric",
      }).format(date);
      const timeText = new Intl.DateTimeFormat(undefined, {
        hour: "numeric",
        minute: "2-digit",
      }).format(date);
      const tz =
        new Intl.DateTimeFormat(undefined, { timeZoneName: "short" })
          .formatToParts(date)
          .find((part) => part.type === "timeZoneName")?.value ?? "";
      return {
        dateText,
        timeText,
        title: `${dateText} ${timeText}${tz ? ` ${tz}` : ""}`,
      };
    }

    function hydrateLocalTimes(root = document) {
      root.querySelectorAll("[data-ask-admin-local-time]").forEach((node) => {
        if (!(node instanceof HTMLElement)) return;
        const iso = node.getAttribute("data-ask-admin-local-time")?.trim() ?? "";
        if (!iso) return;
        const formatted = formatLocalSubmission(iso);
        if (!formatted) {
          node.setAttribute("title", "Submission time unavailable");
          const dateEl = node.querySelector("[data-ask-admin-date]");
          if (dateEl) dateEl.textContent = "Submission time unavailable";
          const timeEl = node.querySelector("[data-ask-admin-time]");
          if (timeEl) timeEl.textContent = "";
          return;
        }
        node.setAttribute("title", formatted.title);
        const dateEl = node.querySelector("[data-ask-admin-date]");
        const timeEl = node.querySelector("[data-ask-admin-time]");
        if (dateEl) dateEl.textContent = formatted.dateText;
        if (timeEl) timeEl.textContent = formatted.timeText;
      });
    }

    function setExpanded(id, expanded) {
      const detail = document.querySelector(`[data-ask-admin-detail="${id}"]`);
      const toggle = document.querySelector(`[data-ask-admin-toggle="${id}"]`);
      if (!(detail instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return;
      detail.hidden = !expanded;
      toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      toggle.classList.toggle("ask-admin-expand--open", expanded);
    }

    function bindExpandControls() {
      document.querySelectorAll("[data-ask-admin-toggle]").forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener("click", (event) => {
          event.stopPropagation();
          const id = button.getAttribute("data-ask-admin-toggle");
          if (!id) return;
          const expanded = button.getAttribute("aria-expanded") === "true";
          setExpanded(id, !expanded);
        });
      });

      document.querySelectorAll("[data-ask-admin-expand]").forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.addEventListener("click", (event) => {
          const id = link.getAttribute("data-ask-admin-expand");
          if (!id) return;
          event.preventDefault();
          setExpanded(id, true);
          document.getElementById(`ask-admin-panel-${id}`)?.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
          });
        });
      });

      document.querySelectorAll("[data-ask-admin-row]").forEach((row) => {
        if (!(row instanceof HTMLTableRowElement)) return;
        row.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          if (target.closest("a, button, form, input, select, textarea, label")) return;
          const id = row.getAttribute("data-ask-admin-row");
          if (!id) return;
          const toggle = document.querySelector(`[data-ask-admin-toggle="${id}"]`);
          const expanded = toggle?.getAttribute("aria-expanded") === "true";
          setExpanded(id, !expanded);
        });
      });
    }

    function boot() {
      hydrateLocalTimes();
      bindExpandControls();
    }

    boot();
    document.addEventListener("astro:page-load", boot);
  </script>
</BaseLayout>

