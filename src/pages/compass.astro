---
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqPageJsonLd } from "../lib/faqPageJsonLd";
import { siteBase } from "../lib/site";
import { activeCompassTraining as T } from "../data/training/active-training";

const title = T.meta.title;
const description = T.meta.description;
const ogUrl = new URL("/compass/", siteBase(Astro)).href;

const cs = T.cohortSchedule;

const compassFaqJsonLd = faqPageJsonLd(
  T.faq.items.map((item) => ({ question: item.q, answerHtml: item.a })),
  ogUrl,
);
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={ogUrl}
  tdcPlacement="none"
  jsonLd={compassFaqJsonLd}
>
  <article class="compass page-inner">
    <section class="compass__hero">
      <div class="compass__hero-copy compass__panel">
        <p class="compass__eyebrow">{T.hero.eyebrow}</p>
        <h1 class="compass__h1">{T.hero.heading}</h1>
        {T.hero.paragraphs.map((p) => <p class="compass__p">{p}</p>)}

        <a class="compass__cta compass__cta--primary" href={T.apply.ctaHref}>
          {T.apply.ctaLabel}
        </a>

        <a class="compass__sub-link" href="/articles/compass-method/">
          Read the COMPASS Method article
        </a>
        <p class="compass__sub-note">
          The COMPASS Method™ is Tides of Knowing's original interpretive framework. Training installs
          it; <a href="/practice/">practice on The Deck Compass</a> stabilises it.
        </p>
      </div>

      <figure class="compass__hero-figure compass__panel">
        <img
          src="/images/compass/system/compass-method-light.png"
          alt="Illustration of the COMPASS Method framework for clear intuitive readings."
          loading="lazy"
          decoding="async"
          class="compass__hero-image"
        />
      </figure>
    </section>

    <section
      class="compass__section compass__section--distinction"
      aria-labelledby="compass-training-practice-heading"
    >
      <h2 id="compass-training-practice-heading" class="compass__h2">
        {T.trainingPractice.heading}
      </h2>
      {T.trainingPractice.paragraphs.map((p) => <p class="compass__p">{p}</p>)}
    </section>

    <section class="compass__section compass__section--soft">
      <p class="compass__eyebrow">{T.problemFit.label}</p>
      <h2 class="compass__h2">{T.problemFit.heading}</h2>
      <ul class="compass__list compass__list--card">
        {T.problemFit.bullets.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="compass__section">
      <p class="compass__eyebrow">{T.method.label}</p>
      <h2 class="compass__h2">{T.method.heading}</h2>
      <p class="compass__pillars">
        {T.method.pillars.map((pillar) => <span>{pillar}</span>)}
      </p>
      {T.method.paragraphs.map((p) => <p class="compass__p">{p}</p>)}
    </section>

    <section class="compass__section compass__section--soft">
      <p class="compass__eyebrow">{T.learningOutcomes.label}</p>
      <h2 class="compass__h2">{T.learningOutcomes.heading}</h2>
      <p class="compass__p">{T.learningOutcomes.intro}</p>
      <ul class="compass__list compass__list--card">
        {T.learningOutcomes.bullets.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="compass__section">
      <p class="compass__eyebrow">{T.howItWorks.label}</p>
      <h2 class="compass__h2">{T.howItWorks.heading}</h2>
      <p class="compass__p compass__process-intro">{T.howItWorks.intro}</p>
      <ul class="compass__list compass__list--card">
        {T.howItWorks.bullets.map((item) => <li>{item}</li>)}
      </ul>
      {T.howItWorks.closingParagraphs.map((p) => <p class="compass__p">{p}</p>)}

      <a class="compass__cta compass__cta--secondary" href={T.apply.ctaHref}>
        {T.apply.ctaLabel}
      </a>
    </section>

    <section class="compass__section compass__section--schedule" aria-labelledby="compass-cohort-heading">
      <p class="compass__eyebrow">{cs.label}</p>
      <h2 id="compass-cohort-heading" class="compass__h2">{cs.heading}</h2>

      {
        cs.variant === "nz" && (
          <>
            {cs.introParagraphs.map((p) => (
              <p class="compass__p">{p}</p>
            ))}

            <div class="compass__cohort-cards">
              {cs.cohortCards.map((c) => (
                <div class="compass__cohort-card compass__panel">
                  <p class="compass__cohort-card-title">{c.title}</p>
                  <p class="compass__cohort-card-status">{c.status}</p>
                </div>
              ))}
            </div>

            <h3 class="compass__h3">{cs.sessionWindowsSubheading}</h3>

            <div class="compass__schedule-window-grid">
              {cs.sessionWindowCards.map((w) => (
                <div class="compass__schedule-window-card compass__panel">
                  <p class="compass__schedule-window-title">{w.title}</p>
                  <ul class="compass__schedule-window-list">
                    {w.lines.map((line) => (
                      <li>{line}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>

            <div class="compass__from-august compass__panel">
              <h3 class="compass__h3 compass__from-august-heading">{cs.fromAugustHeading}</h3>
              <p class="compass__p compass__from-august-lead">{cs.fromAugustLead}</p>
              <ul class="compass__list compass__from-august-list">
                {cs.fromAugustBullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>

            <p class="compass__p">{cs.usWaitParagraph}</p>

            <a class="compass__cta compass__cta--secondary" href={cs.registerInterest.href}>
              {cs.registerInterest.text}
            </a>
          </>
        )
      }

      {
        cs.variant === "mexico" && (
          <>
            {cs.introParagraphs.map((p) => (
              <p class="compass__p">{p}</p>
            ))}

            <div class="compass__cohort-cards">
              {cs.availabilityItems.map((row) => (
                <div class="compass__cohort-card compass__panel">
                  <p class="compass__cohort-card-title">{row.period}</p>
                  <p class="compass__cohort-card-status">{row.status}</p>
                </div>
              ))}
            </div>

            {cs.timezoneParagraphs.map((p) => (
              <p class="compass__p">{p}</p>
            ))}

            {cs.closingParagraph && <p class="compass__p">{cs.closingParagraph}</p>}
          </>
        )
      }
    </section>

    <section class="compass__section compass__section--investment" aria-labelledby="compass-investment-heading">
      <p class="compass__eyebrow">{T.investment.label}</p>
      <h2 id="compass-investment-heading" class="compass__h2">{T.investment.heading}</h2>
      <p class="compass__p">{T.investment.intro}</p>

      <div class="compass__pricing-grid">
        {
          T.investment.tiers.map((tier) => (
            <div class="compass__pricing-card compass__panel">
              <h3 class="compass__pricing-tier-title">{tier.title}</h3>
              {tier.body.map((para) => (
                <p class="compass__pricing-tier-p">{para}</p>
              ))}
            </div>
          ))
        }
      </div>

      <h3 class="compass__h3">{T.investment.afterHeading}</h3>
      {T.investment.afterParagraphs.map((p) => <p class="compass__p">{p}</p>)}
    </section>

    <section class="compass__section compass__section--warm">
      <p class="compass__eyebrow">{T.about.label}</p>
      <h2 class="compass__h2">{T.about.heading}</h2>
      {T.about.paragraphs.map((p) => <p class="compass__p">{p}</p>)}
    </section>

    <section class="compass__section compass__section--soft" aria-labelledby="compass-faq-heading">
      <p class="compass__eyebrow">{T.faq.label}</p>
      <h2 id="compass-faq-heading" class="compass__h2">{T.faq.heading}</h2>
      <dl class="compass__faq">
        {
          T.faq.items.map((item) => (
            <div class="compass__faq-item">
              <dt class="compass__faq-q">{item.q}</dt>
              <dd class="compass__faq-a" set:html={item.a} />
            </div>
          ))
        }
      </dl>
    </section>

    <section class="compass__section compass__section--final" id="apply" aria-labelledby="compass-apply-heading">
      <p class="compass__eyebrow">{T.apply.label}</p>
      <h2 id="compass-apply-heading" class="compass__h2">{T.apply.heading}</h2>
      <p class="compass__p">{T.apply.intro}</p>
      <ul class="compass__list">
        {T.apply.checklist.map((item) => <li>{item}</li>)}
      </ul>
      <p class="compass__p">{T.apply.note}</p>
      <a class="compass__cta" href={T.apply.ctaHref}>
        {T.apply.ctaLabel}
      </a>
    </section>

    <p class="compass__page-attribution tok-ip-attribution">{T.footerAttribution}</p>
  </article>
</BaseLayout>

<style>
  .compass {
    padding: clamp(2rem, 6vw, 4rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 62rem;
    color: var(--tok-text-light);
  }

  .compass__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    align-items: start;
    margin-bottom: 3rem;
  }

  .compass__hero-copy {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .compass__panel {
    background: var(--tok-surface-panel);
    border: 1px solid var(--tok-border-system);
    border-radius: var(--radius-control);
    padding: clamp(1rem, 3vw, 1.5rem);
    color: var(--tok-text-light);
    box-shadow: var(--shadow-sys-sm);
  }

  .compass__hero-figure {
    margin: 0;
  }

  .compass__hero-image {
    display: block;
    width: 100%;
    max-width: 600px;
    height: auto;
    border-radius: var(--radius-soft);
    border: 1px solid var(--tok-border-system);
    box-shadow: var(--shadow-sys-md);
  }

  .compass__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .compass__h1 {
    margin: 0 0 0.9rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.65rem);
    line-height: 1.15;
    color: var(--tok-text-light);
  }

  .compass__h2 {
    margin: 0 0 0.85rem;
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.8vw, 1.65rem);
    font-weight: 600;
    font-style: normal;
    color: var(--tok-text-light);
    line-height: 1.25;
  }

  .compass__h3 {
    margin: 1.25rem 0 0.65rem;
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    font-weight: 600;
    color: var(--tok-text-light);
    line-height: 1.3;
  }

  .compass__section--schedule .compass__h3:first-of-type {
    margin-top: 0.5rem;
  }

  .compass__section + .compass__section {
    margin-top: 1.25rem;
  }

  .compass__section--distinction {
    margin-bottom: 0.25rem;
    background: var(--tok-surface-panel);
    border: 1px solid var(--tok-border-system);
    box-shadow: var(--shadow-sys-sm);
  }

  .compass__section--distinction .compass__h2 {
    color: var(--tok-text-light);
  }

  .compass__p {
    margin: 0 0 0.9rem;
    font-size: 1.06rem;
    line-height: 1.72;
    color: var(--tok-text-light-soft);
  }

  .compass__panel .compass__p {
    color: var(--tok-text-light-soft);
  }

  .compass__pillars {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0 0 1rem;
  }

  .compass__pillars span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.42rem 0.68rem;
    border: 1px solid color-mix(in srgb, var(--tok-teal-light) 45%, transparent);
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--tok-teal) 10%, transparent);
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--tok-text-light);
  }

  .compass__list {
    margin: 0 0 0.9rem;
    padding-left: 1.35rem;
    font-size: 1.06rem;
    line-height: 1.7;
    color: var(--tok-text-light-soft);
  }

  .compass__list li {
    margin-bottom: 0.4rem;
  }

  .compass__section--soft .compass__list,
  .compass__section--warm .compass__list {
    color: var(--tok-text-dark);
  }

  .compass__list--card {
    margin-bottom: 0;
    padding: 0.85rem 1.1rem 0.45rem 2.1rem;
    background: var(--tok-surface-panel);
    border: 1px solid var(--tok-border-system);
    border-radius: var(--radius-control);
    color: var(--tok-text-light);
  }

  .compass__section--soft .compass__list--card,
  .compass__section--warm .compass__list--card {
    background: var(--tok-surface-reading-soft);
    border: 1px solid var(--tok-border-light);
    color: var(--tok-text-dark);
  }

  .compass__process-intro {
    margin-bottom: 0.7rem;
  }

  .compass__cohort-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.85rem;
    margin: 0 0 1.25rem;
  }

  .compass__cohort-card {
    margin: 0;
  }

  .compass__cohort-card-title {
    margin: 0 0 0.35rem;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--tok-text-light);
  }

  .compass__cohort-card-status {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--tok-text-light-soft);
  }

  .compass__schedule-window-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
    gap: 0.85rem;
    margin: 0 0 1.25rem;
  }

  .compass__schedule-window-card {
    margin: 0;
    height: 100%;
  }

  .compass__schedule-window-title {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--tok-text-light);
  }

  .compass__schedule-window-list {
    margin: 0;
    padding-left: 1.1rem;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--tok-text-light-soft);
  }

  .compass__schedule-window-list li {
    margin-bottom: 0.35rem;
  }

  .compass__from-august {
    margin: 0 0 1rem;
  }

  .compass__from-august-heading {
    margin-top: 0;
  }

  .compass__from-august-lead {
    margin-bottom: 0.5rem;
  }

  .compass__from-august-list {
    margin-bottom: 0;
    color: var(--tok-text-light-soft);
  }

  .compass__pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16.5rem), 1fr));
    gap: 1rem;
    margin: 1rem 0 1.25rem;
  }

  .compass__pricing-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    height: 100%;
  }

  .compass__pricing-tier-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.08rem;
    font-weight: 600;
    color: var(--tok-text-light);
    line-height: 1.3;
  }

  .compass__pricing-tier-p {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--tok-text-light-soft);
  }

  .compass__section--investment .compass__h3 {
    margin-top: 1.5rem;
  }

  .compass__table-wrap {
    margin: 0.5rem 0 0;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--radius-soft);
    border: 1px solid var(--tok-border-system);
  }

  .compass__data-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
    font-size: 0.88rem;
    background: var(--tok-surface-panel);
    color: var(--tok-text-light);
  }

  .compass__data-table th,
  .compass__data-table td {
    padding: 0.45rem 0.55rem;
    text-align: left;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-border-system) 80%, transparent);
  }

  .compass__data-table th {
    font-weight: 600;
    color: var(--tok-gold);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .compass__tz-block + .compass__tz-block {
    margin-top: 1.25rem;
  }

  .compass__tz-range {
    margin-bottom: 0.35rem;
  }

  .compass__tz-footnote {
    margin-top: 0.75rem;
    font-size: 0.98rem;
    font-style: italic;
    color: color-mix(in srgb, var(--tok-text-light-soft) 95%, transparent);
  }

  .compass__which-window-list {
    margin-top: 0.35rem;
  }

  .compass__faq {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .compass__faq-item {
    padding: 1rem 0;
    border-top: 1px solid color-mix(in srgb, var(--tok-teal-light) 28%, transparent);
  }

  .compass__faq-item:first-of-type {
    border-top: none;
    padding-top: 0.35rem;
  }

  .compass__faq-q {
    margin: 0 0 0.45rem;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--tok-water);
  }

  .compass__faq-a {
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.72;
    color: var(--tok-text-dark);
  }

  .compass__faq-link {
    color: var(--tok-water);
    font-weight: 600;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.15em;
  }

  .compass__faq-link:hover {
    color: var(--tok-teal);
  }

  .compass__section {
    padding: clamp(1.1rem, 2.6vw, 1.45rem);
    border-radius: var(--radius-control);
  }

  .compass__section--soft {
    background: var(--tok-surface-reading-soft);
    border: 1px solid var(--tok-border-light);
    color: var(--tok-text-dark);
  }

  .compass__section--soft .compass__h2,
  .compass__section--soft .compass__p,
  .compass__section--soft .compass__list {
    color: var(--tok-text-dark);
  }

  .compass__section--warm {
    background: color-mix(in srgb, var(--tok-gold) 8%, var(--tok-surface-reading));
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, transparent);
    color: var(--tok-text-dark);
  }

  .compass__section--warm .compass__h2,
  .compass__section--warm .compass__p {
    color: var(--tok-text-dark);
  }

  .compass__section--final {
    background: var(--tok-deep-ocean);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 45%, transparent);
  }

  .compass__section--final .compass__h2,
  .compass__section--final .compass__p,
  .compass__section--final .compass__list {
    color: var(--tok-text-light);
  }

  .compass__section--final .compass__eyebrow {
    color: var(--tok-gold);
  }

  .compass__section--final .compass__cta {
    color: var(--tok-text-light);
    border-color: var(--tok-gold);
  }

  .compass__page-attribution {
    margin: 2rem 0 0;
    text-align: center;
    font-style: italic;
    max-width: none;
  }

  .compass__sub-link {
    margin-top: 0.25rem;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-teal-light);
  }

  .compass__sub-link:hover {
    color: var(--tok-text-light-strong);
  }

  .compass__sub-note {
    margin: 0.75rem 0 0;
    max-width: 36rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--tok-text-muted);
  }

  .compass__sub-note a {
    color: var(--tok-teal-light);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .compass__sub-note a:hover {
    color: var(--tok-text-light-strong);
  }

  .compass__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.25rem;
    padding: 0.85rem 1.75rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-text-light);
    border: 2px solid var(--tok-gold);
    border-radius: var(--radius-2);
    background: transparent;
  }

  .compass__cta--primary {
    align-self: flex-start;
  }

  .compass__cta--secondary {
    margin-top: 1.5rem;
  }

  .compass__cta:hover {
    background: color-mix(in srgb, var(--tok-gold) 14%, transparent);
    color: var(--tok-text-light-strong);
    border-color: var(--tok-gold);
  }

  .compass__section--soft .compass__cta,
  .compass__section--warm .compass__cta {
    color: var(--tok-water);
  }

  .compass__section--soft .compass__cta:hover,
  .compass__section--warm .compass__cta:hover {
    color: var(--tok-water);
  }

  .compass__section--schedule .compass__cta--secondary {
    color: var(--tok-text-light);
  }

  .compass__section--schedule .compass__cta--secondary:hover {
    color: var(--tok-text-light-strong);
  }

  .compass__section--final .compass__cta:hover {
    color: var(--tok-text-light-strong);
    background: color-mix(in srgb, var(--tok-gold) 20%, transparent);
  }

  .compass__cta:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 4px;
  }

  @media (max-width: var(--bp-nav)) {
    .compass__hero {
      grid-template-columns: minmax(0, 1fr);
    }

    .compass__hero-figure {
      order: -1;
    }
  }

  @media (max-width: var(--bp-xs)) {
    .compass__section {
      padding: 0.95rem;
    }

    .compass__h1 {
      font-size: clamp(2rem, 9vw, 2.45rem);
    }
  }
</style>
