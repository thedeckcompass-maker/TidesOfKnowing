---
import BaseLayout from "../layouts/BaseLayout.astro";
import BrandImagePlaceholder from "../components/home/BrandImagePlaceholder.astro";
import DiscernmentChecklistCapture from "../components/lead-magnets/DiscernmentChecklistCapture.astro";
import {
  COMPASS_CAPACITY,
  COMPASS_OFFER_ID,
  COMPASS_SESSION_TIME_LABEL,
  COMPASS_TIMEZONE,
} from "../data/training/compass-cohorts";
import { listCompassCohortViews, type CompassCohortView } from "../lib/compass/cohorts";
import { faqPageJsonLd } from "../lib/faqPageJsonLd";
import { siteBase } from "../lib/site";
import {
  compassPageFooterAttribution,
  compassPageMeta,
} from "../data/training/compass-page";
import "../styles/home.css";

const title = compassPageMeta.title;
const description = compassPageMeta.description;
const ogUrl = new URL("/compass/", siteBase(Astro)).href;

/** Stable in-page anchor for cohort selection (not a Stripe redirect). */
const COMPASS_CHOOSE_COHORT_HREF = "#choose-your-cohort";

let paidCounts = new Map<string, number>();
try {
  const { createCommunityServiceClient } = await import("../lib/community/supabaseServer");
  const { getCompassPaidCountsByCohort } = await import("../lib/compass/capacity");
  const service = createCommunityServiceClient(Astro.locals);
  paidCounts = await getCompassPaidCountsByCohort(service);
} catch {
  // Sales page still renders with configured open/full/closed when DB is unavailable.
}

const cohortViews = listCompassCohortViews(new Date(), paidCounts);

type CompassMonthViewGroup = {
  monthKey: string;
  monthLabel: string;
  cohorts: CompassCohortView[];
};

const cohortMonthGroups: CompassMonthViewGroup[] = [];
for (const view of cohortViews) {
  const existing = cohortMonthGroups.find((g) => g.monthKey === view.monthKey);
  if (existing) existing.cohorts.push(view);
  else {
    cohortMonthGroups.push({
      monthKey: view.monthKey,
      monthLabel: view.monthLabel,
      cohorts: [view],
    });
  }
}

const firstOpenMonthKey =
  cohortMonthGroups.find((g) => g.cohorts.some((c) => c.selectable))?.monthKey ??
  cohortMonthGroups[0]?.monthKey;

const enrolQuery = Astro.url.searchParams.get("enrol");
const enrolFlash =
  enrolQuery === "invalid"
    ? "Please check your cohort selection, contact details, and confirmations, then try again."
    : enrolQuery === "full"
      ? "That cohort is full. Please choose another available cohort."
      : enrolQuery === "unavailable"
        ? "We could not start enrolment just now. Please try again shortly, or contact hello@tidesofknowing.com."
        : "";

const recognitionCards = [
  {
    heading: "You sense the answer but cannot yet hold the thread",
    copy: "You recognise that something important is present, but the reading fragments into individual meanings, extra cards, and explanations that do not resolve into one coherent understanding.",
  },
  {
    heading: "You question what you perceived",
    copy: "You receive an intuitive impression, then immediately wonder whether it is accurate, imagined, influenced by fear, or simply what you expected to find.",
  },
  {
    heading: "You understand more than you can communicate",
    copy: "The insight feels clear internally, but translating it into language another person can understand becomes difficult. You soften, qualify, over-explain, or lose the central point.",
  },
] as const;

const practicalCostItems = [
  "Pull more cards because the first answer does not feel complete",
  "Keep searching for clarification instead of trusting what is present",
  "Give clients broad or vague interpretations",
  "Struggle to explain how they reached a conclusion",
  "Lose time moving between meanings, impressions, and possibilities",
  "Second-guess themselves after the reading",
  "Confuse additional information with greater accuracy",
  "Recognise something important but cannot identify the central thread",
] as const;

/** Compact asymmetric results: short label + supporting line. */
const transformationOutcomes = [
  {
    label: "Business decisions",
    copy: "Recognise patterns earlier and act with clearer professional judgement.",
  },
  {
    label: "Relationship dynamics",
    copy: "See what sits beneath words, behaviour, and recurring tension.",
  },
  {
    label: "Meaning in transition",
    copy: "Find direction within challenging or uncertain periods.",
  },
  {
    label: "Clarity and agency",
    copy: "Navigate readings and everyday life with greater confidence.",
  },
  {
    label: "Clearer self-readings",
    copy: "Settle with what is present instead of chasing the next card.",
  },
  {
    label: "Clearer client readings",
    copy: "Give friends and clients a coherent thread they can use.",
  },
  {
    label: "Less anxiety, less over-pulling",
    copy: "Stop treating extra cards as proof that the answer was incomplete.",
  },
  {
    label: "Less over-explaining",
    copy: "Say what belongs without diluting the central point.",
  },
  {
    label: "Interpretive precision",
    copy: "Test impressions against context until the reading coheres.",
  },
  {
    label: "Knowing when it has landed",
    copy: "Recognise when the answer is complete and the work can stop.",
  },
] as const;

const differentiationBlocks = [
  {
    heading: "Meanings give you vocabulary",
    copy: "They help you recognise what an individual card may represent. They do not automatically tell you which meaning matters here, in this question, for this person, at this moment.",
  },
  {
    heading: "Intuition gives you information",
    copy: "It may arrive as an image, feeling, physical response, association, memory, tension, or sudden knowing. Without a structure for testing and organising it, valuable information can remain unclear or become mixed with assumption.",
  },
  {
    heading: "Interpretation creates understanding",
    copy: "Interpretation is the disciplined work of bringing card, question, context, relationship, and intuitive signal together until the reading becomes coherent and useful.",
  },
] as const;

const compassPillars = [
  {
    name: "Center",
    key: "center",
    icon: "/images/compass/icons/center/center-transparent.svg",
    copy: "Arrive before interpreting. Settle attention, establish the question, and recognise what you are bringing into the reading.",
  },
  {
    name: "Open",
    key: "open",
    icon: "/images/compass/icons/open/open-transparent.svg",
    copy: "Make space for information that does not match the answer you expected or preferred.",
  },
  {
    name: "Map",
    key: "map",
    icon: "/images/compass/icons/map/map-transparent.svg",
    copy: "See the structure of the whole reading before becoming absorbed in individual details.",
  },
  {
    name: "Perceive",
    key: "perceive",
    icon: "/images/compass/icons/perceive/perceive-transparent.svg",
    copy: "Notice what is actually present through cards, imagery, sensation, pattern, language, and intuitive response.",
  },
  {
    name: "Align",
    key: "align",
    icon: "/images/compass/icons/align/align-transparent.svg",
    copy: "Test what you perceive against the question, context, evidence, and relationships within the reading.",
  },
  {
    name: "Sense",
    key: "sense",
    icon: "/images/compass/icons/sense/sense-transparent.svg",
    copy: "Follow the living thread between the elements and recognise where meaning gathers weight.",
  },
  {
    name: "Seal",
    key: "seal",
    icon: "/images/compass/icons/seal/seal-transparent.svg",
    copy: "Recognise when the answer has landed, communicate the central understanding, and close without adding noise.",
  },
] as const;

const COMPASS_METHOD_BANNER = "/images/home/tok-home-compass-method-banner.png";

const programmeFacts = [
  "Four live teaching sessions",
  "60–90 minutes per session",
  "Maximum six participants",
  "Almost three weeks of guided application",
  "One observed seeker reading with private feedback",
  "Three months of The Deck Compass membership included",
] as const;

const phaseOneSessions = [
  {
    label: "Session 1",
    heading: "Establish the container",
    copy: "Learn Center and Seal as the structural bookends of the method, including how to arrive before interpreting and how to recognise when the answer has landed.",
  },
  {
    label: "Session 2",
    heading: "Develop perceptual range",
    copy: "Work with two of the internal pillars and begin recognising how intuitive information arrives through imagery, language, sensation, pattern, and relationship.",
  },
  {
    label: "Session 3",
    heading: "Test and organise meaning",
    copy: "Add two further pillars and practise distinguishing useful signal from assumption, habit, emotional investment, and unnecessary complication.",
  },
  {
    label: "Session 4",
    heading: "Complete the framework and enter practice",
    copy: "Learn the final pillar, bring the full method together, and receive your onboarding into The Deck Compass platform.",
  },
] as const;

const phaseTwoPractices = [
  {
    heading: "Conduct readings through the platform",
    copy: "Use the COMPASS framework in live and personal readings while the method is still fresh.",
  },
  {
    heading: "Journal inside each reading",
    copy: "The Deck Compass includes structured journalling so you can record impressions, decisions, changes in emphasis, and the point at which the answer became clear.",
  },
  {
    heading: "Share your journal for review",
    copy: "You can share selected journalling notes with Leigh for review through the platform, helping you identify patterns in how you perceive and interpret.",
  },
  {
    heading: "Build your own responsive practice",
    copy: "You learn which pillars require greater attention in different circumstances and how to use the framework without turning it into a mechanical checklist.",
  },
] as const;

const membershipBenefits = [
  "Continued access to the reading and journalling platform",
  "Journal sharing and review through the member interface",
  "One guaranteed live member training each month",
  "Access to other member activities scheduled during your membership",
  "Connection with your cohort and the wider practitioner community",
] as const;

const offerInclusions = [
  "Four live teaching sessions",
  "60–90 minutes per session",
  "Almost three weeks of guided application",
  "One observed seeker reading with private feedback",
  "Journal sharing and review through The Deck Compass",
  "Three months of Deck Compass membership",
  "One guaranteed live member training each month",
  "Maximum six participants",
  "Every confirmed cohort proceeds",
] as const;

/** Approved COMPASS training testimonial reused from the homepage proof section. */
const mareeTestimonial = {
  name: "Maree",
  credential: "Business and life coach · The COMPASS Method™ practitioner",
  resultLabel: "Stronger professional interpretation",
  paragraphs: [
    "Working with Leigh has been a game changer for me.",
    "I’ve worked with tarot and oracle in my practice for many years, but I had a wall around trusting my intuition and knowing what to do with the intuitive information I was receiving. As a business and life coach, I often receive messages that do not come from the material directly in front of me, and I did not know how to ground that information practically or communicate it clearly to clients.",
    "Leigh’s training reflects the real depth of her experience and goes far beyond the topic on the surface. For me, as an adult student wanting to tighten my practice, that breadth was pure gold. I cannot speak highly enough of her skill as a trainer or the depth of knowledge she brings to this work.",
    "I am deeply grateful for what I have learned. I will continue applying these skills and will return for any training Leigh offers next. I highly recommend her training to anyone who has reached the point in their practice where they want to go deeper but are unsure how to develop their skills and offerings.",
  ],
} as const;

const supportingTestimonials = [
  {
    name: "April",
    resultLabel: "A clearer container for self-reading",
    pullQuote:
      "What the method gave me was a way to anchor my own readings in a system that brought real clarity.",
    paragraphs: [
      "One of the challenges when you read for yourself is not continuing to reach for more cards, looking for deeper answers or different answers, instead of settling with the cards already in front of you. The COMPASS Method did exactly that, and it reduced my anxiety considerably.",
      "I used to read and then wonder, have I got this right, what am I supposed to do next. What this gave me instead was a container to hold the information, and by being able to sit with it in a still way, I was able to glean the answers I actually needed.",
      "This has been incredibly valuable, and it is now something I work with automatically as part of my practice.",
    ],
  },
  {
    name: "Alexandra",
    resultLabel: "Greater accuracy, control, and confidence",
    pullQuote:
      "This training has given me the confidence to read well and to use the cards as a tool rather than let them dictate the reading.",
    paragraphs: [
      "I’m relatively new to tarot, and I did this training so I’d have a system I could actually use. What I’d tried before mostly followed the Golden Dawn method, and I found the cards tended to drive the process. What I found with the COMPASS Method training was that it gave me a way of actually being in charge of the tools I was using, which is ultimately what I want to be able to do.",
      "So many spreads and ways of using the cards end up determining the direction of the reading, when I think it should be the other way around.",
      "This training has given me, as a relatively new reader, the confidence to read well and to use the cards as a tool rather than let them dictate the reading, while still getting really clear responses. The best part is that my accuracy has gone through the roof because I’m taking my time, and yet I’m actually a lot faster at reading the cards than I was before. It’s an interesting thing when you learn a skill properly: you can end up getting better results in less time.",
    ],
  },
] as const;

const compassFaqItems = [
  {
    q: "How do I choose a cohort and enrol?",
    a: "Select a month, choose one cohort by its start date, review the three further teaching dates, enter your name and email, confirm attendance and terms, then continue to payment. Your place is reserved only after payment is completed.",
  },
  {
    q: "Do I need to be an experienced professional reader?",
    a: "No. COMPASS is for readers who already understand the basic language of their cards and can complete a reading independently. You may read professionally, for friends, or primarily for yourself.",
  },
  {
    q: "Is COMPASS only for tarot readers?",
    a: "Tarot and oracle readers are the primary audience. The interpretive principles can also support coaching, facilitation, writing, leadership, and other work involving pattern recognition and intuitive judgement.",
  },
  {
    q: "Is this suitable for complete beginners?",
    a: "No. The programme does not teach basic card meanings. You should already be able to work with your deck and complete a reading without step-by-step instruction.",
  },
  {
    q: "Will I have to read in front of the group?",
    a: "Live practice is part of the programme, but the environment is small, structured, and developmental. You are not expected to perform. The purpose is to apply the method and receive useful feedback.",
  },
  {
    q: "What happens if I miss a teaching session?",
    a: "Attendance is strongly recommended. Where scheduling permits, you may attend the equivalent lesson with another cohort. Relevant written materials will also be provided. The programme is not designed as a replay-based course.",
  },
  {
    q: "Are sessions recorded?",
    a: "Teaching sessions are not routinely recorded, protecting participant privacy and live discussion.",
  },
  {
    q: "How much time should I allow?",
    a: "Allow 60–90 minutes for each of the four live sessions, plus time for practice readings and journalling during the remaining integration period.",
  },
  {
    q: "What does the observed reading involve?",
    a: "You conduct a reading for a seeker while Leigh observes. The seeker must understand the training context. The reading is not recorded by default. Leigh provides private feedback afterwards.",
  },
  {
    q: "When must I complete the observed reading?",
    a: "You may schedule it when you feel ready, provided it takes place before your complimentary three-month Deck Compass membership expires.",
  },
  {
    q: "What happens after the three complimentary months?",
    a: "Your access ends unless you choose to continue your Deck Compass membership at US$39 per month.",
  },
  {
    q: "Is membership renewed automatically?",
    a: "Renewal mechanics are confirmed separately at checkout. This page does not state that billing is automatic until the Stripe configuration has been audited.",
  },
  {
    q: "What is the refund and transfer policy?",
    a: "You may request a full refund within 48 hours of purchase, provided the cohort has not begun. After that period, payment is non-refundable because your place and live delivery capacity have been reserved. One transfer to another available cohort is permitted with at least 72 hours’ notice. If Tides of Knowing postpones or cancels a cohort, you may transfer or receive a full refund.",
  },
  {
    q: "What if the method changes after I enrol?",
    a: "COMPASS is a proprietary system and may be refined as it is applied and taught. Any change affecting your confirmed cohort or included benefits will be communicated in advance and will not reduce the value of your enrolment.",
  },
] as const;

const LEIGH_AUTHORITY_PORTRAIT = "/images/home/leigh-spencer-profile.png";

const compassFaqJsonLd = faqPageJsonLd(
  compassFaqItems.map((item) => ({ question: item.q, answerHtml: item.a })),
  ogUrl,
);

const compassOfferJsonLd = {
  "@context": "https://schema.org",
  "@type": "Course",
  "@id": `${ogUrl}#course`,
  name: "The COMPASS Method™ Live Practitioner Training",
  description,
  url: ogUrl,
  provider: {
    "@type": "Organization",
    name: "Tides of Knowing",
    url: siteBase(Astro).href,
  },
  offers: {
    "@type": "Offer",
    "@id": `${ogUrl}#offer`,
    name: "The COMPASS Method™ Live Practitioner Training",
    price: "997.00",
    priceCurrency: "USD",
    availability: "https://schema.org/InStock",
    url: ogUrl,
  },
};

const pageJsonLd = [compassFaqJsonLd, compassOfferJsonLd];
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={ogUrl}
  tdcPlacement="none"
  jsonLd={pageJsonLd}
>
  <article class="compass">
    <div class="tok-home compass-open">
      <section
        class="tok-home__band tok-home__band--ocean compass-open__hero"
        aria-labelledby="compass-hero-heading"
      >
        <div class="tok-home__inner compass-open__banner-shell">
          <figure class="compass-open__banner">
            <img
              class="compass-open__banner-img"
              src={COMPASS_METHOD_BANNER}
              alt="Tides of Knowing COMPASS Method banner showing the seven pillars of the interpretive framework"
              width="1640"
              height="720"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        </div>

        <div class="tok-home__inner compass-open__hero-split">
          <div class="compass-open__hero-copy">
            <p class="tok-home__eyebrow">The COMPASS Method™</p>
            <h1 id="compass-hero-heading" class="tok-home__h1 compass-open__h1">
              Turn intuitive perception into clear, coherent understanding
            </h1>
            <p class="tok-home__lede">
              Learn to recognise and accurately decode the information that arrives before words, then
              give it a reliable structure for interpretation. The COMPASS Method™ helps you understand
              what is moving beneath the surface, communicate what you perceive clearly, and use that
              insight to navigate readings, relationships, business decisions, and life with greater
              confidence.
            </p>
          </div>

          <aside class="compass-open__hero-panel" aria-label="Enrolment details">
            <p class="compass-open__audience">
              Live small-cohort training for tarot and oracle readers who already understand the
              language of their cards and are ready to move beyond meanings into interpretation.
            </p>
            <p class="tok-home__actions compass-open__actions">
              <a
                class="tok-home__cta tok-home__cta--primary compass-open__cta"
                href={COMPASS_CHOOSE_COHORT_HREF}
              >
                Choose Your Cohort
              </a>
              <a
                class="tok-home__cta tok-home__cta--secondary compass-open__cta"
                href="#programme-details"
              >
                Explore What’s Included
              </a>
            </p>
            <p class="compass-open__offer">US$997 · Direct enrolment · Maximum six participants</p>
            <p class="tok-home__trust compass-open__reassure">
              Two cohorts begin each month. Every confirmed cohort proceeds, even with one participant.
            </p>
          </aside>
        </div>
      </section>

      <section
        class="tok-home__band tok-home__band--cream compass-open__recognition"
        aria-labelledby="compass-recognition-heading"
      >
        <div class="tok-home__inner compass-open__recognition-split">
          <header class="compass-open__recognition-intro">
            <p class="tok-home__eyebrow">You already perceive more than you can explain</p>
            <h2 id="compass-recognition-heading" class="tok-home__h2">
              The difficulty is not always receiving the information. It is knowing what to do with
              it.
            </h2>
            <p class="tok-home__lede">
              Intuitive information often arrives before language. It may appear as a feeling, image,
              tension, bodily response, pattern, or half-formed knowing. Without a reliable
              interpretive structure, it can remain vague, become distorted by projection, or
              disappear beneath too much analysis.
            </p>
            <p class="compass-open__close">
              The result is not a lack of intuition. It is intuitive information without a dependable
              container.
            </p>
          </header>

          <ol class="compass-open__recognition-stack">
            {
              recognitionCards.map((card, index) => (
                <li class:list={[{ "compass-open__recognition-stack-item--lead": index === 0 }]}>
                  <h3>{card.heading}</h3>
                  <p>{card.copy}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section
        class="tok-home__band tok-home__band--ocean compass-open__cost"
        aria-labelledby="compass-cost-heading"
      >
        <div class="tok-home__inner compass-open__cost-split">
          <header class="compass-open__cost-intro">
            <p class="tok-home__eyebrow">When the answer never quite lands</p>
            <h2 id="compass-cost-heading" class="tok-home__h2">
              Unstructured intuition creates more work, not more clarity
            </h2>
            <p class="tok-home__lede">
              Without a reliable interpretive container, capable readers often keep working the
              reading long after the useful signal has already arrived.
            </p>
          </header>

          <ol class="compass-open__cost-list">
            {
              practicalCostItems.map((item, index) => (
                <li>
                  <span class="compass-open__cost-index" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ol>

          <p class="compass-open__cost-bridge">
            The problem is rarely that nothing is coming through. The problem is knowing what
            belongs, what matters, and when the answer is complete.
          </p>
        </div>
      </section>

      <section
        class="tok-home__band tok-home__band--muted-teal compass-open__bridge"
        aria-labelledby="compass-bridge-heading"
      >
        <div class="tok-home__inner">
          <div class="compass-open__bridge-lead">
            <p class="tok-home__eyebrow">What changes</p>
            <h2 id="compass-bridge-heading" class="tok-home__h2">
              What once arrived as a vague feeling, image, tension, or half-formed knowing becomes
              information you can decode, test, and use.
            </h2>
            <p class="tok-home__lede">
              The COMPASS Method™ gives intuitive perception a disciplined interpretive structure. You
              learn to recognise the deeper pattern, test meaning against context, and translate
              pre-verbal information into clear understanding.
            </p>
          </div>
          <ul class="compass-open__outcome-asymmetric">
            {
              transformationOutcomes.map((item, index) => (
                <li
                  class:list={[
                    {
                      "compass-open__outcome-asymmetric-item--wide":
                        index === 0 || index === 4 || index === 9,
                    },
                  ]}
                >
                  <strong>{item.label}</strong>
                  <span>{item.copy}</span>
                </li>
              ))
            }
          </ul>
          <p class="tok-home__lede tok-home__lede--follow compass-open__bridge-end">
            You learn to see more of what is happening, understand what it means, and decide how to
            respond.
          </p>
        </div>
      </section>

      <section
        class="tok-home__band tok-home__band--cream compass-method__diff"
        aria-labelledby="compass-diff-heading"
      >
        <div class="tok-home__inner">
          <header class="compass-method__intro">
            <p class="tok-home__eyebrow">Why other training often stops too soon</p>
            <h2 id="compass-diff-heading" class="tok-home__h2">
              Knowing card meanings is not the same as knowing how to interpret what is happening.
            </h2>
            <p class="tok-home__lede">
              Most tarot and oracle education concentrates on symbols, keywords, spreads, and
              technique. Those foundations matter, but they do not fully address the moment when
              several impressions arrive at once and you must decide what belongs, what carries the
              most weight, and how the pieces resolve into one useful understanding.
            </p>
          </header>

          <ol class="compass-method__progression" aria-label="Meanings to intuition to interpretation">
            {
              differentiationBlocks.map((block, index) => (
                <li>
                  <span class="compass-method__progression-step" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <h3>{block.heading}</h3>
                  <p>{block.copy}</p>
                </li>
              ))
            }
          </ol>

          <p class="compass-method__highlight">
            The COMPASS Method™ teaches the part between perception and understanding.
          </p>
        </div>
      </section>

      <section
        class="tok-home__band tok-home__band--pale-teal compass-method__framework"
        aria-labelledby="compass-framework-heading"
      >
        <div class="tok-home__inner compass-method__framework-split">
          <div class="compass-method__intro">
            <p class="tok-home__eyebrow">A proprietary interpretive framework</p>
            <h2 id="compass-framework-heading" class="tok-home__h2">
              Seven pillars create the container. You learn how to work within it.
            </h2>
            <p class="tok-home__lede">
              The COMPASS Method™ is not another card-meaning system, spread library,
              psychic-development course, or fixed script. It is a structured framework for
              recognising, testing, organising, and communicating intuitive information.
            </p>
            <p class="tok-home__lede tok-home__lede--follow">
              Center and Seal form the bookends of the method. They establish how you enter the work
              and how you recognise completion. The five pillars within that container are not used as
              a rigid sequence. Their emphasis changes according to the reading, the context, and your
              own intuitive strengths.
            </p>
          </div>

          <ul class="compass-method__symbol-strip" aria-hidden="true">
            {
              compassPillars.map((pillar) => (
                <li>
                  <img
                    src={pillar.icon}
                    alt=""
                    width="72"
                    height="72"
                    loading="lazy"
                    decoding="async"
                  />
                  <span>{pillar.name}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section
        class="tok-home__band tok-home__band--cream compass-method__pillars-band"
        aria-labelledby="compass-pillars-heading"
      >
        <div class="tok-home__inner">
