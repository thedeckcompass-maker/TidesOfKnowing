---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteBase } from "../../lib/site";

const title = "Register COMPASS interest | Tides of Knowing";
const description =
  "Register interest in the next COMPASS cohort. Short form; responses are reviewed personally.";
const ogUrl = new URL("/compass/apply/", siteBase(Astro)).href;
---

<BaseLayout title={title} description={description} ogUrl={ogUrl} tdcPlacement="none">
  <article class="compass-apply page-inner">
    <header class="compass-apply__hero">
      <p class="compass-apply__eyebrow">COMPASS training</p>
      <h1 class="compass-apply__title">Register interest</h1>
      <p class="compass-apply__subtext">
        The next intake cycle is approaching. This short form helps me understand your practice and timing before enrolment opens.
      </p>
    </header>

    <section class="compass-apply__panel">
      <p class="compass-apply__form-note">
        This is a short interest form, reviewed personally. You can expect a response within 48 hours. The
        COMPASS Method is an original interpretive framework created by Tides of Knowing.
      </p>

      <form id="compass-application-form" class="compass-apply__form">
        <div class="compass-apply__grid">
          <label class="compass-apply__field">
            <span>Name *</span>
            <input name="name" type="text" autocomplete="name" required />
          </label>

          <label class="compass-apply__field">
            <span>Email *</span>
            <input name="email" type="email" autocomplete="email" required />
          </label>

          <fieldset
            class="compass-apply__fieldset compass-apply__fieldset--full"
            aria-describedby="compass-intake-hint"
          >
            <legend class="compass-apply__legend">What are you registering interest in? *</legend>
            <div class="compass-apply__intake-options">
              <label class="compass-apply__radio">
                <input
                  type="radio"
                  name="intakePreference"
                  value="Next cohort (Central Time, Mexico City)"
                  required
                />
                <span>Next cohort (Central Time, Mexico City)</span>
              </label>
              <label class="compass-apply__radio">
                <input
                  type="radio"
                  name="intakePreference"
                  value="General COMPASS interest (timing to be discussed)"
                />
                <span>General COMPASS interest (timing to be discussed)</span>
              </label>
            </div>
            <p id="compass-intake-hint" class="compass-apply__field-hint compass-apply__field-hint--intake">
              June and July are fully booked; August is unavailable due to relocation. Interest for the next cohort opens in August. Choose the general option if your timing is still open.
            </p>
          </fieldset>

          <label class="compass-apply__field">
            <span>Location</span>
            <input name="location" type="text" autocomplete="address-level2" />
          </label>

          <label class="compass-apply__field">
            <span>Experience level *</span>
            <select name="experience_level" required>
              <option value="">Select one</option>
              <option value="Beginner">Beginner</option>
              <option value="Developing">Developing</option>
              <option value="Experienced">Experienced</option>
            </select>
          </label>
        </div>

        <label class="compass-apply__field">
          <span>What is not working in your readings right now? *</span>
          <textarea name="current_situation" rows="5" required></textarea>
        </label>

        <label class="compass-apply__field">
          <span>What outcome are you wanting from COMPASS? *</span>
          <textarea name="desired_outcome" rows="5" required></textarea>
        </label>

        <label class="compass-apply__field">
          <span>Why now? *</span>
          <textarea name="why_now" rows="5" required></textarea>
        </label>

        <div class="compass-apply__actions">
          <button id="compass-apply-submit" type="submit" class="compass-apply__submit">
            Register interest
          </button>
          <p id="compass-apply-error" class="compass-apply__error" aria-live="polite"></p>
        </div>
      </form>

      <p id="compass-apply-success" class="compass-apply__success" hidden>
        Your interest has been received. I will review it personally and respond within 48 hours.
      </p>
    </section>
  </article>
</BaseLayout>

<script is:inline>
  (function () {
    const form = document.getElementById("compass-application-form");
    const submitBtn = document.getElementById("compass-apply-submit");
    const errorEl = document.getElementById("compass-apply-error");
    const successEl = document.getElementById("compass-apply-success");

    if (!(form instanceof HTMLFormElement)) return;
    if (!(submitBtn instanceof HTMLButtonElement)) return;

    form.addEventListener("submit", async function (event) {
      event.preventDefault();
      if (errorEl) errorEl.textContent = "";
      if (successEl) successEl.hidden = true;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting...";

      try {
        const response = await fetch("/api/compass-apply", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });

        const data = await response.json().catch(function () {
          return {};
        });

        if (!response.ok || !data.ok) {
          throw new Error(data.error || "Unable to submit right now. Please try again.");
        }

        form.reset();
        if (successEl) successEl.hidden = false;
      } catch (err) {
        if (errorEl) {
          errorEl.textContent =
            err instanceof Error ? err.message : "Unable to submit right now. Please try again.";
        }
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Register interest";
      }
    });
  })();
</script>

<style>
  .compass-apply {
    padding: clamp(2rem, 6vw, 4rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 46rem;
  }

  .compass-apply__hero {
    margin-bottom: 1.4rem;
  }

  .compass-apply__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .compass-apply__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.8vw, 2.75rem);
    line-height: 1.16;
    color: var(--tok-water);
  }

  .compass-apply__subtext {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.7;
  }

  .compass-apply__panel {
    padding: clamp(1rem, 3vw, 1.45rem);
    border-radius: var(--radius-control);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--tok-air) 20%, transparent) 0%,
      var(--tok-surface-reading) 100%
    );
  }

  .compass-apply__form-note {
    margin: 0 0 0.85rem;
    max-width: 70ch;
    padding: 0.55rem 0 0.55rem 0.65rem;
    border-left: 2px solid color-mix(in srgb, var(--tok-gold) 55%, transparent);
    background: color-mix(in srgb, var(--tok-gold) 5%, transparent);
    font-size: 0.84rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--tok-text-dark) 82%, transparent);
  }

  .compass-apply__form {
    display: grid;
    gap: 1rem;
  }

  .compass-apply__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }

  .compass-apply__fieldset {
    margin: 0;
    padding: 0;
    border: none;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .compass-apply__fieldset--full {
    grid-column: 1 / -1;
  }

  .compass-apply__legend {
    padding: 0;
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tok-water);
  }

  .compass-apply__intake-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
  }

  .compass-apply__radio {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--tok-text-dark);
    cursor: pointer;
  }

  .compass-apply__radio > span:last-child {
    font-family: var(--font-body);
    font-size: var(--tok-text-body-size);
    line-height: 1.55;
  }

  .compass-apply__radio input[type="radio"] {
    width: auto;
    min-width: 1rem;
    margin: 0;
    accent-color: var(--tok-gold);
    cursor: pointer;
  }

  .compass-apply__radio input:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 2px;
  }

  .compass-apply__field-hint {
    margin: 0.15rem 0 0;
    max-width: 70ch;
    font-size: 0.88rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--tok-text-dark) 78%, transparent);
  }

  .compass-apply__field-hint--intake {
    margin-top: 0.35rem;
  }

  @media (max-width: 640px) {
    .compass-apply__intake-options {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.45rem;
    }

    .compass-apply__radio {
      align-items: flex-start;
    }

    .compass-apply__radio input[type="radio"] {
      margin-top: 0.2rem;
    }
  }

  .compass-apply__field {
    display: grid;
    gap: 0.35rem;
  }

  .compass-apply__field > span {
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--tok-water);
  }

  .compass-apply__field input,
  .compass-apply__field select,
  .compass-apply__field textarea {
    width: 100%;
    font: inherit;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--tok-text-dark);
    background: var(--tok-surface-reading);
    border: 1px solid color-mix(in srgb, var(--tok-teal-light) 55%, transparent);
    border-radius: var(--radius-soft);
    padding: 0.62rem 0.7rem;
  }

  .compass-apply__field textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .compass-apply__field input:focus-visible,
  .compass-apply__field select:focus-visible,
  .compass-apply__field textarea:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 1px;
  }

  .compass-apply__actions {
    margin-top: 0.35rem;
  }

  .compass-apply__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.75rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-water);
    border: 2px solid var(--tok-gold);
    border-radius: var(--radius-2);
    background: transparent;
    cursor: pointer;
  }

  .compass-apply__submit:hover {
    background: color-mix(in srgb, var(--tok-gold) 14%, transparent);
  }

  .compass-apply__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .compass-apply__error {
    margin: 0.65rem 0 0;
    color: #8c2f2f;
    font-size: 0.95rem;
    line-height: 1.5;
    min-height: 1.2rem;
  }

  .compass-apply__success {
    margin: 1.1rem 0 0;
    padding: 0.85rem 1rem;
    border-left: 3px solid var(--tok-gold);
    background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
    font-size: 1rem;
    line-height: 1.65;
  }

  @media (max-width: 720px) {
    .compass-apply__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

