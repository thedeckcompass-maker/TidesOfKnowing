---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { siteBase } from "../../../lib/site";

const title = "Interest received | Tides of Knowing";
const description =
  "Thank you for registering your interest in The COMPASS Method. Leigh Spencer will review your note personally.";
const ogUrl = new URL("/compass/apply/thank-you/", siteBase(Astro)).href;
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={ogUrl}
  tdcPlacement="none"
  metaRobots="noindex, nofollow"
>
  <article class="compass-interest-thanks page-inner">
    <header class="compass-interest-thanks__hero">
      <p class="compass-interest-thanks__eyebrow">COMPASS Training</p>
      <h1 class="compass-interest-thanks__title">Interest received</h1>
    </header>

    <div class="compass-interest-thanks__body">
      <p class="compass-interest-thanks__p">
        Thank you for registering your interest in The COMPASS Method™.
      </p>
      <p class="compass-interest-thanks__p">
        I'll review your note personally and respond within 48 hours.
      </p>
      <p class="compass-interest-thanks__p">
        Registering interest does not obligate you to enrol. It simply helps me understand where your practice is now, which tier you are considering, and whether the next cohort timing is likely to suit.
      </p>
      <p class="compass-interest-thanks__p">
        If anything changes or you need to add timing details, email:
      </p>
      <p class="compass-interest-thanks__contact">
        <a href="mailto:hello@tidesofknowing.com">hello@tidesofknowing.com</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .compass-interest-thanks {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 40rem;
  }

  .compass-interest-thanks__hero {
    margin-bottom: 1.35rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
  }

  .compass-interest-thanks__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-compact);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .compass-interest-thanks__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.65rem, 3.5vw, 2rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--tok-water);
  }

  .compass-interest-thanks__body {
    padding: clamp(1rem, 3vw, 1.45rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .compass-interest-thanks__p,
  .compass-interest-thanks__contact {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-dark);
  }

  .compass-interest-thanks__contact {
    margin-bottom: 0;
  }

  .compass-interest-thanks__contact a {
    color: var(--tok-water);
    font-weight: 600;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .compass-interest-thanks__contact a:hover {
    color: var(--tok-teal);
  }
</style>
