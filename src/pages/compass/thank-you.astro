---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteBase } from "../../lib/site";

export const prerender = false;

const title = "Thank You | COMPASS Training";
const description =
  "Thank you for enrolling in The COMPASS Method™. Leigh will contact you personally.";
const ogUrl = new URL("/compass/thank-you/", siteBase(Astro)).href;
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={ogUrl}
  tdcPlacement="none"
  metaRobots="noindex, nofollow"
>
  <article class="compass-thanks page-inner">
    <header class="compass-thanks__hero">
      <p class="compass-thanks__eyebrow">COMPASS enrolment</p>
      <h1 class="compass-thanks__title">You’re enrolled. I’ll be in touch personally.</h1>
    </header>

    <div class="compass-thanks__body">
      <p class="compass-thanks__p">
        Thank you for enrolling in The COMPASS Method™. Your checkout is complete, and I’ll contact
        you directly at the email address you used to enrol.
      </p>
      <p class="compass-thanks__p">
        I’ll confirm your cohort dates, preparation details, and Deck Compass access with you
        personally.
      </p>
      <p class="compass-thanks__p">
        Please allow up to two working days for my message. If you need to reach me sooner, email{" "}
        <a href="mailto:hello@tidesofknowing.com">hello@tidesofknowing.com</a>.
      </p>

      <p class="compass-thanks__signoff">
        <span class="compass-thanks__sign-name">Leilia</span>
        <span class="compass-thanks__sign-role">Founder, The COMPASS Method™</span>
      </p>

      <p class="compass-thanks__actions">
        <a class="compass-thanks__cta compass-thanks__cta--primary" href="/">
          Return to Tides of Knowing
        </a>
        <a class="compass-thanks__cta compass-thanks__cta--secondary" href="/compass/">
          View the COMPASS programme
        </a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .compass-thanks {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 40rem;
  }

  .compass-thanks__hero {
    margin-bottom: 1.35rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
  }

  .compass-thanks__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-compact);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .compass-thanks__title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.65rem, 3.5vw, 2rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--tok-water);
  }

  .compass-thanks__body {
    padding: clamp(1rem, 3vw, 1.45rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .compass-thanks__p {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-dark);
  }

  .compass-thanks__body a {
    color: var(--tok-water);
    font-weight: 600;
  }

  .compass-thanks__body a:hover {
    color: var(--tok-teal);
  }

  .compass-thanks__signoff {
    margin: 1.5rem 0 1.75rem;
    display: grid;
    gap: 0.2rem;
  }

  .compass-thanks__sign-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--tok-text-dark);
  }

  .compass-thanks__sign-role {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: color-mix(in srgb, var(--tok-text-dark) 78%, transparent);
  }

  .compass-thanks__actions {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.1rem;
  }

  .compass-thanks__cta {
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .compass-thanks__cta--primary {
    color: var(--tok-water);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    text-decoration-line: underline;
  }

  .compass-thanks__cta--secondary {
    color: color-mix(in srgb, var(--tok-text-dark) 82%, transparent);
  }

  .compass-thanks__cta:hover {
    color: var(--tok-teal);
  }
</style>
