      h +=
        '<div class="tok2-shift-row tok2-shift-row--move"><div class="tok2-shift-label">The move</div><div class="tok2-shift-value">' +
        escHtml(formatBlockText(moveText)) +
        "</div></div>";
      h += "</div>";
