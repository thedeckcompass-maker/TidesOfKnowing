        escHtml(moveText) +
        "</span></div>";
      h += "</div>";
    }
    h += "</section>";

    const reflectionQ = reflectionQuestionForPair(c1, c2, p1, p2);
    const readDate = formatReadingDate();

    h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section tok2-reflection-wrap">';
    h += '<h3 class="tarot-tool__out-h3">Reflection Question</h3>';
    h += '<div class="tok2-reflection-block">';
    h += '<p class="tok2-reflection-lead">Before you leave this reading, ask:</p>';
    h += '<p class="tok2-reflection-question">' + escHtml(reflectionQ) + "</p>";
    h += '<p class="tok2-return-prompt">You read this on ' + escHtml(readDate) + ". Return in 7 days and ask what has shifted.</p>";
    h += "</div>";
    h += '<div class="tok2-deeper-invite">';
    h +=
      "<p>" +
      escHtml(
        "If this reading names something active between you and another person, the next layer is The Table Between Them. It explores what is spoken, what is unspoken, and what is waiting to emerge.",
      ) +
      "</p>";
    h += "</div>";

    const toolWrap = document.getElementById("tok2-tool");
    const threeCardHref =
      toolWrap instanceof HTMLElement && typeof toolWrap.dataset.threeCardHref === "string"
        ? toolWrap.dataset.threeCardHref.trim()
        : "";

    h += '<div class="tok2-tools-card">';
    h += '<p class="tools-eyebrow">Tarot tools</p>';
    h += '<div class="tok2-tools-list">';
    h += '<div class="tok2-tool">';
    h += '<div class="tok2-tool-line">';
    h += '<span class="tok2-tool-title">When Two Cards Meet</span>';
    h += '<span class="tok2-tool-meta">current</span>';
    h += "</div></div>";
    h += '<div class="tok2-tool">';
    h += '<div class="tok2-tool-line">';
    if (threeCardHref) {
      h +=
        '<a href="' +
        escAttr(threeCardHref) +
        '" class="tok2-tool-title">The Table Between Them</a>';
      h += '<span class="tok2-tool-meta">three-card interpreter</span>';
    } else {
      h += '<span class="tok2-tool-title">The Table Between Them</span>';
      h += '<span class="tok2-tool-meta">coming next</span>';
    }
    h += "</div>";
    if (threeCardHref) {
      h +=
        '<a href="' +
        escAttr(threeCardHref) +
        '" class="tok2-tool-subline">Open the three-card interpreter</a>';
    }
    h += "</div>";
    h += '<div class="tok2-tool">';
    h += '<div class="tok2-tool-line">';
    h += '<span class="tok2-tool-title">Repeated Card Meaning Tool</span>';
    h += '<span class="tok2-tool-meta">coming next</span>';
    h += "</div></div>";
    h += "</div></div>";

    const supportP1 =
      "This tool was built by Leigh Spencer — writer, intuitive guide, and fourth-generation Matakite. Matakite is a Māori term for those who carry inherited sight: the capacity to perceive what the visible world doesn't show. Leigh brings that lineage alongside 40+ years of tarot practice and 30 years as a professional journalist. The journalist disciplines the intuitive. The intuitive reads what the facts alone cannot reach. This work sits at that intersection.";
    const supportP2 = "If this reading gave you something useful, a coffee keeps the work going.";

    h += '<div class="support-block tok2-support">';
    h += "<p>" + escHtml(supportP1) + "</p>";
    h +=
      '<a href="https://www.buymeacoffee.com/tidesofknowing" target="_blank" rel="noopener noreferrer" class="bmc-image-link"><img src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png" alt="Buy Me a Coffee" class="bmc-image-button" loading="lazy" decoding="async" /></a>';
    h += "<p>" + escHtml(supportP2) + "</p>";
    h += "</div>";

    h += "</section>";

    out.innerHTML = h;
  }

  const sel1 = document.getElementById("tok2-card-1");
  const sel2 = document.getElementById("tok2-card-2");
  const btn = document.getElementById("tok2-read-btn");

  if (sel1 instanceof HTMLSelectElement) fillSelect(sel1);
  if (sel2 instanceof HTMLSelectElement) fillSelect(sel2);

  if (btn instanceof HTMLButtonElement) {
    btn.addEventListener("click", renderReading);
  }
</script>

