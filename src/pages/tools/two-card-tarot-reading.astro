  function normaliseRelevanceToken(str) {
    return String(str || "")
      .toLowerCase()
      .replace(/[^\w\s-]/g, "")
      .trim();
  }

  function selectRelevantExtendedKeywords(extendedKeywords = [], tokens = [], limit = 4) {
    if (!Array.isArray(extendedKeywords) || !extendedKeywords.length) return [];

    const relevanceTerms = new Set();

    tokens
      .map(normaliseRelevanceToken)
      .forEach((token) => {
        const terms = keywordRelevanceMap[token];
        if (Array.isArray(terms)) {
          terms.forEach((term) => relevanceTerms.add(term.toLowerCase()));
        }
      });

    const seen = new Set();

    const scored = extendedKeywords
      .filter(Boolean)
      .map((phrase) => {
        const text = String(phrase).trim();
        const lower = text.toLowerCase();
        let score = 0;

        relevanceTerms.forEach((term) => {
          if (lower.includes(term)) score += 1;
        });

        return { text, score };
      })
      .filter((item) => {
        const key = item.text.toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });

    const matched = scored
      .filter((item) => item.score > 0)
      .sort((a, b) => b.score - a.score)
      .map((item) => item.text);

    const fallback = scored
      .filter((item) => item.score === 0)
      .map((item) => item.text);

    return [...matched, ...fallback].slice(0, limit);
  }

  function scrubExtendedKeywordPhrase(phrase) {
    return cleanRelationalSceneLanguage(String(phrase || "").trim());
  }

  function splitMeaningSentences(str) {
    if (!str) return [];
    return String(str)
      .replace(/\s+/g, " ")
      .trim()
      .split(/(?<=[.!?])\s+/)
      .map((s) => s.trim())
      .filter(Boolean);
  }

  function selectRelevantMeaningSentences(coreMeaning = "", tokens = [], limit = 2) {
    const sentences = splitMeaningSentences(coreMeaning);
    if (!sentences.length) return [];

    const relevanceTerms = new Set();

    tokens
      .map(normaliseRelevanceToken)
      .forEach((token) => {
        const terms = keywordRelevanceMap[token];
        if (Array.isArray(terms)) {
          terms.forEach((term) => relevanceTerms.add(term.toLowerCase()));
        }
      });

    const seen = new Set();

    const scored = sentences
      .map((sentence) => {
        const cleaned =
          typeof cleanRelationalSceneLanguage === "function"
            ? cleanRelationalSceneLanguage(sentence)
            : sentence;

        const text = String(cleaned).trim();
        const lower = text.toLowerCase();
        let score = 0;

        relevanceTerms.forEach((term) => {
          if (lower.includes(term)) score += 1;
        });

        return { text, score };
      })
      .filter((item) => {
        if (!item.text) return false;
        const key = item.text.toLowerCase();
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });

    const matched = scored
      .filter((item) => item.score > 0)
      .sort((a, b) => b.score - a.score)
      .map((item) => item.text);

    const fallback = scored
      .filter((item) => item.score === 0)
      .map((item) => item.text);

    return [...matched, ...fallback].slice(0, limit);
  }

  function buildUnderneathSurfaceText(c1, c2, card1Lines = [], card2Lines = []) {
    const first = String(card1Lines[0] || "").trim();
    const second = String(card2Lines[0] || "").trim();
    const third = String(card1Lines[1] || "").trim();
    const fourth = String(card2Lines[1] || "").trim();

    const parts = [];

    if (first && second) {
      parts.push(
        `Underneath this pairing, ${c1.name} shows one side of the deeper pattern: ${sentenceCase(first)}. ${c2.name} shows the pressure point: ${sentenceCase(second)}.`,
      );
    } else if (first) {
      parts.push(`Underneath this pairing, ${c1.name} reveals the deeper pattern: ${sentenceCase(first)}.`);
    } else if (second) {
      parts.push(`Underneath this pairing, ${c2.name} reveals the pressure point: ${sentenceCase(second)}.`);
    }

    if (third || fourth) {
      parts.push(
        joinCleanSentences([
          "Together they name what still lies beneath the surface.",
          third,
          fourth,
        ].filter(Boolean)),
      );
    }

    return formatBlockText(joinCleanSentences(parts));
  }

  function normaliseSignalTerm(term) {
    const value = String(term || "").toLowerCase();

    const map = {
      fulfilling: "completion",
      accelerating: "acceleration",
      driving: "momentum",
      defeating: "conflict",
      ending: "ending",
      bonding: "connection",
    };

    return map[value] || value;
  }

  const ARCHETYPE_KEYS = new Set([
    "giving",
    "conflict",
    "holding",
    "withdrawal",
    "expansion",
    "dispersal",
    "pressure",
    "alignment",
    "shift",
    "focus",
    "opening",
    "closure",
  ]);

  /** Map displayed signal words (vocabulary or signalWordMap labels) to CSV archetype column keys. */
  function signalWordToArchetypeKey(displayToken) {
    const w = String(displayToken || "").toLowerCase().trim();
    if (!w) return "";
    const synonymToKey = {
      giving: "giving",
      conflict: "conflict",
      holding: "holding",
      withdrawal: "withdrawal",
      expansion: "expansion",
      dispersal: "dispersal",
      pressure: "pressure",
      alignment: "alignment",
      shift: "shift",
      focus: "focus",
      opening: "opening",
      closure: "closure",
      completion: "closure",
      momentum: "shift",
      connection: "alignment",
      depletion: "withdrawal",
      collapse: "closure",
      rupture: "conflict",
      concealment: "holding",
      acceleration: "expansion",
      rigidity: "holding",
      support: "giving",
      stability: "holding",
      direction: "focus",
      bonding: "alignment",
      ending: "closure",
      release: "dispersal",
      clarity: "focus",
      reflection: "shift",
      threshold: "opening",
      block: "holding",
      constraint: "holding",
      restriction: "holding",
      severance: "closure",
      depth: "withdrawal",
      drive: "shift",
      introduction: "opening",
      nurture: "giving",
      obscuring: "holding",
      stillness: "holding",
      structure: "holding",
      sustain: "giving",
      withholding: "holding",
    };
    if (synonymToKey[w]) return synonymToKey[w];
    if (ARCHETYPE_KEYS.has(w)) return w;
    return "";
  }

  function getInteractionArchetype(p1, p2) {
    const k1 = signalWordToArchetypeKey(p1);
    const k2 = signalWordToArchetypeKey(p2);
    if (!k1 || !k2) return "";
    const key = `${k1}|${k2}`;
    return interactionArchetypeMap[key] || "";
  }

  function vocabularyWord(card, isReversed) {
    const vocab = card.relationalVocabulary;
    if (!vocab) return null;

    const list = isReversed ? vocab.reversed : vocab.upright;
    if (!Array.isArray(list) || list.length === 0) return null;

    const preferred = [
      "threshold",
      "momentum",
      "connection",
      "completion",
      "depletion",
      "collapse",
      "rupture",
      "concealment",
      "acceleration",
      "rigidity",
      "support",
      "stability",
      "direction",
      "opening",
      "bonding",
      "ending",
      "conflict",
      "alignment",
      "pressure",
      "release",
      "clarity",
      "withdrawal",
      "reflection",
    ];

    const match = preferred.find((term) =>
      list.some((item) => String(item).toLowerCase() === term),
    );

    if (match) return normaliseSignalTerm(match);

    return normaliseSignalTerm(list[0]);
  }

  function signalWord(prefix, card, isReversed) {
    const vocab = vocabularyWord(card, isReversed);
    if (vocab) {
      return vocab.charAt(0).toUpperCase() + vocab.slice(1);
    }

    if (signalWordMap[prefix]) {
      return signalWordMap[prefix];
    }

    return "Shift";
  }

  function clean(v) {
    return String(v || "").trim();
  }

  function capitaliseFirst(text) {
    const value = clean(text);
    if (!value) return "";
    return value.charAt(0).toUpperCase() + value.slice(1);
  }

  function toSentenceCase(str) {
    const s = String(str ?? "").trim();
    if (!s) return "";
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function ensureTerminalPunctuation(str) {
    if (!str) return "";
    const trimmed = str.trim();
    return /[.!?]$/.test(trimmed) ? trimmed : `${trimmed}.`;
  }

  function sentenceCase(str) {
    if (!str) return "";
    const trimmed = str.trim();
    return trimmed.charAt(0).toUpperCase() + trimmed.slice(1);
  }

  function cleanSentence(str) {
    return ensureTerminalPunctuation(sentenceCase(str));
  }

  function ensureCompleteSentence(str) {
    if (!str) return "";
    let s = String(str).trim();
    if (!s) return "";

    const fragmentStart =
      /^(keeping|breaking|holding|creating|moving|drawing|pulling|fragmenting|circulating|redirecting|resisting|stabilising|stabilizing|opening|closing|expanding|contracting|disrupting|integrating|intensifying|softening|anchoring|testing|pressuring|scattering|gathering|withdrawing|amplifying|revealing|concealing)\b/i;

    if (fragmentStart.test(s)) {
      s = `It ${s}`;
    }

    s = s.charAt(0).toUpperCase() + s.slice(1);

    if (!/[.!?]$/.test(s)) {
      s += ".";
    }

    return s;
  }

  function lowerInitial(str) {
    if (!str) return "";
    const trimmed = String(str).trim();
    return trimmed.charAt(0).toLowerCase() + trimmed.slice(1);
  }

  function humaniseReadingSentence(str) {
    if (!str) return "";

    let text = String(str).trim();

    const replacements = [
      [/^Establishes a condition of /i, "creates "],
      [/^Establishes /i, "creates "],
      [/^Introduces /i, "brings in "],
      [/^Extends /i, "extends "],
      [/^Disrupts /i, "disrupts "],
      [/^Integrates /i, "integrates "],
      [/^Anchors /i, "anchors "],
      [/^Distorts /i, "distorts "],
      [/^Completes /i, "completes "],
      [/^Begins /i, "begins "],
      [/^Moves /i, "moves "],
      [/^Brings /i, "brings "],
      [/^Redirects /i, "redirects "],
      [/^Circulates /i, "circulates "],
      [/^Fragments adjacent cards within /i, "breaks the connection between the cards within "],
      [/^Fragments /i, "breaks "],
      [/^Adjacent cards through /i, "places the cards in relation through "],
    ];

    for (const [pattern, replacement] of replacements) {
      text = text.replace(pattern, replacement);
    }

    text = text
      .replace(/\bfield\b/gi, "situation")
      .replace(/\bmaterial\b/gi, "")
      .replace(/\bcondition\b/gi, "")
      .replace(/\s+/g, " ")
      .trim();

    return cleanSentence(text);
  }

  function humaniseReadingParagraph(text) {
    const raw = clean(text);
    if (!raw) return "";
    const spans = raw.split(/(?<=[.!?])\s+/).map((s) => s.trim()).filter(Boolean);
    if (spans.length === 0) return "";
    return spans.map((s) => humaniseReadingSentence(s)).filter(Boolean).join(" ");
  }

  function normaliseRelationalLanguage(str) {
    if (!str) return "";

    return String(str)
      .replace(/\bsets the field\b/gi, "establishes the situation")
      .replace(/\benters the field\b/gi, "enters the situation")
      .replace(/\banchors the field\b/gi, "anchors the situation")
      .replace(/\bestablishes a field\b/gi, "establishes a condition")
      .replace(/\bwithin the field\b/gi, "within the situation")
      .replace(/\bthe field is set as\b/gi, "This begins as")
      .replace(/\bincoming charge\b/gi, "what is already moving")
      .replace(/\bpreceding charge\b/gi, "what came before")
      .replace(/\bfield\b/gi, "situation");
  }

  function cleanRelationalSceneLanguage(str) {
    if (!str) return "";
    return String(str)
      .replace(/\badjacent cards?\b/gi, "the situation")
      .replace(/\bincoming charge\b/gi, "what enters")
      .replace(/\bpreceding charge\b/gi, "what came before")
      .replace(/\boperative condition\b/gi, "active condition")
      .replace(/\bfield condition\b/gi, "condition")
      .replace(/\bthe field\b/gi, "the room")
      .replace(/\brelationalEffect\b/gi, "")
      .replace(/\bextendedKeywords\b/gi, "")
      .replace(/\bcoreMeaning\b/gi, "")
      .replace(/\bcombinationLogic\b/gi, "")
      .replace(/\bpairingTendencies\b/gi, "")
      .replace(/\bspecificPairings\b/gi, "")
      .replace(/\s+/g, " ")
      .trim();
  }

  function formatBlockText(text) {
    const n = normaliseRelationalLanguage(clean(text));
    if (!n) return "";
    return cleanSentence(n);
  }

  function cleanInteractionSourceText(str) {
    if (!str) return "";
    const cleaned =
      typeof cleanRelationalSceneLanguage === "function"
        ? cleanRelationalSceneLanguage(String(str))
        : String(str);

    return formatBlockText(
      cleaned
        .replace(/\bUpright,\s*/gi, "")
        .replace(/\bReversed,\s*/gi, "")
        .replace(/\s+/g, " ")
        .trim(),
    );
  }

  function getPairingCategory(c1, c2) {
    const isMajor = c1?.arcana === "Major" || c2?.arcana === "Major";
    if (isMajor) return "majorArcana";

    const courtRanks = new Set(["Page", "Knight", "Queen", "King"]);
    const isCourt = courtRanks.has(c1?.rank) || courtRanks.has(c2?.rank);
    if (isCourt) return "courtCards";

    if (c1?.suit && c2?.suit && c1.suit === c2.suit) return "sameSuit";

    if (
      c1?.arcana === "Minor" &&
      c2?.arcana === "Minor" &&
      c1?.suit &&
      c2?.suit &&
      c1.suit !== c2.suit
    ) {
      return "conflictingSuit";
    }

    return "";
  }

  function getAuthoredInteractionText(c1, c2) {
    const specific1 = Array.isArray(c1?.combinationLogic?.specificPairings)
      ? c1.combinationLogic.specificPairings
      : [];

    const specific2 = Array.isArray(c2?.combinationLogic?.specificPairings)
      ? c2.combinationLogic.specificPairings
      : [];

    const matchFromC1 = specific1.find((line) =>
      String(line || "").toLowerCase().includes(String(c2?.name || "").toLowerCase()),
    );

    if (matchFromC1) {
      return cleanInteractionSourceText(matchFromC1);
    }

    const matchFromC2 = specific2.find((line) =>
      String(line || "").toLowerCase().includes(String(c1?.name || "").toLowerCase()),
    );

    if (matchFromC2) {
      return cleanInteractionSourceText(matchFromC2);
    }

    const category = getPairingCategory(c1, c2);
    if (!category) return "";

    const tendency1 = c1?.combinationLogic?.pairingTendencies?.[category] || "";
    if (tendency1 && String(tendency1).trim()) {
      return cleanInteractionSourceText(tendency1);
    }

    const tendency2 = c2?.combinationLogic?.pairingTendencies?.[category] || "";
    if (tendency2 && String(tendency2).trim()) {
      return cleanInteractionSourceText(tendency2);
    }

    return "";
  }

  function formatAuthoredInteractionForProse(c1, c2, authoredText) {
    if (!clean(authoredText)) return "";
    const lc = String(authoredText).toLowerCase();
    const n1 = String(c1?.name || "").toLowerCase();
    const n2 = String(c2?.name || "").toLowerCase();
    const hasBoth = n1 && n2 && lc.includes(n1) && lc.includes(n2);
    if (hasBoth) return authoredText;
    return formatBlockText(
      joinCleanSentences([
        `${c1.name} and ${c2.name} name a pair-specific pattern here.`,
        authoredText,
      ]),
    );
  }

  function selectStrongestSentence(str) {
    const raw = clean(str);
    if (!raw) return "";
    const parts = raw.split(/(?<=[.!?])\s+/).map((s) => s.trim()).filter(Boolean);
    if (parts.length <= 1) return raw;
    const longest = parts.slice().sort((a, b) => b.length - a.length)[0];
    return /[.!?]$/.test(longest) ? longest : `${longest}.`;
  }

  function joinCleanSentences(parts) {
    return parts
      .map((p) => String(p ?? "").trim())
      .filter(Boolean)
      .map((part) => cleanSentence(part))
      .join(" ");
  }

  function isGeneric(str) {
    const s = String(str || "");
    return (
      /pause before deciding|not yet decisive|supports, redirects, or resists/i.test(s) ||
      /the interaction depends on how the second energy meets the first/i.test(s) ||
      /the combined line resolves as support/i.test(s)
    );
  }

  function normaliseForDedupe(str) {
    return cleanSentence(panelFilterBanned(clean(str)))
      .toLowerCase()
      .replace(/\s+/g, " ")
      .trim();
  }

  function firstSentenceOnly(text) {
    const t = clean(text);
    if (!t) return "";
    const parts = t.split(/(?<=[.!?])\s+/);
    return parts[0] ? parts[0].trim() : t;
  }

  function sentencesHighlySimilar(a, b) {
    const na = normaliseForDedupe(formatBlockText(a));
    const nb = normaliseForDedupe(formatBlockText(b));
    if (!na || !nb) return false;
    if (na === nb) return true;
    const wa = na.split(/\s+/).filter((w) => w.length > 2);
    const wb = nb.split(/\s+/).filter((w) => w.length > 2);
    if (!wa.length || !wb.length) return false;
    const setB = new Set(wb);
    let inter = 0;
    for (const w of wa) {
      if (setB.has(w)) inter++;
    }
    const union = wa.length + wb.length - inter;
    return union > 0 && inter / union >= 0.45;
  }

  function stockOldSecondCardRelationLine(sig) {
    const t = clean(sig).toLowerCase();
    return (
      t === "the second card changes the conditions the first card had established." ||
      /\bthe second card changes the conditions the first card\b/.test(t)
    );
  }

  function signalDuplicatesInteractionSummary(sig, sum, c1, c2) {
    if (!clean(sum) || !clean(sig)) return false;
    if (sentencesHighlySimilar(sig, sum)) return true;
    const n1 = c1?.name || "";
    const n2 = c2?.name || "";
    if (n1 && n2 && sum.includes(n1) && sum.includes(n2) && stockOldSecondCardRelationLine(sig)) return true;
    return false;
  }

  function shortSignalNoticeFromLine(signalLine) {
    const r = splitSignalRoles(signalLine);
    if (!r.first || !r.second) return "";
    return cleanSentence(`Notice how ${r.first.toLowerCase()} meets ${r.second.toLowerCase()}.`);
  }

  /** Banned stock copy for scrubbed fragments (anchor/outcome, etc.). */
  function isGenericRelPanelCopy(str) {
    const t = String(str || "").toLowerCase().trim();
    if (!t) return false;
    if (isGeneric(str)) return true;
    if (t.includes("this pairing is not yet decisive")) return true;
    if (t.includes("whether the second energy supports") || t.includes("whether the second card supports"))
      return true;
    if (t.includes("depends on whether the second") && t.includes("supports")) return true;
    return false;
  }

  function scrubGenericRelPanelFragment(s) {
    return isGenericRelPanelCopy(s) ? "" : clean(s);
  }

  function splitSignalRoles(signalLine) {
    const parts = String(signalLine || "")
      .split("+")
      .map((part) => part.trim())
      .filter(Boolean);

    return {
      first: parts[0] || "",
      second: parts[1] || "",
      interaction: parts[2] || "",
    };
  }

  function buildSynthesisSentence(c1, c2, signalLine, f1, f2) {
    const roles = splitSignalRoles(signalLine);
    const first = roles.first.toLowerCase();
    const second = roles.second.toLowerCase();
    const interaction = roles.interaction.toLowerCase();

    if (first && second && interaction && interaction !== "shift") {
      return cleanSentence(
        `The meeting holds ${first} and ${second} in a ${interaction} pattern.`,
      );
    }

    if (first && second) {
      return cleanSentence(`One pattern meets another: ${first} meets ${second}.`);
    }

    if (f2?.responseBehaviour && f1?.relationalEffect) {
      return cleanSentence(`${c2.name} changes how ${c1.name} can continue`);
    }

    return "";
  }

  function buildInteractionFallbackSummary(c1, c2, signalLine) {
    const roles = splitSignalRoles(signalLine);
    const r1 = roles.first ? roles.first.toLowerCase() : "";
    const r2 = roles.second ? roles.second.toLowerCase() : "";
    if (r1 && r2) {
      return cleanSentence(
        `${c2.name} changes the conditions ${c1.name} had established, asking whether ${r1} can remain intact once ${r2} enters the room.`,
      );
    }
    return cleanSentence(
      `${c2.name} changes the conditions ${c1.name} had established, asking what can still hold once the second card enters.`,
    );
  }

  function buildInteractionConsequence(c1, c2, signalLine) {
    const roles = splitSignalRoles(signalLine);
    const first = roles.first ? roles.first.toLowerCase() : "";
    const second = roles.second ? roles.second.toLowerCase() : "";

    if (first && second) {
      return cleanSentence(
        `What ${c1.name} opens through ${first} is tested by ${second} when ${c2.name} enters the room.`,
      );
    }

    return cleanSentence(
      `${c2.name} changes what ${c1.name} had already set in motion.`,
    );
  }

  function buildMoveText(c1, c2, signalLine) {
    const roles = splitSignalRoles(signalLine);
    const first = roles.first ? roles.first.toLowerCase() : "";
    const second = roles.second ? roles.second.toLowerCase() : "";

    if (first && second) {
      return cleanSentence(
        `Watch the point where ${first} meets ${second}, and name what has to change next.`,
      );
    }

    return cleanSentence(
      `Watch what changes after ${c2.name} enters the room ${c1.name} has created.`,
    );
  }

  function isGenericInteractionLine(line) {
    const t = clean(line);
    if (!t) return true;
    return (
      t.startsWith("The interaction depends on how the second energy meets the first") ||
      t.includes("whether it supports, redirects, or resists what is already in motion")
    );
  }

  function interactionSignal(interactionLine) {
    if (!interactionLine || isGenericInteractionLine(interactionLine) || isGeneric(interactionLine)) {
      return "Shift";
    }

    const line = String(interactionLine || "").toLowerCase();

    if (line.includes("forward movement") || line.includes("rather than resistance")) return "Sequence";
    if (line.includes("exhaustion") || line.includes("collapse") || line.includes("finality")) return "Collapse";
    if (line.includes("confirms") || line.includes("completes") || line.includes("support")) return "Support";
    if (line.includes("natural sequence") || line.includes("builds on")) return "Sequence";
    if (line.includes("strain") || line.includes("forced movement")) return "Strain";
    if (line.includes("reset")) return "Reset";
    if (line.includes("breaks") || line.includes("overrides")) return "Rupture";
    if (line.includes("reduces") || line.includes("drains")) return "Dissolution";
    if (line.includes("tension")) return "Tension";

    return "Shift";
  }

  function extractOrientationText(text, orientation) {
    if (!text) return "";

    const uprightMatch = text.match(/Upright,([^]+?)(?=Reversed,|$)/);
    const reversedMatch = text.match(/Reversed,([^]+)$/);

    if (orientation === "upright" && uprightMatch) {
      return uprightMatch[1].trim();
    }

    if (orientation === "reversed" && reversedMatch) {
      return reversedMatch[1].trim();
    }

    // fallback if structure is not matched
    return text;
  }

  function panelFilterBanned(s) {
    return String(s || "")
      .replace(/\b(energy|journey|process|vibration)\b/gi, "")
      .replace(/\s+/g, " ")
      .trim();
  }

  /** Rewrites stock arrival phrasing into plain relational language (no "field" framing). */
  function panelHumaniseExistingDynamic(text) {
    let t = panelFilterBanned(String(text || "").trim());
    if (!t) return "";

    t = t.replace(
      /^Sets the field as\s+(.+?)\.\s*It defines the space as one where\s+/i,
      "This begins as $1, where ",
    );
    t = t.replace(
      /^Sets the field as\s+(.+?)\.\s*It defines the space as a place where\s+/i,
      "This begins as $1, where ",
    );
    t = t.replace(
      /^Sets the field as\s+(.+?)\.\s*It defines the space through\s+/i,
      "This begins as $1, through ",
    );
    t = t.replace(/^Sets the field as\s+/i, "This begins in a state of ");
    t = t.replace(/\.\s*It defines the space as one where\s+/gi, ", where ");
    t = t.replace(/\.\s*It defines the space as a place where\s+/gi, ", where ");
    t = t.replace(/\.\s*It defines the space through\s+/gi, ", through ");
    t = t.replace(/\.\s*Sets a field where\s+/gi, ". Here, ");
    t = t.replace(/^Sets a field where\s+/i, "The situation opens where ");
    t = t.replace(/\bthe field\b/gi, "the situation");
    t = t.replace(/\ba field\b/gi, "a situation");
    t = t.replace(/\s+/g, " ").trim();
    t = normaliseRelationalLanguage(t);
    return t;
  }

  function panelFieldCondition(f1) {
    const arrival = clean(f1.arrivalBehaviour);
    const essence = clean(f1.essenceSentence);
    if (arrival && essence && arrival !== essence) {
      return joinCleanSentences(
        [arrival, essence].map((x) => panelHumaniseExistingDynamic(panelFilterBanned(x))),
      );
    }
    const merged = arrival || essence;
    return joinCleanSentences([panelHumaniseExistingDynamic(panelFilterBanned(merged))].filter(Boolean));
  }

  function panelIncomingPressure(f2) {
    const rsp = clean(f2.responseBehaviour);
    const rel = humaniseEffect(f2.relationalEffect);
    const joined = joinCleanSentences(
      [rsp, rel]
        .filter(Boolean)
        .map((p) => panelHumaniseExistingDynamic(panelFilterBanned(p))),
    );
    return selectStrongestSentence(joined);
  }

  /** Card 1 arrival + essence, scene-scrubbed (not framed); used only in Before Card 2 Arrived. */
  function sceneCard1EstablishedBody(f1) {
    const arrival = clean(f1.arrivalBehaviour);
    const essence = clean(f1.essenceSentence);
    if (!arrival && !essence) return "";
    let inner;
    if (arrival && essence && arrival !== essence) {
      inner = joinCleanSentences(
        [arrival, essence].map((x) => panelHumaniseExistingDynamic(panelFilterBanned(x))),
      );
    } else {
      inner = joinCleanSentences([panelHumaniseExistingDynamic(panelFilterBanned(arrival || essence))].filter(Boolean));
    }
    inner = cleanRelationalSceneLanguage(inner);
    if (!clean(inner)) return "";
    return humaniseReadingParagraph(inner);
  }

  function buildBeforeCard2ArrivedProse(c1, c2, f1) {
    const body = sceneCard1EstablishedBody(f1);
    if (!clean(body)) return "";
    const lead = `Before ${c2.name} arrived, ${c1.name} had already set what the room would be asked to hold.`;
    return joinCleanSentences([lead, body]);
  }

  function buildTheArrivalProse(c1, c2, f2, rev2, whenSecondText) {
    const rspBase = scrubGenericRelPanelFragment(clean(f2.responseBehaviour));
    let rsp = "";
    if (rspBase) {
      rsp = humaniseReadingSentence(
        cleanRelationalSceneLanguage(panelHumaniseExistingDynamic(panelFilterBanned(rspBase))),
      );
      if (isGenericRelPanelCopy(rsp)) rsp = "";
    }

    let relH = "";
    if (clean(String(f2.relationalEffect || ""))) {
      relH = humaniseReadingSentence(
        ensureCompleteSentence(humaniseEffect(f2.relationalEffect)),
      );
      relH = cleanRelationalSceneLanguage(relH);
      if (!clean(relH)) relH = "";
    }

    let whenH = "";
    const whenRaw = scrubGenericRelPanelFragment(clean(String(whenSecondText || "")));
    if (
      whenRaw &&
      !isGeneric(whenRaw) &&
      !isGenericInteractionLine(whenRaw) &&
      !isGenericRelPanelCopy(whenRaw)
    ) {
      whenH = humaniseReadingSentence(
        cleanRelationalSceneLanguage(panelHumaniseExistingDynamic(panelFilterBanned(whenRaw))),
      );
      if (isGenericRelPanelCopy(whenH)) whenH = "";
    }

    if (!rsp && !relH && !whenH) return "";

    const orient = rev2 ? " reversed" : "";
    const lead = `${c2.name} enters${orient} into what ${c1.name} had already set in motion in the room, and the two cards meet on those terms.`;
    const details = joinCleanSentences([rsp, relH, whenH].filter(Boolean));
    if (!details) return cleanSentence(lead);
    return joinCleanSentences([lead, details]);
  }

  function panelInteractionResult(
    interactionLine,
    verdictText,
    f1,
    f2,
    c1,
    c2,
    signalLine,
    panelExistingText,
    panelIncomingText,
    verdictUsedInSignal,
  ) {
    const il = clean(interactionLine);
    const classifyFirst = il ? firstSentenceOnly(il) : "";
    const classifyOk =
      il &&
      !isGenericInteractionLine(il) &&
      !isGeneric(il) &&
      !isGeneric(classifyFirst) &&
      !/the combined line resolves as support/i.test(classifyFirst);

    let summary = "";
    if (classifyOk) {
      summary = cleanSentence(panelFilterBanned(classifyFirst));
    } else {
      const syn = buildSynthesisSentence(c1, c2, signalLine, f1, f2);
      if (clean(syn) && !isGeneric(syn)) {
        summary = syn;
      } else {
        summary = cleanSentence(panelFilterBanned(buildInteractionFallbackSummary(c1, c2, signalLine)));
      }
    }
    if (isGeneric(summary)) {
      const syn = buildSynthesisSentence(c1, c2, signalLine, f1, f2);
      if (clean(syn) && !isGeneric(syn)) {
        summary = syn;
      } else {
        summary = cleanSentence(panelFilterBanned(buildInteractionFallbackSummary(c1, c2, signalLine)));
      }
    }

    summary = cleanSentence(panelFilterBanned(firstSentenceOnly(summary)));

    let note = "";
    const vt = clean(verdictText);
    if (vt && !isGeneric(vt) && !verdictUsedInSignal) {
      const v = cleanSentence(panelFilterBanned(firstSentenceOnly(vt)));
      if (
        !isGeneric(v) &&
        normaliseForDedupe(v) !== normaliseForDedupe(summary) &&
        normaliseForDedupe(v) !== normaliseForDedupe(panelExistingText || "") &&
        normaliseForDedupe(v) !== normaliseForDedupe(panelIncomingText || "")
      ) {
        note = v;
      }
    }
    if (!clean(note) || isGeneric(note)) {
      const roles = splitSignalRoles(signalLine);
      const firstN = roles.first.toLowerCase();
      const secondN = roles.second.toLowerCase();
      note = cleanSentence(
        firstN && secondN
          ? `Watch the point where ${firstN} meets ${secondN}, and notice whether the contact steadies the pattern or bends it out of shape.`
          : `Watch what changes when ${c2.name} enters the room ${c1.name} has created.`,
      );
    }
    if (normaliseForDedupe(note) === normaliseForDedupe(summary)) {
      note = "";
    }
    if (
      clean(note) &&
      normaliseForDedupe(firstSentenceOnly(note)) === normaliseForDedupe(summary)
    ) {
      note = "";
    }

    const summaryOut = formatBlockText(summary);
    let noteOut = note ? formatBlockText(note) : "";
    if (normaliseForDedupe(noteOut) === normaliseForDedupe(summaryOut)) {
      noteOut = "";
    }

    return {
      summary: summaryOut,
      note: noteOut,
      full: joinCleanSentences([summaryOut, noteOut].filter(Boolean)),
    };
  }

  function reflectionQuestionForPair(c1, c2, p1, p2, signalLine) {
    const n1 = c1.name;
    const n2 = c2.name;
    if (p1 === "opens" && (p2 === "drives" || p2 === "propels" || p2 === "focuses")) {
      return `What wants to land clearly once ${n2} gives direction to how ${n1} opened the pattern?`;
    }
    if ((p1 === "pairs" && p2 === "completes") || (p1 === "aligns" && p2 === "completes")) {
      return `What would deepen if you trusted what ${n1} and ${n2} are already settling into together?`;
    }
    if (
      (p1 === "depletes" && p2 === "drives") ||
      (p1 === "drains" && p2 === "drives") ||
      (p1 === "cuts" && p2 === "depletes") ||
      (p1 === "pressures" && p2 === "shatters")
    ) {
      return `Where might you still be adding force after ${n1} has already thinned the ground that ${n2} crosses?`;
    }
    if (p1 === "withholds" && p2 === "accelerates") {
      return `What stays withheld that ${n2} could be outrunning before ${n1} has finished holding it back?`;
    }
    if ((p1 === "constrains" || p1 === "structures" || p1 === "binds") && p2 === "shatters") {
      return `What are you bracing to keep upright that ${n2} is already taking down away from ${n1}'s frame?`;
    }
    if (p1 === "nourishes" && p2 === "sustains") {
      return `What would grow more steadily if you let ${n1} and ${n2} keep feeding what they have started?`;
    }
    const roles = splitSignalRoles(signalLine || "");
    const first = roles.first ? roles.first.toLowerCase() : "";
    const second = roles.second ? roles.second.toLowerCase() : "";
    if (first && second) {
      return `Where is ${first} being changed by ${second}, and what does that reveal?`;
    }
    return `What changes when ${n2} enters the room ${n1} has created?`;
  }

  function formatReadingDate() {
    try {
      return new Intl.DateTimeFormat("en-GB", {
        day: "numeric",
        month: "long",
        year: "numeric",
      }).format(new Date());
    } catch {
      return new Date().toLocaleDateString();
    }
  }

  function renderReading() {
    const sel1 = document.getElementById("tok2-card-1");
    const sel2 = document.getElementById("tok2-card-2");
    const out = document.getElementById("tok2-output");
    if (!(sel1 instanceof HTMLSelectElement) || !(sel2 instanceof HTMLSelectElement) || !(out instanceof HTMLElement)) return;

    if (!sel1.value || !sel2.value) {
      out.innerHTML = '<p class="tarot-tool__out-p">Select both cards to continue.</p>';
      return;
    }

    const c1 = findCardByName(sel1.value);
    const c2 = findCardByName(sel2.value);
    if (!c1 || !c2) {
      out.innerHTML = '<p class="tarot-tool__out-p">Could not load one or both cards from this interaction.</p>';
      return;
    }

    const rev1 = readOrientReversed("tok2_orient_1");
    const rev2 = readOrientReversed("tok2_orient_2");
    const f1 = face(c1, rev1);
    const f2 = face(c2, rev2);
    const l1 = orientationLabel(rev1);
    const l2 = orientationLabel(rev2);

    const imgCls1 = "tarot-tool__card-img" + (rev1 ? " tarot-tool__card-img--reversed" : "");
    const imgCls2 = "tarot-tool__card-img" + (rev2 ? " tarot-tool__card-img--reversed" : "");
    const alt1 = escAttr(c1.name + " (" + l1 + ")");
    const alt2 = escAttr(c2.name + " (" + l2 + ")");

    const whenFirst1 = c1.combinationLogic && String(c1.combinationLogic.whenFirst || "").trim();
    const whenSecond2 = c2.combinationLogic && String(c2.combinationLogic.whenSecond || "").trim();
    const o1 = rev1 ? "reversed" : "upright";
    const o2 = rev2 ? "reversed" : "upright";
    const whenFirstText = extractOrientationText(whenFirst1, o1);
    const whenSecondText = extractOrientationText(whenSecond2, o2);

    const src1 = cardImagePath(c1);
    const src2 = cardImagePath(c2);
    const imgErr = "this.style.display='none';this.nextElementSibling.style.display='block';";

    const p1 = effectPrefix(f1.relationalEffect);
    const p2 = effectPrefix(f2.relationalEffect);

    const classifyLine = classifyInteraction(p1, p2, c1, c2);
    const authoredInteractionText = getAuthoredInteractionText(c1, c2);
    const panelField = panelFieldCondition(f1);
    const panelIncoming = panelIncomingPressure(f2);
    const s1 = signalWord(p1, c1, rev1);
    const s2 = signalWord(p2, c2, rev2);
    const archetypeProse = getInteractionArchetype(s1, s2);
    const interactionLineForPanel = clean(archetypeProse) ? archetypeProse : classifyLine;
    const s3 = interactionSignal(classifyLine);

    const signal = s1 + " + " + s2 + " + " + s3;

    let verdictText = "";

    if (
      (p1 === "depletes" && p2 === "drives") ||
      (p1 === "drains" && p2 === "drives") ||
      (p1 === "cuts" && p2 === "depletes") ||
      (p1 === "pressures" && p2 === "shatters")
    ) {
      verdictText =
        "This moves toward breakdown. Stop feeding the pattern and step back from escalation.";
    }

    if (
      (p1 === "pairs" && p2 === "completes") ||
      (p1 === "aligns" && p2 === "completes") ||
      (p1 === "nourishes" && p2 === "sustains")
    ) {
      verdictText =
        "This is stabilising. Let it develop without forcing a new problem onto it.";
    }

    if (
      (p1 === "opens" && p2 === "drives") ||
      (p1 === "opens" && p2 === "propels") ||
      (p1 === "opens" && p2 === "focuses")
    ) {
      verdictText =
        "This has forward motion. Let the opening become direction before interfering with it.";
    }

    if (p1 === "withholds" && p2 === "accelerates") {
      verdictText =
        "Do not confuse speed with resolution. Slow the exchange until what is hidden becomes clear.";
    }

    if (
      (p1 === "deepens" && p2 === "slows") ||
      (p1 === "withholds" && p2 === "slows") ||
      (["deepens", "stills", "withholds", "draws", "reduces", "slows"].includes(p1) &&
        ["deepens", "stills", "withholds", "draws", "reduces", "slows"].includes(p2))
    ) {
      verdictText =
        "This needs reflection, not pressure. Let the deeper signal clarify before acting.";
    }

    if (
      (p1 === "constrains" && p2 === "shatters") ||
      (p1 === "structures" && p2 === "shatters") ||
      (p1 === "binds" && p2 === "shatters") ||
      c2.id === "the-tower" ||
      c2.name === "The Tower"
    ) {
      verdictText = "This is breaking open. Stop trying to preserve what can no longer hold.";
    }

    const resolvedSignalSentence = "";
    let signalSentence = "";
    if (resolvedSignalSentence && resolvedSignalSentence.length > 0) {
      signalSentence = resolvedSignalSentence;
    }
    if (!signalSentence || isGeneric(signalSentence)) {
      const il = clean(classifyLine);
      if (il && !isGenericInteractionLine(il) && !isGeneric(il)) {
        const cand = cleanSentence(panelFilterBanned(firstSentenceOnly(il)));
        if (!isGeneric(cand)) signalSentence = cand;
      }
    }
    if (!signalSentence || isGeneric(signalSentence)) {
      const syn = buildSynthesisSentence(c1, c2, signal, f1, f2);
      if (clean(syn) && !isGeneric(syn)) {
        signalSentence = syn;
      }
    }
    if (!signalSentence || isGeneric(signalSentence)) {
      const sigT = String(signal || "").trim();
      if (sigT) {
        signalSentence = joinCleanSentences([
          "This meeting moves through " + sigT.toLowerCase() + ".",
          "Do not force a conclusion before the pattern has shown itself.",
        ]);
      }
    }
    if (!signalSentence || isGeneric(signalSentence)) {
      signalSentence =
        "Pause before deciding. Observe the pair until the next step stays clear.";
    }
    if (
      panelIncoming &&
      signalSentence &&
      normaliseForDedupe(signalSentence) === normaliseForDedupe(panelIncoming)
    ) {
      const sigT = String(signal || "").trim();
      if (sigT) {
        signalSentence = joinCleanSentences([
          "This meeting moves through " + sigT.toLowerCase() + ".",
          "Do not force a conclusion before the pattern has shown itself.",
        ]);
      }
    }

    const verdictUsedInSignal = false;

    let panelIx = panelInteractionResult(
      interactionLineForPanel,
      verdictText,
      f1,
      f2,
      c1,
      c2,
      signal,
      panelField,
      panelIncoming,
      verdictUsedInSignal,
    );

    if (clean(authoredInteractionText)) {
      const authoredSummary = formatAuthoredInteractionForProse(c1, c2, authoredInteractionText);
      if (clean(authoredSummary)) {
        panelIx = {
          summary: authoredSummary,
          note: "",
          full: authoredSummary,
        };
      }
    }

    const sigNorm = normaliseForDedupe(formatBlockText(signalSentence));
    const ixNorm = normaliseForDedupe(panelIx.summary);
    if (sigNorm === ixNorm) {
      const cons = formatBlockText(buildInteractionConsequence(c1, c2, signal));
      let noteAdj = panelIx.note;
      if (noteAdj && normaliseForDedupe(noteAdj) === normaliseForDedupe(cons)) {
        noteAdj = "";
      }
      panelIx = {
        summary: cons,
        note: noteAdj,
        full: joinCleanSentences([cons, noteAdj].filter(Boolean)),
      };
      const shortSig = shortSignalNoticeFromLine(signal);
      signalSentence = shortSig || "";
    }

    const card1Action = humaniseReadingSentence(
      ensureCompleteSentence(humaniseEffect(f1.relationalEffect)),
    );
    const card2Action = humaniseReadingSentence(
      ensureCompleteSentence(humaniseEffect(f2.relationalEffect)),
    );
    const openingProse = joinCleanSentences([
      `${c1.name} sets the tone here`,
      card1Action,
      `When ${c2.name} enters, the pattern shifts`,
      card2Action,
    ]);

    const interactionSummary = clean(panelIx.summary) ? String(panelIx.summary).trim() : "";
    const interactionNote = clean(panelIx.note) ? String(panelIx.note).trim() : "";
    const ndIx = (s) => normaliseForDedupe(s);
    if (clean(interactionSummary) && clean(signalSentence) && signalDuplicatesInteractionSummary(signalSentence, interactionSummary, c1, c2)) {
      const shortSig = shortSignalNoticeFromLine(signal);
      signalSentence = shortSig || "";
    }
    const showSummary =
      Boolean(interactionSummary) && ndIx(interactionSummary) !== ndIx(openingProse);
    const showNote =
      Boolean(interactionNote) &&
      ndIx(interactionNote) !== ndIx(openingProse) &&
      (!showSummary || ndIx(interactionNote) !== ndIx(interactionSummary));

    let h = "";

    h += '<div class="signal-block">';
    h += '<div class="signal-label">The Signal</div>';
    h +=
      '<p class="tok2-section-intro">' +
      escHtml("Three signals name the movement between the cards.") +
      "</p>";
    h += '<div class="signal-words">' + escHtml(signal) + "</div>";
    if (clean(formatBlockText(signalSentence))) {
      h += '<div class="signal-note">' + escHtml(formatBlockText(signalSentence)) + "</div>";
    }
    h += "</div>";

    h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section">';
    h += '<h3 class="tarot-tool__out-h3">The Two Cards</h3>';
    h +=
      '<p class="tok2-section-intro">' +
      escHtml(`${c1.name} holds the room. ${c2.name} enters.`) +
      "</p>";

    h += '<div class="tarot-tool__combo-images">';
    h += '<div class="card-block"><div class="tarot-tool__card-slot"><img class="' +
      imgCls1 +
      '" src="' +
      escAttr(src1) +
      '" alt="' +
      alt1 +
      '" loading="lazy" decoding="async" onerror="' +
      imgErr +
      '" /><p class="tarot-tool__card-placeholder" style="display:none;">Image unavailable</p></div>';
    h +=
      '<div class="card-caption"><span class="caption-card">' +
      escHtml(c1.name) +
      '</span><br/><span class="caption-orient">' +
      escHtml(l1) +
      "</span></div></div>";
    h += '<div class="card-block"><div class="tarot-tool__card-slot"><img class="' +
      imgCls2 +
      '" src="' +
      escAttr(src2) +
      '" alt="' +
      alt2 +
      '" loading="lazy" decoding="async" onerror="' +
      imgErr +
      '" /><p class="tarot-tool__card-placeholder" style="display:none;">Image unavailable</p></div>';
    h +=
      '<div class="card-caption"><span class="caption-card">' +
      escHtml(c2.name) +
      '</span><br/><span class="caption-orient">' +
      escHtml(l2) +
      "</span></div></div>";
    h += "</div>";

    h += "</section>";

    const beforeCard2Prose = buildBeforeCard2ArrivedProse(c1, c2, f1);
    const beforeCard2Out = beforeCard2Prose
      ? formatBlockText(cleanRelationalSceneLanguage(beforeCard2Prose))
      : "";
    if (clean(beforeCard2Out)) {
      h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section">';
      h += '<h3 class="tarot-tool__out-h3">Before Card 2 Arrived</h3>';
      h += '<div class="tok2-prose">';
      h +=
        '<p class="tok2-section-intro">' +
        escHtml("First, look at what was already established.") +
        "</p>";
      h += '<p class="tarot-tool__out-p">' + escHtml(beforeCard2Out) + "</p>";
      h += "</div>";
      h += "</section>";
    }

    const theArrivalProse = buildTheArrivalProse(c1, c2, f2, rev2, whenSecondText);
    const theArrivalOut = theArrivalProse
      ? formatBlockText(cleanRelationalSceneLanguage(theArrivalProse))
      : "";
    if (clean(theArrivalOut)) {
      h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section">';
      h += '<h3 class="tarot-tool__out-h3">The Arrival</h3>';
      h += '<div class="tok2-prose">';
      h +=
        '<p class="tok2-section-intro">' +
        escHtml("Now notice what changes when the second card enters.") +
        "</p>";
      h += '<p class="tarot-tool__out-p">' + escHtml(theArrivalOut) + "</p>";
      h += "</div>";
      h += "</section>";
    }

    const signalTokens = [s1, s2, s3];
    const card1ActiveKeywords = selectRelevantExtendedKeywords(f1.extendedKeywords || [], signalTokens, 4)
      .map(scrubExtendedKeywordPhrase)
      .filter((p) => clean(p));
    const card2ActiveKeywords = selectRelevantExtendedKeywords(f2.extendedKeywords || [], signalTokens, 4)
      .map(scrubExtendedKeywordPhrase)
      .filter((p) => clean(p));
    if (card1ActiveKeywords.length || card2ActiveKeywords.length) {
      h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section">';
      h += '<h3 class="tarot-tool__out-h3">What\u2019s Actually in Play</h3>';
      h += '<div class="tok2-prose tok2-inplay">';
      h +=
        '<p class="tarot-tool__out-p tok2-inplay-intro tok2-section-intro">' +
        escHtml("These are the specific textures activated by the meeting.") +
        "</p>";
      if (card1ActiveKeywords.length) {
        h += '<div class="tok2-inplay-block">';
        h +=
          '<p class="tok2-inplay-label">' +
          escHtml(c1.name + " is bringing:") +
          "</p>";
        h += '<ul class="tok2-extended-kw-list">';
        for (const phrase of card1ActiveKeywords) {
          h += '<li>' + escHtml(phrase) + "</li>";
        }
        h += "</ul></div>";
      }
      if (card2ActiveKeywords.length) {
        h += '<div class="tok2-inplay-block">';
        h +=
          '<p class="tok2-inplay-label">' +
          escHtml(c2.name + " is bringing:") +
          "</p>";
        h += '<ul class="tok2-extended-kw-list">';
        for (const phrase of card2ActiveKeywords) {
          h += '<li>' + escHtml(phrase) + "</li>";
        }
        h += "</ul></div>";
      }
      h += "</div></section>";
    }

    if (clean(openingProse) || showSummary || showNote) {
      h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section">';
      h += '<h3 class="tarot-tool__out-h3">The Interaction</h3>';
      h += '<div class="tok2-prose tok2-interaction">';
      h +=
        '<p class="tok2-section-intro">' +
        escHtml("This is what the two cards produce together.") +
        "</p>";
      if (clean(openingProse)) {
        h += '<p class="tarot-tool__out-p tarot-tool__out-p--signal">' + escHtml(openingProse) + "</p>";
      }
      if (showSummary) {
        h += '<p class="tarot-tool__out-p">' + escHtml(interactionSummary) + "</p>";
      }
      if (showNote) {
        h += '<p class="tarot-tool__out-p tarot-tool__out-p--note">' + escHtml(interactionNote) + "</p>";
      }
      h += "</div></section>";
    }

    const underneathForbidNorms = new Set();
    [beforeCard2Out, theArrivalOut, humaniseReadingParagraph(panelField), openingProse, interactionSummary].forEach(
      (block) => {
        if (!clean(block)) return;
        underneathForbidNorms.add(normaliseForDedupe(block));
        splitMeaningSentences(block).forEach((s) => {
          if (clean(s)) underneathForbidNorms.add(normaliseForDedupe(s));
        });
      },
    );

    const card1MeaningLines = selectRelevantMeaningSentences(f1.coreMeaning, signalTokens, 2).filter(
      (ln) => clean(ln) && !underneathForbidNorms.has(normaliseForDedupe(ln)),
    );
    const card2MeaningLines = selectRelevantMeaningSentences(f2.coreMeaning, signalTokens, 2).filter(
      (ln) => clean(ln) && !underneathForbidNorms.has(normaliseForDedupe(ln)),
    );
    const underneathSurfaceText = buildUnderneathSurfaceText(c1, c2, card1MeaningLines, card2MeaningLines);

    if (clean(underneathSurfaceText)) {
      h += '<section class="tarot-tool__out-block tok2-read-block tok2-out-section">';
      h += '<h3 class="tarot-tool__out-h3">Underneath the Surface</h3>';
      h += '<div class="tok2-prose">';
      h +=
        '<p class="tok2-section-intro">' +
        escHtml("This is the deeper pattern beneath the exchange.") +
        "</p>";
      h += '<p class="tarot-tool__out-p">' + escHtml(underneathSurfaceText) + "</p>";
      h += "</div></section>";
    }

    h +=
      '<section class="tarot-tool__out-block tok2-read-block tok2-out-section"><h3 class="tarot-tool__out-h3">What Wants to Shift</h3>';
    h +=
      '<p class="tok2-section-intro">' +
      escHtml("This is the practical movement the reading is pointing toward.") +
      "</p>";
    {
      let moveText = null;

      if (
        (p1 === "depletes" && p2 === "drives") ||
        (p1 === "drains" && p2 === "drives") ||
        (p1 === "cuts" && p2 === "depletes") ||
        (p1 === "pressures" && p2 === "shatters")
      ) {
        moveText =
          "Stop trying to recover this through more force. The second card is not repairing the first condition; it is carrying it toward exhaustion, collapse, or finality.";
      }

      if (
        !moveText &&
        ((p1 === "constrains" && p2 === "shatters") ||
          (p1 === "structures" && p2 === "shatters") ||
          (p1 === "binds" && p2 === "shatters"))
      ) {
        moveText =
          "Stop trying to hold the structure together by force. The second card is exposing what can no longer be contained, controlled, or repaired by maintaining the old frame.";
      }

      if (
        !moveText &&
        ((p1 === "opens" && p2 === "focuses") ||
          (p1 === "introduces" && p2 === "drives") ||
          (p1 === "pairs" && p2 === "completes") ||
          (p1 === "aligns" && p2 === "completes"))
      ) {
        moveText =
          "Let the sequence complete before questioning it. The second card is not fighting the first; it is giving direction, shape, or completion to what has already begun.";
      }

      if (
        !moveText &&
        ((p1 === "nourishes" && p2 === "sustains") ||
          (p1 === "opens" && p2 === "nourishes") ||
          (p1 === "stabilises" && p2 === "sustains"))
      ) {
        moveText =
          "Let the connection develop instead of forcing a new question onto it. The second card appears to confirm, complete, or stabilise what the first has already opened.";
      }

      if (!moveText && p1 === "withholds" && p2 === "accelerates") {
        moveText =
          "Do not mistake speed for resolution. Something important is still withheld, and movement without alignment may increase strain rather than solve it.";
      }

      if (
        moveText === null &&
        ((p1 === "deepens" && p2 === "reduces") ||
          (p1 === "deepens" && p2 === "draws") ||
          (p1 === "withholds" && p2 === "draws") ||
          (p1 === "stills" && p2 === "draws") ||
          (p1 === "deepens" && p2 === "stills") ||
          (p1 === "deepens" && p2 === "slows") ||
          (p1 === "withholds" && p2 === "slows"))
      ) {
        moveText =
          "Do not rush this into action. Stay with what is being revealed, reduce the noise, and let the deeper signal become clear before deciding what comes next.";
      }

      if (
        moveText === null &&
        ["deepens", "stills", "withholds", "draws", "reduces", "slows"].includes(p1) &&
        ["deepens", "stills", "withholds", "draws", "reduces", "slows"].includes(p2)
      ) {
        moveText =
          "This is not asking for immediate action. Listen longer, reduce pressure, and let the real meaning surface before making a decision.";
      }

      if (!moveText) {
        moveText = buildMoveText(c1, c2, signal);
      }

      if (c2.id === "the-tower" || c2.name === "The Tower") {
        moveText =
          "Do not try to stabilise this. The second card is breaking something open that cannot be held together any longer. Let what is collapsing fall, rather than trying to preserve it.";
      }

      h += '<div class="tok2-shift-stack">';
      if (whenFirst1) {
        h +=
          '<div class="tok2-shift-row"><div class="tok2-shift-label">The room</div><div class="tok2-shift-value">' +
          escHtml(formatBlockText(capitaliseFirst(whenFirstText))) +
          "</div></div>";
