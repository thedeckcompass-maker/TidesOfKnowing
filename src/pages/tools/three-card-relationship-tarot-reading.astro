---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteBase } from "../../lib/site";

const title = "Three Card Tarot Reading for Relationships – The Table Between Them";
const description =
  "A deeper tarot tool for exploring the relational field between three cards. This tool is currently in development.";
const ogUrl = new URL("/tools/three-card-relationship-tarot-reading/", siteBase(Astro)).href;
---

<BaseLayout title={title} description={description} ogUrl={ogUrl}>
  <article class="tool-holding page-inner">
    <p class="tool-holding__eyebrow">TAROT TOOL IN DEVELOPMENT</p>
    <h1 class="tool-holding__title">The Table Between Them</h1>
    <h2 class="tool-holding__h2-intent">
      A three-card relational tarot reading for what is spoken, what remains unspoken, and what is beginning to take shape between two people.
    </h2>
    <p class="tool-holding__intro">
      Where When Two Cards Meet explores the tension between two forces, The Table Between Them introduces a third presence: the relational field itself.
    </p>
    <p class="tool-holding__body">
      This reading is designed to examine:<br />
      - what is openly expressed<br />
      - what sits beneath the interaction<br />
      - what the connection is moving toward
    </p>
    <p class="tool-holding__body">
      The spread is intended for relationships of all kinds — romantic, familial, creative, professional, strained, or unresolved — with a focus on the dynamics emerging between people rather than fixed personality descriptions.
    </p>
    <p class="tool-holding__status">The Table Between Them is currently in development.</p>

    <section class="tool-holding__signup" aria-labelledby="tool-updates-heading">
      <h2 id="tool-updates-heading" class="tool-holding__signup-title">
        Get notified when this tool is live
      </h2>
      <p class="tool-holding__signup-copy">
        Join the Tides of Knowing list for new tarot tools, articles, and COMPASS method updates.
      </p>
      <!-- TODO: Connect this signup form to the chosen email/newsletter provider. -->
      <form class="tool-holding__form" action="/subscribe/" method="get">
        <label class="tool-holding__label" for="holding-email-table">Email</label>
        <input
          class="tool-holding__input"
          id="holding-email-table"
          name="email"
          type="email"
          autocomplete="email"
          placeholder="you@example.com"
          required
        />
        <button class="tool-holding__button" type="submit">Notify Me</button>
      </form>
      <p class="tool-holding__privacy">No spam. Just new tools, articles, and occasional Tides of Knowing updates.</p>
    </section>

    <p class="tool-holding__back-wrap">
      <a class="tool-holding__back" href="/tools/two-card-tarot-reading/">Back to When Two Cards Meet</a>
    </p>
  </article>
</BaseLayout>

<style>
  .tool-holding {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 38rem;
  }

  .tool-holding__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .tool-holding__title {
    margin: 0 0 0.8rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--tok-text-light);
  }

  .tool-holding__h2-intent {
    margin: 0 0 0.55rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.62;
    font-weight: 500;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__intro {
    margin: 0 0 0.9rem;
    font-size: 1.04rem;
    line-height: 1.72;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__body {
    margin: 0 0 0.85rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__status {
    margin: 0 0 1.45rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__signup {
    border: 1px solid color-mix(in srgb, var(--tok-gold) 40%, transparent);
    border-radius: 0.4rem;
    background: color-mix(in srgb, var(--tok-surface-reading) 45%, transparent);
    padding: 1rem 1.1rem 1.15rem;
    color: var(--tok-text-dark);
  }

  .tool-holding__signup-title {
    margin: 0 0 0.45rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--tok-water);
  }

  .tool-holding__signup-copy {
    margin: 0 0 0.9rem;
    font-size: 0.96rem;
    line-height: 1.65;
    color: var(--tok-text-dark);
  }

  .tool-holding__form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.6rem;
    align-items: end;
  }

  .tool-holding__label {
    grid-column: 1 / -1;
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-water);
  }

  .tool-holding__input {
    border: 1px solid color-mix(in srgb, var(--tok-water) 28%, transparent);
    border-radius: 0.2rem;
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    padding: 0.68rem 0.72rem;
  }

  .tool-holding__button {
    padding: 0.78rem 1.1rem;
    font-family: var(--font-body);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-water);
    border: 2px solid var(--tok-gold);
    border-radius: 2px;
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
  }

  .tool-holding__button:hover {
    background: color-mix(in srgb, var(--tok-gold) 14%, transparent);
  }

  .tool-holding__privacy {
    margin: 0.72rem 0 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--tok-text-muted);
    opacity: 0.9;
  }

  .tool-holding__back-wrap {
    margin: 1.2rem 0 0;
  }

  .tool-holding__back {
    color: var(--tok-teal-light);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .tool-holding__back:hover {
    color: var(--tok-text-light);
  }

  @media (max-width: 560px) {
    .tool-holding__form {
      grid-template-columns: 1fr;
    }
  }
</style>
