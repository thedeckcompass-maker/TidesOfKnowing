---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteBase } from "../../lib/site";
import { withSubscribeSourceAttribution } from "../../lib/subscribeAttribution";

const title = "Tarot Interpretation Tools | Tides of Knowing";
const description =
  "Practise tarot card relationships, spread flow, and repeated pattern recognition with free interpretation tools from Tides of Knowing.";
const ogUrl = new URL("/tools/", siteBase(Astro)).href;

const tableBetweenThemUrl = "/tools/three-card-relationship-tarot-reading/";
const repeatedCardMeaningUrl = "/tools/repeating-tarot-cards-meaning/";

const notifySubscribeHref = withSubscribeSourceAttribution("/subscribe/", {
  pagePathname: Astro.url.pathname,
  sourceComponent: "tools-hub-notify-link",
});
---

<BaseLayout title={title} description={description} ogUrl={ogUrl}>
  <article class="tools-hub page-inner">
    <div class="tools-hub__frame">
      <p class="tools-hub__frame-label">the COMPASS Method in practice</p>
      <p class="tools-hub__frame-lede">
        These tools are not here to give you more meanings to memorise. They are controlled practice
        spaces for noticing how symbolic information behaves, how patterns form, and where your
        attention begins to stabilise.
      </p>
    </div>

    <h1 class="tools-hub__title">Tarot Interpretation Tools</h1>
    <p class="tools-hub__intro">
      These tools help tarot readers practise card relationships, spread flow, and repeated pattern recognition, so readings stay relational instead of collapsing into isolated keywords.
    </p>

    <ul class="tools-hub__grid" role="list">
      <li class="tools-hub__card">
        <a class="tools-hub__card-link" href="/tools/two-card-tarot-reading/">
          <span class="tools-hub__card-name">When Two Cards Meet</span>
        </a>
        <p class="tools-hub__card-desc">Two-card relational reading: room and entering force.</p>
        <p class="tools-hub__compass">
          This tool trains Map and Sense: noticing the relationship between two cards before forcing
          them into a fixed interpretation.
        </p>
        <p class="tools-hub__status tools-hub__status--live">Available now</p>
      </li>
      <li class="tools-hub__card tools-hub__card--soon">
        <a class="tools-hub__card-link tools-hub__card-link--soon" href={tableBetweenThemUrl}>
          <span class="tools-hub__card-name">The Table Between Them</span>
        </a>
        <p class="tools-hub__card-desc">Three-card interpreter: movement, sequence, and story.</p>
        <p class="tools-hub__status tools-hub__status--next">COMING SOON</p>
      </li>
      <li class="tools-hub__card tools-hub__card--soon">
        <a class="tools-hub__card-link tools-hub__card-link--soon" href={repeatedCardMeaningUrl}>
          <span class="tools-hub__card-name">Repeated Card Meaning Tool</span>
        </a>
        <p class="tools-hub__card-desc">
          Explore why a card may keep appearing and what repeated patterns may be asking you to notice.
        </p>
        <p class="tools-hub__status tools-hub__status--next">COMING SOON</p>
      </li>
    </ul>

    <section class="tools-hub__prompt" aria-labelledby="tools-prompt-heading">
      <h2 id="tools-prompt-heading" class="tools-hub__prompt-title">Practice Prompt of the Week</h2>
      <p class="tools-hub__prompt-lead">
        Before you interpret, name the first relationship you notice between the cards.
      </p>
      <p class="tools-hub__prompt-support">
        A short weekly exercise for strengthening perception before explanation.
      </p>
    </section>

    <p class="tools-hub__bridge">
      If this helps in isolation, The Deck Compass is where the practice stabilises with other readers
      and seekers.{" "}
      <a class="tools-hub__bridge-link" href="/practice/">Practice the Method</a>
    </p>

    <p class="tools-hub__notify">
      <a class="tools-hub__notify-link" href={notifySubscribeHref}>
        Get notified when The Table Between Them launches.
      </a>
    </p>
  </article>
</BaseLayout>

<style>
  .tools-hub {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 48rem;
  }

  .tools-hub__frame {
    margin: 0 0 clamp(1.5rem, 4vw, 2rem);
    padding-bottom: clamp(1.25rem, 3vw, 1.75rem);
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
  }

  .tools-hub__frame-label {
    margin: 0 0 0.65rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .tools-hub__frame-lede {
    margin: 0;
    max-width: 42rem;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--tok-text-light-soft);
    opacity: 0.96;
  }

  .tools-hub__title {
    margin: 0 0 0.75rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.65rem);
    line-height: 1.15;
    color: var(--tok-text-light);
  }

  .tools-hub__intro {
    margin: 0 0 1.35rem;
    font-size: 1.05rem;
    line-height: 1.72;
    max-width: 40rem;
    color: var(--tok-text-light-soft);
  }

  .tools-hub__grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .tools-hub__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .tools-hub__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tools-hub__card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.85rem 1rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 45%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--tok-surface-reading) 40%, transparent);
    min-height: 0;
  }

  .tools-hub__card--soon {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--tok-water) 22%, transparent);
    background: color-mix(in srgb, var(--tok-water) 3%, transparent);
  }

  .tools-hub__card-link {
    text-decoration: none;
    color: var(--tok-teal-light);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.35;
  }

  .tools-hub__card-link:hover {
    color: var(--tok-water);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .tools-hub__card-link--soon {
    color: var(--tok-water);
    opacity: 0.92;
  }

  .tools-hub__card-name--plain {
    display: block;
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.35;
    color: var(--tok-water);
  }

  .tools-hub__card-desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.62;
    color: var(--tok-text-dark);
    flex: 1;
  }

  .tools-hub__compass {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.58;
    color: var(--tok-text-dark);
    opacity: 0.92;
    padding-top: 0.35rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-water) 12%, transparent);
  }

  .tools-hub__prompt {
    margin: clamp(2rem, 5vw, 2.75rem) 0 0;
    padding: clamp(1.35rem, 4vw, 1.85rem) 0 0;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
  }

  .tools-hub__prompt-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.6vw, 1.45rem);
    font-weight: 600;
    font-style: italic;
    line-height: 1.25;
    color: var(--tok-text-light);
  }

  .tools-hub__prompt-lead {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--tok-text-light-soft);
    max-width: 40rem;
  }

  .tools-hub__prompt-support {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--tok-text-light-soft) 88%, transparent);
    max-width: 38rem;
  }

  .tools-hub__bridge {
    margin: clamp(1.75rem, 4vw, 2.25rem) 0 0;
    font-size: 1.02rem;
    line-height: 1.68;
    color: var(--tok-text-light-soft);
    max-width: 42rem;
  }

  .tools-hub__bridge-link {
    font-weight: 600;
    color: var(--tok-teal-light);
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  .tools-hub__bridge-link:hover {
    color: var(--tok-text-light-strong);
  }

  .tools-hub__notify {
    margin: 1.15rem 0 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .tools-hub__notify-link {
    color: var(--tok-teal-light);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .tools-hub__notify-link:hover {
    color: var(--tok-text-light-strong);
  }

  .tools-hub__status {
    margin: 0.15rem 0 0;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tools-hub__status--live {
    color: var(--tok-water);
  }

  .tools-hub__status--next {
    color: var(--tok-gold);
  }
</style>
