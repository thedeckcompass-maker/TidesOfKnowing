---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteBase } from "../../lib/site";

const title = "Tarot Combination Interpreter | Tides of Knowing";
const description =
  "Practice reading two tarot cards as a relationship: initiating and responding energy, using the full 78-card deck as a structural scaffold.";
const ogUrl = new URL("/tools/tarot-combination-interpreter/", siteBase(Astro)).href;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What is a tarot combination?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "A tarot combination is the interpretive relationship between two cards in the same spread or question. Instead of stacking two fixed definitions, you track how the second card answers, redirects, softens, or sharpens what the first card opens. On Tides of Knowing, that work is treated as a practice of attention: you are learning to read movement, not collecting slogans.",
      },
    },
    {
      "@type": "Question",
      name: "How do I read two tarot cards together?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Name what the first card is doing in the situation—initiating, naming a tension, or setting a tone—then ask what changes when the second card is allowed to respond to that exact move. Stay with verbs and relationships (mirrors, delays, intensifies) rather than treating each card as a sealed keyword. If you can describe the dialogue in plain language, you are already interpreting.",
      },
    },
    {
      "@type": "Question",
      name: "Why do tarot cards change meaning in context?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "A card never arrives alone in a reading: the question, the seeker's language, and the neighbouring images all steer tone. The same symbol can lean cautious or courageous depending on what sits beside it, because meaning is relational. Context is not decoration; it is part of the signal you are meant to follow.",
      },
    },
    {
      "@type": "Question",
      name: "Can this tool predict the future?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "No. This interpreter is a learning aid for relational reading. It does not forecast guaranteed outcomes, tell you what will happen, or replace your judgment. It offers structured prompts—keywords, core meanings, arcana and suit pairing, and rank framing—so you can practise noticing how two cards modify one another in a grounded, responsible way.",
      },
    },
    {
      "@type": "Question",
      name: "Does this replace learning tarot?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "It does not replace study, mentorship, or lived practice at the table. It supports a specific skill: moving from memorised meanings into interpretation. You still bring the question, the ethics, and the final say. Think of it as training wheels for relationship-based reading, not a substitute for your own sense-making.",
      },
    },
  ],
};
---

<BaseLayout title={title} description={description} ogUrl={ogUrl} jsonLd={faqJsonLd}>
  <article class="tarot-tool page-inner">
    <h1 class="tarot-tool__title">Tarot Combination Interpreter</h1>
    <p class="tarot-tool__intro">
      This tool helps you explore how tarot cards interact, rather than reading them in isolation.
    </p>

    <div id="tarot-tool" class="tarot-tool__tool-wrap">
    <div class="tarot-tool__panel" aria-labelledby="tarot-tool-heading">
      <h2 class="visually-hidden" id="tarot-tool-heading">Choose two cards</h2>
      <div class="tarot-tool__fields">
        <div class="tarot-tool__field">
          <label class="tarot-tool__label" for="tarot-card-1">Card 1</label>
          <select class="tarot-tool__select" id="tarot-card-1" name="card1" required aria-required="true">
            <option value="">Select a card</option>
          </select>
          <fieldset class="tarot-tool__orient" id="tarot-orient-fieldset-1">
            <legend class="tarot-tool__orient-legend">Orientation</legend>
            <div class="tarot-tool__orient-row">
              <label class="tarot-tool__orient-choice">
                <input type="radio" name="tok_orient_1" value="upright" checked />
                Upright
              </label>
              <label class="tarot-tool__orient-choice">
                <input type="radio" name="tok_orient_1" value="reversed" />
                Reversed
              </label>
            </div>
          </fieldset>
        </div>
        <div class="tarot-tool__field">
          <label class="tarot-tool__label" for="tarot-card-2">Card 2</label>
          <select class="tarot-tool__select" id="tarot-card-2" name="card2" required aria-required="true">
            <option value="">Select a card</option>
          </select>
          <fieldset class="tarot-tool__orient" id="tarot-orient-fieldset-2">
            <legend class="tarot-tool__orient-legend">Orientation</legend>
            <div class="tarot-tool__orient-row">
              <label class="tarot-tool__orient-choice">
                <input type="radio" name="tok_orient_2" value="upright" checked />
                Upright
              </label>
              <label class="tarot-tool__orient-choice">
                <input type="radio" name="tok_orient_2" value="reversed" />
                Reversed
              </label>
            </div>
          </fieldset>
        </div>
      </div>
      <button class="tarot-tool__button" type="button" id="tarot-interpret-btn">Interpret Combination</button>
      <div
        class="tarot-tool__output"
        id="output"
        style="white-space: pre-line;"
        aria-live="polite"
      ></div>
    </div>
    </div>

    <nav class="tarot-tool__crossnav" aria-label="Tarot tools">
      <p class="tarot-tool__crossnav-title">Tarot tools</p>
      <ul class="tarot-tool__crossnav-list">
        <li class="tarot-tool__crossnav-item">
          <a
            class="tarot-tool__crossnav-link"
            href="/tools/tarot-combination-interpreter/"
            aria-current="page"
            >Two-Card Combination Interpreter</a
          >
          <span class="tarot-tool__crossnav-label tarot-tool__crossnav-label--current">Current</span>
        </li>
        <li class="tarot-tool__crossnav-item">
          <a class="tarot-tool__crossnav-link tarot-tool__crossnav-link--soon" href="/tools/three-card-tarot-spread-interpreter/"
            >Three-Card Spread Interpreter</a
          >
          <span class="tarot-tool__crossnav-label tarot-tool__crossnav-label--soon">Coming next</span>
        </li>
        <li class="tarot-tool__crossnav-item">
          <a class="tarot-tool__crossnav-link tarot-tool__crossnav-link--soon" href="/tools/repeated-tarot-card-meaning/"
            >Repeated Card Meaning Tool</a
          >
          <span class="tarot-tool__crossnav-label tarot-tool__crossnav-label--soon">Coming next</span>
        </li>
      </ul>
    </nav>

    <div class="tarot-tool__seo-intro">
      <p>
        This tarot combination interpreter is designed for readers who already know some card meanings but want help understanding how two cards speak to each other. A two-card tarot combination is rarely just one meaning placed beside another. The first card opens a force, theme, or question; the second card modifies, mirrors, challenges, softens, or redirects it. This tool uses the full 78-card Rider–Waite–Smith system, including card imagery, keywords, arcana, suit, and rank relationships, to help you notice the movement between the cards. It is not intended to replace your intuition or turn tarot into a fixed formula. It is a practice tool for learning how interpretation works.
      </p>
    </div>

    <nav class="tarot-tool__jump" aria-label="On this page">
      <p class="tarot-tool__jump-title">On this page</p>
      <ul class="tarot-tool__jump-list">
        <li><a class="tarot-tool__jump-link" href="#how-combinations-work">How combinations work</a></li>
        <li><a class="tarot-tool__jump-link" href="#common-mistakes">Common mistakes</a></li>
        <li><a class="tarot-tool__jump-link" href="#faq">FAQ</a></li>
      </ul>
    </nav>

    <section class="tarot-tool__seo">
      <h2 class="tarot-tool__h2" id="how-combinations-work">What Is a Tarot Combination?</h2>
      <p class="tarot-tool__p">
        A tarot combination is not a third "super-meaning" you download from a list. It is the live relationship between two images in a question: where they agree, where they argue, and what changes when they are read as a pair. On Tides of Knowing, combinations are treated as a craft problem—how attention moves—rather than a trivia problem of matching keywords. When you read two cards together, you are tracking how one card’s pressure meets another card’s response, and what that meeting does to the story you were about to tell yourself.
      </p>
      <p class="tarot-tool__p">
        The interpreter above gives you a structured scaffold: names, imagery, concise meanings, and relationship cues across arcana, suit, and (where relevant) rank. The goal is to keep you inside interpretation long enough for a real pattern to form, without pretending the cards can do your thinking for you.
      </p>

      <h2 class="tarot-tool__h2">Why Tarot Cards Change Meaning in Context</h2>
      <p class="tarot-tool__p">
        Context steers tone. A card that reads as steady support in one spread can read as stubborn delay in another, not because the symbol is inconsistent, but because the question and the neighbouring cards change what is being asked of it. Elemental language helps here: a Cups card carries a different humidity than a Swords card, and a Major Arcana card widens the frame beyond daily mechanics. Good reading names that shift honestly instead of forcing the same adjective every time a card appears.
      </p>
      <p class="tarot-tool__p">
        This is why relational practice matters. If you train only on single-card definitions, you learn labels. If you train on pairs, you learn how meaning behaves under pressure—which is closer to how readings actually unfold.
      </p>

      <h2 class="tarot-tool__h2">How to Read Two Cards Together</h2>
      <p class="tarot-tool__p">
        Start by stating what the first card is doing in plain language: opening, tightening, revealing, concealing, speeding up, or slowing down. Then treat the second card as an answer to that move. Does it echo, contradict, refine, or redirect? If you cannot yet say what the relationship is, say what it is not. That negative space is often where the reading becomes accurate.
      </p>
      <p class="tarot-tool__p">
        Keep your verbs simple and your claims modest. The point is not to sound mystical; the point is to be precise enough that another person could recognise the same interaction if they were watching the spread with you.
      </p>

      <h2 class="tarot-tool__h2" id="common-mistakes">Common Mistakes in Tarot Interpretation</h2>
      <p class="tarot-tool__p">
        One common mistake is treating the second card as a footnote: you announce Card 1, then append Card 2 as an afterthought. Another is keyword stacking—stringing adjectives until the reading sounds impressive but says nothing testable. A third mistake is ignoring position and relationship entirely, as if order does not imply responsibility for how a story begins and how it answers.
      </p>
      <p class="tarot-tool__p">
        Beginners also sometimes confuse certainty with clarity. A sharp reading can be humble. If you notice yourself guaranteeing outcomes, you have left interpretation and entered performance. Pull back, return to the cards, and let the combination teach you what kind of movement is actually present.
      </p>

      <h2 class="tarot-tool__h2">How the COMPASS Method Approaches This</h2>
      <p class="tarot-tool__p">
        The COMPASS Method is the house framework on Tides of Knowing for grounded intuitive work: holding a question cleanly, recognising signal, and following how meaning settles across a spread rather than collapsing into slogans. Combinations are a training ground for that discipline, because they force you to stay with relationship long enough for the reading to become coherent.
      </p>
      <p class="tarot-tool__p">
        If you want the fuller methodology, read <a href="/articles/compass-method/">The COMPASS Method</a> after you have practised a few pairs here. The article is written for the same audience: people who are ready to interpret, not merely collect meanings.
      </p>

      <h2 class="tarot-tool__h2" id="faq">Frequently Asked Questions</h2>
      <dl class="tarot-tool__faq">
        <dt class="tarot-tool__faq-q">What is a tarot combination?</dt>
        <dd class="tarot-tool__faq-a">
          A tarot combination is the interpretive relationship between two cards in the same spread or question. Instead of stacking two fixed definitions, you track how the second card answers, redirects, softens, or sharpens what the first card opens. On Tides of Knowing, that work is treated as a practice of attention: you are learning to read movement, not collecting slogans.
        </dd>
        <dt class="tarot-tool__faq-q">How do I read two tarot cards together?</dt>
        <dd class="tarot-tool__faq-a">
          Name what the first card is doing in the situation—initiating, naming a tension, or setting a tone—then ask what changes when the second card is allowed to respond to that exact move. Stay with verbs and relationships (mirrors, delays, intensifies) rather than treating each card as a sealed keyword. If you can describe the dialogue in plain language, you are already interpreting.
        </dd>
        <dt class="tarot-tool__faq-q">Why do tarot cards change meaning in context?</dt>
        <dd class="tarot-tool__faq-a">
          A card never arrives alone in a reading: the question, the seeker's language, and the neighbouring images all steer tone. The same symbol can lean cautious or courageous depending on what sits beside it, because meaning is relational. Context is not decoration; it is part of the signal you are meant to follow.
        </dd>
        <dt class="tarot-tool__faq-q">Can this tool predict the future?</dt>
        <dd class="tarot-tool__faq-a">
          No. This interpreter is a learning aid for relational reading. It does not forecast guaranteed outcomes, tell you what will happen, or replace your judgment. It offers structured prompts—keywords, core meanings, arcana and suit pairing, and rank framing—so you can practise noticing how two cards modify one another in a grounded, responsible way.
        </dd>
        <dt class="tarot-tool__faq-q">Does this replace learning tarot?</dt>
        <dd class="tarot-tool__faq-a">
          It does not replace study, mentorship, or lived practice at the table. It supports a specific skill: moving from memorised meanings into interpretation. You still bring the question, the ethics, and the final say. Think of it as training wheels for relationship-based reading, not a substitute for your own sense-making.
        </dd>
      </dl>
    </section>
  </article>
</BaseLayout>

<script>
  import { tarotCards } from "../../data/tarotCards.js";

  function findCardByName(name) {
    for (let i = 0; i < tarotCards.length; i++) {
      if (tarotCards[i].name === name) return tarotCards[i];
    }
    return null;
  }

  function fillSelect(select) {
    for (let i = 0; i < tarotCards.length; i++) {
      const opt = document.createElement("option");
      opt.value = tarotCards[i].name;
      opt.textContent = tarotCards[i].name;
      select.appendChild(opt);
    }
  }

  function escAttr(str) {
    return String(str).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;");
  }

  function escHtml(str) {
    return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/"/g, "&quot;");
  }

  /** First three keywords for combination template (data guarantees five). */
  function kwTriple(card) {
    const k = card.keywords || [];
    const a = k[0] != null ? String(k[0]) : "relation";
    const b = k[1] != null ? String(k[1]) : a;
    const c = k[2] != null ? String(k[2]) : b;
    return [escHtml(a), escHtml(b), escHtml(c)];
  }

  function keywordsFiveLine(card) {
    const k = (card.keywords || []).slice(0, 5);
    return k.map((w) => escHtml(String(w))).join(", ");
  }

  function extendedKeywordsLine(card) {
    const ex = card.extendedKeywords;
    if (!Array.isArray(ex) || ex.length === 0) return "";
    return ex.map((w) => escHtml(String(w))).join(", ");
  }

  function orientationLabel(isReversed) {
    return isReversed ? "Reversed" : "Upright";
  }

  /**
   * Upright: essenceSentence when present, otherwise coreMeaning (HTML-safe).
   * Reversed: fixed interpretive frame naming loss of flow (not “simple opposite”).
   */
  function orientationFrame(card, isReversed) {
    const n = escHtml(card.name);
    if (!isReversed) {
      const ess = card.essenceSentence && String(card.essenceSentence).trim();
      if (ess) return escHtml(ess);
      return escHtml(String(card.coreMeaning || "").trim());
    }
    return (
      "When reversed, " +
      n +
      " suggests that its usual movement is blocked, internalised, delayed, distorted, or being expressed without clear alignment. The question is not simply the opposite of the upright card, but where its energy has lost flow, proportion, or conscious direction."
    );
  }

  function readOrientReversed(radioName) {
    const el = document.querySelector('input[name="' + radioName + '"]:checked');
    return el instanceof HTMLInputElement && el.value === "reversed";
  }

  function applySavedOrientation(radioName, storageKey) {
    const raw = localStorage.getItem(storageKey);
    const v = raw === "reversed" ? "reversed" : "upright";
    const input = document.querySelector('input[name="' + radioName + '"][value="' + v + '"]');
    if (input instanceof HTMLInputElement) input.checked = true;
  }

  function saveTarotPreferences(sel1, sel2) {
    if (sel1.value) localStorage.setItem("tok_card1", sel1.value);
    if (sel2.value) localStorage.setItem("tok_card2", sel2.value);
    const o1 = readOrientReversed("tok_orient_1") ? "reversed" : "upright";
    const o2 = readOrientReversed("tok_orient_2") ? "reversed" : "upright";
    localStorage.setItem("tok_card1_orientation", o1);
    localStorage.setItem("tok_card2_orientation", o2);
  }

  const ARC_MAJOR = "Major Arcana";
  const ARC_MINOR = "Minor Arcana";

  /** Cross-suit pairing for two Minor Arcana cards (keys sorted alphabetically). */
  const SUIT_CROSS = {
    "Cups|Pentacles":
      "Cups and Pentacles cross heart with ground: feeling tests what can be held or afforded, while work and body speak back about what is realistic.",
    "Cups|Swords":
      "Cups and Swords cross heart with edge: tenderness meets language that can clarify or cut, so watch for truth that forgets cost—or cost that forgets mercy.",
    "Cups|Wands":
      "Cups and Wands cross heart with spark: emotion tests courage and visibility, while initiative stirs what the heart has been sitting on.",
    "Pentacles|Swords":
      "Pentacles and Swords cross matter with mind: labour, money, and health meet scrutiny, argument, or a verdict that wants evidence, not vibe.",
    "Pentacles|Wands":
      "Pentacles and Wands cross work with heat: sustained effort meets appetite for risk or recognition; build quality and pace negotiate with hunger.",
    "Swords|Wands":
      "Swords and Wands cross mind with drive: ideas and words meet motion and nerve; speed can outrun a premise, or a premise can cool reckless motion.",
  };

  /**
   * Relational frame from arcana and suit pairing (initiating card first, modifying second).
   * Returns HTML-safe text (names and suits escaped).
   */
  function relationshipFrame(first, second) {
    const a1 = first.arcana;
    const a2 = second.arcana;
    const s1 = first.suit;
    const s2 = second.suit;
    const n1 = escHtml(first.name);
    const n2 = escHtml(second.name);

    if (a1 === ARC_MAJOR && a2 === ARC_MAJOR) {
      return (
        "Both cards are Major Arcana: two archetypal forces are in dialogue, so the pair reads at the level of life-pattern rather than small detail. " +
        "Ask how " +
        n2 +
        " reshapes the story that " +
        n1 +
        " opens, rather than treating either as a footnote."
      );
    }

    if (a1 === ARC_MAJOR && a2 === ARC_MINOR) {
      const suit = second.suit ? escHtml(String(second.suit)) : "the suit";
      return (
        n1 +
        " (Major) sets the initiating archetype; " +
        n2 +
        " carries that pressure into " +
        suit +
        " territory—where the theme gains friction, habit, or proof in lived experience."
      );
    }

    if (a1 === ARC_MINOR && a2 === ARC_MAJOR) {
      const suit = first.suit ? escHtml(String(first.suit)) : "the suit";
      return (
        n1 +
        " grounds the opening in " +
        suit +
        " life—work, feeling, mind, or matter—while " +
        n2 +
        " (Major) widens, judges, or re-aims what that field is trying to become."
      );
    }

    if (a1 === ARC_MINOR && a2 === ARC_MINOR && s1 && s2) {
      if (s1 === s2) {
        return (
          "Both cards are Minor Arcana in " +
          escHtml(s1) +
          ": one stream of energy is splitting across ranks, so read for escalation, repair, or repetition inside the same storyline—not two unrelated plots."
        );
      }
      const key = [String(s1), String(s2)].sort().join("|");
      let line = SUIT_CROSS[key];
      if (!line) {
        line =
          "Two different suits answer together: track how one channel disciplines, feeds, or contradicts the other instead of averaging them.";
      }
      const sameRank =
        first.rank &&
        second.rank &&
        String(first.rank) === String(second.rank);
      if (sameRank) {
        line +=
          " Same rank: parallel \"octaves\" in two elements—ask what stays constant while the medium changes.";
      }
      return line;
    }

    return "Read this pair as two instruments answering the same question from different registers; let arcana and suit tell you which voice leads.";
  }

  /** Keywords shared between two cards (first five only each), original casing from card2 where possible. */
  function sharedKeywordsList(card1, card2) {
    const a = new Set();
    for (const w of card1.keywords || []) {
      a.add(String(w).toLowerCase());
    }
    const shared = [];
    const got = new Set();
    for (const w of card2.keywords || []) {
      const low = String(w).toLowerCase();
      if (a.has(low) && !got.has(low)) {
        got.add(low);
        shared.push(String(w));
      }
    }
    return shared;
  }

  function joinSharedKeywordsHtml(words) {
    if (words.length === 0) return "";
    if (words.length === 1) return escHtml(words[0]);
    if (words.length === 2) return escHtml(words[0]) + " and " + escHtml(words[1]);
    return (
      words
        .slice(0, -1)
        .map((w) => escHtml(w))
        .join(", ") +
      ", and " +
      escHtml(words[words.length - 1])
    );
  }

  /**
   * Three-sentence combination meaning when both upright: active force + context, interaction, outcome direction.
   * Uses names and kwTriple only (no changes to keyword extraction helpers).
   */
  function combinationMeaningBothUpright(card1, card2) {
    const n1 = escHtml(card1.name);
    const n2 = escHtml(card2.name);
    const k1 = kwTriple(card1);
    const k2 = kwTriple(card2);
    const a1 = card1.arcana;
    const a2 = card2.arcana;
    const shared = sharedKeywordsList(card1, card2);

    const s1 =
      n1 +
      " reads as the moving force—" +
      k1[0] +
      ", " +
      k1[1] +
      ", and " +
      k1[2] +
      ". " +
      n2 +
      " reads as the surrounding condition—" +
      k2[0] +
      ", " +
      k2[1] +
      ", and " +
      k2[2] +
      ".";

    let s2;
    if (shared.length > 0) {
      s2 =
        "They lean into the same pressure through " +
        joinSharedKeywordsHtml(shared) +
        ", so the second image mostly amplifies or steadies what the first already carries rather than changing the subject.";
    } else if (a1 === ARC_MAJOR && a2 === ARC_MINOR) {
      s2 =
        "The broad arc of " +
        n1 +
        " lands inside the tighter weather of " +
        n2 +
        ", where motive meets cost, habit, or rivalry in a form you can actually touch.";
    } else if (a1 === ARC_MINOR && a2 === ARC_MAJOR) {
      s2 =
        "The concrete texture of " +
        n1 +
        " is being reframed by " +
        n2 +
        ", so what felt like a local hassle now answers to a larger pattern that will not stay politely in the background.";
    } else if (a1 === ARC_MAJOR && a2 === ARC_MAJOR) {
      s2 =
        "Two large themes negotiate without one erasing the other: where they agree, the conviction deepens, and where they disagree, the fault line becomes the most honest part of the reading.";
    } else {
      const sameSuit = card1.suit && card2.suit && String(card1.suit) === String(card2.suit);
      if (sameSuit) {
        s2 =
          "Both cards breathe the same suit’s air, so the friction is less about mixed signals and more about whether the storyline escalates, repairs, or simply rehearses itself.";
      } else {
        s2 =
          "Different channels answer at once, so the live question is which voice sets the pace and which one is trying to correct the first—tension stays practical rather than abstract.";
      }
    }

    let s3;
    if (shared.length > 0) {
      s3 =
        "What gathers is a single through-line: small choices start to feel like they belong to one stubborn pattern that will keep returning until it is named cleanly.";
    } else if (a1 === ARC_MAJOR && a2 === ARC_MINOR) {
      s3 =
        "The drift is toward proof in the body and the ledger—whether the stance of " +
        n1 +
        " can still steer once " +
        n2 +
        " has named what is strained, contested, or scarce.";
    } else if (a1 === ARC_MINOR && a2 === ARC_MAJOR) {
      s3 =
        "The emerging shape is threshold energy: " +
        n1 +
        " keeps offering tactical moves while " +
        n2 +
        " insists the next chapter will not respect half-measures.";
    } else if (a1 === ARC_MAJOR && a2 === ARC_MAJOR) {
      s3 =
        "The combination keeps bending toward a life-pattern decision—whichever theme you feed begins to own the emotional colour of what follows.";
    } else {
      s3 =
        "The outcome direction is pragmatic sorting inside one situation—who carries the cost, what repeats, and what would actually have to shift for the pressure to ease.";
    }

    return s1 + " " + s2 + " " + s3;
  }

  /**
   * Combination meaning with orientation: both upright uses base logic plus lived essence when present;
   * mixed or double reversal stresses blocked, delayed, or distorted exchange (not fortune-telling).
   */
  function combinationMeaningParagraph(card1, card2, rev1, rev2) {
    const n1 = escHtml(card1.name);
    const n2 = escHtml(card2.name);
    const k1 = kwTriple(card1);
    const k2 = kwTriple(card2);
    if (!rev1 && !rev2) {
      let p = combinationMeaningBothUpright(card1, card2);
      const e1 = card1.essenceSentence && String(card1.essenceSentence).trim();
      const e2 = card2.essenceSentence && String(card2.essenceSentence).trim();
      if (e1 || e2) {
        p += " At the lived level: ";
        if (e1 && e2) p += escHtml(e1) + " " + escHtml(e2);
        else p += escHtml(e1 || e2);
      }
      return p;
    }
    if (rev1 && !rev2) {
      return (
        n1 +
        " still carries the vocabulary of " +
        k1[0] +
        ", " +
        k1[1] +
        ", and " +
        k1[2] +
        ", but reversed it reads as a blocked or distorted initiating force: present, yet struggling for proportion, outlet, or conscious aim. " +
        n2 +
        " remains upright as the surrounding field—" +
        k2[0] +
        ", " +
        k2[1] +
        ", and " +
        k2[2] +
        "—so it answers with clearer voltage, like corrective friction, a mirror that will not soften the lie, or steady pressure that refuses to cosign the twist. " +
        "The combination tilts toward repair through what " +
        n2 +
        " names outright, while " +
        n1 +
        " keeps asking where the starting impulse corks itself before it can become useful."
      );
    }
    if (!rev1 && rev2) {
      return (
        n1 +
        " reads as the moving force—" +
        k1[0] +
        ", " +
        k1[1] +
        ", and " +
        k1[2] +
        "—still legible and outward-facing. " +
        n2 +
        ", reversed, arrives as muffled, delayed, or interned condition around " +
        k2[0] +
        ", " +
        k2[1] +
        ", and " +
        k2[2] +
        ": the response channel struggles to answer cleanly, so support, context, or consequence may arrive distorted, late, or folded inward. " +
        "The drift is toward over steering the opening while the second voice cannot meet it on stable ground—integration waits on whatever keeps " +
        n2 +
        " from moving in one honest piece."
      );
    }
    return (
      n1 +
      " and " +
      n2 +
      " still invoke " +
      k1[0] +
      ", " +
      k1[1] +
      ", and " +
      k1[2] +
      " against " +
      k2[0] +
      ", " +
      k2[1] +
      ", and " +
      k2[2] +
      ", yet both reversed folds the exchange toward doubled static: pressure met with pressure that will not cross into clean contact. " +
      "Hidden tension, withheld movement, or unfinished quarrel with the self tends to run the understory, so the pair reads less like a sharp fight and more like a revolving door of unintegrated material. " +
      "What gathers is oblique surfacing—symptoms, repeats, and off-centre signals—until the story admits where flow, proportion, and direction both went missing at once."
    );
  }

  /** One situational reflection question when both cards upright; arcana-aware without initiating/modifying framing. */
  function compassReflectionUprightPair(card1, card2) {
    const n1 = escHtml(card1.name);
    const n2 = escHtml(card2.name);
    const k1 = kwTriple(card1);
    const k2 = kwTriple(card2);
    const a1 = card1.arcana;
    const a2 = card2.arcana;
    const shared = sharedKeywordsList(card1, card2);

    if (shared.length > 0) {
      return (
        "Where am I treating " +
        joinSharedKeywordsHtml(shared) +
        " as background noise even though both " +
        n1 +
        " and " +
        n2 +
        " keep returning it to the centre?"
      );
    }
    if (a1 === ARC_MAJOR && a2 === ARC_MINOR) {
      return (
        "What is missing in how I handle " +
        k2[0] +
        ", " +
        k2[1] +
        ", and " +
        k2[2] +
        " if I keep answering the situation mainly from the posture " +
        n1 +
        " prefers?"
      );
    }
    if (a1 === ARC_MINOR && a2 === ARC_MAJOR) {
      return (
        "Is this a case of " +
        n1 +
        " asking for a practical fix while " +
        n2 +
        " is really naming a threshold I keep stepping around?"
      );
    }
    if (a1 === ARC_MAJOR && a2 === ARC_MAJOR) {
      return (
        "Which story do " +
        n1 +
        " and " +
        n2 +
        " jointly refuse to let me simplify—and what would honesty cost if I stopped negotiating with either one?"
      );
    }
    return (
      "Where does " +
      n1 +
      " with its " +
      k1[0] +
      " and " +
      n2 +
      " with its " +
      k2[0] +
      " disagree about what has to change first?"
    );
  }

  /** COMPASS-style reflection; orientation steers the opening question before arcana nuance. */
  function compassReflectionQuestion(card1, card2, rev1, rev2) {
    if (rev1 && rev2) {
      return "What is trying to surface here, but cannot yet move cleanly?";
    }
    if (rev1) {
      return "Where is the starting energy blocked before it can become useful?";
    }
    if (rev2) {
      return "What response or support is unavailable, distorted, or not yet ready?";
    }
    return compassReflectionUprightPair(card1, card2);
  }

  function coreEssenceSectionHtml(card1, card2, rev1, rev2) {
    const l1 = orientationLabel(rev1);
    const l2 = orientationLabel(rev2);
    let h =
      '<section class="tarot-tool__out-block">' +
      '<h3 class="tarot-tool__out-h3">Core meanings and essence</h3>' +
      '<p class="tarot-tool__out-p"><strong>Card 1: ' +
      escHtml(card1.name) +
      " (" +
      escHtml(l1) +
      ') as the initiating force</strong></p>' +
      '<p class="tarot-tool__out-p">' +
      orientationFrame(card1, rev1) +
      "</p>";
    if (!rev1) {
      h +=
        '<p class="tarot-tool__out-p"><strong>Core meaning</strong><br />' + escHtml(String(card1.coreMeaning || "").trim()) + "</p>";
      const ex1 = extendedKeywordsLine(card1);
      if (ex1) {
        h += '<p class="tarot-tool__out-p"><strong>Extended keywords</strong><br />' + ex1 + "</p>";
      }
    }
    h +=
      '<p class="tarot-tool__out-p"><strong>Card 2: ' +
      escHtml(card2.name) +
      " (" +
      escHtml(l2) +
      ') as the modifying force</strong></p>' +
      '<p class="tarot-tool__out-p">' +
      orientationFrame(card2, rev2) +
      "</p>";
    if (!rev2) {
      h +=
        '<p class="tarot-tool__out-p"><strong>Core meaning</strong><br />' + escHtml(String(card2.coreMeaning || "").trim()) + "</p>";
      const ex2 = extendedKeywordsLine(card2);
      if (ex2) {
        h += '<p class="tarot-tool__out-p"><strong>Extended keywords</strong><br />' + ex2 + "</p>";
      }
    }
    h += "</section>";
    return h;
  }

  const RANK_MEANING = {
    Ace: "seed, beginning, emergence, raw potential",
    Two: "polarity, choice, relationship, tension between forces",
    Three: "development, expression, first visible growth",
    Four: "structure, pause, containment, consolidation",
    Five: "friction, disruption, instability, conflict",
    Six: "adjustment, repair, movement toward harmony",
    Seven: "testing, challenge, discernment, defence",
    Eight: "momentum, repetition, practice, focused movement",
    Nine: "threshold, intensity, near-completion, inner pressure",
    Ten: "completion, consequence, burden, fulfilment",
    Page: "first contact, study, curiosity, apprenticeship",
    Knight: "pursuit, movement, urgency, directed force",
    Queen: "embodiment, receptivity, inner mastery, mature expression",
    King: "command, authorship, outward mastery, responsibility",
  };

  function minorWithRank(card) {
    return card.arcana === ARC_MINOR && card.rank && String(card.rank).trim() !== "";
  }

  function rankMeaning(rank) {
    const key = String(rank).trim();
    return RANK_MEANING[key] ? escHtml(RANK_MEANING[key]) : "";
  }

  /**
   * Minor Arcana rank framing. Empty string unless at least one card is Minor with a rank.
   * Returns HTML-safe text.
   */
  function rankFrame(card1, card2) {
    const m1 = minorWithRank(card1);
    const m2 = minorWithRank(card2);
    if (!m1 && !m2) return "";

    const r1 = m1 ? String(card1.rank).trim() : "";
    const r2 = m2 ? String(card2.rank).trim() : "";
    const n1 = escHtml(card1.name);
    const n2 = escHtml(card2.name);
    const rank1Esc = escHtml(r1);
    const rank2Esc = escHtml(r2);
    const mean1 = rankMeaning(r1);
    const mean2 = rankMeaning(r2);

    const bothMinor = card1.arcana === ARC_MINOR && card2.arcana === ARC_MINOR;

    if (bothMinor && r1 && r2 && r1 === r2) {
      const m = rankMeaning(r1);
      if (!m) return "";
      return (
        "Both cards sit at the " +
        rank1Esc +
        " stage of their suits. This creates a parallel rhythm: the same developmental moment is appearing through two different elemental fields. " +
        rank1Esc +
        " carries the pattern of " +
        m +
        "."
      );
    }

    if (bothMinor && r1 && r2 && r1 !== r2) {
      if (!mean1 || !mean2) return "";
      return (
        n1 +
        " carries the " +
        rank1Esc +
        " pattern of " +
        mean1 +
        ". " +
        n2 +
        " carries the " +
        rank2Esc +
        " pattern of " +
        mean2 +
        ". Read together, the combination shows movement from one developmental stage into another."
      );
    }

    if (m1 && !m2 && r1) {
      const m = rankMeaning(r1);
      if (!m) return "";
      return (
        n1 +
        " begins from the " +
        rank1Esc +
        " pattern of " +
        m +
        ". The movement into " +
        n2 +
        " suggests that this everyday pattern is being widened into an archetypal or life-pattern question."
      );
    }

    if (!m1 && m2 && r2) {
      const m = rankMeaning(r2);
      if (!m) return "";
      return (
        n1 +
        " begins as an archetypal force. " +
        n2 +
        " brings that force down into the " +
        rank2Esc +
        " pattern of " +
        m +
        ", where it must be lived, tested, or expressed in practical experience."
      );
    }

    return "";
  }

  function cardImageSlotHtml(src, name, reversed) {
    const imgCls = "tarot-tool__card-img" + (reversed ? " tarot-tool__card-img--reversed" : "");
    const meta = reversed ? "Reversed" : "Upright";
    const alt = escAttr(name + " (" + meta + ")");
    return (
      '<div class="tarot-tool__card-slot">' +
      '<img class="' +
      imgCls +
      '" src="' +
      escAttr(src) +
      '" alt="' +
      alt +
      '" loading="lazy" decoding="async" />' +
      "</div>"
    );
  }

  function initTarotTool() {
    const sel1 = document.getElementById("tarot-card-1");
    const sel2 = document.getElementById("tarot-card-2");
    const btn = document.getElementById("tarot-interpret-btn");
    const out = document.getElementById("output");

    if (!(sel1 instanceof HTMLSelectElement) || !(sel2 instanceof HTMLSelectElement) || !(btn instanceof HTMLButtonElement) || !(out instanceof HTMLElement)) {
      return;
    }

    fillSelect(sel1);
    fillSelect(sel2);

    const saved1 = localStorage.getItem("tok_card1");
    const saved2 = localStorage.getItem("tok_card2");
    if (saved1) sel1.value = saved1;
    if (saved2) sel2.value = saved2;
    applySavedOrientation("tok_orient_1", "tok_card1_orientation");
    applySavedOrientation("tok_orient_2", "tok_card2_orientation");

    const persist = () => saveTarotPreferences(sel1, sel2);
    sel1.addEventListener("change", persist);
    sel2.addEventListener("change", persist);
    const orientInputs = document.querySelectorAll('input[name="tok_orient_1"], input[name="tok_orient_2"]');
    for (let i = 0; i < orientInputs.length; i++) {
      orientInputs[i].addEventListener("change", persist);
    }

    btn.addEventListener("click", () => {
      const c1 = sel1.value.trim();
      const c2 = sel2.value.trim();
      if (!c1 || !c2) {
        out.textContent = "Please choose both Card 1 and Card 2.";
        return;
      }
      const card1 = findCardByName(c1);
      const card2 = findCardByName(c2);
      if (!card1 || !card2) {
        out.textContent = "Please choose both Card 1 and Card 2.";
        return;
      }

      persist();

      const rev1 = readOrientReversed("tok_orient_1");
      const rev2 = readOrientReversed("tok_orient_2");
      const l1 = orientationLabel(rev1);
      const l2 = orientationLabel(rev2);

      const src1 = "/images/tarot/rws/" + card1.slug + ".jpg";
      const src2 = "/images/tarot/rws/" + card2.slug + ".jpg";

      const comboParagraph = combinationMeaningParagraph(card1, card2, rev1, rev2);
      const compassParagraph = compassReflectionQuestion(card1, card2, rev1, rev2);
      const coreEssenceHtml = coreEssenceSectionHtml(card1, card2, rev1, rev2);

      const relationshipParagraph = relationshipFrame(card1, card2);
      const rankParagraph = rankFrame(card1, card2);
      const rankSectionHtml =
        rankParagraph !== ""
          ? '<section class="tarot-tool__out-block">' +
            '<h3 class="tarot-tool__out-h3">Rank relationship</h3>' +
            '<p class="tarot-tool__out-p">' +
            rankParagraph +
            "</p>" +
            "</section>"
          : "";

      out.innerHTML =
        '<div class="tarot-tool__combo-images">' +
        cardImageSlotHtml(src1, card1.name, rev1) +
        cardImageSlotHtml(src2, card2.name, rev2) +
        "</div>" +
        '<div class="tarot-tool__combo-copy">' +
        "<p class=\"tarot-tool__out-lede\">Combination selected:<br>" +
        escHtml(c1) +
        " (" +
        escHtml(l1) +
        ") + " +
        escHtml(c2) +
        " (" +
        escHtml(l2) +
        ")</p>" +
        '<section class="tarot-tool__out-block">' +
        '<h3 class="tarot-tool__out-h3">Card keywords</h3>' +
        '<p class="tarot-tool__out-p"><strong>' +
        escHtml(card1.name) +
        " (" +
        escHtml(l1) +
        "):</strong> " +
        keywordsFiveLine(card1) +
        "</p>" +
        '<p class="tarot-tool__out-p"><strong>' +
        escHtml(card2.name) +
        " (" +
        escHtml(l2) +
        "):</strong> " +
        keywordsFiveLine(card2) +
        "</p>" +
        "</section>" +
        coreEssenceHtml +
        '<section class="tarot-tool__out-block">' +
        '<h3 class="tarot-tool__out-h3">Arcana and suit relationship</h3>' +
        '<p class="tarot-tool__out-p">' +
        relationshipParagraph +
        "</p>" +
        "</section>" +
        rankSectionHtml +
        '<section class="tarot-tool__out-block">' +
        '<h3 class="tarot-tool__out-h3">Combination meaning</h3>' +
        '<p class="tarot-tool__out-p">' +
        comboParagraph +
        "</p>" +
        "</section>" +
        '<section class="tarot-tool__out-block">' +
        '<h3 class="tarot-tool__out-h3">COMPASS reflection</h3>' +
        '<p class="tarot-tool__out-p">' +
        compassParagraph +
        "</p>" +
        "</section>" +
        '<p class="tarot-tool__out-next"><strong>Next step:</strong><br />' +
        '<a href="/articles/compass-method/">Learn how to interpret this properly using the COMPASS Method</a>' +
        "</p>" +
        "</div>";
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTarotTool);
  } else {
    initTarotTool();
  }
</script>

