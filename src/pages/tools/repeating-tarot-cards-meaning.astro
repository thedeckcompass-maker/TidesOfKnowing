---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteBase } from "../../lib/site";
import { getSubscribeFormHiddenFields } from "../../lib/subscribeAttribution";

const title = "Repeating Tarot Cards Meaning – Why the Same Card Keeps Appearing";
const description =
  "A tarot tool for understanding why the same card keeps appearing across readings. This tool is currently in development.";
const ogUrl = new URL("/tools/repeating-tarot-cards-meaning/", siteBase(Astro)).href;

const subscribeHidden = getSubscribeFormHiddenFields({
  pagePathname: Astro.url.pathname,
  sourceComponent: "tool-holding-page",
});
---

<BaseLayout title={title} description={description} ogUrl={ogUrl}>
  <article class="tool-holding page-inner">
    <p class="tool-holding__eyebrow">TAROT TOOL IN DEVELOPMENT</p>
    <h1 class="tool-holding__title">Repeated Card Meaning Tool</h1>
    <h2 class="tool-holding__h2-intent">
      A tarot interpretation tool for exploring recurring cards across readings, relationships, situations, and periods of time.
    </h2>
    <p class="tool-holding__intro">
      When the same card continues appearing, the repetition often points toward something unresolved, unintegrated, re-emerging, or still unfolding beneath the surface of events.
    </p>
    <p class="tool-holding__body">
      Rather than treating repeated cards as isolated meanings, this tool is being developed to examine:<br />
      - what pattern may be attempting to stabilise across multiple readings<br />
      - what dynamic continues returning into awareness<br />
      - whether the repetition reflects pressure, timing, avoidance, confirmation, transition, or unfinished movement<br />
      - how the meaning of a recurring card shifts depending on surrounding circumstances and relational context
    </p>
    <p class="tool-holding__body">
      The focus is not simply the card itself, but the evolving relationship between the card, the situation, and the reader's changing position within it.
    </p>
    <p class="tool-holding__status">This tool is currently in development.</p>

    <section class="tool-holding__signup" aria-labelledby="tool-updates-heading">
      <h2 id="tool-updates-heading" class="tool-holding__signup-title">
        Get notified when this tool is live
      </h2>
      <p class="tool-holding__signup-copy">
        Join the Tides of Knowing list for new tarot tools, articles, and COMPASS method updates.
      </p>
      <!-- TODO: Connect this signup form to the chosen email/newsletter provider. -->
      <form class="tool-holding__form" action="/subscribe/" method="get">
        {
          Object.entries(subscribeHidden).map(([name, value]) => (
            <input type="hidden" name={name} value={value} />
          ))
        }
        <label class="tool-holding__label" for="holding-email-repeated">Email</label>
        <input
          class="tool-holding__input"
          id="holding-email-repeated"
          name="email"
          type="email"
          autocomplete="email"
          placeholder="you@example.com"
          required
        />
        <button class="tool-holding__button" type="submit">Notify Me</button>
      </form>
      <p class="tool-holding__privacy">No spam. Just new tools, articles, and occasional Tides of Knowing updates.</p>
    </section>

    <p class="tool-holding__back-wrap">
      <a class="tool-holding__back" href="/tools/two-card-tarot-reading/">Back to When Two Cards Meet</a>
    </p>
  </article>
</BaseLayout>

<style>
  .tool-holding {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 38rem;
  }

  .tool-holding__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .tool-holding__title {
    margin: 0 0 0.8rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.5rem);
    line-height: 1.15;
    color: var(--tok-text-light);
  }

  .tool-holding__h2-intent {
    margin: 0 0 0.55rem;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.62;
    font-weight: 500;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__intro {
    margin: 0 0 0.9rem;
    font-size: 1.04rem;
    line-height: 1.72;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__body {
    margin: 0 0 0.85rem;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__status {
    margin: 0 0 1.45rem;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--tok-text-light-soft);
  }

  .tool-holding__signup {
    border: 1px solid color-mix(in srgb, var(--tok-gold) 40%, transparent);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--tok-surface-reading) 45%, transparent);
    padding: 1rem 1.1rem 1.15rem;
    color: var(--tok-text-dark);
  }

  .tool-holding__signup-title {
    margin: 0 0 0.45rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--tok-water);
  }

  .tool-holding__signup-copy {
    margin: 0 0 0.9rem;
    font-size: 0.96rem;
    line-height: 1.65;
    color: var(--tok-text-dark);
  }

  .tool-holding__form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.6rem;
    align-items: end;
  }

  .tool-holding__label {
    grid-column: 1 / -1;
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-water);
  }

  .tool-holding__input {
    border: 1px solid color-mix(in srgb, var(--tok-water) 28%, transparent);
    border-radius: var(--radius-soft);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.5;
    padding: 0.68rem 0.72rem;
  }

  .tool-holding__button {
    padding: 0.78rem 1.1rem;
    font-family: var(--font-body);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-water);
    border: 2px solid var(--tok-gold);
    border-radius: var(--radius-2);
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
  }

  .tool-holding__button:hover {
    background: color-mix(in srgb, var(--tok-gold) 14%, transparent);
  }

  .tool-holding__privacy {
    margin: 0.72rem 0 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--tok-text-muted);
    opacity: 0.9;
  }

  .tool-holding__back-wrap {
    margin: 1.2rem 0 0;
  }

  .tool-holding__back {
    color: var(--tok-teal-light);
    text-decoration: underline;
    text-underline-offset: 0.12em;
  }

  .tool-holding__back:hover {
    color: var(--tok-text-light);
  }

  @media (max-width: 560px) {
    .tool-holding__form {
      grid-template-columns: 1fr;
    }
  }
</style>
