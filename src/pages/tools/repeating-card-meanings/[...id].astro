---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import RepeatingCardMeaningArticle from "../../../components/RepeatingCardMeaningArticle.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { isRepeatingMeaningReady } from "../../../lib/repeatingCardMeanings";
import { buildRepeatingCardPageModel } from "../../../lib/repeatingCardPageModel";
import {
  getRepeatingCardBreadcrumbs,
  getRepeatingCardMetaDescription,
  getRepeatingCardMetaTitle,
  getRepeatingCardOgImage,
} from "../../../lib/repeatingCardSeo";
import { getRepeatingCardToolPageJsonLd } from "../../../lib/repeatingCardEntitySchema";
import { getRepeatingCardCanonicalUrl, getRepeatingCardHubPath } from "../../../lib/repeatingCardUrls";
import { siteBase } from "../../../lib/site";

export const prerender = true;

export async function getStaticPaths() {
  const collection = await getCollection("repeatingCardMeanings");
  return collection
    .filter((entry) => isRepeatingMeaningReady(entry))
    .map((entry) => ({
      params: { id: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const paramId = Astro.params.id?.replace(/\/$/, "") ?? "";

if (!entry || entry.id !== paramId || !isRepeatingMeaningReady(entry)) {
  return Astro.redirect(getRepeatingCardHubPath());
}

const model = await buildRepeatingCardPageModel(entry);
if (!model) {
  return Astro.redirect(getRepeatingCardHubPath());
}

const base = siteBase(Astro);
const siteHref = base.href;
/** Tool URL is not self-canonical; entity page is the indexable canonical. */
const canonical = getRepeatingCardCanonicalUrl(entry, siteHref);
const title = getRepeatingCardMetaTitle(entry);
const description = getRepeatingCardMetaDescription(entry);
const ogImage = getRepeatingCardOgImage(entry, siteHref);
const crumbs = getRepeatingCardBreadcrumbs(entry);
const jsonLd = getRepeatingCardToolPageJsonLd(entry, siteHref);
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={canonical}
  ogType="article"
  ogImage={ogImage}
  metaAuthor="Leigh Spencer"
  jsonLd={jsonLd}
>
  <RepeatingCardMeaningArticle
    model={model}
    variant="tool"
    hubHref={getRepeatingCardHubPath()}
    hubLabel="Open the card selector tool"
  >
    <Breadcrumbs items={crumbs} slot="breadcrumbs" />
    <p class="rcm-card__back-wrap" slot="footer">
      <a class="rcm-card__back" href={getRepeatingCardHubPath()}>Back to Repeating Card Meanings</a>
      <span class="rcm-card__back-sep" aria-hidden="true">·</span>
      <a class="rcm-card__back" href="/tools/">Back to Tarot tools</a>
    </p>
  </RepeatingCardMeaningArticle>
</BaseLayout>
