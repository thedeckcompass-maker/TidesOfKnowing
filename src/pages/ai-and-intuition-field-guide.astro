---
import BaseLayout from "../layouts/BaseLayout.astro";
import AiIntuitionCta from "../components/lead-magnets/AiIntuitionCta.astro";
import { siteBase } from "../lib/site";

const title = "The AI and Intuition Field Guide | Tides of Knowing";
const description =
  "A compiled edition of the seven-part Tides of Knowing series: the essays, an additional unpublished closing essay, and private field notes for slower rereading.";
const ogUrl = new URL("/ai-and-intuition-field-guide/", siteBase(Astro)).href;
---

<BaseLayout title={title} description={description} ogUrl={ogUrl} tdcPlacement="none">
  <article class="tok-field-guide-page page-inner">
    <header class="tok-field-guide-page__hero">
      <p class="tok-field-guide-page__eyebrow">Field guide</p>
      <h1 class="tok-field-guide-page__title">The AI and Intuition Series</h1>
      <div class="tok-field-guide-page__lede">
        <p>
          This field guide gathers the full seven-part series into one place for rereading and reference. It is built
          for readers who want to hold the arc of the argument together: how symbolic work meets machine fluency, and
          what stays perceptual rather than merely verbal.
        </p>
        <p>
          The edition includes an additional unpublished closing essay written for the same audience as the essays,
          not published on the site. It also opens a short private sequence of seven field notes, sent weekly by email,
          that extend patterns and perceptual detail beyond what the public pieces hold room for.
        </p>
        <p>
          If you would like that edition and the notes, use the request below. The compiled PDF is delivered after
          signup through the same email path; there is no public download on this page.
        </p>
      </div>
    </header>

    <div class="tok-field-guide-page__cta" aria-label="Request the field guide edition">
      <AiIntuitionCta />
    </div>

    <footer class="tok-field-guide-page__closing">
      <p>
        Tides of Knowing is an ongoing exploration of symbolic perception, intuitive structure, and the conditions
        under which meaning becomes visible.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .tok-field-guide-page {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: 42rem;
  }

  .tok-field-guide-page__hero {
    margin-bottom: 1.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
  }

  .tok-field-guide-page__eyebrow {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-compact);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .tok-field-guide-page__title {
    margin: 0 0 1rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.55rem);
    line-height: 1.15;
    color: var(--tok-water);
  }

  .tok-field-guide-page__lede p {
    margin: 0 0 0.85rem;
    font-size: 1.05rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-dark);
  }

  .tok-field-guide-page__lede p:last-child {
    margin-bottom: 0;
  }

  .tok-field-guide-page__cta {
    margin: 0 0 2.25rem;
    padding: 0 0 0.5rem;
    max-width: 38rem;
  }

  .tok-field-guide-page__cta :global(.tok-ai-cta) {
    border-top: none;
    padding-top: 0;
  }

  .tok-field-guide-page__closing {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--tok-border-light);
  }

  .tok-field-guide-page__closing p {
    margin: 0;
    font-size: 0.98rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-muted);
  }
</style>
