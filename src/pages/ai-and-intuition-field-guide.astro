---
import BaseLayout from "../layouts/BaseLayout.astro";
import AiIntuitionCta from "../components/lead-magnets/AiIntuitionCta.astro";
import { siteBase } from "../lib/site";

const title = "The AI and Intuition Field Guide | Tides of Knowing";
const description =
  "A compiled edition of the seven-part Tides of Knowing series: the essays, an additional unpublished closing essay, and private field notes for slower rereading.";
const ogUrl = new URL("/ai-and-intuition-field-guide/", siteBase(Astro)).href;
/** Publication cover (static asset; no PDF link on this page). */
const coverSrc = "/images/lead-magnets/ai-intuition-field-guide-cover.png";
---

<BaseLayout title={title} description={description} ogUrl={ogUrl} tdcPlacement="none" mailerLite>
  <article class="tok-field-guide-page page-inner">
    <section class="tok-field-guide-page__acquisition" aria-labelledby="tok-field-guide-title">
      <div class="tok-field-guide-page__layout">
        <div class="tok-field-guide-page__cover-col">
          <figure class="tok-field-guide-page__cover">
            <img
              class="tok-field-guide-page__cover-img"
              src={coverSrc}
              alt="Cover of The AI and Intuition Series field guide"
              width="640"
              height="960"
              loading="eager"
              decoding="async"
            />
          </figure>
        </div>
        <div class="tok-field-guide-page__content-col">
          <p class="tok-field-guide-page__eyebrow">Field guide</p>
          <h1 id="tok-field-guide-title" class="tok-field-guide-page__title">The AI and Intuition Series</h1>
          <div class="tok-field-guide-page__lede">
            <p>
              This field guide gathers the full seven-part series into one place for rereading and reference. It is built
              for readers who want to hold the arc of the argument together: how symbolic work meets machine fluency, and
              what stays perceptual rather than merely verbal.
            </p>
            <p>
              The edition includes an additional unpublished closing essay written for the same audience as the essays,
              not published on the site. It also opens a short private sequence of seven field notes, sent weekly by email,
              that extend patterns and perceptual detail beyond what the public pieces hold room for.
            </p>
            <p>
              If you would like that edition and the notes, use the request below. The compiled PDF is delivered after
              signup through the same email path; there is no public download on this page.
            </p>
          </div>
          <div class="tok-field-guide-page__cta-wrap" aria-label="Request the field guide edition">
            <AiIntuitionCta showHeading={false} />
          </div>
        </div>
      </div>
    </section>

    <footer class="tok-field-guide-page__closing">
      <p>
        Tides of Knowing is an ongoing exploration of symbolic perception, intuitive structure, and the conditions
        under which meaning becomes visible.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .tok-field-guide-page {
    padding: clamp(2rem, 6vw, 3.5rem) 0 clamp(3rem, 8vw, 5rem);
    max-width: min(52rem, 100% - 2rem);
    margin-inline: auto;
  }

  .tok-field-guide-page__acquisition {
    margin-bottom: 0;
    padding-bottom: clamp(1.75rem, 4vw, 2.25rem);
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
  }

  .tok-field-guide-page__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.15rem 0;
    align-items: start;
  }

  @media (min-width: var(--bp-md)) {
    .tok-field-guide-page__layout {
      grid-template-columns: minmax(10.25rem, 12.5rem) minmax(0, 1fr);
      gap: 1.5rem clamp(1.5rem, 3vw, 2.25rem);
    }
  }

  .tok-field-guide-page__cover-col {
    min-width: 0;
  }

  .tok-field-guide-page__cover {
    margin: 0;
    padding: 0;
    max-width: min(11rem, 72vw);
    border: none;
  }

  @media (min-width: var(--bp-md)) {
    .tok-field-guide-page__cover {
      max-width: none;
    }
  }

  .tok-field-guide-page__cover-img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, var(--tok-border-light));
    border-radius: var(--radius-2);
    box-shadow: var(--shadow-sm);
  }

  .tok-field-guide-page__content-col {
    min-width: 0;
  }

  .tok-field-guide-page__eyebrow {
    margin: 0 0 0.45rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-compact);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-tdc);
    text-transform: uppercase;
    color: var(--tok-text-muted);
  }

  .tok-field-guide-page__title {
    margin: 0 0 1rem;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.85rem, 3.8vw, 2.45rem);
    line-height: 1.15;
    color: var(--tok-water);
  }

  .tok-field-guide-page__lede p {
    margin: 0 0 0.75rem;
    font-size: 1.05rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-dark);
  }

  .tok-field-guide-page__lede p:last-child {
    margin-bottom: 0;
  }

  .tok-field-guide-page__cta-wrap {
    margin-top: 0.65rem;
    padding-top: 0;
    max-width: 38rem;
  }

  .tok-field-guide-page__cta-wrap :global(.tok-ai-cta) {
    margin: 0;
    padding: 0.5rem 0 0;
    border-top: none;
    max-width: none;
  }

  .tok-field-guide-page__cta-wrap :global(.tok-ai-cta__body) {
    margin-bottom: 0.85rem;
  }

  .tok-field-guide-page__closing {
    margin-top: clamp(1.75rem, 4vw, 2.25rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--tok-border-light);
    max-width: 42rem;
  }

  .tok-field-guide-page__closing p {
    margin: 0;
    font-size: 0.98rem;
    line-height: var(--tok-line-body);
    color: var(--tok-text-muted);
  }
</style>
