---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanDisplayName } from "../../lib/community/auth";
import { authRedirect } from "../../lib/community/supabaseServer";
import { validateDisplayName } from "../../lib/community/validation";

export const prerender = false;

const title = "Join the Practice Commons | Tides of Knowing";
const description = "Join the Practice Commons at Tides of Knowing with a simple email sign-in link.";

let error = "";
let errorReference = "";
let errorCode = "";
const redirectTo = "/community/";

function emailDomain(email: string): string {
  return email.split("@")[1] ?? "";
}

function authErrorDetails(error: unknown) {
  if (!error || typeof error !== "object") {
    return {
      name: "UnknownAuthError",
      message: String(error),
      status: null,
      code: null,
    };
  }

  const authError = error as {
    name?: unknown;
    message?: unknown;
    status?: unknown;
    code?: unknown;
    error_code?: unknown;
    errorCode?: unknown;
  };
  const code = authError.code ?? authError.error_code ?? authError.errorCode;

  return {
    name: typeof authError.name === "string" ? authError.name : "AuthError",
    message: typeof authError.message === "string" ? authError.message : "No message returned.",
    status: typeof authError.status === "number" ? authError.status : null,
    code: typeof code === "string" ? code : null,
  };
}

function adminDiagnosticForAuthError(message: string): string {
  const normalized = message.toLowerCase();

  if (normalized.includes("redirect") || normalized.includes("not allowed")) {
    return "Check Supabase Auth Site URL and Redirect URLs. The production callback URL must be allowed.";
  }

  if (normalized.includes("email") && normalized.includes("disabled")) {
    return "Check Supabase Auth providers. Email authentication may be disabled.";
  }

  if (normalized.includes("invalid api key") || normalized.includes("jwt")) {
    return "Check PUBLIC_SUPABASE_ANON_KEY in Cloudflare Pages.";
  }

  if (normalized.includes("rate")) {
    return "Check Supabase Auth rate limits and recent repeated magic-link requests.";
  }

  return "Check Supabase Auth logs for this reference id and confirm email provider, redirect allow-list, and email delivery settings.";
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") ?? "").trim().toLowerCase();
  const displayName = cleanDisplayName(form.get("displayName"));
  const displayNameValidation = validateDisplayName(form.get("displayName"));
  const next = "/community/";

  if (!Astro.locals.supabase) {
    error = "Practice Commons sign-in is not configured yet.";
  } else if (!displayNameValidation.ok) {
    error = displayNameValidation.error;
  } else if (!email || !email.includes("@")) {
    error = "Please enter a valid email address.";
  } else {
    const registrationReference = crypto.randomUUID();
    const emailRedirectTo = new URL(
      `/auth/callback/?redirectTo=${encodeURIComponent(next)}`,
      Astro.url,
    ).href;

    let signInError: unknown = null;

    try {
      const result = await Astro.locals.supabase.auth.signInWithOtp({
        email,
        options: {
          emailRedirectTo,
          shouldCreateUser: true,
          data: { display_name: displayName },
        },
      });
      signInError = result.error;
    } catch (caughtError) {
      signInError = caughtError;
    }

    if (signInError) {
      const details = authErrorDetails(signInError);
      console.error("Practice Commons sign-in link request failed", {
        reference: registrationReference,
        errorName: details.name,
        errorCode: details.code,
        errorMessage: details.message,
        errorStatus: details.status,
        adminDiagnostic: adminDiagnosticForAuthError(details.message),
        emailDomain: emailDomain(email),
        redirectTo: next,
        emailRedirectTo,
        requestUrl: Astro.url.href,
      });
      error = "Unable to send a sign-in link right now. Please try again.";
      errorReference = registrationReference;
      errorCode = details.code ?? "";
    } else {
      const checkEmailUrl = new URL("/auth/check-email/", Astro.url);
      checkEmailUrl.searchParams.set("email", email);
      checkEmailUrl.searchParams.set("displayName", displayName);
      checkEmailUrl.searchParams.set("redirectTo", next);
      return authRedirect(checkEmailUrl.pathname + checkEmailUrl.search, Astro.cookies);
    }
  }
}
---

<BaseLayout title={title} description={description} metaRobots="noindex, nofollow">
  <main class="auth-page page-inner">
    <section class="auth-card" aria-labelledby="auth-heading">
      <div data-auth-entry>
        <p class="auth-kicker">Practice Commons</p>
        <h1 id="auth-heading">Join the Practice Commons</h1>
        <p class="auth-lede">
          Enter your name and email address and we'll email you a secure sign-in link.
        </p>

        {
          error ? (
            <div class="auth-notice auth-notice--error">
              <p>{error}</p>
              {errorReference ? <p>Reference: {errorReference}</p> : null}
              {errorCode ? <p>Error code: {errorCode}</p> : null}
            </div>
          ) : null
        }

        <form method="post" action="/auth/register/" class="auth-form" data-auth-register-form>
          <input type="hidden" name="redirectTo" value={redirectTo} />
          <label for="displayName">Your name</label>
          <input id="displayName" name="displayName" type="text" autocomplete="nickname" minlength="2" maxlength="60" required />
          <label for="email">Email address</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
          <button type="submit" data-auth-register-submit>Continue</button>
          <p class="auth-submit-status" data-auth-register-status hidden>
            Please wait... we're sending your secure sign-in link.
          </p>
        </form>
      </div>
      <div class="auth-confirmation" data-auth-confirmation hidden>
        <h2>✓ Check your email</h2>
        <p>
          We've sent a secure sign-in link to:
          <strong data-auth-confirmation-email></strong>
        </p>
        <p>Click the link in that email to enter the Practice Commons.</p>
        <p>If it doesn't arrive within a minute or two, check your Spam or Promotions folder.</p>
        <button type="button" data-auth-reset>Send another link</button>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const forms = document.querySelectorAll("[data-auth-register-form]");

  forms.forEach((form) => {
    if (!(form instanceof HTMLFormElement) || form.dataset.submitBound === "true") return;

    form.dataset.submitBound = "true";
    let submitted = false;
    const originalAction = form.getAttribute("action") || window.location.pathname;
    const submitButton = form.querySelector("[data-auth-register-submit]");
    const statusMessage = form.querySelector("[data-auth-register-status]");
    const entry = form.closest("[data-auth-entry]");
    const card = form.closest(".auth-card");
    const confirmation = card?.querySelector("[data-auth-confirmation]");
    const confirmationEmail = confirmation?.querySelector("[data-auth-confirmation-email]");
    const resetButton = confirmation?.querySelector("[data-auth-reset]");

    function restoreForm() {
      submitted = false;
      card?.classList.remove("auth-card--confirmed");
      if (entry instanceof HTMLElement) entry.hidden = false;
      if (confirmation instanceof HTMLElement) confirmation.hidden = true;
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
        submitButton.textContent = "Continue";
      }
      if (statusMessage instanceof HTMLElement) {
        statusMessage.hidden = true;
        statusMessage.textContent = "Please wait... we're sending your secure sign-in link.";
      }
    }

    resetButton?.addEventListener("click", restoreForm);

    form.addEventListener("submit", async (event) => {
      if (submitted) {
        event.preventDefault();
        return;
      }

      if (!form.checkValidity()) return;

      event.preventDefault();
      submitted = true;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = "Sending sign-in link...";
      }

      if (statusMessage instanceof HTMLElement) {
        statusMessage.hidden = false;
        statusMessage.textContent = "Please wait... we're sending your secure sign-in link.";
      }

      const formData = new FormData(form);
      const email = String(formData.get("email") || "").trim();

      try {
        const response = await fetch(originalAction, {
          method: "POST",
          body: formData,
          headers: { Accept: "text/html" },
          credentials: "same-origin",
        });
        const responseUrl = new URL(response.url);

        if (response.redirected && responseUrl.pathname === "/auth/check-email/") {
          if (confirmationEmail instanceof HTMLElement) confirmationEmail.textContent = email;
          card?.classList.add("auth-card--confirmed");
          if (entry instanceof HTMLElement) entry.hidden = true;
          if (confirmation instanceof HTMLElement) confirmation.hidden = false;
          return;
        }

        if (response.redirected) {
          window.location.assign(response.url);
          return;
        }

        throw new Error("Sign-in link request did not reach the confirmation page.");
      } catch (_error) {
        submitted = false;
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = "Continue";
        }
        if (statusMessage instanceof HTMLElement) {
          statusMessage.hidden = false;
          statusMessage.textContent = "Unable to send a sign-in link right now. Please try again.";
        }
      }
    });
  });
</script>

<style>
  .auth-page {
    position: relative;
    isolation: isolate;
    min-height: calc(100dvh - var(--tok-header-height));
    padding: clamp(0.9rem, 3vw, 2rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .auth-page::before {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: "";
    background:
      linear-gradient(
        120deg,
        color-mix(in srgb, var(--tok-deep-ocean) 8%, transparent),
        transparent 55%
      ),
      url("/images/community/compass-feather-hourglass.png") right top / min(48vw, 36rem) auto no-repeat;
    opacity: 0.12;
    pointer-events: none;
  }

  .auth-page::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--tok-surface-reading) 82%, transparent),
      color-mix(in srgb, var(--tok-surface-reading) 58%, transparent)
    );
    pointer-events: none;
  }

  .auth-card {
    max-width: 34rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 82%, transparent);
    box-shadow: var(--shadow-sm);
  }

  .auth-kicker {
    margin: 0 0 0.5rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .auth-card h1 {
    margin: 0 0 0.45rem;
    font-family: var(--font-accent);
    font-size: clamp(2rem, 6vw, 2.8rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--tok-water);
  }

  .auth-lede,
  .auth-alt,
  .auth-confirmation p {
    color: var(--tok-text-muted);
    line-height: 1.55;
  }

  .auth-form {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .auth-form[hidden] {
    display: none;
  }

  [data-auth-entry][hidden] {
    display: none;
  }

  .auth-card--confirmed [data-auth-entry] {
    display: none !important;
  }

  .auth-card--confirmed .auth-confirmation {
    margin-top: 0;
  }

  .auth-form label {
    font-size: var(--tok-type-label);
    font-weight: 700;
  }

  .auth-form label span,
  .auth-help {
    color: var(--tok-text-muted);
    font-weight: 400;
  }

  .auth-help {
    margin: -0.35rem 0 0.25rem;
    font-size: var(--tok-type-meta);
    line-height: 1.5;
  }

  .auth-form input {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
  }

  .auth-form button {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .auth-submit-status {
    margin: -0.35rem 0 0;
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
    line-height: 1.5;
  }

  .auth-confirmation {
    display: grid;
    gap: 0.55rem;
    margin-top: 1rem;
    padding: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--tok-teal) 34%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-teal) 7%, var(--tok-surface-reading) 93%);
  }

  .auth-confirmation[hidden] {
    display: none;
  }

  .auth-confirmation h2 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 4vw, 1.5rem);
    letter-spacing: normal;
    text-transform: none;
    color: var(--tok-water);
  }

  .auth-confirmation p {
    margin: 0;
  }

  .auth-confirmation strong {
    display: block;
    margin-top: 0.2rem;
    color: var(--tok-text-dark);
    font-weight: 800;
  }

  .auth-confirmation button {
    justify-self: start;
    padding: 0.55rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, transparent);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--tok-water);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .auth-notice {
    padding: 0.75rem 0.85rem;
    border-radius: var(--radius-control);
    line-height: 1.6;
  }

  .auth-notice p {
    margin: 0;
  }

  .auth-notice p + p {
    margin-top: 0.35rem;
  }

  .auth-notice--error {
    border: 1px solid color-mix(in srgb, #b42318 45%, transparent);
  }
</style>
