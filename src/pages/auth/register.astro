---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanDisplayName } from "../../lib/community/auth";
import { validateDisplayName } from "../../lib/community/validation";

export const prerender = false;

const title = "Join the Practice Commons | Tides of Knowing";
const description = "Join the Practice Commons at Tides of Knowing with a simple email sign-in link.";

let error = "";
let errorReference = "";
let errorCode = "";
const redirectTo = "/community/";

function emailDomain(email: string): string {
  return email.split("@")[1] ?? "";
}

function authErrorDetails(error: unknown) {
  if (!error || typeof error !== "object") {
    return {
      name: "UnknownAuthError",
      message: String(error),
      status: null,
      code: null,
    };
  }

  const authError = error as {
    name?: unknown;
    message?: unknown;
    status?: unknown;
    code?: unknown;
    error_code?: unknown;
    errorCode?: unknown;
  };
  const code = authError.code ?? authError.error_code ?? authError.errorCode;

  return {
    name: typeof authError.name === "string" ? authError.name : "AuthError",
    message: typeof authError.message === "string" ? authError.message : "No message returned.",
    status: typeof authError.status === "number" ? authError.status : null,
    code: typeof code === "string" ? code : null,
  };
}

function adminDiagnosticForAuthError(message: string): string {
  const normalized = message.toLowerCase();

  if (normalized.includes("redirect") || normalized.includes("not allowed")) {
    return "Check Supabase Auth Site URL and Redirect URLs. The production callback URL must be allowed.";
  }

  if (normalized.includes("email") && normalized.includes("disabled")) {
    return "Check Supabase Auth providers. Email authentication may be disabled.";
  }

  if (normalized.includes("invalid api key") || normalized.includes("jwt")) {
    return "Check PUBLIC_SUPABASE_ANON_KEY in Cloudflare Pages.";
  }

  if (normalized.includes("rate")) {
    return "Check Supabase Auth rate limits and recent repeated magic-link requests.";
  }

  return "Check Supabase Auth logs for this reference id and confirm email provider, redirect allow-list, and email delivery settings.";
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") ?? "").trim().toLowerCase();
  const displayName = cleanDisplayName(form.get("displayName"));
  const displayNameValidation = validateDisplayName(form.get("displayName"));
  const next = "/community/";

  if (!Astro.locals.supabase) {
    error = "Practice Commons sign-in is not configured yet.";
  } else if (!displayNameValidation.ok) {
    error = displayNameValidation.error;
  } else if (!email || !email.includes("@")) {
    error = "Please enter a valid email address.";
  } else {
    const registrationReference = crypto.randomUUID();
    const emailRedirectTo = new URL(
      `/auth/callback/?redirectTo=${encodeURIComponent(next)}`,
      Astro.url,
    ).href;

    console.info("Practice Commons sign-in link request started", {
      reference: registrationReference,
      emailDomain: emailDomain(email),
      displayNameLength: displayName.length,
      redirectTo: next,
      emailRedirectTo,
      requestUrl: Astro.url.href,
    });

    let signInError: unknown = null;

    try {
      const result = await Astro.locals.supabase.auth.signInWithOtp({
        email,
        options: {
          emailRedirectTo,
          shouldCreateUser: true,
          data: { display_name: displayName },
        },
      });
      signInError = result.error;
    } catch (caughtError) {
      signInError = caughtError;
    }

    if (signInError) {
      const details = authErrorDetails(signInError);
      console.error("Practice Commons sign-in link request failed", {
        reference: registrationReference,
        errorName: details.name,
        errorCode: details.code,
        errorMessage: details.message,
        errorStatus: details.status,
        adminDiagnostic: adminDiagnosticForAuthError(details.message),
        emailDomain: emailDomain(email),
        redirectTo: next,
        emailRedirectTo,
        requestUrl: Astro.url.href,
      });
      error = "Unable to send a sign-in link right now. Please try again.";
      errorReference = registrationReference;
      errorCode = details.code ?? "";
    } else {
      console.info("Practice Commons sign-in link request accepted", {
        reference: registrationReference,
        emailDomain: emailDomain(email),
        redirectTo: next,
        emailRedirectTo,
      });
      const checkEmailUrl = new URL("/auth/check-email/", Astro.url);
      checkEmailUrl.searchParams.set("email", email);
      checkEmailUrl.searchParams.set("displayName", displayName);
      checkEmailUrl.searchParams.set("redirectTo", next);
      return Astro.redirect(checkEmailUrl.pathname + checkEmailUrl.search, 303);
    }
  }
}
---

<BaseLayout title={title} description={description} metaRobots="noindex, nofollow">
  <main class="auth-page page-inner">
    <section class="auth-card" aria-labelledby="auth-heading">
      <p class="auth-kicker">Practice Commons</p>
      <h1 id="auth-heading">Join the Practice Commons</h1>
      <p class="auth-lede">
        Enter your name and email. We'll email you a sign-in link.
      </p>

      {
        error ? (
          <div class="auth-notice auth-notice--error">
            <p>{error}</p>
            {errorReference ? <p>Reference: {errorReference}</p> : null}
            {errorCode ? <p>Error code: {errorCode}</p> : null}
          </div>
        ) : null
      }

      <form method="post" class="auth-form" data-auth-register-form>
        <input type="hidden" name="redirectTo" value={redirectTo} />
        <label for="displayName">Display name</label>
        <input id="displayName" name="displayName" type="text" autocomplete="nickname" minlength="2" maxlength="60" required />
        <p class="auth-help">This is the name shown beside your posts and replies.</p>
        <label for="email">Email address</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
        <button type="submit" data-auth-register-submit>Continue</button>
        <p class="auth-submit-status" data-auth-register-status hidden>
          Please wait... we're sending your secure sign-in link.
        </p>
      </form>
    </section>
  </main>
</BaseLayout>

<script>
  const form = document.querySelector("[data-auth-register-form]");

  if (form instanceof HTMLFormElement && form.dataset.submitBound !== "true") {
    form.dataset.submitBound = "true";
    let submitted = false;

    form.addEventListener("submit", (event) => {
      if (submitted) {
        event.preventDefault();
        return;
      }

      submitted = true;

      const submitButton = form.querySelector("[data-auth-register-submit]");
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = "Sending...";
      }

      const statusMessage = form.querySelector("[data-auth-register-status]");
      if (statusMessage instanceof HTMLElement) {
        statusMessage.hidden = false;
      }
    });
  }
</script>

<style>
  .auth-page {
    padding: clamp(1.5rem, 5vw, 4rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .auth-card {
    max-width: 34rem;
    padding: clamp(1.25rem, 4vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .auth-kicker {
    margin: 0 0 0.5rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .auth-card h1 {
    margin: 0 0 0.75rem;
    font-family: var(--font-accent);
    font-size: clamp(2rem, 7vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--tok-water);
  }

  .auth-lede,
  .auth-alt {
    color: var(--tok-text-muted);
    line-height: 1.7;
  }

  .auth-form {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .auth-form label {
    font-size: var(--tok-type-label);
    font-weight: 700;
  }

  .auth-form label span,
  .auth-help {
    color: var(--tok-text-muted);
    font-weight: 400;
  }

  .auth-help {
    margin: -0.35rem 0 0.25rem;
    font-size: var(--tok-type-meta);
    line-height: 1.5;
  }

  .auth-form input {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
  }

  .auth-form button {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .auth-submit-status {
    margin: -0.35rem 0 0;
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
    line-height: 1.5;
  }

  .auth-notice {
    padding: 0.75rem 0.85rem;
    border-radius: var(--radius-control);
    line-height: 1.6;
  }

  .auth-notice p {
    margin: 0;
  }

  .auth-notice p + p {
    margin-top: 0.35rem;
  }

  .auth-notice--error {
    border: 1px solid color-mix(in srgb, #b42318 45%, transparent);
  }
</style>
