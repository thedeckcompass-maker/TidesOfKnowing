---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanDisplayName } from "../../lib/community/auth";
import { runAuthOtpRegisterFlow } from "../../lib/community/authOtpRegister";
import {
  createAuthOtpSubmissionId,
  normalizeAuthOtpClaimMode,
} from "../../lib/community/otpIdempotency";
import { authRedirect } from "../../lib/community/supabaseServer";
import { validateDisplayName } from "../../lib/community/validation";

export const prerender = false;

const title = "Join the Practice Commons | Tides of Knowing";
const description = "Join the Practice Commons at Tides of Knowing with a simple email sign-in link.";

let error = "";
let errorReference = "";
const redirectTo = "/community/";
const joinSubmissionId = createAuthOtpSubmissionId();

function authErrorDetails(error: unknown) {
  if (!error || typeof error !== "object") {
    return {
      name: "UnknownAuthError",
      message: String(error),
      status: null,
      code: null,
    };
  }

  const authError = error as {
    name?: unknown;
    message?: unknown;
    status?: unknown;
    code?: unknown;
    error_code?: unknown;
    errorCode?: unknown;
  };
  const code = authError.code ?? authError.error_code ?? authError.errorCode;

  return {
    name: typeof authError.name === "string" ? authError.name : "AuthError",
    message: typeof authError.message === "string" ? authError.message : "No message returned.",
    status: typeof authError.status === "number" ? authError.status : null,
    code: typeof code === "string" ? code : null,
  };
}

function isExpectedReturningMemberPrivacyError(error: unknown): boolean {
  const details = authErrorDetails(error);
  const normalized = details.message.toLowerCase();
  const code = details.code?.toLowerCase() ?? "";

  return (
    code.includes("user_not_found") ||
    code.includes("signup") ||
    normalized.includes("user not found") ||
    normalized.includes("signup") ||
    normalized.includes("signups not allowed")
  );
}

function checkEmailRedirect(
  email: string,
  displayName: string,
  next: string,
  includeDisplayName: boolean,
) {
  const checkEmailUrl = new URL("/auth/check-email/", Astro.url);
  checkEmailUrl.searchParams.set("email", email);
  if (includeDisplayName) {
    checkEmailUrl.searchParams.set("displayName", displayName);
  }
  checkEmailUrl.searchParams.set("redirectTo", next);
  return authRedirect(checkEmailUrl.pathname + checkEmailUrl.search, Astro.cookies);
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") ?? "").trim().toLowerCase();
  const authModeRaw = String(form.get("authMode") ?? "join");
  const claimMode = normalizeAuthOtpClaimMode(authModeRaw);
  const isReturningMemberSignIn = claimMode === "sign-in";
  const displayName = cleanDisplayName(form.get("displayName"));
  const displayNameValidation = claimMode === "join"
    ? validateDisplayName(form.get("displayName"))
    : ({ ok: true, value: { displayName: "" } } as const);
  const next = "/community/";
  const submissionId = String(form.get("submissionId") ?? "").trim();
  const headerSubmissionId = Astro.request.headers.get("x-auth-submission-id")?.trim() ?? "";

  if (!Astro.locals.supabase) {
    error = "Practice Commons sign-in is not configured yet.";
  } else if (!displayNameValidation.ok) {
    error = displayNameValidation.error;
  } else if (!email || !email.includes("@")) {
    error = "Please enter a valid email address.";
  } else {
    const emailRedirectTo = new URL(
      `/auth/callback/?redirectTo=${encodeURIComponent(next)}`,
      Astro.url,
    ).href;

    const flow = await runAuthOtpRegisterFlow(
      {
        submissionId,
        headerSubmissionId,
        authMode: claimMode,
        email,
        displayName,
        emailRedirectTo,
      },
      {
        locals: Astro.locals,
        isExpectedReturningMemberPrivacyError,
        signInWithOtp: async ({ email: otpEmail, emailRedirectTo: redirect, shouldCreateUser, displayName: otpDisplayName }) => {
          const result = await Astro.locals.supabase!.auth.signInWithOtp({
            email: otpEmail,
            options: {
              emailRedirectTo: redirect,
              shouldCreateUser,
              ...(otpDisplayName ? { data: { display_name: otpDisplayName } } : {}),
            },
          });
          return { error: result.error };
        },
      },
    );

    if (flow.outcome === "accepted") {
      return checkEmailRedirect(
        email,
        displayName,
        next,
        !isReturningMemberSignIn && Boolean(displayName),
      );
    }

    errorReference = flow.invocationId;
    if (flow.reason === "missing_submission") {
      error = "Unable to send a sign-in link right now. Please try again from the sign-in form.";
    } else if (flow.reason === "claim_unavailable") {
      error = "Unable to send a sign-in link right now. Please try again.";
    } else {
      error = "Unable to send a sign-in link right now. Please try again.";
    }
  }
}
---

<BaseLayout title={title} description={description} metaRobots="noindex, nofollow">
  <main class="auth-page page-inner">
    <section class="auth-card" aria-labelledby="auth-heading">
      <div data-auth-entry>
        <p class="auth-kicker">Practice Commons</p>
        <h1 id="auth-heading">Join the Practice Commons</h1>
        <p class="auth-lede">
          Enter your name and email address and we'll email you a secure sign-in link.
        </p>

        {
          error ? (
            <div class="auth-notice auth-notice--error">
              <p>{error}</p>
              {errorReference ? <p>Reference: {errorReference}</p> : null}
            </div>
          ) : null
        }

        <form method="post" action="/auth/register/" class="auth-form" data-auth-register-form>
          <input type="hidden" name="authMode" value="join" />
          <input type="hidden" name="redirectTo" value={redirectTo} />
          <input type="hidden" name="submissionId" value={joinSubmissionId} />
          <label for="displayName">Your name</label>
          <input id="displayName" name="displayName" type="text" autocomplete="nickname" minlength="2" maxlength="60" required />
          <label for="email">Email address</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
          <button type="submit" data-auth-register-submit>Continue</button>
          <p class="auth-submit-status" data-auth-register-status hidden>
            Please wait... we're sending your secure sign-in link.
          </p>
        </form>
      </div>
      <div class="auth-confirmation" data-auth-confirmation hidden>
        <h2>✓ Check your email</h2>
        <p>
          Check your email for your secure sign-in link:
          <strong data-auth-confirmation-email></strong>
        </p>
        <p>Click the link in that email to enter the Practice Commons.</p>
        <p>If it doesn't arrive within a minute or two, check your Spam or Promotions folder.</p>
        <button type="button" data-auth-reset>Send another link</button>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import { bindAuthRegisterForms } from "../../lib/community/authRegisterForm";

  bindAuthRegisterForms({
    cardSelector: ".auth-card",
    confirmedClass: "auth-card--confirmed",
    defaultButtonText: "Continue",
  });
</script>

<style>
  .auth-page {
    position: relative;
    isolation: isolate;
    min-height: calc(100dvh - var(--tok-header-height));
    padding: clamp(0.9rem, 3vw, 2rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .auth-page::before {
    position: absolute;
    inset: 0;
    z-index: -2;
    content: "";
    background:
      linear-gradient(
        120deg,
        color-mix(in srgb, var(--tok-deep-ocean) 8%, transparent),
        transparent 55%
      ),
      url("/images/community/compass-feather-hourglass.png") right top / min(48vw, 36rem) auto no-repeat;
    opacity: 0.12;
    pointer-events: none;
  }

  .auth-page::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--tok-surface-reading) 82%, transparent),
      color-mix(in srgb, var(--tok-surface-reading) 58%, transparent)
    );
    pointer-events: none;
  }

  .auth-card {
    max-width: 34rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 82%, transparent);
    box-shadow: var(--shadow-sm);
  }

  .auth-kicker {
    margin: 0 0 0.5rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .auth-card h1 {
    margin: 0 0 0.45rem;
    font-family: var(--font-accent);
    font-size: clamp(2rem, 6vw, 2.8rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--tok-water);
  }

  .auth-lede,
  .auth-alt,
  .auth-confirmation p {
    color: var(--tok-text-muted);
    line-height: 1.55;
  }

  .auth-form {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .auth-form[hidden] {
    display: none;
  }

  [data-auth-entry][hidden] {
    display: none;
  }

  .auth-card--confirmed [data-auth-entry] {
    display: none !important;
  }

  .auth-card--confirmed .auth-confirmation {
    margin-top: 0;
  }

  .auth-form label {
    font-size: var(--tok-type-label);
    font-weight: 700;
  }

  .auth-form label span,
  .auth-help {
    color: var(--tok-text-muted);
    font-weight: 400;
  }

  .auth-help {
    margin: -0.35rem 0 0.25rem;
    font-size: var(--tok-type-meta);
    line-height: 1.5;
  }

  .auth-form input {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border: 1px solid var(--tok-border-light);
    border-radius: var(--radius-control);
    background: var(--tok-surface-reading);
    color: var(--tok-text-dark);
  }

  .auth-form button {
    justify-self: start;
    padding: var(--tok-ui-btn-pad-y) var(--tok-ui-btn-pad-x);
    border: 0;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .auth-submit-status {
    margin: -0.35rem 0 0;
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
    line-height: 1.5;
  }

  .auth-confirmation {
    display: grid;
    gap: 0.55rem;
    margin-top: 1rem;
    padding: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--tok-teal) 34%, transparent);
    border-radius: var(--radius-control);
    background: color-mix(in srgb, var(--tok-teal) 7%, var(--tok-surface-reading) 93%);
  }

  .auth-confirmation[hidden] {
    display: none;
  }

  .auth-confirmation h2 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 4vw, 1.5rem);
    letter-spacing: normal;
    text-transform: none;
    color: var(--tok-water);
  }

  .auth-confirmation p {
    margin: 0;
  }

  .auth-confirmation strong {
    display: block;
    margin-top: 0.2rem;
    color: var(--tok-text-dark);
    font-weight: 800;
  }

  .auth-confirmation button {
    justify-self: start;
    padding: 0.55rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--tok-gold) 42%, transparent);
    border-radius: var(--radius-control);
    background: transparent;
    color: var(--tok-water);
    font-weight: var(--tok-ui-btn-font-weight);
    cursor: pointer;
  }

  .auth-notice {
    padding: 0.75rem 0.85rem;
    border-radius: var(--radius-control);
    line-height: 1.6;
  }

  .auth-notice p {
    margin: 0;
  }

  .auth-notice p + p {
    margin-top: 0.35rem;
  }

  .auth-notice--error {
    border: 1px solid color-mix(in srgb, #b42318 45%, transparent);
  }
</style>
