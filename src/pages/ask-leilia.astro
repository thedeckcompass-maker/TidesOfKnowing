---
import BaseLayout from "../layouts/BaseLayout.astro";
import AskLeiliaPricingGrid from "../components/ask-leilia/AskLeiliaPricingGrid.astro";
import AskLeiliaProofReviews from "../components/ask-leilia/AskLeiliaProofReviews.astro";
import AskLeiliaSamplePreviews from "../components/ask-leilia/AskLeiliaSamplePreviews.astro";
import AskLeiliaReviewsCarousel from "../components/ask-leilia/AskLeiliaReviewsCarousel.astro";
import {
  ASK_LEILIA_PURCHASE_REASSURANCE,
  ASK_LEILIA_READINGS,
  ASK_LEILIA_DELIVERABLES,
  ASK_LEILIA_DELIVERABLE_PUBLIC_LABELS,
  ASK_LEILIA_PUBLIC_BRAND,
  ASK_LEILIA_SALES_SAMPLE_PREVIEWS,
  LEILIA_PORTRAIT_ALT,
  LEILIA_PORTRAIT_PATH,
  askLeiliaAuthorPersonNode,
  type AskLeiliaSalesSamplePreview,
} from "../data/askLeilia";
import { siteBase } from "../lib/site";
import { createCommunityServiceClient } from "../lib/community/supabaseServer";
import { listPublicAskLeiliaReviews } from "../lib/ask-leilia/reviews/queries";
import { selectAskLeiliaProofReviews } from "../lib/ask-leilia/salesPageProof";
import { getPublishedLibraryPublicationBySlug } from "../lib/readingLibrary";
import "../styles/ask-leilia.css";
import "../styles/ask-leilia-reviews.css";

export const prerender = false;

const title = "Ask Leilia | Professional Written Tarot Readings";
const description =
  "Choose a personally interpreted tarot reading from Leilia: one focused question, an in-depth exploration, or a Personal Guidance Reading that includes her signature Waka Spread and private recorded interpretation. Delivered within 48 hours.";
const canonical = new URL("/ask-leilia/", siteBase(Astro)).href;

let publicReviews: Awaited<ReturnType<typeof listPublicAskLeiliaReviews>> = [];
let proofReviews: typeof publicReviews = [];
let salesSamples: AskLeiliaSalesSamplePreview[] = ASK_LEILIA_SALES_SAMPLE_PREVIEWS;

try {
  const service = createCommunityServiceClient(Astro.locals);
  publicReviews = await listPublicAskLeiliaReviews(service, 6);
  proofReviews = selectAskLeiliaProofReviews(publicReviews, 2);

  const resolvedSamples = await Promise.all(
    ASK_LEILIA_SALES_SAMPLE_PREVIEWS.map(async (fallback) => {
      const publication = await getPublishedLibraryPublicationBySlug(service, fallback.slug);
      if (!publication) return fallback;
      const imagePath = publication.spreadImagePaths[0] || fallback.imagePath;
      const summary = publication.summary?.trim();
      return {
        ...fallback,
        title: publication.title || fallback.title,
        description:
          summary && summary.length > 0
            ? summary.length > 160
              ? `${summary.slice(0, 157).trim()}…`
              : summary
            : fallback.description,
        imagePath,
      };
    }),
  );
  salesSamples = resolvedSamples;
} catch (error) {
  console.error("Unable to load Ask Leilia sales-page proof content:", error);
  proofReviews = selectAskLeiliaProofReviews(publicReviews, 2);
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Ask Leilia",
  description,
  url: canonical,
  provider: askLeiliaAuthorPersonNode(),
  offers: ASK_LEILIA_READINGS.map((reading) => ({
    "@type": "Offer",
    name: reading.name,
    description: reading.positioning,
    price: reading.price.replace(/[^\d.]/g, ""),
    priceCurrency: "USD",
    availability: "https://schema.org/PreOrder",
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={canonical}
  ogTitle={title}
  ogDescription={description}
  metaAuthor={ASK_LEILIA_PUBLIC_BRAND}
  jsonLd={jsonLd}
>
  <main class="ask-leilia page-inner">
    <section class="ask-leilia-hero" aria-labelledby="ask-leilia-heading">
      <div class="ask-leilia-hero__copy">
        <p class="ask-leilia__kicker">Professional Tarot Readings</p>
        <h1 id="ask-leilia-heading">Ask Leilia</h1>
        <p class="ask-leilia-hero__lede">
          What the cards actually show, not what would feel nice to hear.
        </p>
        <p class="ask-leilia-hero__lede">
          Forty years of tarot practice, read honestly, whatever you're asking. The aim is clarity
          you can use, not comfort you'll outgrow.
        </p>
        <p class="ask-leilia-hero__lede">
          Every Ask Leilia reading is written personally for your question, not a template, not a
          general spread. It's interpreted entirely by me, with no AI involved at any stage, and
          delivered within 48 hours.
        </p>
        <p class="ask-leilia-hero__actions">
          <a class="ask-leilia-hero__cta" href="#choose-your-reading">Choose Your Reading</a>
        </p>
      </div>
    </section>

    <AskLeiliaProofReviews reviews={proofReviews} />

    <AskLeiliaPricingGrid
      sectionId="choose-your-reading"
      heading="Choose the depth that fits what you need"
      headingId="readings-heading"
      intro="Every reading is interpreted personally by me. The difference is the scope of what you bring, the depth of the exploration, and the way the reading is delivered."
      readings={ASK_LEILIA_READINGS}
      buttonLabel="Request This Reading"
    />

    <aside class="ask-leilia-reassure" aria-label="Purchase reassurance">
      <ul class="ask-leilia-reassure__list">
        {
          ASK_LEILIA_PURCHASE_REASSURANCE.map((point) => (
            <li>
              <span class="ask-leilia-reassure__mark" aria-hidden="true">
                •
              </span>
              {point}
            </li>
          ))
        }
      </ul>
    </aside>

    <AskLeiliaSamplePreviews samples={salesSamples} />

    <section class="ask-leilia-library-cta" aria-labelledby="ask-leilia-library-cta-heading">
      <h2 id="ask-leilia-library-cta-heading">Explore more genuine readings</h2>
      <p>
        Browse authorised client readings and see the cards, spreads, and full interpretations across
        different questions and situations.
      </p>
      <a class="ask-leilia-library-cta__link" href="/recent-client-readings/">
        Explore the Reading Library
      </a>
    </section>

    <section class="ask-leilia-return" aria-labelledby="ask-leilia-return-heading">
      <h2 id="ask-leilia-return-heading">Ready to choose your reading?</h2>
      <p>Select the level of depth that fits what you need now.</p>
      <p class="ask-leilia-return__actions">
        <a class="ask-leilia-hero__cta" href="#choose-your-reading">Choose My Reading</a>
      </p>
      <ul class="ask-leilia-return__links">
        {
          ASK_LEILIA_READINGS.map((reading) => (
            <li>
              <a href={reading.requestHref}>{reading.name}</a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="ask-leilia-hero__copy" aria-label="About Ask Leilia readings">
      <p class="ask-leilia-hero__subheading">
        Professional written tarot readings, personally interpreted by Leilia.
      </p>
      <p class="ask-leilia-hero__lede">
        Whether you're facing a difficult decision, seeking clarity about a relationship,
        wondering what comes next, or simply looking for another perspective, each reading is
        personally completed using traditional tarot methods and delivered as a professionally
        written PDF.
      </p>
    </section>

    <section class="ask-leilia-about" aria-labelledby="meet-leilia-heading">
      <figure class="ask-leilia-about__portrait">
        <img
          class="ask-leilia-about__photo"
          src={LEILIA_PORTRAIT_PATH}
          width="640"
          height="853"
          alt={LEILIA_PORTRAIT_ALT}
          loading="lazy"
          decoding="async"
        />
      </figure>

      <div class="ask-leilia-about__copy">
        <h2 id="meet-leilia-heading">Meet Leilia</h2>
        <p>
          Leilia – Tides of Knowing is the name I use for my professional tarot practice. I've been
          reading tarot since I first carried a deck to school at the age of ten. What began as
          childhood curiosity slowly became a lifelong practice.
        </p>
        <p>
          Over the last four decades, I've read cards through many seasons of life.
          Alongside that journey, I spent more than thirty years working as a
          journalist, broadcaster and editor, learning to listen carefully, ask
          thoughtful questions and look beneath the surface of people's stories.
        </p>
        <p>
          My approach is less about prediction and more about understanding. I am
          interested in the patterns beneath experience, the tensions we carry, the
          choices before us, and the guidance that emerges when we look honestly at
          what the cards reveal.
        </p>
        <p>
          Every Ask Leilia reading is written personally by me. There are no templates
          and no automated interpretations. I spend time with your question, the cards
          and the wider story surrounding what you are experiencing.
        </p>
        <p class="ask-leilia-about__trust">
          Reading cards for more than 40 years • Journalist and editor for more than 30
          years • Creator of The COMPASS Method™
        </p>
      </div>
    </section>

    <section class="ask-leilia-grid" aria-label="Process and service details">
      <article class="ask-leilia-card">
        <h2>How It Works</h2>
        <ol>
          <li>Choose your reading and share your question.</li>
          <li>Complete your booking.</li>
          <li>Receive your reading within 48 hours.</li>
        </ol>
      </article>

      <article class="ask-leilia-card">
        <h2>What You Receive</h2>
        <ul>
          <li>A personally interpreted tarot reading.</li>
          <li>
            <strong>{ASK_LEILIA_DELIVERABLE_PUBLIC_LABELS["one-question"]}:</strong>
            <ul>
              {ASK_LEILIA_DELIVERABLES["one-question"].map((item) => <li>{item}</li>)}
            </ul>
          </li>
          <li>
            <strong>{ASK_LEILIA_DELIVERABLE_PUBLIC_LABELS["in-depth"]}:</strong>
            <ul>
              {ASK_LEILIA_DELIVERABLES["in-depth"].map((item) => <li>{item}</li>)}
            </ul>
          </li>
          <li>
            <strong>{ASK_LEILIA_DELIVERABLE_PUBLIC_LABELS["personal-guidance"]}:</strong>
            <span class="ask-leilia-card__descriptor"> Includes Leilia’s signature Waka Spread.</span>
            <ul>
              {ASK_LEILIA_DELIVERABLES["personal-guidance"].map((item) => <li>{item}</li>)}
            </ul>
          </li>
        </ul>
      </article>
    </section>

    <AskLeiliaReviewsCarousel reviews={publicReviews} />

    <section class="ask-leilia-section" aria-labelledby="questions-heading">
      <h2 id="questions-heading">Questions People Bring</h2>
      <p>
        Whether you are navigating a crossroads, seeking clarity around a relationship,
        or wondering what comes next, Ask Leilia offers professional written guidance
        grounded in traditional tarot interpretation.
      </p>
      <div class="ask-leilia-question-grid">
        <article>
          <h3>Who</h3>
          <ul>
            <li>Who am I becoming through this experience?</li>
            <li>Who or what is asking for my attention?</li>
            <li>Who am I when familiar roles no longer fit?</li>
          </ul>
        </article>
        <article>
          <h3>What</h3>
          <ul>
            <li>What am I being invited to understand?</li>
            <li>What assumptions am I carrying into this situation?</li>
            <li>What might I be overlooking?</li>
            <li>What is trying to emerge here?</li>
          </ul>
        </article>
        <article>
          <h3>Where</h3>
          <ul>
            <li>Where am I being asked to place my attention?</li>
            <li>Where have I become disconnected from myself?</li>
            <li>Where does this path appear to be leading?</li>
            <li>Where is growth asking something of me?</li>
          </ul>
        </article>
        <article>
          <h3>How</h3>
          <ul>
            <li>How might I work consciously with this transition?</li>
            <li>How do these cards deepen my understanding?</li>
            <li>How can I navigate this with greater awareness?</li>
            <li>How might I respond rather than react?</li>
          </ul>
        </article>
      </div>
      <p class="ask-leilia-pull">
        Many people also bring their own cards and simply ask:
        <span>"I've pulled these cards. What might I not be seeing?"</span>
      </p>
    </section>
  </main>
</BaseLayout>
