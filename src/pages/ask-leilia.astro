---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteBase } from "../lib/site";

const title = "Ask Leilia | Personal Tarot Reflections and Symbolic Guidance";
const description =
  "Ask Leilia offers thoughtful written tarot reflections for readers and seekers, with one question, three cards, and a written response within 48 hours.";
const canonical = new URL("/ask-leilia/", siteBase(Astro)).href;

const offer = {
  name: "One Question - Three Cards",
  price: "US$25",
  delivery: "Delivered within 48 hours",
};
const leiliaPortraitPath = "/images/about/leigh-spencer-profile.png";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Ask Leilia",
  description,
  url: canonical,
  provider: {
    "@type": "Person",
    name: "Leigh Spencer",
  },
  offers: {
    "@type": "Offer",
    name: offer.name,
    price: "25",
    priceCurrency: "USD",
    availability: "https://schema.org/PreOrder",
  },
};
---

<BaseLayout
  title={title}
  description={description}
  ogUrl={canonical}
  ogTitle={title}
  ogDescription={description}
  jsonLd={jsonLd}
>
  <main class="ask-leilia page-inner">
    <section class="ask-leilia-hero" aria-labelledby="ask-leilia-heading">
      <div class="ask-leilia-hero__copy">
        <p class="ask-leilia__kicker">Personal Tarot Reflections</p>
        <h1 id="ask-leilia-heading">Ask Leilia</h1>
        <p class="ask-leilia-hero__lede">
          Thoughtful written reflections for readers and seekers.
        </p>
        <div class="ask-leilia-hero__offer" aria-label="Offer summary">
          <p>Three cards • One question • Delivered within 48 hours</p>
          <p class="ask-leilia-hero__price">US$25</p>
        </div>
        <p>
          <a class="ask-leilia-hero__cta" href="/ask-leilia/request/">Begin Your Reflection</a>
        </p>
      </div>
    </section>

    <section class="ask-leilia-about" aria-labelledby="meet-leilia-heading">
      <figure class="ask-leilia-about__portrait">
        <img
          class="ask-leilia-about__photo"
          src={leiliaPortraitPath}
          width="640"
          height="853"
          alt="Professional portrait of Leigh Spencer, founder of Tides of Knowing, smiling outdoors in a park setting."
          loading="eager"
          decoding="async"
        />
      </figure>

      <div class="ask-leilia-about__copy">
        <h2 id="meet-leilia-heading">Meet Leigh (Leilia)</h2>
        <p>
          Readers know me as Leilia, the name I use when working with the cards.
          Outside the reading room, I'm Leigh Spencer. I've been reading tarot since
          I first carried a deck to school at the age of ten. What began as childhood
          curiosity slowly became a lifelong practice.
        </p>
        <p>
          Over the last four decades, I've read cards through many seasons of life.
          Alongside that journey, I spent more than thirty years working as a
          journalist, broadcaster and editor, learning to listen carefully, ask
          thoughtful questions and look beneath the surface of people's stories.
        </p>
        <p>
          My approach is less about prediction and more about reflection. I am
          interested in the patterns beneath experience, the tensions we carry, the
          choices before us, and the meanings that quietly emerge when we give ourselves
          permission to look honestly.
        </p>
        <p>
          Every Ask Leilia reflection is written personally by me. There are no templates
          and no automated interpretations. I spend time with your question, the cards
          and the wider story surrounding what you are experiencing.
        </p>
        <p class="ask-leilia-about__trust">
          Reading cards for more than 40 years • Journalist and editor for more than 30
          years • Creator of The COMPASS Method™
        </p>
      </div>
    </section>

    <section class="ask-leilia-grid" aria-label="Process and service details">
      <article class="ask-leilia-card">
        <h2>Process</h2>
        <ol>
          <li>Share one question.</li>
          <li>Complete your booking.</li>
          <li>Receive a thoughtful written reflection within 48 hours.</li>
        </ol>
      </article>

      <article class="ask-leilia-card">
        <h2>What you receive</h2>
        <ul>
          <li>One question.</li>
          <li>A three-card reading.</li>
          <li>A thoughtful written reflection.</li>
          <li>Delivery within 48 hours.</li>
        </ul>
      </article>
    </section>

    <section class="ask-leilia-section" aria-labelledby="questions-heading">
      <h2 id="questions-heading">Questions people bring</h2>
      <p>
        Whether you are exploring your own cards, navigating a crossroads, or seeking
        clarity around a question, Ask Leilia provides a quiet space for reflection.
      </p>
      <div class="ask-leilia-question-grid">
        <article>
          <h3>Who</h3>
          <ul>
            <li>Who am I becoming through this experience?</li>
            <li>Who or what is asking for my attention?</li>
            <li>Who am I when familiar roles no longer fit?</li>
          </ul>
        </article>
        <article>
          <h3>What</h3>
          <ul>
            <li>What am I being invited to understand?</li>
            <li>What assumptions am I carrying into this situation?</li>
            <li>What might I be overlooking?</li>
            <li>What is trying to emerge here?</li>
          </ul>
        </article>
        <article>
          <h3>Where</h3>
          <ul>
            <li>Where am I being asked to place my attention?</li>
            <li>Where have I become disconnected from myself?</li>
            <li>Where does this path appear to be leading?</li>
            <li>Where is growth asking something of me?</li>
          </ul>
        </article>
        <article>
          <h3>How</h3>
          <ul>
            <li>How might I work consciously with this transition?</li>
            <li>How do these cards deepen my understanding?</li>
            <li>How can I navigate this with greater awareness?</li>
            <li>How might I respond rather than react?</li>
          </ul>
        </article>
      </div>
      <p class="ask-leilia-pull">
        Many people also bring their own cards and simply ask:
        <span>"I've pulled these cards. What might I not be seeing?"</span>
      </p>
    </section>

    <p class="ask-leilia-bottom-cta">
      <a class="ask-leilia-hero__cta" href="/ask-leilia/request/">Begin Your Reflection</a>
    </p>
  </main>
</BaseLayout>

<style>
  .ask-leilia {
    padding: clamp(1rem, 3vw, 2rem) 0 clamp(2.5rem, 6vw, 4rem);
  }

  .ask-leilia__kicker {
    margin: 0 0 0.55rem;
    font-size: var(--tok-type-meta);
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: var(--tok-gold-deep);
  }

  .ask-leilia-hero {
    display: grid;
    gap: 1rem;
    padding: clamp(1.1rem, 4vw, 2.15rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 38%, transparent);
    border-radius: var(--radius-promo);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--tok-surface-reading) 88%, transparent),
        color-mix(in srgb, var(--tok-surface-reading-soft) 76%, transparent)
      );
    box-shadow: var(--shadow-sm);
  }

  .ask-leilia-hero__copy {
    max-width: 42rem;
  }

  .ask-leilia h1,
  .ask-leilia-section h2,
  .ask-leilia-about h2,
  .ask-leilia-request h2 {
    margin: 0 0 0.85rem;
    font-family: var(--font-accent);
    font-weight: 400;
    color: var(--tok-water);
  }

  .ask-leilia h1 {
    font-size: clamp(2.75rem, 9vw, 5rem);
    line-height: 0.95;
  }

  .ask-leilia-section h2,
  .ask-leilia-about h2,
  .ask-leilia-request h2 {
    font-size: clamp(1.9rem, 6vw, 3rem);
    line-height: 1.08;
  }

  .ask-leilia-hero__lede {
    max-width: 34rem;
    margin: 0 0 0.85rem;
    font-size: clamp(1.08rem, 2.4vw, 1.25rem);
    color: var(--tok-text-dark);
  }

  .ask-leilia-hero__offer {
    display: grid;
    gap: 0.25rem;
    max-width: 34rem;
    margin: 0.9rem 0;
    padding: 0.75rem 0;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 36%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--tok-gold) 36%, transparent);
  }

  .ask-leilia-hero__offer p {
    margin: 0;
    color: var(--tok-text-dark);
  }

  .ask-leilia-hero__price,
  .ask-leilia-card h2 {
    font-family: var(--font-heading);
    font-weight: 400;
    color: var(--tok-water);
  }

  .ask-leilia-hero__price {
    padding-top: 0.2rem;
    font-size: 1.45rem;
  }

  .ask-leilia-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.75rem 1.15rem;
    border-radius: var(--radius-control);
    background: var(--tok-btn-filled-bg);
    color: var(--tok-btn-filled-fg);
    font-weight: 700;
    text-decoration: none;
  }

  .ask-leilia-section,
  .ask-leilia-grid,
  .ask-leilia-about {
    margin-top: clamp(1.75rem, 5vw, 3.25rem);
  }

  .ask-leilia-about {
    margin-top: clamp(1rem, 3vw, 1.5rem);
  }

  .ask-leilia-section {
    max-width: 48rem;
  }

  .ask-leilia p,
  .ask-leilia li {
    color: var(--tok-text-dark);
    line-height: 1.82;
  }

  .ask-leilia-section p {
    font-size: 1.03rem;
  }

  .ask-leilia-about {
    display: grid;
    gap: clamp(1rem, 3vw, 1.5rem);
    align-items: start;
    padding: clamp(1rem, 3vw, 1.5rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 30%, transparent);
    border-radius: var(--radius-promo);
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--tok-surface-reading) 78%, transparent),
        color-mix(in srgb, var(--tok-surface-reading-soft) 58%, transparent)
      );
    box-shadow: var(--shadow-sm);
  }

  .ask-leilia-about__portrait {
    margin: 0;
    max-width: min(100%, 17.5rem);
  }

  .ask-leilia-about__photo {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-soft);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 40%, transparent);
    box-shadow: var(--shadow-md);
    object-fit: cover;
    object-position: center top;
  }

  .ask-leilia-about__copy {
    max-width: 48rem;
  }

  .ask-leilia-about__copy p {
    margin: 0;
    font-size: 1rem;
  }

  .ask-leilia-about__copy p + p {
    margin-top: 0.8rem;
  }

  .ask-leilia-about__trust {
    padding-top: 0.8rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    color: var(--tok-text-muted);
    font-size: var(--tok-type-meta);
    letter-spacing: 0.02em;
  }

  .ask-leilia-grid {
    display: grid;
    gap: 0.9rem;
  }

  .ask-leilia-card {
    padding: clamp(0.95rem, 3vw, 1.35rem);
    border: 1px solid color-mix(in srgb, var(--tok-gold) 32%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading) 72%, transparent);
  }

  .ask-leilia-card h2,
  .ask-leilia-question-grid h3 {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 4vw, 1.6rem);
    color: var(--tok-water);
  }

  .ask-leilia-card ul,
  .ask-leilia-card ol,
  .ask-leilia-question-grid ul {
    margin: 0;
    padding-left: 1.15rem;
  }

  .ask-leilia-card li + li,
  .ask-leilia-question-grid li + li {
    margin-top: 0.45rem;
  }

  .ask-leilia-question-grid {
    display: grid;
    gap: 0.9rem;
    margin-top: 1rem;
  }

  .ask-leilia-question-grid article {
    padding: 0.95rem;
    border: 1px solid color-mix(in srgb, var(--tok-border-light) 85%, transparent);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tok-surface-reading-soft) 42%, transparent);
  }

  .ask-leilia-pull {
    margin-top: 1.5rem;
    padding: 1rem 0 0;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
    color: var(--tok-text-muted);
  }

  .ask-leilia-pull span {
    display: block;
    margin-top: 0.45rem;
    font-family: var(--font-accent);
    font-size: clamp(1.35rem, 4vw, 1.85rem);
    color: var(--tok-water);
  }

  .ask-leilia-bottom-cta {
    margin-top: clamp(1.75rem, 5vw, 3rem);
  }

  @media (min-width: 760px) {
    .ask-leilia-grid,
    .ask-leilia-question-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ask-leilia-about {
      grid-template-columns: minmax(11.5rem, 14.75rem) minmax(0, 1fr);
      column-gap: clamp(1.25rem, 4vw, 2rem);
    }

    .ask-leilia-about__portrait {
      max-width: 14.75rem;
    }
  }
</style>
