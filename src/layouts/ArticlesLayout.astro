---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import ArticleHeader from "../components/ArticleHeader.astro";
import ShareButtons from "../components/share/ShareButtons.astro";
import ShareSidebar from "../components/share/ShareSidebar.astro";
import ArticleAudio from "../components/ArticleAudio.astro";
import ArticleSeries from "../components/ArticleSeries.astro";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { getArticleAudio } from "../lib/articleAudio";
import AuthorBlock from "../components/AuthorBlock.astro";
import FurtherReading from "../components/FurtherReading.astro";
import ShortAnswerBlock from "../components/ShortAnswerBlock.astro";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../lib/breadcrumbs";
import { ENTITY_IDS } from "../lib/ecosystem-structured-data";
import { siteBase } from "../lib/site";
import {
  isRepeatingCardPatternsArticle,
  REPEATING_CARD_PATTERNS_SERIES_NAME,
} from "../lib/repeatingCardPatternsSeries";
import { slugify } from "../utils/slugify";

interface Props {
  article: CollectionEntry<"articles">;
  readingMinutes?: number;
  /** When set, used for the visible article H1 instead of frontmatter title. */
  headerTitle?: string;
  /** When set (including empty string), overrides frontmatter subtitle for the header. */
  headerSubtitle?: string | null;
  /** When true, omits the global "Continue through the system" block (e.g. the COMPASS Method hub has its own pathways). */
  hideSystemPathway?: boolean;
  /** Optional per-page override for the author attribution line shown above article body. */
  authorBioOverride?: string;
  /** Hide top share buttons in article header for specific pages. */
  hideTopShare?: boolean;
  /** Hide mobile sticky share bar for specific pages. */
  hideMobileShareBar?: boolean;
  /** Optional overrides for the conversion CTA copy. */
  conversionBlockCopy?: {
    kicker?: string;
    heading?: string;
    description?: string;
    ctaLabel?: string;
    ctaHref?: string;
  };
  /** When true, loads MailerLite universal.js (e.g. AI series lead-magnet modal). */
  mailerLite?: boolean;
}

const {
  article,
  readingMinutes,
  headerTitle,
  headerSubtitle,
  hideSystemPathway = false,
  authorBioOverride,
  hideTopShare = false,
  hideMobileShareBar = false,
  conversionBlockCopy,
  mailerLite = false,
} = Astro.props;
const d = article.data;
const resolvedHeaderTitle = headerTitle ?? d.title;
const resolvedHeaderSubtitle =
  headerSubtitle !== undefined ? headerSubtitle : d.subtitle;
const base = siteBase(Astro);
const canonicalPath = `/articles/${d.slug}/`;
const ogUrl = new URL(canonicalPath, base).href;
const heroAbsolute = new URL(d.heroImage, base).href;

const pageTitle =
  d.metaTitle?.trim() || `${d.title} | Tides of Knowing`;
const metaDescription = d.metaDescription?.trim() || d.excerpt;
const publishedISO = d.publishDate.toISOString();
const modifiedISO = d.updatedDate?.toISOString();

const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Articles", url: "/articles/" },
];
if (d.seriesName) {
  crumbs.push({
    label: d.seriesName,
    url: `/series/${slugify(d.seriesName)}/`,
  });
}
crumbs.push({ label: d.title, url: null });

const authorStructured =
  d.author.trim() === "Leigh Spencer"
    ? { "@id": ENTITY_IDS.person }
    : { "@type": "Person", name: d.author };

const articleLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: d.title,
  description: metaDescription,
  image: heroAbsolute,
  datePublished: publishedISO,
  dateModified: modifiedISO ?? publishedISO,
  author: authorStructured,
  publisher: { "@id": ENTITY_IDS.tidesOrg },
  url: ogUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": ogUrl,
  },
  keywords: d.tags.join(", "),
};

const jsonLdCombined = [
  articleLd,
  breadcrumbJsonLd(crumbs, base.href),
];

const canonicalUrl = ogUrl;

const articleAudio = getArticleAudio({
  slug: d.slug,
  frontmatterAudio: d.audio,
});

const shortAnswer = d.shortAnswer?.trim() ?? "";
const furtherReading = d.furtherReading ?? [];

/** Repeating Card Patterns heroes are portrait compositions; avoid cover crop. */
const heroImageFit =
  d.heroImageFit ??
  (d.seriesName === REPEATING_CARD_PATTERNS_SERIES_NAME ? "contain" : "cover");

/*
 * TODO: Optional frontmatter-driven article pathways (e.g. custom link labels and hrefs per article).
 * TODO: Optional per-article "Apply this" callout copy via frontmatter or manual MDX, not a global generic block.
 */
const pathwayLinks: { href: string; label: string; dataCompass?: boolean }[] = [
  { href: "/articles/compass-method/", label: "Understand the framework" },
  { href: "/tools/", label: "Practise the relationship" },
  { href: "/practice/", label: "Build the habit" },
  { href: "/compass/", label: "Train with COMPASS", dataCompass: true },
];
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  ogUrl={ogUrl}
  ogType="article"
  articlePublishedTime={publishedISO}
  articleModifiedTime={modifiedISO}
  ogImage={heroAbsolute}
  ogTitle={pageTitle}
  ogDescription={metaDescription}
  articleTags={d.tags}
  metaAuthor={d.author}
  tdcPlacement="none"
  jsonLd={jsonLdCombined}
  mailerLite={mailerLite}
>
  <div class="article-shell page-inner tok-article-share-shell">
    <div class="tok-articles-breadcrumbs">
      <Breadcrumbs items={crumbs} />
    </div>
    <div class="tok-articles-share-layout">
      <ShareSidebar title={d.title} url={canonicalUrl} />
      <div class="article-main tok-articles-main surface-reading">
        <ArticleHeader
          title={resolvedHeaderTitle}
          shareTitle={d.title}
          subtitle={resolvedHeaderSubtitle}
          publishDate={d.publishDate}
          readingTime={readingMinutes}
          heroImage={d.heroImage}
          heroImageAlt={d.heroImageAlt}
          heroImageFit={heroImageFit}
          author={d.author}
          shareUrl={canonicalUrl}
          hideTopShare={hideTopShare}
        />

        <article class="article tok-articles-article">
          {
            articleAudio ? (
              <div class="tok-articles-audio-wrap">
                <ArticleAudio
                  idPrefix={d.slug}
                  src={articleAudio.src}
                  duration={articleAudio.duration}
                  transcript={articleAudio.transcript}
                />
              </div>
            ) : null
          }
          {
            authorBioOverride ? (
              <p class="tok-article-trust" data-reveal>{authorBioOverride}</p>
            ) : d.author.trim() === "Leigh Spencer" ? (
              <AuthorBlock class="tok-article-trust" />
            ) : (
              <p class="tok-article-trust" data-reveal>By {d.author}.</p>
            )
          }
          {shortAnswer ? (
            <ShortAnswerBlock text={shortAnswer} class="tok-articles-short-answer" />
          ) : null}
          <div class="article-prose article__body tok-articles-body">
            <slot name="prepend" />
            <slot />
            <slot name="body-end" />
          </div>
          <slot name="append" />
          <FurtherReading items={furtherReading} class="tok-articles-further-reading" />
          {
            !hideSystemPathway && (
              <section
                class="tok-article-pathway"
                aria-labelledby="article-pathway-heading"
                data-reveal
              >
                <h2 id="article-pathway-heading" class="tok-article-pathway__title">
                  Continue through the system
                </h2>
                <ul class="tok-article-pathway__list" role="list">
                  {pathwayLinks.map((item) => (
                    <li class="tok-article-pathway__item">
                      <a
                        class="tok-article-pathway__link"
                        href={item.href}
                        {...(item.dataCompass ? { "data-link": "compass" } : {})}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )
          }
          <ShareButtons title={d.title} url={canonicalUrl} placement="bottom" />
        </article>

        {
          d.seriesName &&
            !isRepeatingCardPatternsArticle(d.slug) && (
            <ArticleSeries
              seriesName={d.seriesName}
              seriesOrder={d.seriesOrder}
              seriesTotal={d.seriesTotal}
              previousArticle={d.previousArticle ?? undefined}
              nextArticle={d.nextArticle ?? undefined}
              currentSlug={d.slug}
            />
          )
        }

        <div data-reveal>
          <TdcConversionBlock
            kicker={conversionBlockCopy?.kicker}
            heading={conversionBlockCopy?.heading}
            description={conversionBlockCopy?.description}
            ctaLabel={conversionBlockCopy?.ctaLabel}
            ctaHref={conversionBlockCopy?.ctaHref}
            subscribePlacement="article-footer-conversion"
          />
        </div>
      </div>
    </div>
    {!hideMobileShareBar && (
      <div class="tok-share-mobile-bar" aria-label="Share this article">
        <ShareButtons title={d.title} url={canonicalUrl} placement="mobile" />
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .tok-articles-breadcrumbs {
    margin-top: 1.5rem;
    max-width: 100%;
    min-width: 0;
  }

  .tok-articles-main {
    padding-bottom: 3rem;
  }

  .tok-articles-body {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  .tok-articles-audio-wrap {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .tok-article-trust {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem 1.15rem;
  }

  .tok-articles-short-answer {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .tok-article-pathway {
    max-width: 65ch;
    margin: 0 auto;
    padding: 0 1rem 1.75rem;
    border-top: 1px solid var(--tok-border-light);
    padding-top: clamp(1.35rem, 3.5vw, 1.85rem);
  }

  .tok-article-pathway__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.4vw, 1.35rem);
    font-weight: 600;
    font-style: italic;
    line-height: 1.25;
    color: var(--tok-water);
  }

  .tok-article-pathway__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  @media (min-width: 640px) {
    .tok-article-pathway__list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem 1.25rem;
    }
  }

  .tok-article-pathway__item {
    margin: 0;
  }

  .tok-article-pathway__link {
    display: block;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.5;
    font-weight: 500;
    color: var(--tok-teal);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 1px;
  }

  .tok-article-pathway__link:hover {
    color: var(--tok-teal-dim);
  }

  .tok-article-ai-signup-wrap {
    margin-top: 2.25rem;
    max-width: 65ch;
    margin-left: auto;
    margin-right: auto;
    padding: 0 1rem;
  }
</style>
