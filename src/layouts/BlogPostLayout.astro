---
import BaseLayout from "./BaseLayout.astro";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import BlogSidebar from "../components/BlogSidebar.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import type { RelatedLink } from "../data/relatedPosts";
import type { BlogCategoryRow } from "../lib/blogCategories";
import { FOUNDATIONAL_FIELD_NOTE_FOOTER } from "../lib/blogFieldNotes";
import { ABOUT_PATH, blogPostingJsonLd } from "../lib/blogSeo";
import { breadcrumbJsonLd, type BreadcrumbItem } from "../lib/breadcrumbs";
import { siteBase } from "../lib/site";

interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  modifiedDate?: Date;
  readingMinutes: number;
  ogUrl: string;
  ogImageAbsolute: string;
  pageTitle?: string;
  ogTitle?: string;
  ogDescription?: string;
  datePublishedIso?: string;
  dateModifiedIso?: string;
  displayDate?: string;
  categoryLabel: string;
  categorySlug: string;
  articleTags: string[];
  related?: RelatedLink[];
  sidebarCategories: BlogCategoryRow[];
  prevPost: NavPost | null;
  nextPost: NavPost | null;
  /** Slower, editorial standalone archive notes (not series or practitioner walkthroughs). */
  foundational?: boolean;
}

const {
  title,
  description,
  date,
  modifiedDate,
  readingMinutes,
  ogUrl,
  ogImageAbsolute,
  pageTitle: pageTitleProp,
  ogTitle,
  ogDescription,
  datePublishedIso,
  dateModifiedIso,
  displayDate: displayDateProp,
  categoryLabel,
  categorySlug,
  articleTags,
  related = [],
  sidebarCategories,
  prevPost,
  nextPost,
  foundational = false,
} = Astro.props;

const pageTitle = pageTitleProp ?? `${title} | Field Notes | Tides of Knowing`;
const isoDate = datePublishedIso ?? date.toISOString();
const modifiedIso =
  dateModifiedIso ?? (modifiedDate ?? date).toISOString();
const displayDate =
  displayDateProp ??
  date.toLocaleDateString("en-AU", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const seoForLd = {
  pageTitle,
  metaDescription: description,
  ogUrl,
  ogImageAbsolute,
  ogTitle: ogTitle ?? pageTitle,
  ogDescription: ogDescription ?? description,
  datePublished: isoDate,
  dateModified: modifiedIso,
};

const base = siteBase(Astro);
const siteHref = base.href;

const crumbs: BreadcrumbItem[] = [
  { label: "Home", url: "/" },
  { label: "Field Notes", url: "/blog/" },
  { label: title, url: null },
];

const blogPostingLd = blogPostingJsonLd(seoForLd, {
  headline: title,
  articleSection: categoryLabel,
  keywords: articleTags.join(", "),
});

const jsonLd = [blogPostingLd, breadcrumbJsonLd(crumbs, siteHref)];
---

<BaseLayout
  title={pageTitle}
  description={description}
  ogUrl={ogUrl}
  ogType="article"
  articlePublishedTime={isoDate}
  articleModifiedTime={modifiedIso}
  ogImage={ogImageAbsolute}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  articleTags={articleTags}
  metaAuthor="Leigh Spencer"
  tdcPlacement="none"
  jsonLd={jsonLd}
>
  <div class="tok-blog-post-shell page-inner">
    <div class="tok-blog-post-breadcrumbs">
      <Breadcrumbs items={crumbs} />
    </div>

    <div class="tok-blog-post-grid">
      <div class="tok-blog-post-main">
        <header class="tok-blog-post-head" data-reveal>
          <p class="tok-blog-post-kicker">
            <span class="tok-blog-post-kind">
              {foundational ? "Foundational Field Note" : "Field Note"}
            </span>
            <span class="tok-blog-post-meta-sep" aria-hidden="true">·</span>
            <a class="tok-blog-post-cat" href={`/blog/category/${categorySlug}/`}>
              {categoryLabel}
            </a>
          </p>
          <h1 class="tok-blog-post-title">{title}</h1>
          <p class="tok-blog-post-byline">
            <a href={ABOUT_PATH}>Leigh Spencer</a>
          </p>
          <p class="tok-blog-post-meta">
            <time datetime={isoDate}>{displayDate}</time>
            <span class="tok-blog-post-meta-sep" aria-hidden="true">·</span>
            <span>{readingMinutes} min read</span>
          </p>
        </header>

        <article class="tok-blog-article">
          <div
            class:list={[
              "article-prose tok-blog-post-prose",
              foundational && "tok-blog-post-prose--foundational",
            ]}
          >
            <slot />
          </div>
        </article>

        {
          foundational ? (
            <>
              <hr class="tok-blog-post-rule" />
              <footer class="tok-blog-post-footer" data-reveal>
                <p class="tok-blog-post-footer__text">
                  <em>{FOUNDATIONAL_FIELD_NOTE_FOOTER}</em>
                </p>
              </footer>
            </>
          ) : null
        }

        <nav class="tok-blog-adj" aria-label="Adjacent Field Notes" data-reveal>
          {
            prevPost ? (
              <a class="tok-blog-adj__link tok-blog-adj__link--prev" href={`/blog/${prevPost.slug}/`}>
                <span class="tok-blog-adj__label">Previous Field Note</span>
                <span class="tok-blog-adj__title">{prevPost.title}</span>
              </a>
            ) : (
              <span class="tok-blog-adj__spacer" />
            )
          }
          {
            nextPost ? (
              <a class="tok-blog-adj__link tok-blog-adj__link--next" href={`/blog/${nextPost.slug}/`}>
                <span class="tok-blog-adj__label">Next Field Note</span>
                <span class="tok-blog-adj__title">{nextPost.title}</span>
              </a>
            ) : (
              <span class="tok-blog-adj__spacer" />
            )
          }
        </nav>

        <div data-reveal>
          <TdcConversionBlock subscribePlacement="blog-post-conversion-block" />
        </div>

        {
          related.length > 0 && (
            <section class="tok-blog-related" aria-labelledby="field-notes-related-heading" data-reveal>
              <h2 id="field-notes-related-heading" class="tok-blog-related__title">
                Suggested reading
              </h2>
              <ul class="tok-blog-related__list">
                {related.map((item) => (
                  <li>
                    <a class="tok-blog-related__link" href={item.href}>
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }
      </div>

      <BlogSidebar categories={sidebarCategories} activeCategorySlug={categorySlug} />
    </div>
  </div>
</BaseLayout>

<style>
  .tok-blog-post-breadcrumbs {
    margin-top: 1.25rem;
    margin-bottom: 1rem;
  }

  .tok-blog-post-grid {
    display: grid;
    gap: 2.5rem;
    padding-bottom: clamp(3rem, 8vw, 5rem);
    align-items: start;
  }

  @media (min-width: 960px) {
    .tok-blog-post-grid {
      grid-template-columns: minmax(0, 1fr) minmax(14rem, var(--tok-blog-sidebar-max));
      gap: 2.75rem;
    }
  }

  .tok-blog-post-main {
    min-width: 0;
    max-width: 42rem;
  }

  .tok-blog-post-kicker {
    margin: 0 0 0.5rem;
  }

  .tok-blog-post-kind {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--tok-teal-dim);
  }

  .tok-blog-post-cat {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-gold);
  }

  .tok-blog-post-cat:hover {
    color: var(--tok-teal);
  }

  .tok-blog-post-byline {
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .tok-blog-post-byline a {
    color: var(--tok-teal);
    text-decoration: none;
  }

  .tok-blog-post-byline a:hover {
    color: var(--tok-teal-dim);
  }

  .tok-blog-post-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 4.5vw, 2.65rem);
    line-height: 1.18;
    color: var(--tok-teal-dim);
  }

  .tok-blog-post-meta {
    margin: 0 0 1.5rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tok-text-dark) 55%, var(--tok-surface-reading));
  }

  .tok-blog-post-meta-sep {
    margin: 0 0.45rem;
  }

  .tok-blog-article {
    margin-bottom: 2rem;
  }

  .tok-blog-post-prose {
    font-size: 1.04rem;
  }

  .tok-blog-post-prose--foundational {
    font-size: 1.06rem;
    line-height: 1.78;
  }

  .tok-blog-post-prose--foundational :global(h2) {
    margin-top: 2.35rem;
    margin-bottom: 0.85rem;
  }

  .tok-blog-post-prose--foundational :global(h2:first-child) {
    margin-top: 1.5rem;
  }

  .tok-blog-post-rule {
    margin: 2rem 0 1.25rem;
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
  }

  .tok-blog-post-footer__text {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.68;
    opacity: 0.9;
  }

  .tok-blog-adj {
    display: grid;
    gap: 1rem;
    margin: 2rem 0 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-gold) 35%, transparent);
  }

  @media (min-width: var(--bp-xs)) {
    .tok-blog-adj {
      grid-template-columns: 1fr 1fr;
    }
  }

  .tok-blog-adj__spacer {
    display: none;
  }

  @media (min-width: var(--bp-xs)) {
    .tok-blog-adj__spacer {
      display: block;
    }
  }

  .tok-blog-adj__link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    color: inherit;
    padding: 0.35rem 0;
    transition: color 0.2s ease;
  }

  .tok-blog-adj__link:hover .tok-blog-adj__title {
    color: var(--tok-teal);
  }

  .tok-blog-adj__link--next {
    text-align: right;
  }

  .tok-blog-adj__label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tok-gold);
  }

  .tok-blog-adj__title {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.35;
    color: var(--tok-teal-dim);
    transition: color 0.2s ease;
  }

  .tok-blog-related {
    margin-top: 1rem;
    padding: 1.5rem 1.25rem;
    background: var(--tok-surface-reading-soft);
    border-left: 3px solid var(--tok-gold);
  }

  .tok-blog-related__title {
    margin: 0 0 0.85rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--tok-teal-dim);
  }

  .tok-blog-related__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tok-blog-related__list li + li {
    margin-top: 0.5rem;
  }

  .tok-blog-related__link {
    font-weight: 600;
  }
</style>
