---
import "../styles/global.css";
import "../styles/share.css";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import { siteBase } from "../lib/site";

interface Props {
  title: string;
  description: string;
  /** Absolute or site-root-relative URL; falls back to the current request URL. */
  ogUrl?: string;
  ogType?: "website" | "article";
  /** When `ogType` is `article`, sets Open Graph published time. */
  articlePublishedTime?: string;
  /** When `ogType` is `article`, optional modified time. */
  articleModifiedTime?: string;
  /** Absolute URL for social preview (Open Graph / Twitter). */
  ogImage?: string;
  /** For `article` type, emits `article:tag` meta tags. */
  articleTags?: string[];
  /** Sets `<meta name="author">` when provided. */
  metaAuthor?: string;
  /** Absolute URLs for paginated lists (`rel="prev"` / `rel="next"`). */
  sequentialLinks?: { prev?: string; next?: string };
  /** When `before-footer`, renders the TDC block above the site footer. Use `none` when TDC is placed inside the page (e.g. home mid-page or article layout). */
  tdcPlacement?: "none" | "before-footer";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Appended to automatic body surface classes (TOK brand). */
  bodyClass?: string;
}

const {
  title,
  description,
  ogUrl,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  ogImage,
  articleTags,
  metaAuthor,
  sequentialLinks,
  tdcPlacement = "before-footer",
  jsonLd,
  bodyClass: bodyClassProp,
} = Astro.props;

const trimmedOg = typeof ogUrl === "string" ? ogUrl.trim() : "";
const effectiveOgUrl =
  trimmedOg !== "" ? trimmedOg : Astro.url.href;

const base = siteBase(Astro);
const canonical = effectiveOgUrl.startsWith("http")
  ? effectiveOgUrl
  : new URL(
      effectiveOgUrl.startsWith("/") ? effectiveOgUrl : `/${effectiveOgUrl}`,
      base
    ).href;

const jsonLdArray = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

const structuredScripts = jsonLdArray.map((obj) => JSON.stringify(obj));

const isToolsSection = /^\/tools(\/|$)/.test(Astro.url.pathname);

const pathname = Astro.url.pathname;
const isToolsRoute = pathname.startsWith("/tools");
const isPracticeRoute = pathname.startsWith("/practice");
const isCompassApplyRoute = pathname.startsWith("/compass/apply");
const isCompassBlueRoute =
  pathname.startsWith("/compass") && !isCompassApplyRoute;
const baseBodySurface =
  isToolsRoute || isCompassBlueRoute ? "tok-body--system" : "tok-body--reading";
const bodyClass = [baseBodySurface, bodyClassProp].filter(Boolean).join(" ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {metaAuthor && <meta name="author" content={metaAuthor} />}
    <link rel="canonical" href={canonical} />
    {sequentialLinks?.prev && (
      <link rel="prev" href={sequentialLinks.prev} />
    )}
    {sequentialLinks?.next && (
      <link rel="next" href={sequentialLinks.next} />
    )}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && metaAuthor && (
      <meta property="article:author" content={metaAuthor} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {articleTags &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {structuredScripts.map((raw) => (
      <script type="application/ld+json" set:html={raw} />
    ))}
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <div class="page-inner site-header__inner">
        <a class="site-logo" href="/">Tides of Knowing</a>
        <button
          class="site-nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-primary-nav"
        >
          Menu
        </button>
        <nav class="site-nav" id="site-primary-nav" aria-label="Primary">
          <a class="site-nav__link" href="/articles/compass-method/">Method</a>
          <a
            class="site-nav__link site-nav__link--tools"
            href="/tools/"
            aria-current={isToolsSection ? "page" : undefined}
          >
            Tools
          </a>
          <a class="site-nav__link" href="/articles/">Articles</a>
          <a
            class="site-nav__link"
            href="/practice/"
            aria-current={isPracticeRoute ? "page" : undefined}
          >
            Practice
          </a>
          <a class="site-nav__link" href="/compass/" data-link="compass">Training</a>
          <a class="site-nav__link" href="/about/">About</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {tdcPlacement === "before-footer" && <TdcConversionBlock />}

    <footer class="site-footer">
      <div class="page-inner site-footer__inner">
        <div class="site-footer__col">
          <p class="site-footer__copy site-footer__copy--center">
            © 2026 Tides of Knowing · Leigh Spencer. All rights reserved. Original content.
          </p>
          <nav class="site-footer__discover" aria-label="Sections">
            <a class="site-footer__discover-link" href="/articles/">Articles</a>
            <a class="site-footer__discover-link" href="/series/">Series</a>
            <a class="site-footer__discover-link" href="/tags/">Topics</a>
            <a class="site-footer__discover-link" href="/blog/">Field Notes</a>
            <a class="site-footer__discover-link" href="/contact/">Contact</a>
            <a class="site-footer__discover-link" href="/privacy/">Privacy Policy</a>
            <a class="site-footer__discover-link" href="/terms/">Terms of Use</a>
          </nav>
        </div>
        <a class="site-footer__email" href="mailto:hello@tidesofknowing.com">hello@tidesofknowing.com</a>
      </div>
      <div class="page-inner site-footer__proprietary-wrap">
        <p class="site-footer__proprietary tok-ip-attribution">
          The COMPASS Method™ is an original interpretive framework created by Tides of Knowing.
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var toggle = document.querySelector(".site-nav-toggle");
        var nav = document.getElementById("site-primary-nav");
        if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) return;

        function closeMenu() {
          nav.classList.remove("site-nav--open");
          toggle.setAttribute("aria-expanded", "false");
        }

        toggle.addEventListener("click", function () {
          var isOpen = nav.classList.toggle("site-nav--open");
          toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });

        nav.addEventListener("click", function (event) {
          var target = event.target;
          if (target instanceof Element && target.closest("a")) {
            closeMenu();
          }
        });

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape") closeMenu();
        });

        window.addEventListener("resize", function () {
          if (window.innerWidth > 900) closeMenu();
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var nodes = document.querySelectorAll("[data-reveal]");
        if (!nodes.length || !("IntersectionObserver" in window)) {
          nodes.forEach(function (el) {
            el.classList.add("is-visible");
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { root: null, rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        nodes.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        document.addEventListener("click", function (event) {
          var target = event.target;
          if (!(target instanceof Element)) return;
          var link = target.closest('[data-link="compass"]');
          if (!link) return;
          console.log("COMPASS link clicked");
        });
      })();
    </script>

    <!-- MailerLite Universal -->
    <script is:inline>
      (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
      .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
      n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
      (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', '2247024');
    </script>
    <!-- End MailerLite Universal -->
  </body>
</html>

<style>
  :root {
    --site-header-height: 4.25rem;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--tok-deep-ocean);
    border-bottom: 1px solid var(--tok-border-system);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    flex-wrap: wrap;
  }

  .site-logo {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--tok-text-light-soft);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-logo:hover {
    color: var(--tok-teal-light);
  }

  .site-nav {
    display: flex;
    gap: clamp(1rem, 4vw, 2rem);
    align-items: center;
  }

  .site-nav-toggle {
    display: none;
  }

  .site-nav__link {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: color-mix(in srgb, var(--tok-text-light-soft) 65%, transparent);
  }

  .site-nav__link:hover {
    color: var(--tok-text-light);
  }

  .site-nav__link--tools {
    color: color-mix(in srgb, var(--tok-gold) 92%, transparent);
    font-weight: 700;
  }

  .site-nav__link--tools:hover {
    color: var(--tok-gold);
  }

  .site-nav__link--tools[aria-current="page"] {
    color: var(--tok-gold);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tok-gold) 55%, transparent);
    text-underline-offset: 0.18em;
  }

  .site-nav__dropdown {
    position: relative;
  }

  .site-nav__dropdown-summary {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tok-text-light-soft) 65%, transparent);
    list-style: none;
    cursor: pointer;
  }

  .site-nav__dropdown-summary::-webkit-details-marker {
    display: none;
  }

  .site-nav__dropdown[open] .site-nav__dropdown-summary,
  .site-nav__dropdown-summary:hover {
    color: var(--tok-text-light);
  }

  .site-nav__dropdown-list {
    position: absolute;
    top: 100%;
    left: 0;
    margin: 0.35rem 0 0;
    padding: 0.5rem 0;
    min-width: 11rem;
    list-style: none;
    background: var(--tok-deep-ocean);
    border: 1px solid var(--tok-border-system);
    border-radius: 0.25rem;
    box-shadow: var(--shadow-sys-md);
    z-index: 60;
  }

  .site-nav__dropdown-link {
    display: block;
    padding: 0.45rem 1rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: color-mix(in srgb, var(--tok-text-light-soft) 75%, transparent);
  }

  .site-nav__dropdown-link:hover {
    color: var(--tok-teal-light);
    background: color-mix(in srgb, var(--tok-surface-panel) 45%, transparent);
  }

  #main-content {
    padding-top: var(--site-header-height, 4.25rem);
  }

  @media (max-width: 900px) {
    .site-header__inner {
      flex-wrap: nowrap;
      min-height: var(--site-header-height);
    }

    .site-nav-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-left: auto;
      padding: 0.45rem 0.75rem;
      font-family: var(--font-body);
      font-size: 0.64rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--tok-text-light);
      background: transparent;
      border: 1px solid color-mix(in srgb, var(--tok-gold) 55%, transparent);
      border-radius: 0.2rem;
      cursor: pointer;
    }

    .site-nav-toggle:hover {
      background: color-mix(in srgb, var(--tok-gold) 12%, transparent);
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.4rem 1.25rem 0.9rem;
      background: var(--tok-deep-ocean);
      border-top: 1px solid var(--tok-border-system);
      border-bottom: 1px solid var(--tok-border-system);
      max-height: calc(100dvh - var(--site-header-height));
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .site-nav.site-nav--open {
      display: flex;
    }

    .site-nav__link {
      display: block;
      padding: 0.72rem 0;
      border-top: 1px solid color-mix(in srgb, var(--tok-border-system) 75%, transparent);
    }

    .site-nav__link:first-child {
      border-top: none;
    }
  }

  .site-footer {
    background: var(--tok-deep-ocean);
    color: var(--tok-text-light-soft);
    border-top: 2px solid var(--tok-gold);
    padding: 2rem 0 2.5rem;
    margin-top: 0;
  }

  .site-footer__copy--center {
    text-align: center;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 2rem;
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .site-footer__discover {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .site-footer__discover-link {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tok-text-light-soft) 55%, transparent);
    text-decoration: none;
  }

  .site-footer__discover-link:hover {
    color: var(--tok-teal-light);
  }

  .site-footer__copy {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.9rem;
    opacity: 0.85;
  }

  .site-footer__email {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tok-text-light-soft) 75%, transparent);
    text-decoration: none;
  }

  .site-footer__email:hover {
    color: var(--tok-teal-light);
  }

  .site-footer__proprietary-wrap {
    margin-top: 1.35rem;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-border-system) 52%, transparent);
  }

  .site-footer__proprietary {
    margin: 0;
    color: color-mix(in srgb, var(--tok-text-light-soft) 82%, transparent);
  }
</style>
