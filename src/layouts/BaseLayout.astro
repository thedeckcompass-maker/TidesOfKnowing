---
import "../styles/global.css";
import "../styles/share.css";
import MailerLiteUniversal from "../components/MailerLiteUniversal.astro";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import { getEcosystemJsonLdGraph } from "../lib/ecosystem-structured-data";
import { siteBase } from "../lib/site";

interface Props {
  title: string;
  description: string;
  /** Absolute or site-root-relative URL; falls back to the current request URL. */
  ogUrl?: string;
  ogType?: "website" | "article";
  /** When `ogType` is `article`, sets Open Graph published time. */
  articlePublishedTime?: string;
  /** When `ogType` is `article`, optional modified time. */
  articleModifiedTime?: string;
  /** Absolute URL for social preview (Open Graph / Twitter). */
  ogImage?: string;
  /** When set, used for Open Graph and Twitter title only (page `<title>` stays `title`). */
  ogTitle?: string;
  /** When set, used for Open Graph and Twitter description only (`description` remains the meta description). */
  ogDescription?: string;
  /** For `article` type, emits `article:tag` meta tags. */
  articleTags?: string[];
  /** Sets `<meta name="author">` when provided. */
  metaAuthor?: string;
  /** Absolute URLs for paginated lists (`rel="prev"` / `rel="next"`). */
  sequentialLinks?: { prev?: string; next?: string };
  /** When `before-footer`, renders the TDC block above the site footer. Use `none` when TDC is placed inside the page (e.g. home mid-page or article layout). */
  tdcPlacement?: "none" | "before-footer";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Appended to automatic body surface classes (TOK brand). */
  bodyClass?: string;
  /** When set, emitted as `<meta name="robots" content="…">` (e.g. `noindex, nofollow`). */
  metaRobots?: string;
  /** Load MailerLite universal.js only when the page has `.ml-embedded` forms (e.g. /subscribe/). */
  mailerLite?: boolean;
}

const {
  title,
  description,
  ogUrl,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  ogImage,
  ogTitle,
  ogDescription,
  articleTags,
  metaAuthor,
  sequentialLinks,
  tdcPlacement = "before-footer",
  jsonLd,
  bodyClass: bodyClassProp,
  metaRobots,
  mailerLite = false,
} = Astro.props;

const trimmedOg = typeof ogUrl === "string" ? ogUrl.trim() : "";
const effectiveOgUrl =
  trimmedOg !== "" ? trimmedOg : Astro.url.href;

const base = siteBase(Astro);
const canonical = effectiveOgUrl.startsWith("http")
  ? effectiveOgUrl
  : new URL(
      effectiveOgUrl.startsWith("/") ? effectiveOgUrl : `/${effectiveOgUrl}`,
      base
    ).href;

const socialTitle =
  typeof ogTitle === "string" && ogTitle.trim() !== "" ? ogTitle.trim() : title;
const socialDescription =
  typeof ogDescription === "string" && ogDescription.trim() !== ""
    ? ogDescription.trim()
    : description;

const pageJsonLd = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

/** Site-wide ecosystem graph first, then page-level JSON-LD (Article, BreadcrumbList, etc.). */
const jsonLdArray = [getEcosystemJsonLdGraph(), ...pageJsonLd];

const structuredScripts = jsonLdArray.map((obj) => JSON.stringify(obj));

const isToolsSection = /^\/tools(\/|$)/.test(Astro.url.pathname);

/**
 * Body surface (TOK dual-surface):
 * - Reading (`tok-body--reading`): default; long-form, tools index exception handled below, COMPASS apply, practice, articles, home, etc.
 * - System (`tok-body--system`): `/tools/*` interactive tools and `/compass/*` except `/compass/apply` (apply stays reading for form-first UX per brand map).
 * Hybrid bands (blue on reading routes) are section-level, not body class changes.
 */
const pathname = Astro.url.pathname;
const isToolsRoute = pathname.startsWith("/tools");
const isPracticeRoute = pathname.startsWith("/practice");
const isCompassApplyRoute = pathname.startsWith("/compass/apply");
const isCompassBlueRoute =
  pathname.startsWith("/compass") && !isCompassApplyRoute;
const isCompassTrainingSection = pathname.startsWith("/compass");
const isCompassMethodRoute = pathname.startsWith("/articles/compass-method");
const isArticlesSection =
  (pathname === "/articles" || pathname.startsWith("/articles/")) &&
  !isCompassMethodRoute;
const isAboutRoute = pathname.startsWith("/about");
const baseBodySurface =
  isToolsRoute || isCompassBlueRoute ? "tok-body--system" : "tok-body--reading";
const bodyClass = [baseBodySurface, bodyClassProp].filter(Boolean).join(" ");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {metaRobots && <meta name="robots" content={metaRobots} />}
    {metaAuthor && <meta name="author" content={metaAuthor} />}
    <link rel="canonical" href={canonical} />
    {sequentialLinks?.prev && (
      <link rel="prev" href={sequentialLinks.prev} />
    )}
    {sequentialLinks?.next && (
      <link rel="next" href={sequentialLinks.next} />
    )}

    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Tides of Knowing™" />
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && metaAuthor && (
      <meta property="article:author" content={metaAuthor} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {articleTags &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {structuredScripts.map((raw) => (
      <script type="application/ld+json" set:html={raw} />
    ))}
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <div class="page-inner site-header__inner">
        <a href="/" class="site-logo site-brand" aria-label="Tides of Knowing home">
          <img
            src="/images/brand/tides-of-knowing-mark.svg"
            alt=""
            class="site-brand__icon"
            width="32"
            height="32"
            aria-hidden="true"
          />
          <span class="site-brand__text">Tides of Knowing</span>
        </a>
        <button
          class="site-nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-primary-nav"
        >
          Menu
        </button>
        <nav class="site-nav" id="site-primary-nav" aria-label="Primary">
          <a
            class="site-nav__link"
            href="/articles/compass-method/"
            aria-current={isCompassMethodRoute ? "page" : undefined}
          >
            Method
          </a>
          <a
            class="site-nav__link"
            href="/tools/"
            aria-current={isToolsSection ? "page" : undefined}
          >
            Tools
          </a>
          <a
            class="site-nav__link"
            href="/articles/"
            aria-current={isArticlesSection ? "page" : undefined}
          >
            Articles
          </a>
          <a
            class="site-nav__link"
            href="/practice/"
            aria-current={isPracticeRoute ? "page" : undefined}
          >
            Practice
          </a>
          <a
            class="site-nav__link site-nav__link--training"
            href="/compass/"
            data-link="compass"
            aria-current={isCompassTrainingSection ? "page" : undefined}
          >
            Training
          </a>
          <a
            class="site-nav__link"
            href="/about/"
            aria-current={isAboutRoute ? "page" : undefined}
          >
            About
          </a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {tdcPlacement === "before-footer" && (
      <TdcConversionBlock subscribePlacement="site-footer-conversion" />
    )}

    <footer class="site-footer">
      <div class="page-inner site-footer__inner">
        <nav class="site-footer__discover" aria-label="Sections">
          <a class="site-footer__discover-link" href="/articles/">Articles</a>
          <a class="site-footer__discover-link" href="/repeating-card-meanings/">Repeating cards</a>
          <a class="site-footer__discover-link" href="/series/">Series</a>
          <a class="site-footer__discover-link" href="/tags/">Topics</a>
          <a class="site-footer__discover-link" href="/blog/">Field Notes</a>
          <a class="site-footer__discover-link" href="/contact/">Contact</a>
          <a class="site-footer__discover-link" href="/media/">Media</a>
          <a class="site-footer__discover-link" href="/privacy/">Privacy Policy</a>
          <a class="site-footer__discover-link" href="/terms/">Terms of Use</a>
        </nav>
        <a class="site-footer__email" href="mailto:hello@tidesofknowing.com">hello@tidesofknowing.com</a>
      </div>
      <div class="page-inner site-footer__meta">
        <p class="site-footer__copy">
          © 2026 Tides of Knowing · Leigh Spencer. All rights reserved. Original content.
        </p>
        <p class="site-footer__attribution tok-ip-attribution">
          The COMPASS Method™ · Original interpretive framework by Tides of Knowing.
        </p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var toggle = document.querySelector(".site-nav-toggle");
        var nav = document.getElementById("site-primary-nav");
        if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) return;

        function closeMenu() {
          nav.classList.remove("site-nav--open");
          toggle.setAttribute("aria-expanded", "false");
        }

        toggle.addEventListener("click", function () {
          var isOpen = nav.classList.toggle("site-nav--open");
          toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });

        nav.addEventListener("click", function (event) {
          var target = event.target;
          if (target instanceof Element && target.closest("a")) {
            closeMenu();
          }
        });

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape") closeMenu();
        });

        window.addEventListener("resize", function () {
          if (window.innerWidth > 900) closeMenu();
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var nodes = document.querySelectorAll("[data-reveal]");
        if (!nodes.length || !("IntersectionObserver" in window)) {
          nodes.forEach(function (el) {
            el.classList.add("is-visible");
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { root: null, rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        nodes.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>
    <script is:inline>
      (function () {
        document.addEventListener("click", function (event) {
          var target = event.target;
          if (!(target instanceof Element)) return;
          var link = target.closest('[data-link="compass"]');
          if (!link) return;
          console.log("COMPASS link clicked");
        });
      })();
    </script>

    {mailerLite ? <MailerLiteUniversal /> : null}
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    background-color: var(--tok-surface-reading);
    background-image: url("/images/brand/tok-landscape-bluff-hill-narrow.svg");
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    border-bottom: 1px solid var(--tok-on-reading-border);
  }

  @media (prefers-color-scheme: dark) {
    .site-header {
      background-image:
        linear-gradient(
          color-mix(in srgb, var(--tok-surface-reading) 90%, transparent),
          color-mix(in srgb, var(--tok-surface-reading) 90%, transparent)
        ),
        url("/images/brand/tok-landscape-bluff-hill-narrow.svg");
    }
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    flex-wrap: wrap;
  }

  .site-logo {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--tok-on-reading);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-logo:hover {
    color: var(--tok-water);
  }

  .site-logo:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 3px;
    border-radius: var(--radius-2);
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex: 0 0 auto;
    min-width: 0;
  }

  .site-brand__icon {
    width: 32px;
    height: 32px;
    display: block;
    flex: 0 0 auto;
  }

  .site-brand__text {
    display: inline-block;
    white-space: nowrap;
  }

  .site-nav {
    display: flex;
    gap: clamp(1rem, 4vw, 2rem);
    align-items: center;
  }

  .site-nav-toggle {
    display: none;
  }

  .site-nav__link {
    font-family: var(--font-body);
    font-size: var(--tok-type-nav);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-nav);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--tok-on-reading-muted);
    border-bottom: 2px solid transparent;
    padding-bottom: 0.15rem;
  }

  .site-nav__link:hover {
    color: var(--tok-on-reading);
  }

  .site-nav__link:hover:not([aria-current="page"]) {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tok-gold) 48%, transparent);
    text-underline-offset: 0.22em;
    text-decoration-thickness: 1px;
  }

  .site-nav__link:focus-visible {
    outline: 2px solid var(--tok-gold);
    outline-offset: 3px;
    border-radius: var(--radius-2);
  }

  .site-nav__link[aria-current="page"] {
    color: var(--tok-on-reading);
    border-bottom-color: var(--tok-gold);
    text-decoration: none;
  }

  .site-nav__link--training {
    color: var(--tok-gold-deep);
    font-weight: 800;
    background: transparent;
    box-shadow: none;
  }

  .site-nav__link--training:hover:not([aria-current="page"]) {
    color: var(--tok-on-reading);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--tok-gold) 65%, transparent);
    text-underline-offset: 0.22em;
    text-decoration-thickness: 1px;
  }

  .site-nav__link--training[aria-current="page"] {
    color: var(--tok-on-reading);
  }

  .site-nav__dropdown {
    position: relative;
  }

  .site-nav__dropdown-summary {
    font-family: var(--font-body);
    font-size: var(--tok-type-nav);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper-nav);
    text-transform: uppercase;
    color: var(--tok-on-reading-muted);
    list-style: none;
    cursor: pointer;
  }

  .site-nav__dropdown-summary::-webkit-details-marker {
    display: none;
  }

  .site-nav__dropdown[open] .site-nav__dropdown-summary,
  .site-nav__dropdown-summary:hover {
    color: var(--tok-on-reading);
  }

  .site-nav__dropdown-list {
    position: absolute;
    top: 100%;
    left: 0;
    margin: 0.35rem 0 0;
    padding: 0.5rem 0;
    min-width: 11rem;
    list-style: none;
    background: var(--tok-deep-ocean);
    border: 1px solid var(--tok-border-system);
    border-radius: var(--radius-control);
    box-shadow: var(--shadow-sys-md);
    z-index: var(--z-dropdown);
  }

  .site-nav__dropdown-link {
    display: block;
    padding: 0.45rem 1rem;
    font-family: var(--font-body);
    font-size: var(--tok-type-nav-dropdown);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    text-decoration: none;
    color: color-mix(in srgb, var(--tok-text-light-soft) 75%, transparent);
  }

  .site-nav__dropdown-link:hover {
    color: var(--tok-teal-light);
    background: color-mix(in srgb, var(--tok-surface-panel) 45%, transparent);
  }

  #main-content {
    padding-top: var(--tok-header-height);
  }

  @media (max-width: var(--bp-nav)) {
    .site-header__inner {
      flex-wrap: nowrap;
      min-height: var(--tok-header-height);
    }

    .site-nav-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-left: auto;
      padding: 0.45rem 0.75rem;
      font-family: var(--font-body);
      font-size: var(--tok-type-nav-compact);
      font-weight: 600;
      letter-spacing: var(--tok-letter-upper-tdc);
      text-transform: uppercase;
      color: var(--tok-on-reading);
      background: transparent;
      border: 1px solid var(--tok-on-reading-control-border);
      border-radius: var(--radius-soft);
      cursor: pointer;
    }

    .site-nav-toggle:hover {
      background: color-mix(in srgb, var(--tok-gold) 22%, transparent);
    }

    .site-nav-toggle:focus-visible {
      outline: 2px solid var(--tok-gold);
      outline-offset: 3px;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.4rem 1.25rem 0.9rem;
      background: var(--tok-deep-ocean);
      border-top: 1px solid var(--tok-border-system);
      border-bottom: 1px solid var(--tok-border-system);
      max-height: calc(100dvh - var(--tok-header-height));
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .site-nav.site-nav--open {
      display: flex;
    }

    .site-nav__link {
      display: block;
      padding: 0.72rem 0;
      border-top: 1px solid color-mix(in srgb, var(--tok-border-system) 75%, transparent);
      color: color-mix(in srgb, var(--tok-text-light-soft) 65%, transparent);
      border-bottom: 2px solid transparent;
    }

    .site-nav__link:first-child {
      border-top: none;
    }

    /* Drawer sits on solid navy; light link treatment */
    .site-nav__link:hover {
      color: var(--tok-text-light);
    }

    .site-nav__link:hover:not([aria-current="page"]) {
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--tok-gold) 45%, transparent);
      text-underline-offset: 0.22em;
      text-decoration-thickness: 1px;
    }

    .site-nav__link[aria-current="page"] {
      color: var(--tok-text-light);
      border-bottom-color: var(--tok-gold);
      text-decoration: none;
    }

    .site-nav__link--training {
      display: block;
      width: auto;
      color: var(--tok-gold);
      font-weight: 800;
      background: transparent;
      border-left: none;
      border-right: none;
    }

    .site-nav__link--training:hover:not([aria-current="page"]) {
      color: var(--tok-gold-light);
      text-decoration: underline;
      text-decoration-color: color-mix(in srgb, var(--tok-gold) 55%, transparent);
      text-underline-offset: 0.22em;
      text-decoration-thickness: 1px;
    }

    .site-nav__link--training[aria-current="page"] {
      color: var(--tok-text-light);
    }
  }

  @media (min-width: var(--bp-nav-min)) {
    .site-header__inner {
      flex-wrap: nowrap;
    }

    .site-nav {
      margin-left: auto;
      flex-wrap: nowrap;
    }

    .site-nav-toggle {
      display: none;
    }
  }

  @media (max-width: var(--bp-sm)) {
    .site-brand__icon {
      width: 28px;
      height: 28px;
    }
  }

  .site-footer {
    background: var(--tok-deep-ocean);
    color: var(--tok-text-light-soft);
    border-top: 2px solid var(--tok-gold);
    padding: 1.35rem 0 1.5rem;
    margin-top: 0;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem 1.5rem;
  }

  .site-footer__discover {
    display: flex;
    flex: 1 1 16rem;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.85rem;
  }

  .site-footer__discover-link {
    font-family: var(--font-body);
    font-size: var(--tok-type-footer);
    font-weight: 600;
    letter-spacing: var(--tok-letter-upper);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tok-text-light-soft) 55%, transparent);
    text-decoration: none;
  }

  .site-footer__discover-link:hover {
    color: var(--tok-teal-light);
  }

  .site-footer__email {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: var(--tok-type-footer-email);
    font-weight: 500;
    letter-spacing: 0.01em;
    text-transform: none;
    color: color-mix(in srgb, var(--tok-text-light-soft) 72%, transparent);
    text-decoration: none;
  }

  .site-footer__email:hover {
    color: var(--tok-teal-light);
  }

  .site-footer__meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 0.85rem;
    padding-top: 0.7rem;
    border-top: 1px solid color-mix(in srgb, var(--tok-border-system) 40%, transparent);
  }

  .site-footer__copy {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.82rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--tok-text-light-soft) 72%, transparent);
  }

  .site-footer__attribution.tok-ip-attribution {
    margin: 0;
    max-width: none;
    font-size: 0.8rem;
    font-weight: 400;
    color: color-mix(in srgb, var(--tok-text-light-soft) 62%, transparent);
  }

  @media (max-width: 640px) {
    .site-footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-footer__email {
      margin-top: 0.15rem;
    }
  }
</style>
