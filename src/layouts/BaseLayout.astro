---
import "../styles/global.css";
import "../styles/share.css";
import TdcConversionBlock from "../components/TdcConversionBlock.astro";
import { siteBase } from "../lib/site";

interface Props {
  title: string;
  description: string;
  /** Absolute or site-root-relative URL; falls back to the current request URL. */
  ogUrl?: string;
  ogType?: "website" | "article";
  /** When `ogType` is `article`, sets Open Graph published time. */
  articlePublishedTime?: string;
  /** When `ogType` is `article`, optional modified time. */
  articleModifiedTime?: string;
  /** Absolute URL for social preview (Open Graph / Twitter). */
  ogImage?: string;
  /** For `article` type, emits `article:tag` meta tags. */
  articleTags?: string[];
  /** Sets `<meta name="author">` when provided. */
  metaAuthor?: string;
  /** Absolute URLs for paginated lists (`rel="prev"` / `rel="next"`). */
  sequentialLinks?: { prev?: string; next?: string };
  /** When `before-footer`, renders the TDC block above the site footer. Use `none` when TDC is placed inside the page (e.g. home mid-page or article layout). */
  tdcPlacement?: "none" | "before-footer";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogUrl,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  ogImage,
  articleTags,
  metaAuthor,
  sequentialLinks,
  tdcPlacement = "before-footer",
  jsonLd,
} = Astro.props;

const trimmedOg = typeof ogUrl === "string" ? ogUrl.trim() : "";
const effectiveOgUrl =
  trimmedOg !== "" ? trimmedOg : Astro.url.href;

const base = siteBase(Astro);
const canonical = effectiveOgUrl.startsWith("http")
  ? effectiveOgUrl
  : new URL(
      effectiveOgUrl.startsWith("/") ? effectiveOgUrl : `/${effectiveOgUrl}`,
      base
    ).href;

const jsonLdArray = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

const structuredScripts = jsonLdArray.map((obj) => JSON.stringify(obj));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {metaAuthor && <meta name="author" content={metaAuthor} />}
    <link rel="canonical" href={canonical} />
    {sequentialLinks?.prev && (
      <link rel="prev" href={sequentialLinks.prev} />
    )}
    {sequentialLinks?.next && (
      <link rel="next" href={sequentialLinks.next} />
    )}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && metaAuthor && (
      <meta property="article:author" content={metaAuthor} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {articleTags &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Lora:ital,wght@0,400;0,600;1,400;1,600&family=Montserrat:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {structuredScripts.map((raw) => (
      <script type="application/ld+json" set:html={raw} />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <div class="page-inner site-header__inner">
        <a class="site-logo" href="/">Tides of Knowing</a>
        <nav class="site-nav" aria-label="Primary">
          <a class="site-nav__link" href="/articles/">Articles</a>
          <details class="site-nav__dropdown">
            <summary class="site-nav__dropdown-summary">Browse</summary>
            <ul class="site-nav__dropdown-list">
              <li>
                <a class="site-nav__dropdown-link" href="/articles/"
                  >All articles</a
                >
              </li>
              <li>
                <a class="site-nav__dropdown-link" href="/series/">Series</a>
              </li>
              <li>
                <a class="site-nav__dropdown-link" href="/tags/">Topics</a>
              </li>
            </ul>
          </details>
          <a class="site-nav__link" href="/library/">Blog</a>
          <a class="site-nav__link" href="/about">About</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    {tdcPlacement === "before-footer" && <TdcConversionBlock />}

    <footer class="site-footer">
      <div class="page-inner site-footer__inner">
        <div class="site-footer__col">
          <p class="site-footer__copy" style="text-align: center;">
            © 2026 Tides of Knowing · Leigh Spencer. All rights reserved. Original content.
          </p>
          <nav class="site-footer__discover" aria-label="Sections">
            <a class="site-footer__discover-link" href="/articles/">Articles</a>
            <a class="site-footer__discover-link" href="/series/">Series</a>
            <a class="site-footer__discover-link" href="/tags/">Topics</a>
            <a class="site-footer__discover-link" href="/library/">Blog</a>
          </nav>
        </div>
        <a class="site-footer__email" href="mailto:hello@tidesofknowing.com">hello@tidesofknowing.com</a>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var nodes = document.querySelectorAll("[data-reveal]");
        if (!nodes.length || !("IntersectionObserver" in window)) {
          nodes.forEach(function (el) {
            el.classList.add("is-visible");
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { root: null, rootMargin: "0px 0px -8% 0px", threshold: 0.08 }
        );
        nodes.forEach(function (el) {
          io.observe(el);
        });
      })();
    </script>

    <!-- MailerLite Universal -->
    <script is:inline>
      (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
      .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
      n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
      (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', '2247024');
    </script>
    <!-- End MailerLite Universal -->
  </body>
</html>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--near-black);
    border-bottom: 1px solid var(--navy);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    flex-wrap: wrap;
  }

  .site-logo {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.35rem;
    color: var(--lavender);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-logo:hover {
    color: var(--pale-horizon);
  }

  .site-nav {
    display: flex;
    gap: clamp(1rem, 4vw, 2rem);
    align-items: center;
  }

  .site-nav__link {
    font-family: var(--font-nav);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(217, 219, 241, 0.65);
  }

  .site-nav__link:hover {
    color: var(--lavender);
  }

  .site-nav__dropdown {
    position: relative;
  }

  .site-nav__dropdown-summary {
    font-family: var(--font-nav);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(217, 219, 241, 0.65);
    list-style: none;
    cursor: pointer;
  }

  .site-nav__dropdown-summary::-webkit-details-marker {
    display: none;
  }

  .site-nav__dropdown[open] .site-nav__dropdown-summary,
  .site-nav__dropdown-summary:hover {
    color: var(--lavender);
  }

  .site-nav__dropdown-list {
    position: absolute;
    top: 100%;
    left: 0;
    margin: 0.35rem 0 0;
    padding: 0.5rem 0;
    min-width: 11rem;
    list-style: none;
    background: var(--near-black);
    border: 1px solid var(--navy);
    border-radius: 0.25rem;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
    z-index: 60;
  }

  .site-nav__dropdown-link {
    display: block;
    padding: 0.45rem 1rem;
    font-family: var(--font-nav);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(217, 219, 241, 0.75);
  }

  .site-nav__dropdown-link:hover {
    color: var(--sky);
    background: rgba(13, 50, 77, 0.45);
  }

  #main-content {
    padding-top: 4.25rem;
  }

  .site-footer {
    background: var(--near-black);
    color: var(--lavender);
    border-top: 2px solid var(--gold);
    padding: 2rem 0 2.5rem;
    margin-top: 0;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 2rem;
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .site-footer__discover {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }

  .site-footer__discover-link {
    font-family: var(--font-nav);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(217, 219, 241, 0.55);
    text-decoration: none;
  }

  .site-footer__discover-link:hover {
    color: var(--sky);
  }

  .site-footer__copy {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.9rem;
    opacity: 0.85;
  }

  .site-footer__email {
    font-family: var(--font-nav);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(217, 219, 241, 0.75);
    text-decoration: none;
  }

  .site-footer__email:hover {
    color: var(--sky);
  }
</style>
