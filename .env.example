# Server-side only. Do not expose this key in client code.
MAILERLITE_API_KEY="replace-with-mailerlite-api-key"

# Shared MailerLite group that receives all lead magnet signups.
MAILERLITE_LEAD_MAGNET_GROUP_ID="replace-with-lead-magnet-group-id"

# Existing newsletter signup group IDs, comma-separated when more than one group is needed.
MAILERLITE_NEWSLETTER_GROUP_IDS=""

# Supabase Practice Commons integration.
PUBLIC_SUPABASE_URL="https://replace-with-project-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"

# Server-side only. Used for admin bootstrap and trusted maintenance actions.
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Comma-separated emails that should be promoted to Practice Commons admin on login.
COMMUNITY_ADMIN_EMAILS="leigh@example.com"

# Server-side email delivery for community notifications.
EMAIL_API_KEY="replace-with-resend-api-key"

# Ask Leilia payment workflow.
STRIPE_SECRET_KEY="sk_replace-with-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_replace-with-stripe-webhook-secret"
# Stripe Dashboard → Webhooks → endpoint URL (must be www, not apex):
# https://www.tidesofknowing.com/api/ask-leilia/stripe-webhook
ASK_LEILIA_NOTIFY_EMAIL="hello@tidesofknowing.com"
